  m_Name: RandomEventStringDataReader
  m_EditorClassIdentifier: Assembly-CSharp::RandomEventStringDataReader
  associatedSheet: 1GCr74ngPVVRLTbKcy8sNDbilnzMgu8WKokqp9r1M-Eo
  associatedWorksheet: RandomEventString
  START_ROW_LENGTH: 3
  END_ROW_LENGTH: -1
  DataList:
  - stringKey: Event_00001_Desc_Discipline_001
    ko: "\uC815\uADDC \uC288\uD305 \uD6C8\uB828 \uC2DC\uAC04, \uD300\uC758 \uD55C
      \uC120\uC218\uAC00 \uC9C0\uC815\uB41C \uC704\uCE58\uAC00 \uC544\uB2CC \uACF3\uC5D0\uC11C
      \uBB34\uBD84\uBCC4\uD558\uAC8C \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Discipline_002
    ko: "\uC120\uC218\uB294 \uAC10\uB3C5\uC774 \uC9C0\uC2DC\uD55C '\uAE30\uBCF8 \uC790\uC138
      \uC720\uC9C0'\uC640 '\uC815\uD574\uC9C4 \uC2A4\uD31F\uC5D0\uC11C\uC758 \uBC18\uBCF5
      \uD6C8\uB828'\uC744 \uBB34\uC2DC\uD55C \uCC44 \uD654\uB824\uD55C \uAE30\uC220\uB9CC
      \uC11E\uC5B4\uAC00\uBA70 2\uC810 \uC29B\uC744 \uC2DC\uB3C4\uD558\uB2E4 \uBBF8\uB044\uB7EC\uC9C8
      \uBED4\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Discipline_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Discipline_001
    ko: "\uC9C0\uAE08\uC740 \uC815\uD655\uB3C4\uB97C \uB192\uC774\uB294 \uAC8C \uC6B0\uC120\uC774\uB2E4.
      \uB124 \uB2A5\uB825\uC744 \uBBFF\uC73C\uB2C8 \uC6D0\uCE59\uB300\uB85C \uB2E4\uC2DC
      \uD574\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Principled_101
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4, \uAC10\uB3C5\uB2D8. \uC81C\uAC00 \uC7A0\uC2DC
      \uD6A8\uC728\uBCF4\uB2E4 \uC7AC\uBBF8\uB97C \uC55E\uC138\uC6E0\uC2B5\uB2C8\uB2E4.
      \uB2E4\uC2DC \uC815\uD574\uC9C4 \uB9E4\uB274\uC5BC\uB300\uB85C 100\uAC1C \uCC44\uC6B0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Principled_102
    ko: "\uC88B\uC544, \uADF8 \uC815\uAD50\uD568\uC774 \uACBD\uAE30\uC7A5\uC5D0 \uADF8\uB300\uB85C
      \uB098\uD0C0\uB0A0 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Principled_1
    ko: "\uADDC\uCE59\uC744 \uBC14\uB85C \uC218\uC6A9\uD588\uC73C\uB098 \uD750\uD2B8\uB7EC\uC9C4
      \uB9AC\uB4EC\uC744 \uBCF5\uAD6C\uD558\uB294 \uB370 \uC2DC\uAC04\uC774 \uC18C\uC694\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Guardian_101
    ko: "\uD300\uC758 \uC2DC\uC2A4\uD15C\uC744 \uB9DD\uCE58\uACE0 \uC788\uC5C8\uAD70\uC694.
      \uC81C\uAC00 \uC911\uC2EC\uC744 \uC7A1\uC544\uC57C \uD558\uB294\uB370... \uC870\uC5B8
      \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uB2E4\uC2DC \uAE30\uBCF8\uBD80\uD130 \uD0C4\uD0C4\uD788
      \uB2E4\uC9C0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Guardian_1
    ko: "\uCC45\uC784\uAC10\uC744 \uB290\uB07C\uACE0 \uC9D1\uC911\uB825\uC744 \uBC1C\uD718\uD558\uC5EC
      \uC29B \uBA54\uCEE4\uB2C8\uC998\uC744 \uC644\uBCBD\uD788 \uBCF5\uAD6C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Tactician_101
    ko: "\uACA9\uB824\uB294 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uC81C \uACC4\uC0B0\uC73C\uB85C\uB294
      \uC774 \uC2B5\uB3C4\uC5D0\uC11C \uC774 \uAC01\uB3C4\uAC00 \uB354 \uD6A8\uC728\uC801\uC774\uB77C
      \uC0DD\uAC01\uD588\uC2B5\uB2C8\uB2E4. \uD63C\uC120\uC774 \uC0DD\uACA8 \uC9D1\uC911\uB825\uC774
      \uB5A8\uC5B4\uC9C0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Tactician_1
    ko: "\uC790\uC2E0\uC758 \uACC4\uC0B0\uACFC \uAC10\uB3C5\uC758 \uC9C0\uC2DC \uC0AC\uC774\uC5D0\uC11C
      \uAC08\uB4F1\uD558\uB2E4 \uBC38\uB7F0\uC2A4\uAC00 \uBD95\uAD34\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Exemplary_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uAE30\uB300\uB97C \uC800\uBC84\uB838\uB124\uC694.
      \uB2E4\uB978 \uBD80\uC6D0\uB4E4\uC774 \uBCF4\uAE30 \uC804\uC5D0 \uC5BC\uB978
      \uC81C\uC790\uB9AC\uB85C \uB3CC\uC544\uAC00 \uC815\uC11D\uB300\uB85C \uC218\uD589\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Exemplary_1
    ko: "\uCCB4\uBA74\uC744 \uCC28\uB9AC\uB290\uB77C \uAE09\uAE09\uD574 \uD6C8\uB828\uC758
      \uC9C8\uC801 \uD5A5\uC0C1\uC740 \uC774\uB8E8\uC5B4\uC9C0\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Discipline_002
    ko: "\uAE30\uBCF8\uB3C4 \uC548 \uB41C \uB140\uC11D\uC774 \uBA4B\uBD80\uB9B4 \uC0DD\uAC01\uBD80\uD130
      \uD558\uB098? \uC81C\uB300\uB85C \uC6D0\uCE59\uC744 \uC9C0\uCF1C!"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Principled_201
    ko: "\uC815\uACE1\uC744 \uCC14\uB838\uC2B5\uB2C8\uB2E4. \uADDC\uC728\uC744 \uC5B4\uAE34
      \uC81C \uC798\uBABB\uC785\uB2C8\uB2E4. \uC29B \uD3FC 1,000\uBC88 \uBC18\uBCF5
      \uD6C4 \uB2E4\uC2DC \uD6C8\uB828\uC5D0 \uC784\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Principled_2
    ko: "\uC5C4\uACA9\uD55C \uD6C8\uC721\uC5D0 \uAC01\uC131\uD558\uC5EC \uD750\uD2B8\uB7EC\uC9D0
      \uC5C6\uB294 \uC644\uBCBD\uD55C \uC288\uD305 \uD3FC\uC744 \uCCB4\uB4DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Guardian_201
    ko: "\uBB34\uC9C8\uC11C\uD55C \uBAA8\uC2B5\uC744 \uBCF4\uC5EC\uB4DC\uB824 \uC1A1\uAD6C\uD569\uB2C8\uB2E4.
      \uD300\uC758 \uBD84\uC704\uAE30\uB97C \uD574\uCE58\uC9C0 \uC54A\uB3C4\uB85D
      \uC790\uC219\uD558\uBA70 \uC5F0\uC2B5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Guardian_2
    ko: "\uC9C8\uCC45\uC73C\uB85C \uC778\uD574 \uC704\uCD95\uB418\uC5B4 \uC790\uC2E0\uAC10\uC774
      \uD558\uB77D\uD55C \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Tactician_201
    ko: "\uC9C0\uC801\uC774 \uD0C0\uB2F9\uD569\uB2C8\uB2E4. \uAC10\uC815\uC5D0 \uCE58\uC6B0\uCE5C
      \uC5F0\uC2B5\uC740 \uBE44\uD6A8\uC728\uC801\uC774\uAD70\uC694. \uB2E4\uC2DC
      \uCCB4\uACC4\uC801\uC778 \uB8E8\uD2F4\uC73C\uB85C \uBCF5\uADC0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Tactician_2
    ko: "\uB17C\uB9AC\uC801\uC73C\uB85C \uB0A9\uB4DD\uD558\uC5EC \uBCF5\uADC0\uD588\uC73C\uB098
      \uD6C8\uB828 \uB370\uC774\uD130\uAC00 \uCD08\uAE30\uD654\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Exemplary_201
    ko: "\uBAA8\uB450\uAC00 \uBCF4\uB294 \uC55E\uC5D0\uC11C \uC774\uB807\uAC8C\uAE4C\uC9C0...
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC81C \uC9C4\uC2EC\uAE4C\uC9C0
      \uBB34\uC2DC\uB2F9\uD55C \uAC83 \uAC19\uC544 \uB9C8\uC74C\uC774 \uBB34\uAC81\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Exemplary_2
    ko: "\uACF5\uAC1C\uC801\uC778 \uC9C8\uCC45\uC5D0 \uC790\uC874\uC2EC\uC774 \uC0C1\uD574
      \uC190 \uB05D\uC758 \uAC10\uAC01\uC774 \uBB34\uB38C\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Discipline_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uBC14\uB77C\uBCF4\uB2E4\uAC00, \uB178\uD2B8\uC5D0
      X\uB97C \uC801\uACE0 \uB2E4\uB978 \uC120\uC218\uC5D0\uAC8C\uB85C \uBC1C\uAE38\uC744
      \uB3CC\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC800\uB97C \uD3EC\uAE30\uD558\uC2E0 \uAC74\uAC00\uC694?
      \uAE30\uC900\uC774 \uC5C6\uB294 \uD6C8\uB828\uC740 \uC758\uBBF8\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4...
      \uAC08\uD53C\uB97C \uBABB \uC7A1\uACA0\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Principled_3
    ko: "\uD1B5\uC81C\uAC00 \uC0AC\uB77C\uC9C0\uC790 \uC2A4\uC2A4\uB85C\uC758 \uAE30\uC900\uB9C8\uC800
      \uD754\uB4E4\uB9AC\uBA70 \uC288\uD305 \uC131\uACF5\uB960\uC774 \uAE09\uB77D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Guardian_301
    ko: "\uC81C\uAC00 \uD300\uC758 \uADDC\uC728\uC744 \uAE68\uB728\uB824\uC11C \uC2E4\uB9DD\uD558\uC2E0
      \uAC70\uAD70\uC694. \uBB34\uC5B8\uC758 \uC555\uBC15\uC774 \uB354 \uAD34\uB86D\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Guardian_3
    ko: "\uC8C4\uCC45\uAC10\uC5D0 \uC0AC\uB85C\uC7A1\uD600 \uC2DC\uC57C\uAC00 \uD750\uB824\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Tactician_301
    ko: "\uAD00\uC2EC\uC744 \uB04A\uC73C\uC2E0 \uAC74\uAC00\uC694? \uC544\uB2C8\uBA74
      \uC2A4\uC2A4\uB85C \uAE68\uB2EB\uAE30\uB97C \uAE30\uB2E4\uB9AC\uC2DC\uB294
      \uAC74\uAC00\uC694? \uC77C\uB2E8 \uD558\uB358 \uB370\uC774\uD130\uB97C \uB9C8\uC800
      \uBF51\uC544\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Tactician_3
    ko: "\uAC10\uB3C5\uC758 \uD53C\uB4DC\uBC31 \uC5C6\uC774 \uD63C\uC790 \uD6C8\uB828\uC744
      \uC774\uC5B4\uAC00\uC9C0\uB9CC \uD55C\uACC4\uC5D0 \uBD80\uB52A\uD614\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Exemplary_301
    ko: "\uC544\uBB34 \uB9D0\uC500 \uC5C6\uC73C\uC2E0 \uAC8C \uAC00\uC7A5 \uBB34\uC12D\uAD70\uC694.
      \uC81C\uAC00 \uC2A4\uC2A4\uB85C \uC99D\uBA85\uD558\uC9C0 \uBABB\uD558\uBA74
      \uC774 \uD300\uC5D0\uC11C \uC81C \uC790\uB9AC\uB294 \uC5C6\uB2E4\uB294 \uB73B\uC774\uACA0\uC8E0.
      \uBCF4\uC2ED\uC2DC\uC624, \uB2E4\uC2DC \uC644\uBCBD\uD558\uAC8C \uB358\uC9C0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Exemplary_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uAD00\uC2EC\uC744 \uC704\uAE30\uB85C \uB290\uB07C\uACE0
      \uC2A4\uC2A4\uB85C\uB97C \uC5C4\uACA9\uD788 \uD1B5\uC81C\uD558\uC5EC \uC288\uD305
      \uC815\uD655\uB3C4\uB97C \uADF9\uB300\uD654\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Bond_001
    ko: "\uC815\uADDC \uC288\uD305 \uD6C8\uB828 \uC2DC\uAC04, \uD300\uC758 \uD55C
      \uC120\uC218\uAC00 \uC9C0\uC815\uB41C \uC704\uCE58\uAC00 \uC544\uB2CC \uACF3\uC5D0\uC11C
      \uBB34\uBD84\uBCC4\uD558\uAC8C \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Bond_002
    ko: "\uC120\uC218\uB294 \uAC10\uB3C5\uC774 \uC9C0\uC2DC\uD55C '\uAE30\uBCF8 \uC790\uC138
      \uC720\uC9C0'\uC640 '\uC815\uD574\uC9C4 \uC2A4\uD31F\uC5D0\uC11C\uC758 \uBC18\uBCF5
      \uD6C8\uB828'\uC744 \uBB34\uC2DC\uD55C \uCC44 \uD654\uB824\uD55C \uAE30\uC220\uB9CC
      \uC11E\uC5B4\uAC00\uBA70 2\uC810 \uC29B\uC744 \uC2DC\uB3C4\uD558\uB2E4 \uBBF8\uB044\uB7EC\uC9C8
      \uBED4\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Bond_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Bond_001
    ko: "\uC790\uC138\uB294 \uB098\uC058\uC9C0 \uC54A\uC9C0\uB9CC, \uC9C0\uAE08\uC740
      \uC57D\uC18D\uB41C \uC9C0\uC810\uC5D0\uC11C \uC815\uD655\uB3C4\uB97C \uB192\uC774\uB294
      \uAC8C \uC6B0\uC120\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Kind_101
    ko: "\uBD80\uB4DC\uB7FD\uAC8C \uB9D0\uC500\uD574 \uC8FC\uC2DC\uB2C8 \uB9C8\uC74C\uC774
      \uB193\uC774\uB124\uC694. \uC2DC\uD0A4\uB294 \uB300\uB85C \uD560\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Kind_1
    ko: "\uC2EC\uB9AC\uC801 \uC548\uC815\uC744 \uB418\uCC3E\uC558\uC744 \uBFD0 \uBCC4
      \uB2E4\uB978 \uBCC0\uD654\uAC00 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC800\uB97C \uBBFF\uC5B4\uC8FC\uC2E0\uB2E4\uBA74,
      \uC800\uB294 \uBB34\uC870\uAC74 \uB530\uB97C \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Loyal_1
    ko: "\uC218\uB3D9\uC801\uC778 \uD0DC\uB3C4\uB97C \uC720\uC9C0\uD558\uC5EC \uBCC4
      \uB2E4\uB978 \uBCC0\uD654\uAC00 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Sincere_101
    ko: "\uBB35\uBB35\uD788 \uC81C \uC790\uB9AC\uB97C \uC9C0\uD0A4\uB294 \uAC8C \uB2F5\uC774\uACA0\uC8E0.
      \uB2E4\uC2DC \uC2DC\uC791\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Sincere_1
    ko: "\uBCC0\uD654 \uC5C6\uB294 \uB8E8\uD2F4\uC744 \uC218\uD589\uD558\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Moodmaker_101
    ko: "\uD5E4\uD5E4, \uC54C\uACA0\uC2B5\uB2C8\uB2E4! \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C
      \uC9C4\uC9C0\uD558\uAC8C \uAC00\uBCFC\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Moodmaker_1
    ko: "\uC5EC\uC804\uD55C \uC0B0\uB9CC\uD55C \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Bond_002
    ko: "\uAE30\uBCF8\uB3C4 \uC548 \uB41C \uB140\uC11D\uC774 \uBA4B\uBD80\uB9B4 \uC0DD\uAC01\uBD80\uD130
      \uD558\uB098? \uB2F9\uC7A5 \uCF54\uD2B8 \uBC16\uC73C\uB85C \uB098\uAC00\uC11C
      \uD0DC\uB3C4\uBD80\uD130 \uACE0\uCCD0!"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Kind_201
    ko: "\uB108\uBB34 \uBB34\uC12D\uAC8C \uB9D0\uC500\uD558\uC2DC\uB124\uC694...
      \uC758\uC695\uC774 \uB69D \uB5A8\uC5B4\uC84C\uC5B4\uC694..."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Kind_2
    ko: "\uC790\uC2E0\uAC10\uC774 \uAE09\uB77D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Loyal_201
    ko: "\uC808 \uD3EC\uAE30\uD558\uC9C0 \uB9C8\uC138\uC694! \uAC10\uB3C5\uB2D8!
      \uB2E4\uC2DC\uB294 \uC2E4\uB9DD \uC548 \uC2DC\uD0B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Loyal_2
    ko: "\uACFC\uB3C4\uD55C \uAE34\uC7A5\uC73C\uB85C \uADFC\uC721\uC774 \uACBD\uC9C1\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Sincere_201
    ko: "\uC5F4\uC2EC\uD788 \uD558\uB824\uB358 \uAC74\uB370... \uC81C\uAC00 \uBD80\uC871\uD588\uB098
      \uBD05\uB2C8\uB2E4. \uC8C4\uC1A1\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Sincere_2
    ko: "\uC790\uCC45\uC73C\uB85C \uC778\uD574 \uC9D1\uC911\uB825\uC774 \uC800\uD558\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Moodmaker_201
    ko: "\uC545! \uBD84\uC704\uAE30 \uC2F8\uD574\uC84C\uB124... \uC870\uC6A9\uD788
      \uC29B\uC774\uB098 \uB358\uC838\uC57C\uACA0\uB2E4..."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Moodmaker_2
    ko: "\uD6C8\uB828\uC5D0 \uD765\uBBF8\uB97C \uC783\uC5B4\uBC84\uB9B0 \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Bond_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uBC14\uB77C\uBCF4\uB2E4\uAC00, \uB178\uD2B8\uC5D0
      X\uB97C \uC801\uACE0 \uB2E4\uB978 \uC120\uC218\uC5D0\uAC8C\uB85C \uBC1C\uAE38\uC744
      \uB3CC\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8? \uD654\uB098\uC168\uC5B4\uC694? \uC81C\uBC1C \uBB50\uB77C\uACE0
      \uB9D0\uC500 \uC880 \uD574\uC8FC\uC138\uC694..."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Kind_3
    ko: "\uAC10\uB3C5\uC744 \uB418\uCC3E\uAE30 \uC704\uD574 \uAC04\uC808\uD558\uAC8C
      \uC29B\uC5D0 \uC9D1\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uCE68\uBB35\uC740 \uC800\uB97C \uB354 \uAC15\uD558\uAC8C
      \uB9CC\uB4DC\uB824\uB294 \uC2DC\uB828\uC77C \uAC81\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Loyal_3
    ko: "\uB9F9\uBAA9\uC801 \uBBFF\uC74C\uC774 \uAC00\uC838\uC628 \uAE30\uC801\uC758
      \uC9D1\uC911\uB825\uC774 \uBC1C\uD718\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Sincere_301
    ko: "\uAE30\uB2E4\uB824 \uC8FC\uC2DC\uB294 \uAC70\uAD70\uC694. \uC81C\uAC00 \uC2A4\uC2A4\uB85C
      \uC815\uB2F5\uC744 \uCC3E\uC744 \uB54C\uAE4C\uC9C0\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Sincere_3
    ko: "\uC790\uAE30 \uC131\uCC30\uC744 \uD1B5\uD574 \uC29B \uD3FC\uC744 \uC644\uC131\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Moodmaker_301
    ko: "\uC5B4\uB77C? \uC790\uC720 \uC2DC\uAC04\uC778\uAC00? \uADF8\uB7FC \uB0B4
      \uB9C8\uC74C\uB300\uB85C \uB354 \uBA4B\uC9C0\uAC8C \uC29B!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Moodmaker_3
    ko: "\uC555\uBC15 \uC5C6\uB294 \uD658\uACBD\uC5D0\uC11C \uCC3D\uC758\uC131\uC744
      \uBC1C\uD718\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Cold_001
    ko: "\uC815\uADDC \uC288\uD305 \uD6C8\uB828 \uC2DC\uAC04, \uD300\uC758 \uD55C
      \uC120\uC218\uAC00 \uC9C0\uC815\uB41C \uC704\uCE58\uAC00 \uC544\uB2CC \uACF3\uC5D0\uC11C
      \uBB34\uBD84\uBCC4\uD558\uAC8C \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Cold_002
    ko: "\uC120\uC218\uB294 \uAC10\uB3C5\uC774 \uC9C0\uC2DC\uD55C '\uAE30\uBCF8 \uC790\uC138
      \uC720\uC9C0'\uC640 '\uC815\uD574\uC9C4 \uC2A4\uD31F\uC5D0\uC11C\uC758 \uBC18\uBCF5
      \uD6C8\uB828'\uC744 \uBB34\uC2DC\uD55C \uCC44 \uD654\uB824\uD55C \uAE30\uC220\uB9CC
      \uC11E\uC5B4\uAC00\uBA70 2\uC810 \uC29B\uC744 \uC2DC\uB3C4\uD558\uB2E4 \uBBF8\uB044\uB7EC\uC9C8
      \uBED4\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Cold_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Cold_001
    ko: "\uC790\uC138\uB294 \uB098\uC058\uC9C0 \uC54A\uC9C0\uB9CC, \uC9C0\uAE08\uC740
      \uC57D\uC18D\uB41C \uC9C0\uC810\uC5D0\uC11C \uC815\uD655\uB3C4\uB97C \uB192\uC774\uB294
      \uAC8C \uC6B0\uC120\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Planner_101
    ko: "\uACA9\uB824 \uB4A4\uC5D0 \uC228\uC740 \uC758\uB3C4\uB97C \uD30C\uC545\uD588\uC2B5\uB2C8\uB2E4.
      \uC77C\uB2E8\uC740 \uB9DE\uCDB0\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Planner_1
    ko: "\uD6C8\uB828\uBCF4\uB2E4 \uAC10\uB3C5\uC758 \uC758\uC911\uC744 \uD30C\uC545\uD558\uB290\uB77C
      \uC815\uC2E0\uC774 \uC5C6\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Opportunist_101
    ko: "\uC9C0\uAE08\uC740 \uC218\uAE0D\uD558\uB294 \uCC99\uD558\uB294 \uAC8C \uC81C
      \uC785\uC9C0\uC5D0 \uC720\uB9AC\uD558\uACA0\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Opportunist_1
    ko: "\uACB0\uC5EC\uB41C \uC9C4\uC815\uC131\uC73C\uB85C \uD6C8\uB828\uC5D0 \uB3C4\uC6C0\uC774
      \uB418\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Cunning_101
    ko: "\uACA9\uB824\uB77C\uB2C8, \uC800\uB97C \uB2E4\uB8E8\uB294 \uBC95\uC744 \uC544\uC2DC\uB124\uC694.
      \uD558\uC9C0\uB9CC \uBAB8\uC740 \uC548 \uB530\uB77C\uC8FC\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Cunning_1
    ko: "\uC2EC\uB9AC\uC801 \uAC70\uB9AC\uAC10\uC73C\uB85C \uC778\uD55C \uBD88\uD611\uD654\uC74C\uC774
      \uBC1C\uC0DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Believer_101
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD2C0\uB838\uB2E4\uACE0 \uC0DD\uAC01\uD558\uC9C4
      \uC54A\uC9C0\uB9CC... \uC77C\uB2E8\uC740 \uBA48\uCD94\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Believer_1
    ko: "\uACE0\uC9D1\uACFC \uC9C0\uC2DC \uC0AC\uC774\uC5D0\uC11C \uAC08\uB4F1\uD558\uB294
      \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Cold_002
    ko: "\uAE30\uBCF8\uB3C4 \uC548 \uB41C \uB140\uC11D\uC774 \uBA4B\uBD80\uB9B4 \uC0DD\uAC01\uBD80\uD130
      \uD558\uB098? \uB2F9\uC7A5 \uCF54\uD2B8 \uBC16\uC73C\uB85C \uB098\uAC00\uC11C
      \uD0DC\uB3C4\uBD80\uD130 \uACE0\uCCD0!"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Planner_201
    ko: "\uACF5\uD3EC \uC815\uCE58\uB97C \uC4F0\uC2DC\uB294\uAD70\uC694. \uD558\uC9C0\uB9CC
      \uD6A8\uC728\uC801\uC778 \uC9C0\uB3C4\uB294 \uC544\uB2CC \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Planner_2
    ko: "\uBC18\uBC1C\uC2EC\uC744 \uC2E4\uB825 \uC99D\uBA85\uC73C\uB85C \uC2B9\uD654\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Opportunist_201
    ko: "\uCE58, \uBB34\uC11C\uC6CC\uC11C \uD558\uACA0\uB098. \uC77C\uB2E8 \uC2DC\uD0A4\uB294
      \uAC70\uB77C\uB3C4 \uC5F4\uC2EC\uD788 \uD558\uC790."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Opportunist_2
    ko: "\uAC10\uB3C5\uC774 \uC2DC\uD0A4\uB294 \uB300\uB85C \uC5F4\uC2EC\uD788 \uD6C8\uB828\uD558\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Cunning_201
    ko: "\uC544\uD504\uB124\uC694. \uD558\uC9C0\uB9CC \uC81C \uC2E4\uB825\uC744 \uBCF4\uC5EC\uC8FC\uBA74
      \uADF8 \uC785\uC744 \uB2EB\uC73C\uC2DC\uACA0\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Cunning_2
    ko: "\uB3C5\uAE30\uB97C \uD488\uC5B4 \uC9D1\uC911\uB825\uC774 \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Believer_201
    ko: "\uC81C \uB18D\uAD6C\uB97C \uBB34\uC2DC\uD558\uC2DC\uB2E4\uB2C8. \uC81C\uAC00
      \uC633\uB2E4\uB294 \uAC78 \uC29B\uC73C\uB85C \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Believer_2
    ko: "\uC2E0\uB150\uC744 \uC9C0\uD0A4\uAE30 \uC704\uD574 \uACE0\uB3C4\uB85C \uBAB0\uC785\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Cold_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uBC14\uB77C\uBCF4\uB2E4\uAC00, \uB178\uD2B8\uC5D0
      X\uB97C \uC801\uACE0 \uB2E4\uB978 \uC120\uC218\uC5D0\uAC8C\uB85C \uBC1C\uAE38\uC744
      \uB3CC\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Planner_301
    ko: "\uC774 \uCE68\uBB35\uC870\uCC28 \uAC10\uB3C5\uB2D8\uC758 \uC2DC\uB098\uB9AC\uC624\uAD70.
      \uB0B4 \uC790\uBC1C\uC131\uC744 \uB04C\uC5B4\uB0B4\uB824\uB294 \uAC74\uAC00."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Planner_3
    ko: "\uBD84\uC11D\uB9CC \uD558\uB290\uB77C \uC2E4\uD589\uB825\uC774 \uBD80\uC871\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Opportunist_301
    ko: "\uAC04\uC12D \uC548 \uD558\uB2C8\uAE4C \uD3B8\uD558\uB124. \uB300\uCDA9
      \uB358\uC9C0\uBA74\uC11C \uC2DC\uAC04\uC774\uB098 \uB54C\uC6B0\uC790."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Opportunist_3
    ko: "\uD6C8\uB828 \uC758\uC695\uC774 \uC800\uD558\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Cunning_301
    ko: "\uBB34\uC2A8 \uAFCD\uAFCD\uC774\uC2E4\uAE4C. \uD568\uC815\uC778\uAC00? \uC77C\uB2E8\uC740
      \uD3C9\uBC94\uD558\uAC8C \uB358\uC9C0\uACE0 \uC788\uC790."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Cunning_3
    ko: "\uC758\uAD6C\uC2EC\uC73C\uB85C \uC778\uD574 \uD0DC\uB3C4\uAC00 \uC18C\uADF9\uC801\uC774\uAC8C
      \uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Believer_301
    ko: "\uB098\uB97C \uC778\uC815\uD55C\uB2E4\uB294 \uB73B\uC778\uAC00. \uC5ED\uC2DC
      \uB0B4 \uB18D\uAD6C\uB294 \uB0B4\uAC00 \uB9CC\uB4DC\uB294 \uAC70\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Believer_3
    ko: "\uB3C5\uB2E8\uC801\uC778 \uD6C8\uB828 \uBC29\uC2DD\uC744 \uACE0\uC218\uD558\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Instinct_001
    ko: "\uC815\uADDC \uC288\uD305 \uD6C8\uB828 \uC2DC\uAC04, \uD300\uC758 \uD55C
      \uC120\uC218\uAC00 \uC9C0\uC815\uB41C \uC704\uCE58\uAC00 \uC544\uB2CC \uACF3\uC5D0\uC11C
      \uBB34\uBD84\uBCC4\uD558\uAC8C \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Instinct_002
    ko: "\uC120\uC218\uB294 \uAC10\uB3C5\uC774 \uC9C0\uC2DC\uD55C '\uAE30\uBCF8 \uC790\uC138
      \uC720\uC9C0'\uC640 '\uC815\uD574\uC9C4 \uC2A4\uD31F\uC5D0\uC11C\uC758 \uBC18\uBCF5
      \uD6C8\uB828'\uC744 \uBB34\uC2DC\uD55C \uCC44 \uD654\uB824\uD55C \uAE30\uC220\uB9CC
      \uC11E\uC5B4\uAC00\uBA70 2\uC810 \uC29B\uC744 \uC2DC\uB3C4\uD558\uB2E4 \uBBF8\uB044\uB7EC\uC9C8
      \uBED4\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Instinct_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Instinct_001
    ko: "\uC790\uC138\uB294 \uB098\uC058\uC9C0 \uC54A\uC9C0\uB9CC, \uC9C0\uAE08\uC740
      \uC57D\uC18D\uB41C \uC9C0\uC810\uC5D0\uC11C \uC815\uD655\uB3C4\uB97C \uB192\uC774\uB294
      \uAC8C \uC6B0\uC120\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Bluffer_101
    ko: "\uC5D0\uC774, \uC81C \uCC9C\uC7AC\uC131\uC744 \uAC00\uB450\uC2DC\uB294 \uAC74\uAC00\uC694?
      \uBB50, \uC77C\uB2E8 \uD558\uB77C\uBA74 \uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Bluffer_1
    ko: "\uC790\uB9CC\uC2EC\uC744 \uC5B5\uB204\uB97C \uC218 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Wild_101
    ko: "\uB2F5\uB2F5\uD574\uC694. \uD2C0\uC5D0 \uBC15\uD78C \uD6C8\uB828\uC740 \uC81C
      \uAC10\uAC01\uC744 \uC8FD\uC774\uB294 \uAC83 \uAC19\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Wild_1
    ko: "\uBCF8\uB2A5 \uC5B5\uC81C\uB85C \uC778\uD574 \uC790\uC2E0\uB9CC\uC758 \uB9AC\uB4EC\uC774
      \uD30C\uAD34\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Egoist_101
    ko: "\uB098\uD55C\uD14C \uC9C0\uC2DC\uD558\uC9C0 \uB9C8\uC138\uC694. \uACA9\uB824\uD55C\uB2E4\uACE0
      \uB0B4\uAC00 \uC88B\uC544\uD560 \uC904 \uC54C\uC558\uB098?"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Egoist_1
    ko: "\uBC18\uD56D\uC2EC\uC73C\uB85C \uD6C8\uB828\uC5D0 \uBB34\uC131\uC758\uD558\uAC8C
      \uC784\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Fighter_101
    ko: "\uACA9\uB824\uBCF4\uB2E4\uB294 \uC2B9\uBD80\uAC00 \uD544\uC694\uD55C\uB370...
      \uC2DC\uC2DC\uD558\uAC8C \uB3CC\uC544\uAC00\uC57C \uD55C\uB2E4\uB2C8."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Fighter_1
    ko: "\uD22C\uC9C0 \uC0C1\uC2E4\uB85C \uC778\uD574 \uC758\uC695\uC774 \uAEBE\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Instinct_002
    ko: "\uAE30\uBCF8\uB3C4 \uC548 \uB41C \uB140\uC11D\uC774 \uBA4B\uBD80\uB9B4 \uC0DD\uAC01\uBD80\uD130
      \uD558\uB098? \uB2F9\uC7A5 \uCF54\uD2B8 \uBC16\uC73C\uB85C \uB098\uAC00\uC11C
      \uD0DC\uB3C4\uBD80\uD130 \uACE0\uCCD0!"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Bluffer_201
    ko: "\uC808 \uACFC\uC18C\uD3C9\uAC00\uD558\uC2DC\uB124? \uC81C \uC29B\uC774 \uADF8\uBB3C
      \uCC22\uB294 \uAC70 \uBCF4\uACE0 \uC0AC\uACFC\uD558\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Bluffer_2
    ko: "\uADFC\uAC70 \uC5C6\uB294 \uC790\uC2E0\uAC10\uC774 \uC2E4\uC9C8\uC801 \uB4DD\uC810\uC73C\uB85C
      \uC774\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Wild_201
    ko: "\uC624, \uADF8 \uAE30\uC138! \uB9C8\uC74C\uC5D0 \uB4ED\uB2C8\uB2E4. \uC57C\uC0DD\uB9C8\uB97C
      \uAE38\uB4E4\uC5EC \uBCF4\uC2DC\uB4E0\uAC00\uC694!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Wild_2
    ko: "\uAC70\uCE5C \uC790\uADF9\uC774 \uAC10\uAC01\uC744 \uAE68\uC6E0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Egoist_201
    ko: "\uB204\uAC00 \uB204\uAD6C\uBCF4\uACE0 \uC2E4 \uC790\uB9AC\uAC00 \uC5C6\uB300?
      \uB0B4\uAC00 \uCF54\uD2B8\uC758 \uC8FC\uC778\uC774\uC57C. \uBD10!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Egoist_2
    ko: "\uADF9\uB3C4\uC758 \uC790\uAE30\uC560\uAC00 \uBB34\uACB0\uC810 \uC29B\uC73C\uB85C
      \uC774\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Fighter_201
    ko: "\uC2F8\uC6C0\uC744 \uAC70\uC2DC\uB294 \uAC74\uAC00\uC694? \uC88B\uC2B5\uB2C8\uB2E4.
      \uC2E4\uB825\uC73C\uB85C \uAD74\uBCF5\uC2DC\uCF1C \uB4DC\uB9AC\uC9C0!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Fighter_2
    ko: "\uC2B9\uBD80\uC695 \uD3ED\uBC1C\uB85C \uC29B \uBA54\uCEE4\uB2C8\uC998\uC774
      \uCD5C\uC801\uD654\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Instinct_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uBC14\uB77C\uBCF4\uB2E4\uAC00, \uB178\uD2B8\uC5D0
      X\uB97C \uC801\uACE0 \uB2E4\uB978 \uC120\uC218\uC5D0\uAC8C\uB85C \uBC1C\uAE38\uC744
      \uB3CC\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Bluffer_301
    ko: "\uD560 \uB9D0\uC744 \uC783\uC73C\uC2E0 \uAC70\uC9C0. \uB0B4 \uC29B\uC774
      \uB108\uBB34 \uC644\uBCBD\uD574\uC11C \uB9D0\uC774\uC57C!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Bluffer_3
    ko: "\uC790\uAE30 \uAC1D\uAD00\uD654\uC5D0 \uC2E4\uD328\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Wild_301
    ko: "\uCE68\uBB35\uC774 \uD750\uB974\uB294 \uCF54\uD2B8... \uC624\uC9C1 \uACF5
      \uC18C\uB9AC\uBFD0. \uB098\uC058\uC9C0 \uC54A\uC740\uB370?"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Wild_3
    ko: "\uC790\uC720\uB97C \uC990\uAE30\uB098 \uC2E4\uB825 \uD5A5\uC0C1\uC740 \uBBF8\uBBF8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Egoist_301
    ko: "\uADF8\uB798, \uCC38\uACAC\uD558\uC9C0 \uB9C8. \uB09C \uB098\uB9CC\uC758
      \uAE38\uC744 \uAC08 \uD14C\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Egoist_3
    ko: "\uBC29\uCE58\uB41C \uCC44 \uD6C8\uB828\uC744 \uC9C0\uC18D\uD558\uC5EC \uBCC0\uD654\uAC00
      \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Fighter_301
    ko: "\uB098\uB97C \uBB34\uC2DC\uD574? \uC5B4\uB514 \uB208\uC744 \uB5BC\uC9C0
      \uBABB\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC8FC\uC9C0!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Fighter_3
    ko: "\uACFC\uC695\uC73C\uB85C \uC778\uD55C \uC29B \uAE30\uBCF5\uC774 \uBC1C\uC0DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Discipline_001
    ko: "\uC815\uADDC \uD6C8\uB828\uC774 \uB05D\uB09C \uB4A4, \uB0A1\uC740 \uACE8\uB300
      \uBC11\uC5D0\uC11C \uD55C \uC120\uC218\uAC00 \uD640\uB85C 2\uC810 \uC29B \uC5F0\uC2B5\uC744
      \uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Discipline_002
    ko: "\uD558\uC9C0\uB9CC \uB9BC\uC774 \uD718\uC5B4\uC838 \uC788\uB294\uC9C0, \uB358\uC9C0\uB294
      \uACF5\uB9C8\uB2E4 \uC790\uAFB8\uB9CC \uB9BC\uC744 \uB9DE\uACE0 \uD295\uACA8
      \uB098\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Discipline_003
    ko: "\uC120\uC218\uB294 \uD55C\uC228\uC744 \uC26C\uBA70 \uB540\uC5D0 \uC816\uC740
      \uC720\uB2C8\uD3FC \uC18C\uB9E4\uB85C \uC774\uB9C8\uB97C \uB2E6\uC2B5\uB2C8\uB2E4.
      \uC774\uB54C \uADFC\uCC98\uB97C \uC9C0\uB098\uAC00\uB358 \uB2F9\uC2E0\uACFC
      \uB208\uC774 \uB9C8\uC8FC\uCE69\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Discipline_004
    ko: "\uC120\uC218\uB294 \uBA38\uC4F1\uD55C \uB4EF \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Discipline_005
    ko: "\uAC10\uB3C5\uB2D8, \uC544\uC9C1 \uC548 \uAC00\uC168\uC5B4\uC694? \uC694\uC998
      \uC911\uAC70\uB9AC \uC29B \uAC10\uAC01\uC774 \uB3C4\uBB34\uC9C0 \uC548 \uC7A1\uD600\uC11C\uC694...
      \uC6B0\uB9AC \uD559\uAD50 \uACE8\uB300\uAC00 \uC880 \uC774\uC0C1\uD55C \uAC74\uC9C0,
      \uC81C \uC190\uC774 \uBB38\uC81C\uC778 \uAC74\uC9C0 \uBAA8\uB974\uACA0\uB124\uC694.
      \uD558\uD558."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Discipline_006
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Discipline_001
    ko: "\uB9BC\uC774 \uD718\uC5B4\uC9C4 \uAC01\uB3C4\uB97C \uACC4\uC0B0\uD558\uBA74\uC11C
      \uD6C8\uB828\uC5D0 \uC815\uC9C4\uD558\uB3C4\uB85D \uD574."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Principled_101
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uD718\uC5B4\uC9C4 \uAC01\uB3C4\uB97C \uACE0\uB824\uD55C
      \uC0C8\uB85C\uC6B4 \uC870\uC900\uC810\uC744 \uC124\uC815\uD574 \uC5F0\uC2B5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Principled_1
    ko: "\uC870\uC5B8\uC774 \uB3C4\uC6C0\uC774 \uB41C \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Guardian_101
    ko: "\uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C \uC81C\uAC00 \uD754\uB4E4\uB9AC\uBA74
      \uC548 \uB418\uC8E0. \uD300\uC758 \uB4DD\uC810\uC6D0\uC73C\uB85C\uC11C \uC790\uBD80\uC2EC\uC744
      \uAC00\uC9C8\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Guardian_1
    ko: "\uC2EC\uB9AC\uC801 \uC555\uBC15\uC744 \uC774\uACA8\uB0B4\uACE0 \uD0C0\uC810\uC744
      \uC815\uD655\uD788 \uCC3E\uC544\uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Tactician_101
    ko: "\uAD74\uC808 \uACC4\uC0B0\uC774\uB77C... \uD765\uBBF8\uB86D\uB124\uC694.
      \uB9BC\uC758 \uC67C\uCABD 5cm \uC9C0\uC810\uC744 \uACA8\uB0E5\uD574\uC11C \uB358\uC838\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Tactician_1
    ko: "\uD718\uC5B4\uC9C4 \uB9BC\uC744 \uACF5\uB7B5\uD558\uB294 \uC0C8\uB85C\uC6B4
      \uD3EC\uC778\uD2B8\uB97C \uACC4\uC0B0\uD574\uB0B4\uBA70 \uC29B \uC9C0\uB2A5\uC774
      \uD55C \uB2E8\uACC4 \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Exemplary_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uAE30\uB300\uB97C \uC800\uBC84\uB9AC\uC9C0 \uC54A\uACA0\uC2B5\uB2C8\uB2E4.
      \uAC00\uC7A5 \uC644\uBCBD\uD55C \uD3FC\uC73C\uB85C \uB123\uC5B4\uBCF4\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Exemplary_1
    ko: "\uD0C0\uC778\uC758 \uAE30\uB300\uB97C \uB3D9\uB825\uC73C\uB85C \uC0BC\uB294
      \uC131\uACA9 \uB355\uBD84\uC5D0 \uC9D1\uC911\uB825\uC774 \uADF9\uB300\uD654\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Discipline_002
    ko: "\uC548 \uB4E4\uC5B4\uAC00\uB294 \uC774\uC720\uB97C \uC678\uBD80\uC5D0\uC11C
      \uCC3E\uC73C\uB824\uB294 \uD0DC\uB3C4 \uC790\uCCB4\uAC00 \uBB38\uC81C\uC57C.
      \uC9D1\uC911\uB825\uC774 \uD750\uD2B8\uB7EC\uC9C4 \uAC70 \uC544\uB2CC\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Principled_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uC81C \uC548\uC77C\uD568\uC744 \uBC18\uC131\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      1,000\uAC1C \uC131\uACF5 \uC804\uC5D4 \uC548 \uAC00\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Principled_2
    ko: "\uC9D1\uC911\uB825\uC774 \uD750\uD2B8\uB7EC\uC9C4 \uCC44 \uD6C8\uB828\uC744
      \uACC4\uC18D\uD574\uC11C \uC9C4\uC804\uC774 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Guardian_201
    ko: "\uD300\uC744 \uC704\uD55C \uD6C8\uB828\uC778\uB370 \uAC1C\uC778\uC801\uC778
      \uBD88\uB9CC\uC744 \uB298\uC5B4\uB193\uC558\uAD70\uC694. \uB2E4\uC2DC \uC9D1\uC911\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Guardian_2
    ko: "\uC2E4\uD328\uC5D0 \uB300\uD55C \uACF5\uD3EC\uAC00 \uCEE4\uC9C0\uBA74\uC11C
      \uC29B \uADA4\uC801\uC774 \uD3C9\uC18C\uBCF4\uB2E4 \uC9E7\uC544\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Tactician_201
    ko: "\uC9D1\uC911\uB825\uC774 \uBD80\uC871\uD588\uB358 \uBAA8\uC591\uC785\uB2C8\uB2E4.
      \uD658\uACBD \uD0D3\uC744 \uD558\uAE30 \uC804 \uBB3C\uB9AC\uC801 \uADA4\uC801\uBD80\uD130
      \uC7AC\uACC4\uC0B0\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Tactician_2
    ko: "\uB108\uBB34 \uB9CE\uC740 \uBCC0\uC218\uB97C \uACE0\uB824\uD558\uB290\uB77C
      \uD6C8\uB828\uC774 \uB354\uB514\uAC8C \uB418\uACE0 \uB9D0\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Exemplary_201
    ko: "\uC5D0\uC774\uC2A4\uB85C\uC11C \uBD80\uB044\uB7EC\uC6B4 \uBAA8\uC2B5\uC744
      \uBCF4\uC600\uB124\uC694. \uB2E4\uC2DC\uB294 \uC7A5\uBE44 \uD0D3\uC744 \uD558\uC9C0
      \uC54A\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Exemplary_2
    ko: "\uAC10\uB3C5\uC758 \uC9C8\uCC45\uC5D0 \uC790\uC874\uC2EC\uC774 \uC0C1\uD574
      \uC5B4\uAE68\uC5D0 \uACFC\uB3C4\uD55C \uD798\uC774 \uB4E4\uC5B4\uAC14\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Discipline_003
    ko: "\uB9D0\uC5C6\uC774 \uC120\uC218\uC758 \uC29B \uB3D9\uC791\uC744 \uB05D\uAE4C\uC9C0
      \uC9C0\uCF1C\uBCF8 \uB4A4, \uB5A8\uC5B4\uC9C4 \uACF5\uC744 \uC9C1\uC811 \uC8FC\uC6CC
      \uC120\uC218\uC5D0\uAC8C \uD328\uC2A4\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uACF5\uC744 \uC8FC\uC6CC\uC8FC\uC2E0 \uAC74 \uC9C1\uC811
      \uAE68\uB2EC\uC73C\uB77C\uB294 \uB73B\uC774\uACA0\uC8E0. \uBA48\uCD94\uC9C0
      \uC54A\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Principled_3
    ko: "\uBB34\uC758\uBBF8\uD55C \uBC18\uBCF5 \uC29B\uC73C\uB85C \uC778\uD574 \uC190\uBAA9\uC5D0
      \uBB34\uB9AC\uAC00 \uC654\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uADF8 \uAC15\uD55C \uD328\uC2A4... \uC81C\uAC00
      \uD300\uC744 \uC9C0\uCF1C\uC57C \uD55C\uB2E4\uB294 \uBB34\uC5B8\uC758 \uC555\uBC15\uC774\uACA0\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Guardian_3
    ko: "\uAE30\uC220\uC801\uC778 \uC870\uC5B8 \uBD80\uC7AC\uB85C \uC778\uD574 \uC131\uACF5\uB960\uC740
      \uD06C\uAC8C \uBCC0\uD558\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Tactician_301
    ko: "\uC774 \uB0A1\uC740 \uACF5\uC758 \uD68C\uC804\uB825\uACFC \uD718\uC5B4\uC9C4
      \uB9BC\uC758 \uC0C1\uAD00\uAD00\uACC4\uB97C \uC9C1\uC811 \uD30C\uC545\uD574\uBCF4\uB77C\uB294
      \uC758\uBBF8\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Tactician_3
    ko: "\uAC10\uB3C5\uC758 \uC758\uC911\uC744 \uD30C\uC545\uD558\uB294 \uB370 \uC5D0\uB108\uC9C0\uB97C
      \uC3DF\uB290\uB77C \uC815\uC791 \uC29B \uBA54\uCEE4\uB2C8\uC998\uC744 \uB193\uCE58\uACE0
      \uB9D0\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Exemplary_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uCE68\uBB35\uC774 \uBB34\uC12D\uB124\uC694. \uB354
      \uC644\uBCBD\uD574\uC838\uC57C\uB9CC \uC778\uC815\uBC1B\uC744 \uC218 \uC788\uB2E4\uB294
      \uB73B\uC774\uACA0\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Exemplary_3
    ko: "\uC778\uC815\uBC1B\uAE30 \uC704\uD574 \uD544\uC0AC\uC801\uC73C\uB85C \uC5F0\uC2B5\uD558\uC9C0\uB9CC
      \uB2A5\uB825\uC758 \uBCC0\uD654\uB294 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bond_001
    ko: "\uC815\uADDC \uD6C8\uB828\uC774 \uB05D\uB09C \uB4A4, \uB0A1\uC740 \uACE8\uB300
      \uBC11\uC5D0\uC11C \uD55C \uC120\uC218\uAC00 \uD640\uB85C 2\uC810 \uC29B \uC5F0\uC2B5\uC744
      \uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bond_002
    ko: "\uD558\uC9C0\uB9CC \uB9BC\uC774 \uD718\uC5B4\uC838 \uC788\uB294\uC9C0, \uB358\uC9C0\uB294
      \uACF5\uB9C8\uB2E4 \uC790\uAFB8\uB9CC \uB9BC\uC744 \uB9DE\uACE0 \uD295\uACA8
      \uB098\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bond_003
    ko: "\uC120\uC218\uB294 \uD55C\uC228\uC744 \uC26C\uBA70 \uB540\uC5D0 \uC816\uC740
      \uC720\uB2C8\uD3FC \uC18C\uB9E4\uB85C \uC774\uB9C8\uB97C \uB2E6\uC2B5\uB2C8\uB2E4.
      \uC774\uB54C \uADFC\uCC98\uB97C \uC9C0\uB098\uAC00\uB358 \uB2F9\uC2E0\uACFC
      \uB208\uC774 \uB9C8\uC8FC\uCE69\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bond_004
    ko: "\uC120\uC218\uB294 \uBA38\uC4F1\uD55C \uB4EF \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bond_005
    ko: "\uAC10\uB3C5\uB2D8, \uC544\uC9C1 \uC548 \uAC00\uC168\uC5B4\uC694? \uC694\uC998
      \uC911\uAC70\uB9AC \uC29B \uAC10\uAC01\uC774 \uB3C4\uBB34\uC9C0 \uC548 \uC7A1\uD600\uC11C\uC694...
      \uC6B0\uB9AC \uD559\uAD50 \uACE8\uB300\uAC00 \uC880 \uC774\uC0C1\uD55C \uAC74\uC9C0,
      \uC81C \uC190\uC774 \uBB38\uC81C\uC778 \uAC74\uC9C0 \uBAA8\uB974\uACA0\uB124\uC694.
      \uD558\uD558."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bond_006
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Bond_001
    ko: "\uD6C8\uB828\uC744 \uBC18\uBCF5\uD558\uB2E4\uBCF4\uBA74 \uC5B8\uC820\uAC00\uB294
      \uAC10\uAC01\uC744 \uAE68\uC6B0\uCE60 \uC218 \uC788\uC744\uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8 \uB9D0\uC500 \uB355\uBD84\uC5D0 \uAC11\uC790\uAE30 \uACF5\uC774
      \uC798 \uB4E4\uC5B4\uAC08 \uAC83 \uAC19\uC740 \uAE30\uBD84\uC774\uC5D0\uC694!
      \uAC10\uC0AC\uD574\uC694."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Kind_102
    ko: "\uB124 \uB9C8\uC74C\uC774 \uD3B8\uC548\uD574\uC57C \uACF5\uB3C4 \uD3B8\uC548\uD558\uAC8C
      \uB0A0\uC544\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Kind_1
    ko: "\uC11C\uC801 \uC9C0\uC9C0\uAC00 \uC5D4\uB3C4\uB974\uD540\uC744 \uC0DD\uC131\uD558\uC5EC
      \uADFC\uC721\uC758 \uAE34\uC7A5\uC744 \uD480\uC5B4\uC8FC\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Loyal_101
    ko: "\uC800\uB97C \uBBFF\uC5B4\uC8FC\uC2DC\uB294 \uAC10\uB3C5\uB2D8\uC744 \uC704\uD574\uC11C\uB77C\uB3C4
      \uC774 \uAC70\uB9AC\uC758 \uC29B\uC740 \uBB34\uC870\uAC74 \uB9C8\uC2A4\uD130\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Loyal_1
    ko: "\uC2E0\uB8B0\uC5D0 \uBCF4\uB2F5\uD558\uB824\uB294 \uAC15\uB825\uD55C \uC815\uC2E0\uB825\uC774
      \uAC01\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Sincere_101
    ko: "\uB124, \uB9BC\uC758 \uC0C1\uD0DC\uC5D0 \uC0C1\uAD00\uC5C6\uC774 \uC81C
      \uD3FC\uC774 \uC77C\uC815\uD558\uBA74 \uACB0\uAD6D \uB4E4\uC5B4\uAC04\uB2E4\uB294
      \uB9D0\uC500\uC774\uC2DC\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Sincere_102
    ko: "\uB9DE\uB2E4. 1%\uC758 \uD658\uACBD\uBCF4\uB2E4 99%\uC758 \uC77C\uAD00\uC131\uC774
      \uC911\uC694\uD558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Sincere_1
    ko: "\uAFB8\uC900\uD568\uC758 \uAC00\uCE58\uB97C \uC778\uC815\uBC1B\uC790 \uD6C8\uB828
      \uBAB0\uC785\uB3C4\uAC00 \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Moodmaker_101
    ko: "\uC624~ \uAC10\uB3C5\uB2D8 \uBA58\uD2B8 \uBA4B\uC9C4\uB370\uC694? \uC644\uC804\uAC10\uAC01
      \uC288\uD130\uC778\uAC00! \uC644\uC804 \uC8FC\uC778\uACF5 \uAC19\uC796\uC544\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Moodmaker_1
    ko: "\uC990\uAC70\uC6B4 \uAE34\uC7A5\uAC10\uC774 \uC9D1\uC911\uB825\uC744 \uB192\uC5EC
      \uD3C9\uC18C\uBCF4\uB2E4 \uB192\uC740 \uC57C\uD22C\uC728\uC744 \uAE30\uB85D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Bond_002
    ko: "\uC548 \uB4E4\uC5B4\uAC00\uB294 \uC774\uC720\uB97C \uC678\uBD80\uC5D0\uC11C
      \uCC3E\uC73C\uB824\uB294 \uD0DC\uB3C4 \uC790\uCCB4\uAC00 \uBB38\uC81C\uC57C.
      \uC9D1\uC911\uB825\uC774 \uD750\uD2B8\uB7EC\uC9C4 \uAC70 \uC544\uB2CC\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Kind_201
    ko: "\uC544... \uAC10\uB3C5\uB2D8 \uD654\uB098\uC168\uB098\uC694? \uC8C4\uC1A1\uD574\uC694.
      \uBD84\uC704\uAE30 \uC88B\uAC8C \uC5F0\uC2B5\uD558\uB824\uACE0 \uD55C \uAC74\uB370..."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Kind_2
    ko: "\uBD80\uC815\uC801\uC778 \uAC10\uC815\uC801 \uCDA9\uACA9\uC774 \uC29B \uAC10\uAC01\uC744
      \uC644\uC804\uD788 \uC557\uC544\uAC14\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Loyal_201
    ko: "\uC81C\uAC00 \uAC10\uB3C5\uB2D8\uAED8 \uC2E4\uB9DD\uC744 \uB4DC\uB838\uAD70\uC694.
      \uC2E4\uB825\uC73C\uB85C \uC81C \uCDA9\uC131\uC2EC\uC744 \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Loyal_2
    ko: "\uC2E4\uB9DD\uAC10\uC744 \uC53B\uAE30 \uC704\uD574 \uB178\uB825\uD558\uC9C0\uB9CC,
      \uACFC\uB3C4\uD55C \uC5F4\uB9DD\uC774 \uC624\uD788\uB824 \uC190\uBAA9\uC758
      \uC2A4\uB0C5\uC744 \uBC29\uD574\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Sincere_201
    ko: "\uBCC0\uBA85\uC740 \uD544\uC694 \uC5C6\uC8E0. \uB4E4\uC5B4\uAC08 \uB54C\uAE4C\uC9C0
      \uBC24\uC744 \uC0C8\uC6CC\uC11C\uB77C\uB3C4 \uAC10\uAC01\uC744 \uCC3E\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Sincere_2
    ko: "\uBB35\uBB35\uD788 \uC5F0\uC2B5\uC744 \uC774\uC5B4\uAC00\uC9C0\uB9CC \uC2E0\uCCB4\uC801
      \uD55C\uACC4\uC5D0 \uBD80\uB52A\uD614\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Moodmaker_201
    ko: "\uC5D0\uC774, \uAC10\uB3C5\uB2D8 \uB108\uBB34 \uC5C4\uACA9\uD558\uC2DC\uB2E4!
      \uC54C\uC558\uC5B4\uC694. \uC9C4\uC9C0 \uBAA8\uB4DC\uB85C \uB531 10\uAC1C\uB9CC
      \uC5F0\uC18D\uC73C\uB85C \uB123\uC744\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Moodmaker_202
    ko: "\uC6C3\uC74C\uAE30\uB97C \uBE7C\uB77C. \uADF8\uB798\uC57C \uC9C4\uC815\uD55C
      \uC288\uD130\uAC00 \uB41C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Moodmaker_2
    ko: "\uD2B9\uC720\uC758 \uD65C\uBC1C\uD568\uC774 \uC5B5\uB20C\uB9AC\uBA70 \uD50C\uB808\uC774\uC758
      \uB9AC\uB4EC\uAC10\uC744 \uC0C1\uC2E4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Bond_003
    ko: "\uB9D0\uC5C6\uC774 \uC120\uC218\uC758 \uC29B \uB3D9\uC791\uC744 \uB05D\uAE4C\uC9C0
      \uC9C0\uCF1C\uBCF8 \uB4A4, \uB5A8\uC5B4\uC9C4 \uACF5\uC744 \uC9C1\uC811 \uC8FC\uC6CC
      \uC120\uC218\uC5D0\uAC8C \uD328\uC2A4\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uACF5\uC744 \uC8FC\uC6CC\uC8FC\uC2DC\uB2E4\uB2C8...
      \uCE24\uB370\uB808 \uAC19\uC73C\uC154. \uB354 \uC5F4\uC2EC\uD788 \uD574\uC57C\uC9C0!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Kind_3
    ko: "\uC29B \uC131\uACF5\uB960\uC740 \uC81C\uC790\uB9AC\uC5D0 \uBA38\uBB3C\uB800\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uB358\uC838\uC900 \uACF5\uC758 \uBB34\uAC8C\uAC00
      \uBB34\uAC81\uB124\uC694. \uB05D\uAE4C\uC9C0 \uB0A8\uC73C\uB77C\uB294 \uC9C0\uC2DC\uB85C
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Loyal_3
    ko: "\uC2EC\uB9AC\uC801\uC73C\uB85C \uC704\uCD95\uB418\uC5B4 \uD3FC\uC774 \uBB34\uB108\uC9C0\uAE30
      \uC2DC\uC791\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Sincere_301
    ko: "\uB9D0\uC5C6\uC774 \uACF5\uC744 \uC8FC\uC6CC\uC8FC\uC2DC\uB294 \uAC10\uB3C5\uB2D8...
      \uC800\uB3C4 \uBB35\uBB35\uD788 \uC81C \uD560 \uC77C\uC744 \uACC4\uC18D\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Sincere_3
    ko: "\uBB35\uBB35\uD788 \uD6C8\uB828\uC744 \uACC4\uC18D\uD558\uB2E4 \uC798\uBABB\uB41C
      \uBC29\uD5A5\uC73C\uB85C \uB098\uC544\uAC00\uACE0 \uB9D0\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Moodmaker_301
    ko: "\uC640, \uAC10\uB3C5\uB2D8 \uD328\uC2A4 \uC9C4\uC9DC \uC138\uB124\uC694!
      \uC800\uB791 \uB0B4\uAE30 \uD55C \uD310 \uD558\uACE0 \uAC00\uC2DC\uC9C0~ \uC544\uC27D\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Moodmaker_3
    ko: "\uAC10\uB3C5\uC758 \uD589\uB3D9\uC5D0 \uD070 \uC758\uBBF8\uB97C \uB450\uC9C0
      \uC54A\uACE0 \uC790\uAE30 \uD398\uC774\uC2A4\uB300\uB85C \uC5F0\uC2B5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cold_001
    ko: "\uC815\uADDC \uD6C8\uB828\uC774 \uB05D\uB09C \uB4A4, \uB0A1\uC740 \uACE8\uB300
      \uBC11\uC5D0\uC11C \uD55C \uC120\uC218\uAC00 \uD640\uB85C 2\uC810 \uC29B \uC5F0\uC2B5\uC744
      \uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cold_002
    ko: "\uD558\uC9C0\uB9CC \uB9BC\uC774 \uD718\uC5B4\uC838 \uC788\uB294\uC9C0, \uB358\uC9C0\uB294
      \uACF5\uB9C8\uB2E4 \uC790\uAFB8\uB9CC \uB9BC\uC744 \uB9DE\uACE0 \uD295\uACA8
      \uB098\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cold_003
    ko: "\uC120\uC218\uB294 \uD55C\uC228\uC744 \uC26C\uBA70 \uB540\uC5D0 \uC816\uC740
      \uC720\uB2C8\uD3FC \uC18C\uB9E4\uB85C \uC774\uB9C8\uB97C \uB2E6\uC2B5\uB2C8\uB2E4.
      \uC774\uB54C \uADFC\uCC98\uB97C \uC9C0\uB098\uAC00\uB358 \uB2F9\uC2E0\uACFC
      \uB208\uC774 \uB9C8\uC8FC\uCE69\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cold_004
    ko: "\uC120\uC218\uB294 \uBA38\uC4F1\uD55C \uB4EF \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cold_005
    ko: "\uAC10\uB3C5\uB2D8, \uC544\uC9C1 \uC548 \uAC00\uC168\uC5B4\uC694? \uC694\uC998
      \uC911\uAC70\uB9AC \uC29B \uAC10\uAC01\uC774 \uB3C4\uBB34\uC9C0 \uC548 \uC7A1\uD600\uC11C\uC694...
      \uC6B0\uB9AC \uD559\uAD50 \uACE8\uB300\uAC00 \uC880 \uC774\uC0C1\uD55C \uAC74\uC9C0,
      \uC81C \uC190\uC774 \uBB38\uC81C\uC778 \uAC74\uC9C0 \uBAA8\uB974\uACA0\uB124\uC694.
      \uD558\uD558."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cold_006
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Cold_001
    ko: "\uD658\uACBD \uD0D3\uD558\uC9C0 \uB9C8\uB77C. \uB9BC\uC774 \uD718\uC5B4
      \uC788\uB2E4\uBA74 \uADF8 \uAD74\uC808\uAE4C\uC9C0 \uACC4\uC0B0\uD574\uC11C
      \uB123\uB294 \uAC8C \uC2E4\uB825\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Planner_101
    ko: "\uAD74\uC808\uC744 \uACC4\uC0B0\uD558\uB77C... \uD655\uC2E4\uD788 \uD658\uACBD
      \uBCC0\uC218\uB97C \uC0C1\uC218\uB85C \uB450\uB294 \uD3B8\uC774 \uC804\uB7B5\uC801\uC73C\uB85C
      \uC720\uB9AC\uD558\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Planner_102
    ko: "\uBCC0\uC218\uB97C \uC9C0\uBC30\uD558\uB294 \uC790\uAC00 \uCF54\uD2B8\uB97C
      \uC9C0\uBC30\uD558\uB294 \uBC95\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Planner_1
    ko: "\uB17C\uB9AC\uC801 \uC218\uAE0D\uC740 \uD588\uC73C\uB098 \uBA38\uB9BF\uC18D\uC73C\uB85C
      \uACF5\uC2DD\uC744 \uC218\uC815\uD558\uB290\uB77C \uBC14\uBE74\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Opportunist_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uBCF4\uC2DC\uB294 \uC55E\uC5D0\uC11C \uC131\uACF5\uC2DC\uCF1C\uC57C
      \uC8FC\uC804 \uC790\uB9AC \uAD73\uD788\uAE30\uC5D0 \uC720\uB9AC\uD558\uACA0\uC8E0.
      \uAC11\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Opportunist_1
    ko: "\uAC10\uB3C5\uC5D0\uAC8C \uC810\uC218\uB97C \uB530\uC57C \uD55C\uB2E4\uB294
      \uC2E4\uB9AC\uC801 \uBAA9\uC801\uC774 \uC9D1\uC911\uB825\uC744 \uC720\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cunning_101
    ko: "\uD6C4\uD6C4, \uB9BC\uC774 \uD718\uC5C8\uB2E4\uB294 \uAC78 \uC0C1\uB300\uAC00
      \uBAA8\uB97C \uB54C \uC81C\uAC00 \uBA3C\uC800 \uC801\uC751\uD558\uBA74, \uC774\uAC74
      \uC800\uB9CC\uC758 \uBE44\uBC00 \uBCD1\uAE30\uAC00 \uB418\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Cunning_1
    ko: "\uBD88\uB9AC\uD55C \uC870\uAC74\uC744 \uBCF8\uC778\uB9CC\uC758 \uC774\uB4DD\uC73C\uB85C
      \uBC14\uAFD4 \uC2EC\uB9AC\uC801 \uC6B0\uC704\uB97C \uC810\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Believer_101
    ko: "\uC81C \uC29B \uD3FC\uC740 \uC644\uBCBD\uD569\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8
      \uB9D0\uC500\uB300\uB85C \uB9BC\uC758 \uC624\uCC28 \uB530\uC704 \uC81C \uC2E4\uB825\uC73C\uB85C
      \uB36E\uC5B4\uBC84\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Believer_1
    ko: "\uC131\uACF5\uB960\uC740 \uB098\uC544\uC9C0\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Cold_002
    ko: "\uC548 \uB4E4\uC5B4\uAC00\uB294 \uC774\uC720\uB97C \uC678\uBD80\uC5D0\uC11C
      \uCC3E\uC73C\uB824\uB294 \uD0DC\uB3C4 \uC790\uCCB4\uAC00 \uBB38\uC81C\uC57C.
      \uC9D1\uC911\uB825\uC774 \uD750\uD2B8\uB7EC\uC9C4 \uAC70 \uC544\uB2CC\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Planner_201
    ko: "\uB9DE\uB294 \uB9D0\uC500\uC785\uB2C8\uB2E4. \uACE8\uB300 \uD0D3\uC744 \uD558\uB294
      \uAC74 \uD558\uC218\uB098 \uD558\uB294 \uC9D3\uC774\uC8E0. \uBC14\uB85C \uBCF4\uC815
      \uC791\uC5C5 \uB4E4\uC5B4\uAC11\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Planner_2
    ko: "\uC678\uBD80 \uD551\uACC4\uB97C \uC989\uAC01 \uCC28\uB2E8\uD558\uACE0 \uB0B4\uBA74\uC758
      \uC2DC\uC2A4\uD15C\uC744 \uAD50\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Opportunist_201
    ko: "\uD6C4\uBCF4\uB85C \uBC00\uB824\uB098\uAE34 \uC2EB\uC73C\uB2C8\uAE4C\uC694.
      \uB2F9\uC7A5 \uACE8\uB300\uC5D0 \uACF5\uC744 \uC464\uC154 \uBC15\uC544\uB123\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Opportunist_2
    ko: "\uC704\uAE30\uAC10 \uB54C\uBB38\uC5D0 \uC29B\uC744 \uB358\uC9C0\uB294 \uD589\uC704
      \uC790\uCCB4\uC5D0 \uAE09\uAE09\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cunning_201
    ko: "\uC815\uC2E0\uB825 \uC6B4\uC6B4\uD558\uC2DC\uB294 \uAC78 \uBCF4\uB2C8 \uC800\uB97C
      \uC2DC\uD5D8\uD558\uC2DC\uB294 \uAC70\uAD70\uC694. \uADF8 \uC2DC\uD5D8, \uAC00\uBCCD\uAC8C
      \uD1B5\uACFC\uD574\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Cunning_2
    ko: "\uAC10\uB3C5\uACFC\uC758 \uC2EC\uB9AC\uC804\uC5D0\uC11C \uC9C0\uC9C0 \uC54A\uC73C\uB824\uB2E4
      \uBCF8\uC778\uC758 \uD398\uC774\uC2A4\uB97C \uC783\uC5B4\uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Believer_201
    ko: "\uC81C \uC9D1\uC911\uB825\uC774 \uBB38\uC81C\uB77C\uACE0\uC694? \uC778\uC815\uD560
      \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uC81C \uBC29\uC2DD\uC774 \uB9DE\uB2E4\uB294
      \uAC78 \uACB0\uACFC\uB85C \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Believer_2
    ko: "\uAC10\uB3C5\uC758 \uBD80\uC815\uC5D0 \uB300\uD55C \uBC18\uBC1C\uC2EC\uC5D0
      \uB3C5\uAE30\uB97C \uD488\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Cold_003
    ko: "\uB9D0\uC5C6\uC774 \uC120\uC218\uC758 \uC29B \uB3D9\uC791\uC744 \uB05D\uAE4C\uC9C0
      \uC9C0\uCF1C\uBCF8 \uB4A4, \uB5A8\uC5B4\uC9C4 \uACF5\uC744 \uC9C1\uC811 \uC8FC\uC6CC
      \uC120\uC218\uC5D0\uAC8C \uD328\uC2A4\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Planner_301
    ko: "\uAC10\uB3C5\uB2D8\uC740 \uC81C\uAC00 \uC2A4\uC2A4\uB85C \uD658\uACBD\uC5D0
      \uC801\uC751\uD558\uB294 \uB2A5\uB825\uC744 \uD0A4\uC6B0\uAE38 \uC6D0\uD558\uC2DC\uB294\uAD70\uC694.
      \uC758\uB3C4 \uD30C\uC545\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Planner_3
    ko: "\uAC10\uB3C5\uC758 \uC758\uB3C4\uB97C \uC124\uACC4\uD558\uB294 \uB370 \uACFC\uBAB0\uC785\uD558\uC5EC
      \uC815\uC791 \uBCF8\uC778\uC758 \uC29B \uD0C0\uC774\uBC0D\uC744 \uB193\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Opportunist_301
    ko: "\uACF5 \uC8FC\uC6CC\uC8FC\uC2DC\uB294 \uAC70 \uBCF4\uB2C8 \uC800\uD55C\uD14C
      \uAE30\uB300\uAC00 \uD06C\uC2E0\uAC00 \uBCF4\uB124\uC694?"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Opportunist_3
    ko: "\uAC10\uB3C5\uC758 \uD589\uB3D9\uC744 \uACFC\uC789 \uD574\uC11D\uD558\uC5EC
      \uC6B0\uCB50\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cunning_301
    ko: "\uAC15\uD55C \uD328\uC2A4\uB85C \uC81C \uBC18\uC751\uC744 \uC0B4\uD53C\uC2E0
      \uAC74\uAC00\uC694? \uAC10\uB3C5\uB2D8\uB3C4 \uCC38 \uC18D\uC744 \uC54C \uC218
      \uC5C6\uB294 \uBD84\uC774\uB77C\uB2C8\uAE4C\uC694."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Cunning_3
    ko: "\uAC10\uC815\uC801\uC73C\uB85C \uD754\uB4E4\uB9AC\uC9C0\uB294 \uC54A\uC73C\uB098
      \uAE30\uC220\uC801\uC778 \uC5F0\uC2B5 \uD6A8\uC728\uC740 \uD3C9\uC774\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Believer_301
    ko: "\uADF8\uB798\uB3C4 \uC804 \uC81C \uC2E0\uB150\uC744 \uAD7D\uD788\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4.
      \uC81C \uAC10\uAC01\uC774 \uB9DE\uC744 \uB54C\uAE4C\uC9C0 \uC548 \uBA48\uCDA5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Believer_3
    ko: "\uC870\uC5B8\uC744 \uC644\uC804\uD788 \uCC28\uB2E8\uD558\uACE0 \uC790\uC2E0\uB9CC\uC758
      \uC138\uACC4\uC5D0 \uAC07\uD614\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Instinct_001
    ko: "\uC815\uADDC \uD6C8\uB828\uC774 \uB05D\uB09C \uB4A4, \uB0A1\uC740 \uACE8\uB300
      \uBC11\uC5D0\uC11C \uD55C \uC120\uC218\uAC00 \uD640\uB85C 2\uC810 \uC29B \uC5F0\uC2B5\uC744
      \uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Instinct_002
    ko: "\uD558\uC9C0\uB9CC \uB9BC\uC774 \uD718\uC5B4\uC838 \uC788\uB294\uC9C0, \uB358\uC9C0\uB294
      \uACF5\uB9C8\uB2E4 \uC790\uAFB8\uB9CC \uB9BC\uC744 \uB9DE\uACE0 \uD295\uACA8
      \uB098\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Instinct_003
    ko: "\uC120\uC218\uB294 \uD55C\uC228\uC744 \uC26C\uBA70 \uB540\uC5D0 \uC816\uC740
      \uC720\uB2C8\uD3FC \uC18C\uB9E4\uB85C \uC774\uB9C8\uB97C \uB2E6\uC2B5\uB2C8\uB2E4.
      \uC774\uB54C \uADFC\uCC98\uB97C \uC9C0\uB098\uAC00\uB358 \uB2F9\uC2E0\uACFC
      \uB208\uC774 \uB9C8\uC8FC\uCE69\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Instinct_004
    ko: "\uC120\uC218\uB294 \uBA38\uC4F1\uD55C \uB4EF \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Instinct_005
    ko: "\uAC10\uB3C5\uB2D8, \uC544\uC9C1 \uC548 \uAC00\uC168\uC5B4\uC694? \uC694\uC998
      \uC911\uAC70\uB9AC \uC29B \uAC10\uAC01\uC774 \uB3C4\uBB34\uC9C0 \uC548 \uC7A1\uD600\uC11C\uC694...
      \uC6B0\uB9AC \uD559\uAD50 \uACE8\uB300\uAC00 \uC880 \uC774\uC0C1\uD55C \uAC74\uC9C0,
      \uC81C \uC190\uC774 \uBB38\uC81C\uC778 \uAC74\uC9C0 \uBAA8\uB974\uACA0\uB124\uC694.
      \uD558\uD558."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Instinct_006
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Instinct_001
    ko: "\uD658\uACBD \uD0D3\uD558\uC9C0 \uB9C8\uB77C. \uB9BC\uC774 \uD718\uC5B4
      \uC788\uB2E4\uBA74 \uADF8 \uAD74\uC808\uAE4C\uC9C0 \uACC4\uC0B0\uD574\uC11C
      \uB123\uB294 \uAC8C \uC2E4\uB825\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bluffer_101
    ko: "\uD558! \uACC4\uC0B0 \uB530\uC704 \uD544\uC694 \uC5C6\uC5B4\uC694! \uB9BC\uC774
      \uD718\uC5C8\uB4E0 \uBD80\uC11C\uC84C\uB4E0 \uC81C \uC190\uC744 \uB5A0\uB09C
      \uACF5\uC740 \uBB34\uC870\uAC74 \uB4E4\uC5B4\uAC11\uB2C8\uB2E4. \uC9C0\uCF1C\uBCF4\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Bluffer_1
    ko: "\uC2E4\uC9C8\uC801\uC778 \uC29B \uC131\uACF5\uB960\uC740 \uD3C9\uC18C\uC640
      \uB2E4\uB97C \uBC14 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Wild_101
    ko: "\uC5ED\uC2DC \uB0B4 \uBCF8\uB2A5\uC774 \uB9DE\uC558\uC5B4! \uADF8\uB7EC\uBA74...
      \uC774\uB807\uAC8C \uD558\uBA74 \uB418\uACA0\uAD70. \uAC11\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Wild_102
    ko: "\uBCF8\uB2A5\uC744 \uBBFF\uC5B4\uB77C. \uBA38\uB9AC\uB85C \uC0DD\uAC01\uD558\uAE30
      \uC804\uC5D0 \uBAB8\uC774 \uBA3C\uC800 \uB098\uAC00\uAC8C \uD574."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Wild_1
    ko: "\uAC10\uB3C5\uC774 \uC57C\uC131\uC801\uC778 \uAC10\uAC01\uC744 \uC9C0\uC9C0\uD574\uC8FC\uC790
      \uC9C1\uAD00\uC774 \uC0B4\uC544\uB0AC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Egoist_101
    ko: "\uB9BC\uC774 \uC81C \uC29B\uC744 \uAC70\uBD80\uD558\uB294 \uAC8C \uAE30\uBD84
      \uB098\uC058\uB124\uC694. \uC81C\uAC00 \uC5B5\uC9C0\uB85C\uB77C\uB3C4 \uAD74\uBCF5\uC2DC\uD0A4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Egoist_1
    ko: "\uC790\uAE30\uC911\uC2EC\uC801\uC778 \uBAB0\uC785\uAC10\uC774 \uCD5C\uACE0\uC870\uC5D0
      \uB2EC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Fighter_101
    ko: "\uACC4\uC0B0? \uADF8\uAC8C \uBB61\uB2C8\uAE4C? \uBAA8\uB974\uACA0\uACE0,
      \uB9BC\uC744 \uBC15\uC0B4\uC744 \uB0B4\uC11C\uB77C\uB3C4 \uC29B\uC744 \uAF42\uC544
      \uB123\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Fighter_1
    ko: "\uC758\uC695\uC774 \uB108\uBB34 \uC55E\uC11C \uC29B \uC2A4\uD53C\uB4DC\uAC00
      \uC9C0\uB098\uCE58\uAC8C \uBE68\uB77C\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Instinct_002
    ko: "\uC548 \uB4E4\uC5B4\uAC00\uB294 \uC774\uC720\uB97C \uC678\uBD80\uC5D0\uC11C
      \uCC3E\uC73C\uB824\uB294 \uD0DC\uB3C4 \uC790\uCCB4\uAC00 \uBB38\uC81C\uC57C.
      \uC9D1\uC911\uB825\uC774 \uD750\uD2B8\uB7EC\uC9C4 \uAC70 \uC544\uB2CC\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bluffer_201
    ko: "\uBB50\uB77C\uACE0\uC694? \uC81C\uAC00 \uC9D1\uC911\uC744 \uC548 \uD55C\uB2E4\uACE0\uC694?
      \uC9C0\uAE08 \uB2F9\uC7A5 \uB208 \uAC10\uACE0\uB3C4 \uB123\uC5B4\uC904 \uD14C\uB2C8\uAE4C
      \uB611\uB611\uD788 \uBCF4\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Bluffer_2
    ko: "\uC790\uC874\uC2EC\uC744 \uAC74 \uB3C4\uBC1C\uC5D0 \uBCF8\uB2A5\uC774 \uAE68\uC5B4\uB0AC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Wild_201
    ko: "\uC794\uC18C\uB9AC\uB294 \uD544\uC694 \uC5C6\uC2B5\uB2C8\uB2E4! \uADF8\uB0E5
      \uB9BC\uC744 \uCC22\uC5B4\uBC84\uB9AC\uBA74 \uADF8\uB9CC\uC778 \uAC70\uC796\uC544\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Wild_2
    ko: "\uC774\uC131\uC801\uC778 \uC9C8\uCC45\uC5D0 \uD765\uBD84\uB3C4\uAC00 \uC9C0\uB098\uCE58\uAC8C
      \uB192\uC544\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Egoist_201
    ko: "\uB0A8 \uD0D3\uC774 \uC544\uB2C8\uB77C \uC81C \uC218\uC900\uC5D0 \uC548
      \uB9DE\uB294 \uACE8\uB300\uC778 \uAC8C \uD329\uD2B8\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Egoist_2
    ko: "\uACE8\uB300\uC640 \uAE30 \uC2F8\uC6C0\uC744 \uD558\uB290\uB77C \uCCB4\uB825\uC744
      \uB0AD\uBE44\uD558\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Fighter_201
    ko: "\uC9D1\uC911\uB825\uC774 \uBD80\uC871\uD558\uB2E4\uB294 \uB9D0, \uCDE8\uC18C\uD558\uAC8C
      \uD574\uB4DC\uB9AC\uC8E0. \uB0B4\uAE30\uB77C\uB3C4 \uD560\uAE4C\uC694? \uC5F0\uC18D\uC73C\uB85C
      100\uAC1C \uB123\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Fighter_2
    ko: "\uC9C8\uCC45\uC774 \uC2B9\uBD80\uC695\uC5D0 \uBD88\uC744 \uC9C0\uD3C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Instinct_003
    ko: "\uB9D0\uC5C6\uC774 \uC120\uC218\uC758 \uC29B \uB3D9\uC791\uC744 \uB05D\uAE4C\uC9C0
      \uC9C0\uCF1C\uBCF8 \uB4A4, \uB5A8\uC5B4\uC9C4 \uACF5\uC744 \uC9C1\uC811 \uC8FC\uC6CC
      \uC120\uC218\uC5D0\uAC8C \uD328\uC2A4\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bluffer_301
    ko: "\uBC29\uAE08 \uADF8 \uD328\uC2A4 \uBCF4\uC168\uC8E0? \uAC10\uB3C5\uB2D8\uB3C4
      \uC81C \uD3ED\uBC1C\uC801\uC778 \uC7A0\uC7AC\uB825\uC744 \uAC10\uB2F9 \uBABB
      \uD574\uC11C \uB3C4\uB9DD\uAC00\uC2DC\uB294 \uAC70\uB77C\uACE0\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Bluffer_3
    ko: "\uCC29\uAC01\uC5D0 \uBE60\uC838 \uC5F0\uC2B5\uBCF4\uB2E4\uB294 \uBA4B\uC9C4
      \uD3EC\uC988\uC640 \uC138\uB9AC\uBA38\uB2C8\uC5D0 \uCE58\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Wild_301
    ko: "\uD06C\uC73C... \uAC10\uB3C5\uB2D8\uC758 \uD328\uC2A4, \uB728\uAC81\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Wild_3
    ko: "\uAC10\uB3C5\uC758 \uAC15\uD55C \uD328\uC2A4\uC5D0\uC11C \uC5D0\uB108\uC9C0\uB97C
      \uC5BB\uC5C8\uC9C0\uB9CC \uC815\uAD50\uD568\uC774 \uBD80\uC871\uD574 \uC131\uACF5\uB960\uC740
      \uB4E4\uC465\uB0A0\uC465\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Egoist_301
    ko: "\uC29B \uC5F0\uC2B5\uC774\uB098 \uB354 \uD558\uB77C\uB294 \uAC74\uAC00\uC694?
      \uC81C\uB300\uB85C \uB41C \uC870\uC5B8\uC740 \uC5B8\uC81C \uD574\uC8FC\uC2DC\uB294\uB370\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Egoist_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uAD00\uC2EC\uC5D0 \uBD84\uB178\uB97C \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Fighter_301
    ko: "...\uBB50\uC9C0? \uB2E4\uC2DC \uD328\uC2A4\uB97C \uD574\uB2EC\uB77C\uB294
      \uAC74\uAC00? \uC774\uAC83\uC740 \uD328\uC2A4 \uC2F8\uC6C0\uC778\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Fighter_3
    ko: "\uAC10\uB3C5\uACFC\uC758 \uBCF4\uC774\uC9C0 \uC54A\uB294 \uC2F8\uC6C0\uC5D0
      \uC9D1\uCC29\uD558\uAE30 \uC2DC\uC791\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Discipline_001
    ko: "\uD300\uC6D0\uB4E4\uC774 \uBAA8\uB450 \uB3CC\uC544\uAC04 \uC2DC\uAC01, \uB9BC\uC744
      \uAC00\uB974\uB294 \uB9C8\uCC30\uC74C \uB300\uC2E0 \uD305\uACA8 \uB098\uC624\uB294
      \uB454\uD0C1\uD55C \uC18C\uB9AC\uB9CC\uC774 \uCCB4\uC721\uAD00\uC744 \uCC44\uC6C1\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Discipline_002
    ko: "\uCD5C\uADFC \uC288\uD305 \uC131\uACF5\uB960\uC774 \uBBF8\uC138\uD558\uAC8C
      \uB5A8\uC5B4\uC9C4 \uD55C \uC120\uC218\uAC00 \uB540\uC5D0 \uC816\uC740 \uCC44
      \uBC18\uBCF5\uD574\uC11C \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Discipline_003
    ko: "\uB370\uC774\uD130\uC640 \uAC01\uB3C4\uC5D0 \uC9D1\uCC29\uD558\uB294 \uC774
      \uC120\uC218\uB294 \uC790\uC2E0\uC758 \uC190\uB05D \uAC10\uAC01\uC774 \uD3C9\uC18C\uC640
      0.1cm \uB2E4\uB974\uB2E4\uB294 \uC0AC\uC2E4\uC5D0 \uADF9\uC2EC\uD55C \uC2A4\uD2B8\uB808\uC2A4\uB97C
      \uB290\uB07C\uBA70 \uC2A4\uC2A4\uB85C\uB97C \uBAB0\uC544\uC138\uC6B0\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Discipline_001
    ko: "\uC870\uAE08\uC740 \uC5C4\uACA9\uD55C \uAE30\uC900\uC744 \uB0B4\uB824\uB193\uC544\uB3C4
      \uAD1C\uCC2E\uC544."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Principled_101
    ko: "\uADF8\uAC83\uC740 \uC81C \uC2E0\uB150\uC5D0 \uB300\uD55C \uD0C0\uD611\uC785\uB2C8\uB2E4.
      \uD0C0\uD611\uD558\uB294 \uC21C\uAC04 \uC81C \uC288\uD305\uC740 \uBB34\uB108\uC9C8
      \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Principled_1
    ko: "\uC790\uC2E0\uC758 \uAC00\uC774\uB4DC\uB77C\uC778\uC774 \uD754\uB4E4\uB9AC\uB294
      \uAC83\uC744 \uACBD\uACC4\uD558\uC5EC \uACA9\uB824\uB97C \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Guardian_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uADF8\uB807\uAC8C \uB9D0\uC500\uD574 \uC8FC\uC2DC\uB2C8
      \uB2E4\uD589\uC785\uB2C8\uB2E4. \uD300\uC744 \uC704\uD574 \uC81C \uAC10\uAC01\uC744
      \uBE68\uB9AC \uB418\uCC3E\uACE0 \uC2F6\uC5C8\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Guardian_1
    ko: "\uAC10\uB3C5\uC758 \uC9C0\uC9C0\uB97C \uD300\uC744 \uC704\uD55C \uD5CC\uC2E0\uC73C\uB85C
      \uCE58\uD658\uD558\uC5EC \uC2EC\uB9AC\uC801 \uC548\uC815\uACFC \uD65C\uB825\uC774
      \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Tactician_101
    ko: "\uAC10\uC0AC\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC774 \uC624\uCC28 \uBC94\uC704\uB97C
      \uC218\uC815\uD558\uC9C0 \uC54A\uC73C\uBA74 \uB2E4\uC74C \uACBD\uAE30 \uC804\uC220\uC5D0
      \uCC28\uC9C8\uC774 \uC0DD\uAE41\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Tactician_1
    ko: "\uACA9\uB824\uB97C \uB4E3\uACE0\uB3C4 \uAC15\uBC15\uC744 \uBC84\uB9AC\uC9C0
      \uBABB\uD574 \uADFC\uC721\uC774 \uACFC\uBD80\uD558 \uC0C1\uD0DC\uB85C \uB0A8\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Exemplary_101
    ko: "\uC81C\uAC00 \uD754\uB4E4\uB9AC\uB294 \uBAA8\uC2B5\uC744 \uBCF4\uC5EC \uC8C4\uC1A1\uD569\uB2C8\uB2E4.
      \uB2E4\uC2DC \uD3C9\uC815\uC2EC\uC744 \uCC3E\uACE0 \uB8E8\uD2F4\uB300\uB85C
      \uB9C8\uBB34\uB9AC\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Exemplary_102
    ko: "\uC0AC\uACFC\uD560 \uAC83 \uC5C6\uB2E4. \uB108\uB294 \uC774\uBBF8 \uC6B0\uB9AC
      \uD300\uC758 \uD6CC\uB96D\uD55C \uBCF8\uBCF4\uAE30\uB2E4. \uC774\uC81C \uADF8\uB9CC
      \uC26C\uC5B4\uB77C."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Exemplary_1
    ko: "\uB3C4\uB355\uC801 \uC548\uB3C4\uAC10\uC740 \uC5BB\uC5C8\uC73C\uB098 \uC288\uD305\uC5D0
      \uB300\uD55C \uAE30\uC220\uC801 \uD574\uACB0\uCC45\uC740 \uCC3E\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Discipline_002
    ko: "\uC815\uD574\uC9C4 \uD734\uC2DD \uC2DC\uAC04\uC744 \uC5B4\uAE30\uACE0 \uBAB8\uC744
      \uD639\uC0AC\uD558\uB294 \uAC74 \uD300\uC758 \uADDC\uC728\uC744 \uC5B4\uAE30\uB294
      \uD589\uC704\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Principled_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uD6C8\uB828 \uC885\uB8CC \uC2DC\uAC04\uC744
      \uC9C0\uD0A4\uB294 \uAC83\uB3C4 \uC120\uC218\uC758 \uC6D0\uCE59\uC778\uB370...
      \uC81C\uAC00 \uC120\uC744 \uB118\uC5C8\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Principled_2
    ko: "\uC2DC\uAC04 \uC5C4\uC218\uB97C \uC77C\uAE68\uC6CC\uC8FC\uC790 \uBBF8\uC2DC\uC801\uC778
      \uAC15\uBC15\uC5D0\uC11C \uBC97\uC5B4\uB098 \uD3FC\uC774 \uD68C\uBCF5\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Guardian_201
    ko: "\uD300\uC5D0 \uD53C\uD574\uB97C \uC8FC\uB824\uB294 \uAC8C \uC544\uB2C8\uC5C8\uC2B5\uB2C8\uB2E4!
      \uB2E8\uC9C0 \uB354 \uC644\uBCBD\uD574\uC838\uC11C \uBAA8\uB450\uB97C \uC9C0\uD0A4\uACE0
      \uC2F6\uC5C8\uC744 \uBFD0\uC785\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Guardian_202
    ko: "\uC644\uBCBD\uD574\uC9C0\uB824\uB2E4 \uBD80\uC0C1\uB2F9\uD558\uBA74 \uADF8\uAC8C
      \uD300\uC744 \uB3D5\uB294 \uAC70\uB0D0? \uB0B4\uC77C \uB2E4\uC2DC \uD574."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Guardian_2
    ko: "\uC9C8\uCC45\uC744 \uBCF8\uC778\uC758 \uD5CC\uC2E0\uC5D0 \uB300\uD55C \uBD80\uC815\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uAE4A\uC740 \uC0C1\uCC98\uB97C \uC785\uACE0 \uC704\uCD95\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Tactician_201
    ko: "\uD6A8\uC728\uC801\uC774\uC9C0 \uBABB\uD55C \uD589\uB3D9\uC774\uC5C8\uC2B5\uB2C8\uB2E4.
      \uB0C9\uC815\uD558\uAC8C \uD310\uB2E8\uD558\uC9C0 \uBABB\uD55C \uC81C \uC798\uBABB\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Tactician_2
    ko: "\uC790\uC2E0\uC758 \uBE44\uD6A8\uC728\uC131\uC744 \uC778\uC815\uD558\uACE0
      \uC989\uAC01 \uBA48\uCD94\uC9C0\uB9CC \uAE30\uB7C9\uC758 \uC989\uAC01\uC801\uC778
      \uBCC0\uD654\uB294 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Exemplary_201
    ko: "\uB2E4\uB978 \uBD80\uC6D0\uB4E4\uC5D0\uAC8C \uC88B\uC9C0 \uBABB\uD55C \uBCF8\uBCF4\uAE30\uAC00
      \uB418\uC5C8\uAD70\uC694. \uBC14\uB85C \uC815\uB9AC\uD558\uACE0 \uB4E4\uC5B4\uAC00\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Exemplary_2
    ko: "\uC790\uC2E0\uC758 \uC704\uCE58\uB97C \uC790\uAC01\uD558\uACE0 \uCC45\uC784\uAC10\uC744
      \uBC1C\uD718\uD558\uC5EC \uD750\uD2B8\uB7EC\uC9C4 \uBC38\uB7F0\uC2A4\uB97C
      \uC989\uC2DC \uBC14\uB85C\uC7A1\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Discipline_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uB97C \uC9C0\uCF1C\uBCF8 \uB4A4,
      \uACF5\uB9CC \uCC59\uACA8\uC11C \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Principled_301
    ko: "\uC65C \uC544\uBB34 \uB9D0\uC500\uB3C4 \uC548 \uD558\uC2DC\uC8E0? \uC81C
      \uBC29\uC2DD\uC774 \uAC10\uB3C5\uB2D8 \uAE30\uC900\uC5D0\uB3C4 \uD569\uACA9\uC774\uB77C\uB294
      \uB73B\uC785\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Principled_3
    ko: "\uCE68\uBB35\uC744 \uBD80\uC815\uC801\uC778 \uD3C9\uAC00\uB85C \uC624\uD574\uD558\uACE0
      \uC815\uB2F5\uC744 \uCC3E\uAE30 \uC704\uD574 \uBAB8\uC744 \uB354 \uD639\uC0AC\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Guardian_301
    ko: "...\uAC10\uB3C5\uB2D8, \uC774\uC81C \uB410\uC2B5\uB2C8\uB2E4. \uC800\uB97C
      \uBBFF\uC5B4\uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Guardian_3
    ko: "\uAC10\uB3C5\uC758 \uC874\uC7AC \uC790\uCCB4\uB85C \uC704\uC548\uC744 \uC5BB\uC9C0\uB9CC
      \uC288\uD305 \uC624\uCC28\uB294 \uC2A4\uC2A4\uB85C \uD574\uACB0\uD558\uC9C0
      \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Tactician_301
    ko: "\uD734\uC2DD\uB3C4 \uD558\uB098\uC758 \uC804\uC220\uC774\uACA0\uC9C0\uC694.
      \uADF8\uB9CC \uD6C8\uB828\uC744 \uC885\uB8CC\uD558\uB3C4\uB85D \uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Tactician_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uC5B8\uC758 \uC555\uBC15\uC744 \uD1B5\uD574 \uD6C8\uB828
      \uC885\uB8CC\uAC00 \uCD5C\uC120\uC758 \uC804\uC220\uC784\uC744 \uAE68\uB2EC\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Exemplary_301
    ko: "\uAC10\uB3C5\uB2D8\uAE4C\uC9C0 \uACE0\uC0DD\uC2DC\uD0A4\uB2E4\uB2C8... \uC81C\uAC00
      \uC815\uB9D0 \uD55C\uC2EC\uD558\uAD70\uC694. \uBC14\uB85C \uC815\uB9AC\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Exemplary_3
    ko: "\uC790\uCC45\uAC10\uC774 \uADF9\uC5D0 \uB2EC\uD574 \uC288\uD305\uC5D0 \uB300\uD55C
      \uC790\uC2E0\uAC10\uC744 \uC783\uACE0 \uC2AC\uB7FC\uD504\uAC00 \uAE4A\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bond_001
    ko: "\uD300\uC6D0\uB4E4\uC774 \uBAA8\uB450 \uB3CC\uC544\uAC04 \uC2DC\uAC01, \uB9BC\uC744
      \uAC00\uB974\uB294 \uB9C8\uCC30\uC74C \uB300\uC2E0 \uD305\uACA8 \uB098\uC624\uB294
      \uB454\uD0C1\uD55C \uC18C\uB9AC\uB9CC\uC774 \uCCB4\uC721\uAD00\uC744 \uCC44\uC6C1\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bond_002
    ko: "\uCD5C\uADFC \uC288\uD305 \uC131\uACF5\uB960\uC774 \uBBF8\uC138\uD558\uAC8C
      \uB5A8\uC5B4\uC9C4 \uD55C \uC120\uC218\uAC00 \uB540\uC5D0 \uC816\uC740 \uCC44
      \uBC18\uBCF5\uD574\uC11C \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bond_003
    ko: "\uB370\uC774\uD130\uC640 \uAC01\uB3C4\uC5D0 \uC9D1\uCC29\uD558\uB294 \uC774
      \uC120\uC218\uB294 \uC790\uC2E0\uC758 \uC190\uB05D \uAC10\uAC01\uC774 \uD3C9\uC18C\uC640
      0.1cm \uB2E4\uB974\uB2E4\uB294 \uC0AC\uC2E4\uC5D0 \uADF9\uC2EC\uD55C \uC2A4\uD2B8\uB808\uC2A4\uB97C
      \uB290\uB07C\uBA70 \uC2A4\uC2A4\uB85C\uB97C \uBAB0\uC544\uC138\uC6B0\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bond_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Bond_001
    ko: "\uD63C\uC790\uC11C \uB2E4 \uC9CA\uC5B4\uC9C0\uB824\uACE0 \uD558\uC9C0 \uB9C8\uB77C.
      0.1cm\uC758 \uC624\uCC28\uBCF4\uB2E4 \uC911\uC694\uD55C \uAC74 \uB124 \uACC1\uC5D0
      \uC6B0\uB9AC\uAC00 \uC788\uB2E4\uB294 \uC0AC\uC2E4\uC774\uC57C."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uC800 \uB54C\uBB38\uC5D0 \uD300\uC6D0\uB4E4\uC774
      \uACE0\uC0DD\uD558\uB294 \uAC83 \uAC19\uC544 \uB9C8\uC74C\uC774 \uD3B8\uCE58
      \uC54A\uC558\uC5B4\uC694. \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Kind_102
    ko: "\uADF8 \uB530\uB73B\uD55C \uB9C8\uC74C\uC774 \uB124 \uC29B\uC5D0 \uB179\uC544\uB4E4
      \uAC70\uB2E4. \uC624\uB298\uC740 \uADF8\uB9CC \uC26C\uB834."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Kind_1
    ko: "\uC815\uC11C\uC801 \uC9C0\uC9C0\uB97C \uD1B5\uD574 \uC2EC\uB9AC\uC801 \uC555\uBC15\uAC10\uC774
      \uD574\uC18C\uB418\uBA70 \uBD80\uB4DC\uB7EC\uC6B4 \uC29B \uD130\uCE58\uAC00
      \uD68C\uBCF5\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uADF8\uB807\uAC8C \uB9D0\uC500\uD558\uC2DC\uB2C8
      \uB354 \uC8C4\uC1A1\uD558\uB124\uC694. \uC81C\uAC00 \uB354 \uC644\uBCBD\uD574\uC57C
      \uAC10\uB3C5\uB2D8 \uCCB4\uBA74\uC774 \uC124 \uD150\uB370..."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Loyal_1
    ko: "\uAC10\uB3C5\uC758 \uACA9\uB824\uB97C \uCC45\uC784\uAC10\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uACE0\uB9C8\uC6CC\uD558\uC9C0\uB9CC, \uC2E4\uB825 \uBCC0\uD654\uB294 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Sincere_101
    ko: "\uB9D0\uC500\uC740 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uC544\uC9C1 \uC81C \uD560\uB2F9\uB7C9\uC744
      \uCC44\uC6B0\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4. \uC870\uAE08\uB9CC \uB354
      \uB358\uC9C0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Sincere_1
    ko: "\uACA9\uB824\uB97C \uB4E3\uACE0\uB3C4 \uBA48\uCD94\uC9C0 \uBABB\uD574 \uD53C\uB85C\uAC00
      \uB204\uC801\uB418\uACE0 \uC288\uD305 \uBC38\uB7F0\uC2A4\uAC00 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Moodmaker_101
    ko: "\uC5D0\uC774, \uAC10\uB3C5\uB2D8! \uAC11\uC790\uAE30 \uADF8\uB807\uAC8C
      \uC9C4\uC9C0\uD558\uAC8C \uB9D0\uC500\uD558\uC2DC\uBA74 \uC800 \uC6B8\uC9C0\uB3C4
      \uBAB0\uB77C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Moodmaker_1
    ko: "\uD2B9\uC720\uC758 \uB099\uCC9C\uC131\uC73C\uB85C \uC0C1\uD669\uC744 \uB118\uAE30\uBA70
      \uAE30\uBD84 \uC804\uD658\uC740 \uC131\uACF5\uD558\uB098 \uB2A5\uB825\uCE58\uC5D0
      \uBCC0\uD654\uB294 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Bond_002
    ko: "\uC544\uC9C1\uB3C4 \uD63C\uC790\uC11C \uD6C8\uB828 \uC911\uC778\uAC00? \uB124
      \uACE0\uC9D1\uC774 \uD300\uC758 \uD654\uD569\uC744 \uAE68\uACE0 \uC788\uB2E4\uB294
      \uAC78 \uC65C \uBAB0\uB77C!"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Kind_201
    ko: "\uD654\uD569\uC744 \uAE68\uB824\uB358 \uAC8C \uC544\uB2C8\uB77C... \uB3C4\uC6C0\uC774
      \uB418\uACE0 \uC2F6\uC5B4\uC11C... \uC8C4\uC1A1\uD569\uB2C8\uB2E4, \uAC10\uB3C5\uB2D8."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Kind_202
    ko: "\uC9C4\uC9DC \uB3C4\uC6C0\uC774 \uB418\uACE0 \uC2F6\uB2E4\uBA74 \uB3D9\uB8CC\uB4E4\uACFC
      \uC18C\uD1B5\uD574\uB77C. \uC5EC\uAE30\uC11C \uC0BD\uC9C8\uD558\uC9C0 \uB9D0\uACE0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Kind_2
    ko: "\uB0A0\uCE74\uB85C\uC6B4 \uBE44\uD310\uC5D0 \uC0C1\uCC98\uB97C \uC785\uACE0
      \uC790\uC2E0\uAC10\uC744 \uC0C1\uC2E4\uD558\uC5EC \uC288\uD305 \uC131\uACF5\uB960\uC774
      \uD558\uB77D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Loyal_201
    ko: "\uC81C \uB3C5\uB2E8\uC801\uC778 \uD589\uB3D9\uC774 \uD300\uC5D0 \uC2E4\uB840\uAC00
      \uB418\uC5C8\uAD70\uC694. \uAC10\uB3C5\uB2D8\uC758 \uC9C0\uC2DC\uB300\uB85C
      \uC989\uC2DC \uC911\uB2E8\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Loyal_202
    ko: "\uADF8\uB798. \uD300\uC758 \uC2B9\uB9AC\uB294 \uB124 \uACE0\uC9D1\uC774
      \uC544\uB2C8\uB77C \uC6B0\uB9AC\uC758 \uD611\uB825\uC5D0\uC11C \uB098\uC628\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Loyal_2
    ko: "\uD300\uC758 \uADDC\uC728\uACFC \uCDA9\uC131\uC2EC\uC744 \uC790\uADF9\uBC1B\uC544
      \uAC1C\uC778 \uAC15\uBC15\uC744 \uBC84\uB9AC\uACE0 \uD300 \uD50C\uB808\uC774\uC5D0
      \uC9D1\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Sincere_201
    ko: "\uAC1C\uC778 \uD6C8\uB828\uB3C4 \uD300\uC5D0 \uAE30\uC5EC\uD558\uB294 \uAE38\uC774\uB77C
      \uC0DD\uAC01\uD588\uC2B5\uB2C8\uB2E4. \uC81C \uD310\uB2E8\uC774 \uD2C0\uB838\uB358
      \uBAA8\uC591\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Sincere_2
    ko: "\uC9C0\uC801\uC744 \uACB8\uD5C8\uD788 \uC218\uC6A9\uD558\uACE0 \uD6C8\uB828\uC744
      \uC911\uB2E8\uD558\uC9C0\uB9CC \uAE30\uB7C9\uC758 \uC989\uAC01\uC801 \uBC18\uB4F1\uC740
      \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Moodmaker_201
    ko: "\uC544\uC774\uAD6C, \uAC10\uB3C5\uB2D8 \uD654\uB098\uC168\uB124! \uC81C\uAC00
      \uC798\uBABB\uD588\uC2B5\uB2C8\uB2E4! \uBD84\uC704\uAE30 \uB9DD\uCE58\uAE30
      \uC804\uC5D0 \uBC14\uB85C \uD1F4\uADFC\uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Moodmaker_2
    ko: "\uC555\uBC15\uAC10\uC5D0 \uC9D3\uB20C\uB824 \uD3C9\uC18C\uC758 \uC720\uC5F0\uD55C
      \uC6C0\uC9C1\uC784\uC744 \uC783\uACE0 \uC288\uD305 \uB9AC\uB4EC\uC774 \uAE68\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Bond_003
    ko: "\uC120\uC218\uAC00 \uC9C0\uCCD0\uC11C \uC2A4\uC2A4\uB85C \uBA48\uCD9C \uB54C\uAE4C\uC9C0
      \uBB35\uBB35\uD788 \uACF5\uC744 \uB358\uC838\uC900\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uB3C4 \uD53C\uACE4\uD558\uC2E4 \uD150\uB370... \uC774\uC81C
      \uADF8\uB9CC\uD560\uAC8C\uC694. \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Kind_3
    ko: "\uAC10\uB3C5\uC758 \uBC30\uB824\uC5D0 \uAC10\uB3D9\uD558\uC5EC \uD6C8\uB828\uC744
      \uBA48\uCDC4\uC9C0\uB9CC \uAC10\uAC01\uC801\uC778 \uBB38\uC81C\uB294 \uD574\uACB0\uB418\uC9C0
      \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uD328\uC2A4\uB97C... \uC81C\uAC00
      \uAC10\uD788 \uC774\uB7F0 \uB300\uC6B0\uB97C \uBC1B\uC544\uB3C4 \uB418\uB294\uC9C0
      \uBAA8\uB974\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Loyal_3
    ko: "\uAC10\uB3C5\uC5D0 \uB300\uD55C \uBBF8\uC548\uD568\uACFC \uACFC\uB3C4\uD55C
      \uBD80\uB2F4\uAC10\uC744 \uB290\uAEF4 \uC288\uD305 \uC190\uB05D\uC774 \uB354\uC6B1
      \uACBD\uC9C1\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Sincere_301
    ko: "...\uC774\uC81C 0.1cm\uAC00 \uBB54\uC9C0 \uC54C \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
      \uAC10\uB3C5\uB2D8 \uB355\uBD84\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Sincere_302
    ko: "\uC2A4\uC2A4\uB85C \uAE68\uB2EC\uC558\uB2E4\uBA74 \uB410\uB2E4. \uADF8 \uAC10\uAC01
      \uC78A\uC9C0 \uB9D0\uACE0 \uC798 \uAC04\uC9C1\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Sincere_3
    ko: "\uAC10\uB3C5\uC758 \uBB35\uBB35\uD55C \uC9C0\uC6D0 \uC18D\uC5D0 \uD3C9\uC815\uC2EC\uC744
      \uCC3E\uACE0 \uC2A4\uC2A4\uB85C \uC288\uD305 \uBA54\uCEE4\uB2C8\uC998\uC744
      \uC644\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Moodmaker_301
    ko: "\uC640! \uAC10\uB3C5\uB2D8\uC774 \uD328\uC2A4 \uC154\uD2C0\uC774\uB77C\uB2C8!
      \uC774\uAC70 \uD300\uC6D0\uB4E4\uC774 \uC54C\uBA74 \uB09C\uB9AC \uB098\uACA0\uB294\uB370\uC694?"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Moodmaker_3
    ko: "\uAC10\uB3C5\uACFC\uC758 \uCE5C\uBC00\uD55C \uAD50\uAC10\uC744 \uD1B5\uD574
      \uD65C\uAE30\uB97C \uB418\uCC3E\uACE0 \uD300\uC6D0\uB4E4\uC744 \uD5A5\uD55C
      \uC2DC\uC57C\uAC00 \uB113\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cold_001
    ko: "\uD300\uC6D0\uB4E4\uACFC \uC5B4\uC6B8\uB9AC\uC9C0 \uBABB\uD558\uACE0 \uD640\uB85C
      \uCF54\uD2B8\uC5D0 \uB0A8\uC740 \uC120\uC218\uAC00 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cold_002
    ko: "\uD3C9\uC18C \uD300\uC6CC\uD06C\uB97C \uC911\uC2DC\uD558\uB358 \uC120\uC218\uC600\uC9C0\uB9CC,
      \uCD5C\uADFC \uC2AC\uB7FC\uD504\uAC00 \uC624\uC790 \uD300\uC758 \uC871\uC1C4\uAC00
      \uB41C\uB2E4\uB294 \uBD80\uB2F4\uAC10\uC5D0 \uC0AC\uB85C\uC7A1\uD600 \uBC84\uB838\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cold_003
    ko: "0.1cm\uC758 \uAC10\uAC01 \uCC28\uC774\uC5D0 \uC9D1\uCC29\uD558\uBA70 \uC2E0\uACBD\uC9C8\uC801\uC73C\uB85C
      \uACF5\uC744 \uB358\uC9C0\uB294 \uC120\uC218\uC758 \uB208\uC740 \uC774\uBBF8
      \uCDA9\uD608\uB418\uC5B4 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cold_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Cold_001
    ko: "\uC218\uCE58\uC5D0 \uB108\uBB34 \uC5F0\uC5F0\uD558\uC9C0 \uB9C8\uB77C. \uC870\uAE08\uB9CC
      \uD798\uC744 \uBE7C\uBA74 \uD3FC\uC744 \uB418\uCC3E\uC744 \uC218 \uC788\uC744
      \uAC70\uC57C."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Planner_101
    ko: "\uC218\uCE58\uB294 \uAC70\uC9D3\uB9D0\uC744 \uC548 \uD569\uB2C8\uB2E4. \uACA9\uB824\uBCF4\uB2E4\uB294
      \uC81C \uADA4\uC801\uC758 \uC624\uCC28 \uC6D0\uC778\uC744 \uC9DA\uC5B4\uC8FC\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Planner_102
    ko: "\uC6D0\uC778\uC740 \uACFC\uBD80\uD558\uB2E4. \uC9C0\uAE08\uC740 \uBD84\uC11D\uBCF4\uB2E4
      \uB1CC\uB97C \uC26C\uAC8C \uD558\uB294 \uAC8C \uC6B0\uC120\uC774\uC57C."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Planner_1
    ko: "\uAC10\uC131\uC801\uC778 \uACA9\uB824\uB97C \uB17C\uB9AC\uC801\uC73C\uB85C
      \uAC70\uBD80\uD558\uBA70 \uD604 \uC0C1\uD0DC\uAC00 \uC720\uC9C0\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Opportunist_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uAD1C\uCC2E\uB2E4\uACE0 \uB9D0\uD55C\uB2E4\uBA74
      \uB2E4\uD589\uC774\uB124\uC694. "
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Opportunist_1
    ko: "\uAC10\uB3C5\uC758 \uAE0D\uC815\uC801 \uD0DC\uB3C4\uB97C \uD655\uC778\uD558\uACE0
      \uC2EC\uB9AC\uC801 \uC555\uBC15\uC5D0\uC11C \uBC97\uC5B4\uB098 \uD3FC\uC774
      \uD68C\uBCF5\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cunning_101
    ko: "\uB124, \uBA85\uC2EC\uD558\uACA0\uC2B5\uB2C8\uB2E4. ...\uD558\uC9C0\uB9CC
      \uADF8\uB798\uB3C4 \uC2AC\uB7FC\uD504\uB97C \uADF9\uBCF5\uD558\uC9C0 \uBABB\uD558\uBA74
      \uC5B4\uB5A1\uD558\uC9C0?"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Cunning_1
    ko: "\uC790\uC2E0\uC758 \uC57D\uC810\uC744 \uAC10\uCD94\uB824\uB294 \uC2EC\uB9AC\uC801
      \uBC29\uC5B4 \uAE30\uC81C\uAC00 \uBAB8\uC744 \uB354 \uACBD\uC9C1\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Believer_101
    ko: "\uAC10\uC0AC\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC800\uB294 \uC81C \uACC4\uC0B0\uC774
      \uB9DE\uB2E4\uB294 \uAC78 \uC99D\uBA85\uD560 \uB54C\uAE4C\uC9C0 \uC548 \uC27D\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Believer_1
    ko: "\uACA9\uB824\uC640 \uC0C1\uAD00\uC5C6\uC774 \uBCF8\uC778\uC758 \uC8FC\uAD00\uB300\uB85C
      \uD6C8\uB828\uC744 \uC9C0\uC18D\uD558\uC5EC \uBCC0\uD654\uAC00 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Cold_002
    ko: "\uC0DD\uAC01 \uC5C6\uC774 \uB358\uC9C0\uAE30\uB9CC \uD55C\uB2E4\uACE0 \uB4E4\uC5B4\uAC08
      \uAC83 \uAC19\uB098? \uB10C \uC804\uD600 \uD6C8\uB828\uD558\uACE0 \uC788\uC9C0
      \uC54A\uC544!"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Planner_201
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uB9F9\uBAA9\uC801\uC778 \uBC18\uBCF5\uC774\uC5C8\uAD70\uC694.
      \uB2E4\uC2DC \uC5ED\uD559\uC801\uC73C\uB85C \uC811\uADFC\uD574\uC11C \uD3FC\uC744
      \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Planner_2
    ko: "\uC790\uC2E0\uC758 \uBE44\uD6A8\uC728\uC131\uC744 \uC989\uAC01 \uC778\uC815\uD558\uACE0
      \uB17C\uB9AC\uC801 \uC218\uC815\uC744 \uD1B5\uD574 \uD6A8\uC728\uC774 \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Opportunist_201
    ko: "\uC73D, \uB4E4\uCF30\uB098\uC694? \uD6A8\uC728\uC774 \uB5A8\uC5B4\uC9C4\uB2E4\uB294
      \uAC74 \uC778\uC815\uD569\uB2C8\uB2E4. \uBC14\uB85C \uBA48\uCD94\uACE0 \uC26C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Opportunist_2
    ko: "\uBE44\uB09C\uC744 \uD53C\uD558\uAE30 \uC704\uD574 \uC989\uAC01 \uC21C\uC751\uD558\uC9C0\uB9CC
      \uC2E4\uC9C8\uC801\uC778 \uAE30\uB7C9 \uBCC0\uD654\uB294 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cunning_201
    ko: "\uC0DD\uAC01\uC774 \uC5C6\uC5C8\uB358 \uAC8C \uC544\uB2C8\uB77C, \uB2E4\uB978
      \uC804\uC220\uC801 \uBCC0\uC218\uB97C \uACE0\uBBFC \uC911\uC774\uC5C8\uC2B5\uB2C8\uB2E4.
      \uC624\uD574\uD558\uC9C0 \uB9C8\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Cunning_2
    ko: "\uC9C0\uC801\uC5D0 \uB300\uD574 \uAC70\uC9D3 \uBCC0\uBA85\uC73C\uB85C \uC77C\uAD00\uD558\uBA70
      \uBB38\uC81C\uC758 \uBCF8\uC9C8\uC744 \uC678\uBA74\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Believer_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD2C0\uB838\uB2E4\uACE0 \uC0DD\uAC01\uD558\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8\uC774 \uD2C0\uB838\uB2E4\uB294
      \uAC78 \uACB0\uACFC\uB85C \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Believer_202
    ko: "\uC88B\uB2E4. \uADF8 \uC624\uAE30\uAC00 \uB3C5\uC774 \uB420\uC9C0 \uC57D\uC774
      \uB420\uC9C0\uB294 \uB0B4\uC77C \uD655\uC778\uD558\uACA0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Believer_2
    ko: "\uAC15\uD55C \uC790\uADF9\uC774 \uC2B9\uBD80\uC695\uC744 \uAC74\uB4DC\uB824
      \uADF9\uD55C\uC758 \uC9D1\uC911\uB825\uC73C\uB85C \uC29B \uC815\uD655\uB3C4\uAC00
      \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Cold_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uB97C \uC9C0\uCF1C\uBCF8 \uB4A4,
      \uACF5\uB9CC \uCC59\uACA8\uC11C \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Planner_301
    ko: "\uBB34\uC5B8\uC758 \uAE0D\uC815\uC778\uAC00... \uC544\uB2C8\uBA74 \uD3EC\uAE30\uC778\uAC00?
      \uB2E4\uC2DC \uACC4\uC0B0\uD574\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Planner_3
    ko: "\uAC00\uC774\uB4DC\uAC00 \uC5C6\uB294 \uC0C1\uD0DC\uC5D0\uC11C \uACFC\uB3C4\uD55C
      \uBD84\uC11D\uC5D0 \uBE60\uC838 \uC288\uD305 \uBA54\uCEE4\uB2C8\uC998\uC774
      \uAF2C\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Opportunist_301
    ko: "\uD734, \uC794\uC18C\uB9AC \uC548 \uB4E4\uC5B4\uC11C \uB2E4\uD589\uC774\uB124.
      \uC801\uB2F9\uD788 \uB358\uC9C0\uB294 \uCC99\uD558\uB2E4\uAC00 \uB4E4\uC5B4\uAC00\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Opportunist_3
    ko: "\uAC10\uC2DC\uAC00 \uC5C6\uC790 \uBC14\uB85C \uC694\uB839\uC744 \uD53C\uC6B0\uBA70
      \uD6C8\uB828 \uBC00\uB3C4\uAC00 \uAE09\uACA9\uD788 \uD558\uB77D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cunning_301
    ko: "\uC544\uBB34 \uB9D0\uB3C4 \uC548 \uD558\uC2DC\uB2E4\uB2C8... \uB0B4 \uAC00\uCE58\uB97C
      \uD14C\uC2A4\uD2B8\uD558\uB294 \uAC74\uAC00? \uB354 \uC644\uBCBD\uD558\uAC8C
      \uB358\uC838\uC57C\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Cunning_3
    ko: "\uCE68\uBB35\uC744 \uC2EC\uB9AC\uC801 \uC2DC\uD5D8\uC73C\uB85C \uD574\uC11D\uD558\uACE0
      \uC9C0\uC9C0 \uC54A\uC73C\uB824 \uC9D1\uC911\uB825\uC744 \uCD5C\uB300\uCE58\uB85C
      \uBC1C\uD718\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Believer_301
    ko: "\uC5ED\uC2DC \uACE0\uB3C5\uD55C \uC2F8\uC6C0\uC774\uAD70. \uAC10\uB3C5\uC870\uCC28
      \uB0B4 \uACE0\uB1CC\uB97C \uC774\uD574 \uBABB \uD558\uB294 \uAC70\uC57C. \uB098
      \uD63C\uC790 \uD574\uB0B8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Believer_3
    ko: "\uACE0\uB3C5\uC744 \uC539\uC73C\uBA70 \uBB35\uBB35\uD788 \uD6C8\uB828\uC744
      \uC774\uC5B4\uAC00\uC9C0\uB9CC \uD2B9\uBCC4\uD55C \uBC18\uB4F1\uC740 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Instinct_001
    ko: "\uD3C9\uC18C \uB3D9\uBB3C\uC801\uC778 \uAC10\uAC01\uC73C\uB85C \uB4DD\uC810\uC744
      \uC62C\uB9AC\uB358 \uC120\uC218\uAC00 \uC624\uB298\uB530\uB77C \uB370\uC774\uD130\uC5D0
      \uB9E4\uBAB0\uB418\uC5B4 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Instinct_002
    ko: "\uC190\uB05D\uC774 0.1cm \uB0AE\uC544... \uAC01\uB3C4\uAC00 \uBD80\uC871\uD574."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Instinct_003
    ko: "\uC790\uC2E0\uC758 \uC57C\uC131\uC744 \uBBFF\uC9C0 \uBABB\uD558\uACE0 \uB370\uC774\uD130\uC5D0
      \uBAB8\uC744 \uB07C\uC6CC \uB9DE\uCD94\uB824\uB294 \uC120\uC218\uC758 \uC6C0\uC9C1\uC784\uC740
      \uB454\uD0C1\uD558\uACE0 \uBD80\uC790\uC5F0\uC2A4\uB7FD\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Instinct_004
    ko: "\uBCF8\uB2A5\uC774 \uC0AC\uB77C\uC9C4 \uC120\uC218\uC758 \uC288\uD305\uC740
      \uB9BC\uC744 \uC678\uBA74\uD55C \uCC44 \uBC14\uB2E5\uC744 \uAD74\uB7EC \uB2F9\uC2E0\uC758
      \uBC1C\uBC11\uC5D0 \uBA48\uCDA5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Instinct_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Instinct_001
    ko: "\uB108\uB294 \uACC4\uC0B0\uAE30\uAC00 \uC544\uB2C8\uB77C \uCF54\uD2B8 \uC704\uC758
      \uD3EC\uC2DD\uC790\uC796\uC544. \uC790\uC2E0\uAC10\uC744 \uAC00\uC838!"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bluffer_101
    ko: "\uD3EC\uC2DD\uC790\uB77C... \uD6C4\uD6D7, \uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740
      \uC81C \uC9C4\uAC00\uB97C \uC544\uC2DC\uB294\uAD70\uC694. \uC88B\uC2B5\uB2C8\uB2E4,
      \uC81C \uC9C4\uBA74\uBAA9\uC744 \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Bluffer_1
    ko: "\uC790\uC874\uAC10\uC744 \uC790\uADF9\uBC1B\uC790 \uC2EC\uB9AC\uC801 \uC704\uCD95\uC774
      \uC0AC\uB77C\uC9C0\uACE0 \uD2B9\uC720\uC758 \uACFC\uAC10\uD55C \uC29B\uC774
      \uC0B4\uC544\uB0AC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Wild_101
    ko: "\uAC10\uAC01... \uB124, \uC54C \uAC83 \uAC19\uC544\uC694. \uBA38\uB9AC\uAC00
      \uC544\uB2C8\uB77C \uBAB8\uC774 \uC2DC\uD0A4\uB294 \uB300\uB85C \uB358\uC838\uBCFC\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Wild_1
    ko: "\uACA9\uB824\uB97C \uB4E3\uACE0 \uB9C8\uC74C\uC740 \uD3B8\uD574\uC84C\uC73C\uB098,
      \uD5DD\uD074\uC5B4\uC9C4 \uD3FC\uC744 \uBC14\uB85C\uC7A1\uAE30\uC5D4 \uC2DC\uAC04\uC774
      \uBD80\uC871\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Egoist_101
    ko: "\uC81C \uC790\uC2E0\uAC10\uC740 \uC81C\uAC00 \uCC59\uAE41\uB2C8\uB2E4. \uC9C0\uAE08\uC740
      \uC774 \uC624\uCC28\uB97C \uD574\uACB0\uD558\uB294 \uAC8C \uC6B0\uC120\uC774\uC5D0\uC694."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Egoist_1
    ko: "\uACA9\uB824\uB97C \uAC04\uC12D\uC73C\uB85C \uCE58\uBD80\uD558\uACE0 \uACE0\uC9D1\uC744
      \uBD80\uB9AC\uB2E4 \uC288\uD305 \uBA54\uCEE4\uB2C8\uC998\uC774 \uC644\uC804\uD788
      \uAF2C\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Fighter_101
    ko: "\uC704\uB85C \uB530\uC704 \uD544\uC694 \uC5C6\uC2B5\uB2C8\uB2E4. \uC81C
      \uAC10\uAC01\uC774 \uD2C0\uB838\uB2E4\uB294 \uC0AC\uC2E4\uC774 \uC9DC\uC99D
      \uB0A0 \uBFD0\uC774\uC5D0\uC694."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Fighter_1
    ko: "\uC2B9\uBD80\uC695\uC740 \uD0C0\uC624\uB974\uC9C0\uB9CC \uACA9\uB824\uB9CC\uC73C\uB85C\uB294
      \uAE30\uC220\uC801\uC778 \uC2AC\uB7FC\uD504\uB97C \uADF9\uBCF5\uD558\uC9C0
      \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Instinct_002
    ko: "\uD55C\uC2EC\uD558\uAD70! \uB370\uC774\uD130\uC5D0 \uC2E0\uACBD \uC4F8\uAC70\uBA74
      \uB18D\uAD6C\uB294 \uADF8\uB9CC\uB450\uACE0 \uC218\uD559 \uBB38\uC81C\uB098
      \uD480\uC5B4\uB77C!"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bluffer_201
    ko: "\uC218\uD559 \uBB38\uC81C\uB77C\uB2C8\uC694, \uB9D0\uC774 \uB108\uBB34 \uC2EC\uD558\uC2DC\uB124!
      \uC81C\uAC00 \uC99D\uBA85\uD558\uBA74 \uC0AC\uACFC\uD558\uC2DC\uB294 \uAC81\uB2C8\uB2E4?"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bluffer_202
    ko: "\uC0AC\uACFC\uB4E0 \uBB50\uB4E0 \uC88B\uC73C\uB2C8 \uACB0\uACFC\uB85C \uBCF4\uC5EC\uB77C.
      \uC785\uB9CC \uC0B4\uC544\uC788\uC9C0 \uB9D0\uACE0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Bluffer_2
    ko: "\uBE44\uB09C\uC5D0 \uB2F9\uD669\uD558\uC5EC \uC5B5\uC9C0\uB85C \uD3FC\uC744
      \uC7A1\uC73C\uB824\uB2E4 \uC624\uD788\uB824 \uC5B4\uAE68\uC5D0 \uD798\uC774
      \uB4E4\uC5B4\uAC00 \uB9DD\uAC00\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Wild_201
    ko: "\uC9C0\uAE08 \uB2F9\uC7A5 \uB9BC\uC774 \uBD80\uC11C\uC9C0\uB294 \uAC78 \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Wild_2
    ko: "\uAC15\uD55C \uC790\uADF9\uC774 \uC7A0\uC790\uB358 \uC57C\uC131\uC744 \uAE68\uC6CC
      \uACC4\uC0B0\uC744 \uBA48\uCD94\uACE0 \uC9C1\uAD00\uC801\uC778 \uC288\uD305
      \uB2A5\uB825\uC744 \uD68C\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Egoist_201
    ko: "\uB204\uAD6C\uBCF4\uACE0 \uB18D\uAD6C\uB97C \uADF8\uB9CC\uB450\uB77C\uB294
      \uAC70\uC8E0? \uC804 \uC81C \uBC29\uC2DD\uB300\uB85C \uCD5C\uACE0\uAC00 \uB420
      \uAC81\uB2C8\uB2E4. \uC9C0\uCF1C\uBCF4\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Egoist_2
    ko: "\uAC10\uB3C5\uC758 \uBB34\uC2DC\uB97C \uACAC\uB514\uC9C0 \uBABB\uD574 \uB3C5\uAE30\uB85C
      \uC9D1\uC911\uB825\uC744 \uBC1C\uD718\uD558\uC5EC \uC2A4\uC2A4\uB85C \uCD5C\uC801\uC758
      \uAC10\uAC01\uC744 \uCC3E\uC544\uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Fighter_201
    ko: "\uC218\uD559 \uBB38\uC81C? \uC6C3\uAE30\uC9C0 \uB9C8\uC138\uC694. \uAC10\uB3C5\uB2D8
      \uCF54\uAC00 \uB0A9\uC791\uD574\uC9C8 \uC815\uB3C4\uB85C \uAF42\uC544 \uB123\uC5B4\uC8FC\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Fighter_2
    ko: "\uACBD\uC7C1\uC2EC\uC740 \uC790\uADF9\uB418\uC5C8\uC73C\uB098 \uACFC\uB3C4\uD55C
      \uD765\uBD84 \uC0C1\uD0DC\uAC00 \uB418\uC5B4 \uC29B \uC131\uACF5\uB960\uC740
      \uC81C\uC790\uB9AC\uAC78\uC74C\uC774 \uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Instinct_003
    ko: "\uC29B\uC5D0 \uC2E4\uD328\uD55C \uACF5\uC744 \uB358\uC838\uC8FC\uBA70 \uC120\uC218\uC758
      \uB208\uC744 \uB6AB\uC5B4\uC9C0\uAC8C \uC751\uC2DC\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bluffer_301
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uC29B \uAC01\uB3C4 \uBCF4\uACE0 \uAC10\uD0C4\uD574\uC11C
      \uB9D0\uC774 \uC548 \uB098\uC624\uC2DC\uB294 \uAC70\uC8E0? \uD558\uD558..."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Bluffer_3
    ko: "\uCE68\uBB35\uC744 \uC790\uAE30 \uC88B\uC744 \uB300\uB85C \uD574\uC11D\uD558\uBA70
      \uADFC\uAC70 \uC5C6\uB294 \uC790\uC2E0\uAC10\uC744 \uC720\uC9C0\uD558\uC9C0\uB9CC
      \uBC1C\uC804\uC740 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Wild_301
    ko: "...\uC65C \uC790\uAFB8 \uCCD0\uB2E4\uBCF4\uC138\uC694? \uC9DC\uC99D \uB098\uAC8C
      \uC9C4\uC9DC!"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Wild_3
    ko: "\uC555\uBC15\uAC10\uC744 \uC774\uAE30\uC9C0 \uBABB\uD558\uACE0 \uCD5C\uC545\uC758
      \uC131\uACF5\uB960\uC744 \uAE30\uB85D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Egoist_301
    ko: "\uC544\uBB34 \uB9D0 \uB9C8\uC138\uC694. \uC81C \uBB38\uC81C\uB294 \uC81C\uAC00
      \uC81C\uC77C \uC798 \uC555\uB2C8\uB2E4. \uACE7 \uB2F5\uC744 \uCC3E\uC744 \uAC70\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Egoist_3
    ko: "\uC678\uBD80\uC758 \uD53C\uB4DC\uBC31 \uC5C6\uC774 \uD63C\uC790\uB9CC\uC758
      \uACE0\uB9BD\uB41C \uD6C8\uB828\uC744 \uC774\uC5B4\uAC00\uBA70 \uD604\uC0C1
      \uC720\uC9C0\uC5D0 \uADF8\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Fighter_301
    ko: "\uC774 \uACF5\uC774 \uB4E4\uC5B4\uAC08 \uB54C\uAE4C\uC9C0 \uC548 \uAC00\uC2E4
      \uAC70\uC8E0? \uC88B\uC2B5\uB2C8\uB2E4. \uB05D\uAE4C\uC9C0 \uAC00\uBCF4\uC790\uACE0\uC694!"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Fighter_3
    ko: "\uAC10\uB3C5\uACFC\uC758 \uAE30\uC2F8\uC6C0\uC5D0\uC11C \uC2B9\uB9AC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Discipline_001
    ko: "\uD300\uC758 \uC5D0\uC774\uC2A4\uAC00 \uC790\uC720\uD22C \uB77C\uC778 \uC591
      \uB05D\uC778 '\uC5D8\uBCF4\uC6B0' \uC9C0\uC5ED\uC5D0\uC11C \uBB34\uC11C\uC6B4
      \uC9D1\uC911\uB825\uC73C\uB85C \uC29B\uC744 \uB358\uC9D1\uB2C8\uB2E4. \uB540\uC5D0
      \uC816\uC740 \uADF8\uAC00 \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC640 \uB2E8\uD638\uD558\uAC8C
      \uB9D0\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Discipline_002
    ko: "\uAC10\uB3C5\uB2D8, \uC774 \uAD6C\uC5ED\uC740 \uC81C '\uC131\uC5ED'\uC785\uB2C8\uB2E4.
      \uC5EC\uAE30\uC11C \uB358\uC9C0\uB294 \uC81C \uC29B\uC740 100% \uB4E4\uC5B4\uAC04\uB2E4\uACE0
      \uBBFF\uC73C\uC154\uB3C4 \uC88B\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Discipline_003
    ko: "\uC81C\uAC00 \uC2B9\uB9AC\uB97C \uAC00\uC838\uB2E4 \uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4.
      \uC808 \uBBFF\uACE0 \uC774 \uAD6C\uC5ED \uC804\uC220\uC744 \uC9DC\uC8FC\uC2E4
      \uC218 \uC788\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Discipline_001
    ko: "\uB124 \uC790\uC2E0\uAC10\uC744 \uBBFF\uC5B4\uBCF4\uB3C4\uB85D \uD558\uACA0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Principled_101
    ko: "\uBBFF\uC5B4\uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uC81C\uAC00
      \uC815\uD55C \uB8E8\uD2F4\uB300\uB85C \uC2B9\uB9AC\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Principled_1
    ko: "\uAC10\uB3C5\uC758 \uC2B9\uC778\uC774 \uC790\uC2E0\uC758 \uC6D0\uCE59\uC5D0
      \uD655\uC2E0\uC744 \uC8FC\uC5B4 \uC288\uD305 \uC815\uD655\uB3C4\uAC00 \uD5A5\uC0C1\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Guardian_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uC804\uC220\uC744 \uC81C\uAC00 \uBC18\uB4DC\uC2DC
      \uC9C0\uCF1C\uB0B4\uACA0\uC2B5\uB2C8\uB2E4. \uD300\uC6D0\uB4E4\uC744 \uBBFF\uAC8C
      \uB9CC\uB4E4\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Guardian_1
    ko: "\uCC45\uC784\uAC10\uC744 \uB290\uB07C\uBA70 \uACB0\uC758\uB97C \uB2E4\uC9C0\uC9C0\uB9CC,
      \uAE30\uB7C9\uC740 \uD3C9\uC18C \uC218\uC900\uC5D0 \uBA38\uBB3C\uB800\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Tactician_101
    ko: "\uD569\uB9AC\uC801\uC778 \uACB0\uC815\uC785\uB2C8\uB2E4. 100%\uC758 \uD655\uB960\uC774
      \uC788\uB294 \uACF3\uC5D0 \uC790\uC6D0\uC744 \uC9D1\uC911\uD574\uC57C\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Tactician_1
    ko: "\uC790\uC2E0\uC758 \uACF5\uACA9 \uAD6C\uC5ED\uC5D0\uB9CC \uB9E4\uBAB0\uB418\uC5B4
      \uB3D9\uB8CC\uB4E4\uC758 \uC6C0\uC9C1\uC784\uC744 \uB193\uCE58\uACE0 \uB9D0\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Exemplary_101
    ko: "\uC88B\uC2B5\uB2C8\uB2E4. \uD300\uC758 \uBCF8\uBCF4\uAE30\uAC00 \uB418\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Exemplary_1
    ko: "\uB3C4\uB355\uC801 \uB9CC\uC871\uAC10\uC744 \uB290\uB07C\uBA70 \uC131\uC2E4\uD788
      \uC784\uD558\uB098 \uAE30\uB7C9 \uBCC0\uD654\uB294 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Discipline_002
    ko: "100%? \uC790\uB9CC\uD558\uC9C0 \uB9C8\uB77C! \uB18D\uAD6C\uC5D0 \uC808\uB300\uC801\uC778
      \uAC74 \uC5C6\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Principled_201
    ko: "\uC790\uB9CC\uC774 \uC544\uB2C8\uC5C8\uC2B5\uB2C8\uB2E4... \uD558\uC9C0\uB9CC
      \uAC10\uB3C5\uB2D8 \uC9C0\uC801\uC774 \uC633\uC2B5\uB2C8\uB2E4. \uADDC\uC728
      \uC548\uC5D0\uC11C \uC6C0\uC9C1\uC774\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Principled_2
    ko: "\uC790\uC2E0\uC758 \uD655\uC2E0\uC774 \uBD80\uC815\uB2F9\uD558\uC790 \uC2EC\uB9AC\uC801\uC73C\uB85C
      \uC704\uCD95\uB418\uC5B4 \uC29B \uAC10\uAC01\uC774 \uD754\uB4E4\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Guardian_201
    ko: "\uD300\uC758 \uC9C8\uC11C\uB97C \uD574\uCE60 \uC0DD\uAC01\uC740 \uC5C6\uC5C8\uC2B5\uB2C8\uB2E4.
      \uC81C\uAC00 \uB108\uBB34 \uC55E\uC11C\uB098\uAC14\uAD70\uC694. \uC8C4\uC1A1\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Guardian_2
    ko: "\uAC1C\uC778\uC758 \uC695\uC2EC\uC744 \uBC84\uB9AC\uACE0 \uD300\uC744 \uC9C0\uD0A4\uB294
      \uD0DC\uB3C4\uB85C \uC804\uD658\uD558\uBA70 \uC9D1\uC911\uB825\uC774 \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Tactician_201
    ko: "\uC81C \uC81C\uC548\uC774 \uBE44\uD6A8\uC728\uC801\uC774\uC5C8\uAD70\uC694.
      \uB2E4\uC2DC \uC804\uCCB4\uC801\uC778 \uD750\uB984\uC5D0 \uB9DE\uAC8C \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uD1B5\uD574 \uC790\uC2E0\uC758 \uD55C\uACC4\uB97C \uAE68\uB2EB\uACE0
      \uC774\uD0C0\uC801\uC778 \uC2DC\uC57C\uB97C \uD655\uBCF4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Exemplary_201
    ko: "\uC81C \uD0DC\uB3C4\uAC00 \uC624\uB9CC\uC73C\uB85C \uBE44\uCCE4\uB2E4\uBA74
      \uBC18\uC131\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uB2E4\uC2DC \uAE30\uBCF8\uBD80\uD130
      \uC900\uBE44\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Exemplary_2
    ko: "\uAC15\uD55C \uC9C8\uCC45\uC5D0 \uD3C9\uC815\uC2EC\uC744 \uC783\uACE0 \uC790\uC2E0\uC758
      \uBA54\uCEE4\uB2C8\uC998\uC5D0 \uC758\uAD6C\uC2EC\uC774 \uC0DD\uACBC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Discipline_003
    ko: "\uC804\uC220 \uBCF4\uB4DC\uC758 \uC5D8\uBCF4\uC6B0 \uC9C0\uC5ED\uC5D0 \uC791\uC740
      \uC6D0 \uD558\uB098\uB9CC \uADF8\uB824\uB193\uACE0 \uC790\uB9AC\uB97C \uB5A0\uB09C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Principled_301
    ko: "...\uADF8\uB798\uC11C \uC5B4\uB5BB\uAC8C \uD558\uB77C\uB294 \uAC78\uAE4C\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Principled_3
    ko: "\uAC08\uD321\uC9C8\uD321\uD558\uB2E4\uAC00 \uBCF8\uC778\uC758 \uB8E8\uD2F4\uC744
      \uC218\uD589\uD558\uAE30\uB85C \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Guardian_301
    ko: "\uC81C\uAC00 \uC99D\uBA85\uD558\uC9C0 \uBABB\uD558\uBA74 \uC774 \uC6D0\uC740
      \uC544\uBB34 \uC758\uBBF8\uAC00 \uC5C6\uACA0\uC8E0. \uB0B4\uC77C \uACB0\uACFC\uB85C
      \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Guardian_3
    ko: "\uCE68\uBB35\uC758 \uC555\uBC15\uC744 \uACFC\uB3C4\uD558\uAC8C \uB290\uAEF4
      \uC5B4\uAE68\uC5D0 \uD798\uC774 \uB4E4\uC5B4\uAC00\uACE0 \uB9AC\uB4EC\uC774
      \uAE68\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Tactician_301
    ko: "\uC804\uB7B5\uC740 \uB3D9\uC758\uD558\uB098 \uC5B4\uB5BB\uAC8C \uD560\uC9C0\uB294
      \uB0B4\uAC00 \uACB0\uC815\uD558\uB77C\uB294 \uAC74\uAC00."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Tactician_3
    ko: "\uC120\uC218\uAC00 \uC9C1\uC811 \uC9E0 \uC804\uC220\uC740 \uD3C9\uBC94\uD558\uAE30
      \uADF8\uC9C0 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Exemplary_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C0\uCF1C\uBCF4\uACE0 \uACC4\uC2DC\uB2C8 \uB354
      \uCC45\uC784\uAC10\uC774 \uB290\uAEF4\uC9D1\uB2C8\uB2E4. \uADF8 \uAE30\uB300\uB97C
      \uC2B9\uB9AC\uB85C \uB3CC\uB824\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Exemplary_3
    ko: "\uC2A4\uC2A4\uB85C \uCC45\uC784\uC838\uC57C \uD560 \uC601\uC5ED\uC774 \uC0DD\uACBC\uC74C\uC744
      \uC9C1\uC2DC\uD558\uACE0 \uAD82\uC740\uC77C\uC5D0 \uC801\uADF9\uC801\uC73C\uB85C
      \uBCC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bond_001
    ko: "\uD300\uC758 \uC5D0\uC774\uC2A4\uAC00 \uC790\uC720\uD22C \uB77C\uC778 \uC591
      \uB05D\uC778 '\uC5D8\uBCF4\uC6B0' \uC9C0\uC5ED\uC5D0\uC11C \uBB34\uC11C\uC6B4
      \uC9D1\uC911\uB825\uC73C\uB85C \uC29B\uC744 \uB358\uC9D1\uB2C8\uB2E4. \uB540\uC5D0
      \uC816\uC740 \uADF8\uAC00 \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC640 \uB2E8\uD638\uD558\uAC8C
      \uB9D0\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bond_002
    ko: "\uAC10\uB3C5\uB2D8, \uC774 \uAD6C\uC5ED\uC740 \uC81C '\uC131\uC5ED'\uC785\uB2C8\uB2E4.
      \uC5EC\uAE30\uC11C \uB358\uC9C0\uB294 \uC81C \uC29B\uC740 100% \uB4E4\uC5B4\uAC04\uB2E4\uACE0
      \uBCF4\uC154\uB3C4 \uC88B\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bond_003
    ko: "\uC81C\uAC00 \uC2B9\uB9AC\uD558\uB294 \uBC95\uC744 \uAC00\uC838\uB2E4 \uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4.
      \uC808 \uBBFF\uACE0 \uC774 \uAD6C\uC5ED \uC804\uC220\uC744 \uC9DC\uC8FC\uC2E4
      \uC218 \uC788\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bond_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Bond_001
    ko: "\uB124 \uC790\uC2E0\uAC10\uC740 \uC778\uC815\uD55C\uB2E4. \uB124\uAC00 \uADF8
      \uAD6C\uC5ED\uC744 \uCC45\uC784\uC838\uC900\uB2E4\uBA74 \uD300\uC5D0 \uD070
      \uD798\uC774 \uB418\uACA0\uC9C0. "
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uBBFF\uC5B4\uC8FC\uC154\uC11C \uAC10\uC0AC\uD574\uC694.
      \uD300\uC6D0\uB4E4\uC5D0\uAC8C \uBBF8\uC548\uD558\uC9C0 \uC54A\uAC8C \uAF2D
      \uB123\uC744\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Kind_1
    ko: "\uAC10\uB3C5\uC758 \uB530\uB73B\uD55C \uC2E0\uB8B0\uC5D0 \uAC10\uB3D9\uD558\uC5EC
      \uC815\uC11C\uC801 \uC548\uC815\uACFC \uC288\uD305 \uC9D1\uC911\uB825\uC774
      \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uC804\uC220\uC744 \uC81C\uAC00 \uBC18\uB4DC\uC2DC
      \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uC800\uB97C \uBBFF\uC5B4\uC8FC\uC2E0
      \uC120\uD0DD, \uD6C4\uD68C \uC5C6\uAC8C \uD558\uC8E0"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Loyal_1
    ko: "\uAC10\uB3C5\uC5D0 \uB300\uD55C \uCDA9\uC131\uC2EC\uC73C\uB85C \uC758\uC9C0\uB294
      \uB2E4\uC9C0\uC9C0\uB9CC, \uAE30\uB7C9\uC740 \uD3C9\uC18C \uC218\uC900\uC5D0
      \uBA38\uBB3C\uB800\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Sincere_101
    ko: "\uAC10\uC0AC\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC 100%\uB97C \uC720\uC9C0\uD558\uB824\uBA74
      500\uAC1C\uB294 \uB354 \uB358\uC9C0\uACE0 \uAC00\uC57C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Sincere_1
    ko: "\uACA9\uB824\uC5D0 \uBCF4\uB2F5\uD558\uB824\uB294 \uAC15\uBC15\uC5D0 \uC624\uBC84\uD398\uC774\uC2A4\uD558\uC5EC
      \uC624\uD788\uB824 \uC190\uBAA9\uC5D0 \uBB34\uB9AC\uAC00 \uAC14\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Moodmaker_101
    ko: "\uC640! \uAC10\uB3C5\uB2D8 \uB098\uC774\uC2A4 \uC0F7! \uC81C\uAC00 \uB0B4\uC77C
      \uCCB4\uC721\uAD00 \uC9C0\uBD95 \uB6AB\uC5B4\uBC84\uB9AC\uB294 \uAC70 \uC9C0\uCF1C\uBCF4\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Moodmaker_1
    ko: "\uD2B9\uC720\uC758 \uB109\uC0B4\uB85C \uBD84\uC704\uAE30\uB294 \uB744\uC6B0\uB098,
      \uC2E4\uC9C8\uC801\uC778 \uAE30\uB7C9 \uBCC0\uD654\uB294 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Bond_002
    ko: "100%? \uC790\uB9CC\uD558\uC9C0 \uB9C8\uB77C! \uB18D\uAD6C\uB294 \uD63C\uC790
      \uD558\uB294 \uAC8C \uC544\uB2C8\uB2E4. \uD300\uC744 \uBA3C\uC800 \uC0DD\uAC01\uD574\uB77C!"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Kind_201
    ko: "\uC544... \uC81C\uAC00 \uB108\uBB34 \uC81C \uC0DD\uAC01\uB9CC \uD588\uB098
      \uBD10\uC694. \uD300\uC6D0\uB4E4\uC774 \uC18C\uC678\uAC10\uC744 \uB290\uAF08\uC744\uC9C0\uB3C4
      \uBAA8\uB974\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Kind_2
    ko: "\uB0A0\uCE74\uB85C\uC6B4 \uC9C0\uC801\uC5D0 \uB9C8\uC74C\uC774 \uC704\uCD95\uB418\uC5B4
      \uC7A5\uC810\uC778 \uBD80\uB4DC\uB7EC\uC6B4 \uC29B \uB9AC\uB4EC\uC774 \uAE68\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Loyal_201
    ko: "\uC81C \uB3C5\uB2E8\uC801\uC778 \uD0DC\uB3C4\uAC00 \uD300\uC758 \uACB0\uC18D\uC744
      \uD574\uCCE4\uAD70\uC694. \uAC10\uB3C5\uB2D8\uC758 \uC9C0\uC2DC\uB300\uB85C
      \uD300 \uC804\uC220\uC5D0 \uB179\uC544\uB4E4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Loyal_2
    ko: "\uAC10\uB3C5\uC758 \uC9C8\uCC45\uC744 \uD300\uC744 \uC704\uD55C \uAC00\uB974\uCE68\uC73C\uB85C
      \uC218\uC6A9\uD558\uBA70 \uC774\uD0C0\uC801\uC778 \uC2DC\uC57C\uAC00 \uD655\uBCF4\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Sincere_201
    ko: "\uC9D1\uC911\uD558\uB290\uB77C \uC8FC\uBCC0\uC744 \uC0B4\uD53C\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4.
      \uB2E4\uC2DC \uD300\uC6D0\uB4E4\uACFC\uC758 \uC5F0\uACC4 \uD6C8\uB828\uC5D0
      \uC9D1\uC911\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Sincere_2
    ko: "\uC790\uC2E0\uC758 \uBD80\uC871\uD568\uC744 \uC778\uC815\uD558\uACE0 \uAD82\uC740\uC77C\uC5D0
      \uB354 \uD5CC\uC2E0\uC801\uC778 \uD0DC\uB3C4\uB85C \uBCC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Moodmaker_201
    ko: "\uC73D, \uAC10\uB3C5\uB2D8 \uB108\uBB34 \uBB34\uC11C\uC6CC\uC694! \uB124,
      \uB124! \uC131\uC5ED \uCDE8\uC18C! \uB0B4\uC77C\uC740 \uD328\uC2A4 \uC154\uD2C0\uC774\uB098
      \uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Moodmaker_2
    ko: "\uC555\uBC15\uAC10\uC5D0 \uD2B9\uC720\uC758 \uC720\uC5F0\uD568\uC774 \uC0AC\uB77C\uC9C0\uACE0
      \uC2E0\uCCB4 \uBC18\uC751\uC774 \uB454\uD574\uC838 \uC29B \uC815\uD655\uB3C4\uAC00
      \uD558\uB77D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Bond_003
    ko: "\uC804\uC220 \uBCF4\uB4DC\uC758 \uC5D8\uBCF4\uC6B0 \uC9C0\uC5ED\uC5D0 \uD300\uC6D0
      \uC804\uC6D0\uC758 \uBC88\uD638\uB97C \uC801\uC5B4 \uB123\uACE0 \uC790\uB9AC\uB97C
      \uB5A0\uB09C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Kind_301
    ko: "\uBAA8\uB450\uAC00 \uD568\uAED8\uD558\uB294 \uAD6C\uC5ED\uC774\uB77C\uB294
      \uB73B\uC774\uAD70\uC694. \uC800 \uD63C\uC790\uAC00 \uC544\uB2C8\uC5C8\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Kind_3
    ko: "\uAC10\uB3C5\uC758 \uC804\uB7B5\uC801 \uC758\uC911\uC744 \uC624\uD574\uD55C
      \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Loyal_301
    ko: "\uB9D0\uC500\uD558\uC2DC\uC9C0 \uC54A\uC544\uB3C4 \uC555\uB2C8\uB2E4. \uC81C
      \uC131\uC5ED\uC744 \uC911\uC2EC\uC73C\uB85C \uBAA8\uB450\uC758 \uD328\uC2A4\uB97C
      \uBC1B\uB294\uB2E4\uB294 \uB73B\uC774\uC8E0? \uD574\uB0B4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Loyal_3
    ko: "\uAC10\uB3C5\uC758 \uCE68\uBB35\uC744 \uACFC\uD55C \uAE30\uB300\uC640 \uC555\uBC15\uC73C\uB85C
      \uB290\uAEF4 \uC288\uD305 \uC2DC \uC5B4\uAE68\uC5D0 \uD798\uC774 \uB4E4\uC5B4\uAC14\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Sincere_301
    ko: "...\uB354 \uC644\uBCBD\uD574\uC838\uC57C\uACA0\uAD70."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Sincere_3
    ko: "\uD3C9\uC18C\uC640 \uB2E4\uB984\uC5C6\uC774 \uBB35\uBB35\uD788 \uD6C8\uB828\uC744
      \uC9C0\uC18D\uD558\uBA70 \uC790\uC2E0\uC758 \uD398\uC774\uC2A4\uB97C \uC720\uC9C0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Moodmaker_301
    ko: "\uC624, \uC5ED\uC2DC \uAC10\uB3C5\uB2D8 \uC13C\uC2A4! \uC6B0\uB9AC \uB2E4
      \uAC19\uC774 \uC774 \uAD6C\uC5ED \uC539\uC5B4\uBA39\uC73C\uB77C\uB294 \uAC70\uC8E0?
      \uC560\uB4E4\uC544, \uBAA8\uC5EC\uBD10!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Moodmaker_3
    ko: "\uAC10\uB3C5\uC758 \uBA54\uC2DC\uC9C0\uB97C \uD300 \uD654\uD569\uC73C\uB85C
      \uC774\uB04C\uC5B4\uB0B4\uBA70 \uC804\uC220 \uC218\uD589 \uB2A5\uB825\uC774
      \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cold_001
    ko: "\uD300\uC758 \uC5D0\uC774\uC2A4\uAC00 \uC790\uC720\uD22C \uB77C\uC778 \uC591
      \uB05D\uC778 '\uC5D8\uBCF4\uC6B0' \uC9C0\uC5ED\uC5D0\uC11C \uBB34\uC11C\uC6B4
      \uC9D1\uC911\uB825\uC73C\uB85C \uC29B\uC744 \uB358\uC9D1\uB2C8\uB2E4. \uB540\uC5D0
      \uC816\uC740 \uADF8\uAC00 \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC640 \uB2E8\uD638\uD558\uAC8C
      \uB9D0\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cold_002
    ko: "\uAC10\uB3C5\uB2D8, \uC774 \uAD6C\uC5ED\uC740 \uC81C '\uC131\uC5ED'\uC785\uB2C8\uB2E4.
      \uC5EC\uAE30\uC11C \uB358\uC9C0\uB294 \uC81C \uC29B\uC740 100% \uB4E4\uC5B4\uAC11\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cold_003
    ko: "\uC2B9\uB9AC\uAC00 \uBB54\uC9C0 \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4.
      \uC808 \uBBFF\uC5B4\uC8FC\uC2E4 \uC218 \uC788\uC73C\uC2ED\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cold_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Cold_001
    ko: "\uB124 \uACC4\uC0B0\uC744 \uBBFF\uB294\uB2E4. \uC6B0\uB9AC \uD300\uC758
      \uC2B9\uB9AC \uD655\uB960\uC740 \uBE44\uC57D\uC801\uC73C\uB85C \uC0C1\uC2B9\uD560
      \uAC70\uC57C."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Planner_101
    ko: "\uD569\uB9AC\uC801\uC778 \uD310\uB2E8\uC785\uB2C8\uB2E4. \uADF8 \uAD6C\uC5ED\uC744
      \uD65C\uC6A9\uD55C \uC138\uBD80 \uB3D9\uC120\uC744 \uB2E4\uC2DC \uC9DC\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Planner_1
    ko: "\uC774\uBBF8 \uACC4\uC0B0\uC744 \uB9C8\uCE5C \uC0C1\uD0DC\uB77C \uACA9\uB824\uAC00
      \uC2E4\uB825 \uC0C1\uC2B9\uC73C\uB85C \uC774\uC5B4\uC9C0\uC9C4 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Opportunist_101
    ko: "\uBC00\uC5B4\uC8FC\uC2E0\uB2E4\uBA74 \uB354\uD560 \uB098\uC704 \uC5C6\uC8E0.
      \uC81C \uAC00\uCE58\uB97C \uC99D\uBA85\uD560 \uCD5C\uACE0\uC758 \uD0C0\uC774\uBC0D\uC774\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Opportunist_1
    ko: "\uAC10\uB3C5\uC758 \uC804\uD3ED\uC801\uC778 \uC9C0\uC9C0\uB97C \uAE30\uD68C\uB85C
      \uC0BC\uC544 \uC790\uC2E0\uAC10\uC774 \uD3ED\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cunning_101
    ko: "\uB124, \uAC10\uC0AC\uD569\uB2C8\uB2E4. ...\uC2E4\uD328\uD574\uB3C4 \uAC10\uB3C5
      \uD0D3\uC744 \uD560 \uAD6C\uC2E4\uC740 \uC0DD\uACBC\uAD70."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Cunning_1
    ko: "\uCC45\uC784 \uD68C\uD53C\uB97C \uC704\uD55C \uBC1C\uC5B8\uC774\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Believer_101
    ko: "\uC81C \uB17C\uB9AC\uAC00 \uD2C0\uB9AC\uC9C0 \uC54A\uC558\uC74C\uC744 \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0.
      \uAC10\uB3C5\uB2D8\uC758 \uC120\uD0DD\uC774 \uC633\uC558\uC74C\uC744 \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Believer_1
    ko: "\uC790\uC2E0\uC758 \uB17C\uB9AC\uB97C \uC7AC\uD655\uC778\uD588\uC744 \uBFD0\uC774\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Cold_002
    ko: "100%? \uC624\uB9CC\uD558\uAD70! \uC218\uCE58\uC5D0 \uB208\uC774 \uBA40\uC5B4
      \uACBD\uAE30 \uC804\uCCB4\uC758 \uD750\uB984\uC744 \uB193\uCE58\uACE0 \uC788\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Planner_201
    ko: "\uB370\uC774\uD130\uC5D0 \uADFC\uAC70\uD588\uC73C\uB098 \uC804\uCCB4 \uBC38\uB7F0\uC2A4\uB97C
      \uB193\uCCE4\uAD70\uC694. \uC2DC\uC57C\uB97C \uB113\uD600 \uC7AC\uACC4\uC0B0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Planner_2
    ko: "\uC9C0\uC801\uC744 \uD1B5\uD574 \uC790\uC2E0\uC758 \uC2DC\uC57C\uAC00 \uC881\uC558\uC74C\uC744
      \uC778\uC815\uD558\uACE0 \uC774\uD0C0\uC801\uC778 \uC2DC\uC57C\uB97C \uD655\uBCF4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Opportunist_201
    ko: "\uC73D, \uC81C \uC695\uC2EC\uC774 \uACFC\uD588\uB098\uC694? \uC54C\uACA0\uC2B5\uB2C8\uB2E4.
      \uD300\uC758 \uD750\uB984\uC5D0 \uBC29\uD574\uB418\uC9C0 \uC54A\uAC8C\uB9CC
      \uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Opportunist_2
    ko: "\uBE44\uB09C\uC744 \uD53C\uD558\uB824\uB2E4 \uBCF4\uB2C8 \uC790\uC2E0\uC758
      \uAC15\uB825\uD55C \uBB34\uAE30\uC778 \uC288\uD305\uB9C8\uC800 \uC8FC\uC800\uD558\uAC8C
      \uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cunning_201
    ko: "\uC544... \uC624\uD574\uD558\uC168\uAD70\uC694. \uD300\uC744 \uC704\uD55C
      \uC21C\uC218\uD55C \uC81C\uC548\uC774\uC5C8\uC2B5\uB2C8\uB2E4. "
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Cunning_2
    ko: "\uAC70\uC9D3 \uC0AC\uACFC\uB85C \uC0C1\uD669\uC744 \uB118\uAE30\uB824 \uD558\uBA70,
      \uC2EC\uB9AC \uC0C1\uD0DC\uC5D0 \uC2E4\uC9C8\uC801 \uBCC0\uD654\uAC00 \uC77C\uC5B4\uB098\uC9C0
      \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Believer_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uC624\uB9CC\uD558\uB2E4\uBA74, \uB0B4\uC77C \uACB0\uACFC\uB85C
      \uC81C \uC624\uB9CC\uC774 \uC815\uB2F5\uC774\uC5C8\uC74C\uC744 \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Believer_2
    ko: "\uC9C8\uCC45\uC5D0 \uC624\uAE30\uAC00 \uBC1C\uB3D9\uD558\uC5EC \uC790\uC2E0\uC758
      \uB17C\uB9AC\uAC00 \uB9DE\uC74C\uC744 \uC99D\uBA85\uD558\uAE30 \uC704\uD574
      \uADF9\uD55C\uC73C\uB85C \uC9D1\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Cold_003
    ko: "\uC804\uC220 \uBCF4\uB4DC\uC758 \uC5D8\uBCF4\uC6B0 \uC9C0\uC5ED\uC5D0 \uC791\uC740
      \uC810 \uD558\uB098\uB9CC \uCC0D\uACE0 \uC790\uB9AC\uB97C \uB5A0\uB09C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Planner_301
    ko: "\uC800 \uC810\uC758 \uC758\uBBF8\uB294... \uC5EC\uBC31?"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Planner_3
    ko: "\uAC10\uB3C5\uC758 \uC758\uB3C4\uB97C \uC9C0\uB098\uCE58\uAC8C \uBCF5\uC7A1\uD558\uAC8C
      \uBD84\uC11D\uD558\uB2E4\uAC00 \uC288\uD305 \uBA54\uCEE4\uB2C8\uC998\uC5D0
      \uD63C\uC120\uC774 \uC654\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Opportunist_301
    ko: "\uAE0D\uC815\uB3C4 \uBD80\uC815\uB3C4 \uC544\uB2C8\uB2C8 \uB0B4 \uB9D8\uB300\uB85C
      \uD574\uB3C4 \uB41C\uB2E4\uB294 \uB73B\uC774\uACA0\uC9C0. \uD3B8\uD558\uB124."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Opportunist_3
    ko: "\uAC04\uC12D\uC774 \uC5C6\uC74C\uC744 \uD3B8\uD558\uAC8C \uC5EC\uAE30\uBA70
      \uD3C9\uC18C \uD558\uB358 \uB300\uB85C\uC758 \uAE30\uB7C9\uC744 \uC720\uC9C0\uD587\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cunning_301
    ko: "\uC544\uBB34 \uD655\uB2F5\uB3C4 \uC548 \uC8FC\uC2DC\uB2E4\uB2C8... \uB0B4
      \uC2E4\uB825\uC73C\uB85C \uC9C1\uC811 \uC804\uC220\uC744 \uC124\uACC4\uD558\uB77C\uB294
      \uB73B\uC778\uAC00."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Cunning_3
    ko: "\uC9C1\uC811 \uC804\uC220\uC744 \uC124\uACC4\uD558\uBA70 \uAC8C\uC784 \uC9C0\uB2A5\uC774
      \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Believer_301
    ko: "\uB9D0\uC774 \uD544\uC694 \uC5C6\uAD70\uC694. \uD558\uC9C0\uB9CC \uAC10\uB3C5\uC870\uCC28
      \uC81C \uACE0\uB1CC\uB97C \uC774\uD574 \uBABB \uD55C\uB2E4\uB2C8..."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Believer_3
    ko: "\uC18C\uD1B5 \uC5C6\uC774 \uC790\uC2E0\uB9CC\uC758 \uC138\uACC4\uC5D0 \uAC07\uD600
      \uACE0\uC9D1\uC2A4\uB7FD\uAC8C \uB358\uC9C0\uB2E4 \uBCF4\uB2C8 \uC288\uD305
      \uB9AC\uB4EC\uC774 \uAD73\uC5B4\uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Instinct_001
    ko: "\uD300\uC758 \uC5D0\uC774\uC2A4\uAC00 \uC790\uC720\uD22C \uB77C\uC778 \uC591
      \uB05D\uC778 '\uC5D8\uBCF4\uC6B0' \uC9C0\uC5ED\uC5D0\uC11C \uBB34\uC11C\uC6B4
      \uC9D1\uC911\uB825\uC73C\uB85C \uC29B\uC744 \uB358\uC9D1\uB2C8\uB2E4. \uB540\uC5D0
      \uC816\uC740 \uADF8\uAC00 \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC640 \uB2E8\uD638\uD558\uAC8C
      \uB9D0\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Instinct_002
    ko: "\uAC10\uB3C5\uB2D8, \uC774 \uAD6C\uC5ED\uC740 \uC81C '\uC131\uC5ED'\uC785\uB2C8\uB2E4.
      \uC5EC\uAE30\uC11C \uB358\uC9C0\uB294 \uC81C \uC29B\uC740 100% \uB4E4\uC5B4\uAC11\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Instinct_003
    ko: "\uC544\uB2C8 \uC9C4\uC9DC \uC5EC\uAE30\uC11C \uC29B \uB358\uC9C0\uBA74 \uB2E4
      \uC774\uAE38 \uC218 \uC788\uB2E4\uB2C8\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Instinct_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Instinct_001
    ko: "\uB124 \uB9C8\uC74C\uB300\uB85C \uD718\uC800\uC5B4\uBD10\uB77C. \uD310\uC740
      \uB0B4\uAC00 \uAE54\uC544\uC8FC\uB9C8."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uBCF4\uB294 \uB208\uC774 \uC788\uC73C\uC2DC\uB124\uC694!
      \uC804\uC124\uC774 \uB418\uB294 \uAC78 \uBCF4\uAC8C \uB418\uC2E4 \uAC81\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Bluffer_1
    ko: "\uC778\uC815\uC744 \uBC1B\uC790 \uAE30\uC138\uAC00 \uC0B4\uC544\uB098 \uC288\uD305
      \uAC10\uAC01\uC774 \uD3ED\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Wild_101
    ko: "\uBBFF\uC5B4\uC8FC\uC2E0 \uB9CC\uD07C \uBAB8\uC73C\uB85C \uBCF4\uC5EC\uB4DC\uB9B4\uAC8C\uC694.
      \uB9BC\uC774 \uBD80\uC11C\uC9C8 \uC815\uB3C4\uB85C \uAF42\uC544 \uB123\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Wild_1
    ko: "\uAE30\uBD84\uC740 \uC88B\uC544\uC84C\uC73C\uB098 \uAE30\uC220\uC801\uC778
      \uC815\uAD50\uD568\uC740 \uD3C9\uC18C\uC640 \uB2E4\uB984\uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Egoist_101
    ko: "\uC81C\uAC00 \uC774\uAE30\uB294 \uAC74 \uB2F9\uC5F0\uD55C \uAC70\uB2C8\uAE4C\uC694.
      \uC804\uC220\uC774\uB098 \uC798 \uC9DC\uC8FC\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Egoist_1
    ko: "\uACFC\uB3C4\uD55C \uC790\uB9CC\uC2EC\uC5D0 \uBE60\uC838 \uC29B \uBC38\uB7F0\uC2A4\uAC00
      \uD750\uD2B8\uB7EC\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Fighter_101
    ko: "\uC88B\uC558\uC5B4! \uB2E4 \uC774\uACA8\uC8FC\uC9C0!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Fighter_1
    ko: "\uB108\uBB34 \uD765\uBD84\uD558\uC5EC \uD6C8\uB828 \uC131\uACFC\uAC00 \uC81C\uB300\uB85C
      \uB098\uC624\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Instinct_002
    ko: "100%? \uC790\uB9CC\uD558\uC9C0 \uB9C8\uB77C! \uC5B8\uC820\uAC00 \uB124 \uC57C\uC131\uC774
      \uBC1C\uBAA9\uC744 \uC7A1\uC744\uAC70\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bluffer_201
    ko: "\uC544... \uC790\uB9CC\uC774 \uC544\uB2C8\uB77C \uD655\uC2E0\uC774\uC5C8\uB294\uB370...
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uD300 \uD50C\uB808\uC774\uC5D0 \uB354 \uC2E0\uACBD
      \uC4F8\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Bluffer_2
    ko: "\uBE44\uB09C\uC5D0 \uAE30\uAC00 \uC8FD\uC5B4 \uACFC\uAC10\uD55C \uC2DC\uB3C4\uB97C
      \uC8FC\uC800\uD558\uAC8C \uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Wild_201
    ko: "\uC81C \uC57C\uC131\uC774 \uD2C0\uB9AC\uC9C0 \uC54A\uC558\uB2E4\uB294 \uAC78
      \uACB0\uACFC\uB85C \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uB450\uACE0
      \uBCF4\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Wild_2
    ko: "\uAC15\uD55C \uC790\uADF9\uC5D0 \uBCF8\uB2A5\uC801\uC778 \uC9D1\uC911\uB825\uC774
      \uC0B4\uC544\uB0AC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Egoist_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uB9C8\uC74C\uC5D0 \uC548 \uB4DC\uC2DC\uB098 \uBCF8\uB370,
      \uACB0\uAD6D \uC800 \uB9D0\uACE0 \uB204\uAC00 \uB4DD\uC810\uD558\uC8E0? \uC804
      \uC81C \uAE38\uC744 \uAC11\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Egoist_2
    ko: "\uBC18\uBC1C\uC2EC\uB9CC \uC0DD\uAE38 \uBFD0 \uC2E4\uB825 \uC790\uCCB4\uC5D0
      \uBCC0\uD654\uB294 \uC0DD\uAE30\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Fighter_201
    ko: "\uC544\uB2C8, \uB0B4\uAC00 \uB9DE\uB2E4\uB2C8\uAE4C! \uC9C0\uAE08 \uC2F8\uC6B0\uC790\uB294
      \uAC70\uC9C0? \uB098 \uD6C8\uB828 \uC548\uD574!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Fighter_2
    ko: "\uAC10\uC815\uC5D0 \uC55E\uC11C \uD6C8\uB828\uC744 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Instinct_003
    ko: "\uC804\uC220 \uBCF4\uB4DC\uC758 \uC5D8\uBCF4\uC6B0 \uC9C0\uC5ED\uC5D0 \uC810
      \uD558\uB098\uB9CC \uCC0D\uACE0 \uC790\uB9AC\uB97C \uB5A0\uB09C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bluffer_301
    ko: "\uC800 \uC810... \uC800\uB97C \uC704\uD55C \uD2B9\uBCC4 \uC804\uC220\uC774\uC8E0?
      \uD558\uD558, \uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uCE24\uB370\uB808\uB77C\uB2C8\uAE4C!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Bluffer_3
    ko: "\uCC29\uAC01 \uC18D\uC5D0 \uD3C9\uC18C \uC2E4\uB825\uC744 \uC720\uC9C0\uD558\uBA70
      \uBCC4\uB2E4\uB978 \uC131\uC7A5\uC774 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Wild_301
    ko: "\uC65C \uB9D0\uC774 \uC5C6\uC73C\uC2DC\uC9C0? \uB9BC\uC744 \uB2E4 \uCC22\uC5B4\uB193\uC73C\uB77C\uB294
      \uAC74\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Wild_3
    ko: "\uD53C\uB4DC\uBC31\uC774 \uC5C6\uC790 \uC870\uAE09\uD568\uC744 \uB290\uB07C\uACE0
      \uC29B \uBC38\uB7F0\uC2A4\uAC00 \uAF2C\uC778 \uCC44 \uD6C8\uB828\uC774 \uC885\uB8CC\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Egoist_301
    ko: "\uD765, \uB300\uB2F5\uD560 \uAC00\uCE58\uB3C4 \uC5C6\uB2E4\uB294 \uAC74\uAC00.
      \uB0B4 \uC2E4\uB825\uC73C\uB85C \uC9C1\uC811 \uC804\uC220\uC744 \uC7C1\uCDE8\uD558\uACA0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Egoist_3
    ko: "\uCE68\uBB35\uC744 \uC2B9\uBD80\uB85C \uBC1B\uC544\uB4E4\uC5EC \uADF9\uD55C\uC758
      \uAC1C\uC778 \uC9D1\uC911\uB825\uC744 \uBC1C\uD718\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Fighter_301
    ko: "\uC800\uACF3\uB9CC \uC815\uBCF5\uD558\uBA74 \uB41C\uB2E4\uB294 \uC18C\uB9AC\uC8E0?
      ...\uAC01\uC624\uD574\uB77C!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Fighter_3
    ko: "\uAD49\uC7A5\uD55C \uC9D1\uC911\uB825\uC744 \uBC1C\uD718\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Discipline_001
    ko: "\uC120\uC218 \uD55C \uBA85\uC774 3\uC810 \uB77C\uC778 \uB4A4\uC5D0\uC11C
      \uBB35\uBB35\uD788 \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Discipline_002
    ko: "\uAC19\uC740 \uD3FC\uC73C\uB85C 100\uAC1C\uB97C \uB358\uC9C0\uB294 \uAC83\uC774
      \uC624\uB298 \uD6C8\uB828\uC758 \uBAA9\uD45C\uC9C0\uB9CC, 90\uBC88\uC9F8 \uACF5\uC744
      \uB358\uC9C8 \uB54C \uD3FC\uC774 \uD750\uD2B8\uB7EC\uC9C0\uACE0 \uB9BC\uC744
      \uBE57\uB098\uAC11\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Discipline_003
    ko: "\uC120\uC218\uB294 \uC790\uC2E0\uC758 \uADDC\uCE59\uC744 \uAE68\uC9C0 \uC54A\uAE30
      \uC704\uD574 \uC9C0\uCE5C \uBAB8\uC744 \uC774\uB04C\uACE0 \uB2E4\uC2DC \uACF5\uC744
      \uC90D\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Discipline_001
    ko: "\uADDC\uCE59\uC744 \uC9C0\uD0A4\uB824 \uB178\uB825\uD558\uB294 \uAC83\uB3C4
      \uC88B\uC9C0\uB9CC \uCEE8\uB514\uC158 \uAD00\uB9AC\uAC00 \uCD5C\uC6B0\uC120\uC774\uC57C. "
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Principled_101
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uB178\uB825\uC744 \uC54C\uC544\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Principled_1
    ko: "\uB530\uB73B\uD55C \uC778\uC815\uC5D0 \uAC10\uB3D9\uD558\uC5EC \uC2E0\uB8B0\uB3C4\uAC00
      \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Guardian_101
    ko: "\uD558\uC9C0\uB9CC, \uD300\uC744 \uC704\uD574\uC11C\uB77C\uBA74 \uB05D\uAE4C\uC9C0
      \uBAA9\uD45C\uB97C \uC218\uD589\uD574\uC57C \uD55C\uB2E4\uACE0 \uC0DD\uAC01\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Guardian_1
    ko: "\uACB8\uC190\uD558\uAC8C \uD6C8\uB828\uC758 \uB2F9\uC704\uC131\uC744 \uACE0\uC218\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Tactician_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uCE6D\uCC2C\uD574\uC8FC\uC2DC\uB2C8 \uD6C8\uB828\uC744
      \uBA48\uCD94\uACE0 \uC2F6\uC5B4\uC9D1\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Tactician_1
    ko: "\uC678\uBD80\uC758 \uC628\uC815\uC5D0 \uAE34\uC7A5\uAC10\uC774 \uD480\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Exemplary_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8 \uCD5C\uACE0! \uB0B4\uC77C \uB354 \uC798\uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Exemplary_1
    ko: "\uCE6D\uCC2C\uC5D0 \uD798\uC785\uC5B4 \uC0AC\uAE30\uAC00 \uC62C\uB790\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Discipline_002
    ko: "\uBB34\uB9AC\uD558\uB294 \uAC74 \uACB0\uCF54 \uD300\uC744 \uC704\uD55C \uAC8C
      \uC544\uB2C8\uC57C. \uB0B4\uC77C \uB2E4\uC2DC \uC644\uBCBD\uD55C \uCEE8\uB514\uC158\uC73C\uB85C
      \uC2DC\uC791\uD558\uC790."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Principled_201
    ko: "\uC81C\uAC00 \uB108\uBB34 \uBD80\uC871\uD574\uC11C \uAC10\uB3C5\uB2D8 \uAC71\uC815\uC744
      \uB07C\uCCE4\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Principled_2
    ko: "\uC9C8\uCC45\uC758 \uC758\uB3C4\uB97C \uC624\uD574\uD574 \uC2A4\uC2A4\uB85C
      \uC704\uCD95\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Guardian_201
    ko: "\uD300\uC744 \uC704\uD574 \uCEE8\uB514\uC158 \uAD00\uB9AC\uC5D0 \uB354 \uD798\uC4F0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Guardian_2
    ko: "\uC790\uC2E0\uBCF4\uB2E4 \uD300\uC758 \uC804\uB825\uC744 \uC0DD\uAC01\uD558\uB294
      \uAC10\uB3C5\uC758 \uB9C8\uC74C\uC744 \uC774\uD574\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Tactician_201
    ko: "\uC9C0\uC2DC\uD558\uC2E0 \uB300\uB85C \uCEE8\uB514\uC158 \uC870\uC808\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uC5C5\uBB34\uC0C1 \uC9C0\uC2DC\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uC131\uC2E4\uD788 \uC774\uD589\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Exemplary_201
    ko: "\uD751... \uC81C\uAC00 \uB108\uBB34 \uBB34\uB9AC\uD588\uB098 \uBD10\uC694."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Exemplary_2
    ko: "\uAC10\uB3C5\uC758 \uC5C4\uACA9\uD55C \uC5B4\uC870\uC5D0 \uD06C\uAC8C \uAE30\uC8FD\uC5B4
      \uAE30\uBD84\uC774 \uB2E4\uC6B4\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Discipline_003
    ko: "\uC120\uC218\uC758 \uBC1C\uCE58\uC5D0 \uC218\uAC74\uACFC \uC2DC\uC6D0\uD55C
      \uBB3C\uC744 \uAC00\uC838\uB2E4 \uB450\uACE0, \uD6C8\uB828 \uBAA8\uC2B5\uC744
      \uBB35\uBB35\uD788 \uC9C0\uCF1C\uBCF8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Principled_301
    ko: "\uD6C8\uB828\uD558\uB294 \uBAA8\uC2B5\uC744 \uB05D\uAE4C\uC9C0 \uC9C0\uCF1C\uBD10
      \uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Principled_3
    ko: "\uAC10\uB3C5\uC744 \uC2E0\uB8B0\uD558\uAC8C \uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Guardian_301
    ko: "\uC65C \uB9D0\uC774 \uC5C6\uC73C\uC2DC\uC9C0... \uC81C\uB300\uB85C \uBAA9\uD45C\uB97C
      \uB2EC\uC131\uD558\uC9C0 \uBABB\uD574 \uC2E4\uB9DD\uD558\uC168\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Guardian_3
    ko: "\uAD00\uC2EC\uC744 \uAC08\uAD6C\uD558\uBA70 \uAC10\uB3C5\uACFC\uC758 \uAC70\uB9AC\uAC10\uC5D0
      \uBD88\uC548\uD568\uC744 \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Tactician_301
    ko: "\uB9D0\uC740 \uC5C6\uC73C\uC2DC\uC9C0\uB9CC, \uC774\uAC83\uB3C4 \uD558\uB098\uC758
      \uACC4\uD68D\uC778\uAC70\uC57C. \uB05D\uAE4C\uC9C0 \uC5F4\uC2EC\uD788 \uD574\uBCF4\uC790!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Tactician_3
    ko: "\uBAA9\uD45C\uB97C \uC644\uBCBD\uD558\uAC8C \uB2EC\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Exemplary_301
    ko: "\uC218\uAC74 \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uADF8\uB7FC \uC774\uC81C \uC26C\uC5B4\uB3C4
      \uB420\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Exemplary_3
    ko: "\uC26C\uB77C\uACE0 \uD55C \uC801\uC740 \uC5C6\uB294\uB370... \uC624\uB298
      \uD6C8\uB828\uC740 \uC81C\uC790\uB9AC\uAC78\uC74C\uC778 \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Bond_001
    ko: "\uC120\uC218 \uD55C \uBA85\uC774 3\uC810 \uB77C\uC778 \uB4A4\uC5D0\uC11C
      \uBB35\uBB35\uD788 \uC29B\uC744 \uB358\uC9C0\uB294 \uB8E8\uD2F4 \uD6C8\uB828
      \uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Bond_002
    ko: "90\uAC1C\uC9F8\uC5D0 \uC811\uC5B4\uB4E4\uC5B4 \uD3FC\uC774 \uD750\uD2B8\uB7EC\uC9C0\uC9C0\uB9CC,
      \uADDC\uCE59\uC744 \uC9C0\uD0A4\uAE30 \uC704\uD574 \uC9C0\uCE5C \uBAB8\uC744
      \uC774\uB04C\uACE0 \uB2E4\uC2DC \uACF5\uC744 \uC90D\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Bond_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Bond_001
    ko: "\uC624\uB298 90\uAC1C\uAE4C\uC9C0 \uC815\uB9D0 \uACE0\uC0DD \uB9CE\uC558\uC5B4.
      \uBAB8 \uC0C1\uD558\uBA74 \uC548 \uB418\uB2C8\uAE4C \uC624\uB298\uC740 \uC5EC\uAE30\uC11C
      \uB05D\uB0B4\uC790."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8\uAED8\uC11C \uC81C \uB178\uB825\uC744 \uC54C\uC544\uC8FC\uC2DC\uB2E4\uB2C8...
      \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Kind_1
    ko: "\uC778\uC815\uC5D0 \uAC10\uB3D9\uD558\uC5EC \uC2E0\uB8B0\uB3C4\uAC00 \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC6D0\uD558\uC2E0\uB2E4\uBA74 \uB2F9\uC7A5 \uBA48\uCD94\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Loyal_1
    ko: "\uB3C4\uC911\uC5D0 \uD6C8\uB828\uC744 \uADF8\uB9CC\uB450\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Sincere_101
    ko: "\uC9C0\uC2DC\uD558\uC2E0 \uB300\uB85C \uB0B4\uC77C \uB2E4\uC2DC \uCEE8\uB514\uC158
      \uAD00\uB9AC\uD574\uC11C \uC2DC\uC791\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Sincere_1
    ko: "\uC870\uC5B8\uC744 \uB8E8\uD2F4\uC758 \uC77C\uBD80\uB85C\uC368 \uB2F4\uB2F4\uD788
      \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Moodmaker_101
    ko: "\uAC10\uB3C5\uB2D8 \uCD5C\uACE0! \uCE6D\uCC2C\uD574\uC8FC\uC2DC\uB2C8 \uB0B4\uC77C\uC740
      100\uAC1C \uAF2D \uC131\uACF5\uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Moodmaker_1
    ko: "\uCE6D\uCC2C\uC5D0 \uD798\uC785\uC5B4 \uC0AC\uAE30\uB97C \uB04C\uC5B4\uC62C\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Bond_002
    ko: "\uD3FC\uC774 \uC774\uAC8C \uBB50\uC57C? \uB2F9\uC7A5 \uADF8\uB9CC\uB46C!"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Kind_201
    ko: "\uAC10\uB3C5\uB2D8... \uC81C\uAC00 \uD300\uC5D0 \uB3C4\uC6C0\uC774 \uB418\uACE0
      \uC2F6\uC5B4\uC11C \uADF8\uB7F0 \uAC74\uB370, \uACB0\uAD6D \uAC71\uC815\uB9CC
      \uB07C\uCCD0 \uB4DC\uB838\uB124\uC694. \uC81C\uAC00 \uB108\uBB34 \uBD80\uC871\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Kind_2
    ko: "\uC790\uC2E0\uC758 \uACFC\uC789 \uC758\uC695\uC774 \uAC10\uB3C5\uACFC\uC758
      \uAD00\uACC4\uB97C \uD574\uCCE4\uB2E4\uB294 \uACB0\uACFC\uC5D0 \uC704\uCD95\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Loyal_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uB9D0\uC500\uD558\uC2E0 \uB300\uB85C \uC9C0\uAE08
      \uC989\uC2DC \uD6C8\uB828\uC744 \uBA48\uCD94\uACE0 \uCEE8\uB514\uC158 \uAD00\uB9AC\uB97C
      \uC6B0\uC120\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC744 \uD300\uC744 \uC704\uD55C \uCC45\uC784\uAC10\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uC989\uAC01 \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Sincere_201
    ko: "100\uAC1C\uB97C \uCC44\uC6B0\uC9C0 \uBABB\uD558\uBA74 \uC81C \uB8E8\uD2F4\uC774
      \uAE68\uC9C0\uB294\uB370... \uC81C \uB178\uB825\uC774 \uB2E4 \uD5C8\uC0AC\uAC00
      \uB41C \uAE30\uBD84\uC785\uB2C8\uB2E4. \uAD34\uB86D\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Sincere_2
    ko: "\uACFC\uC815\uC758 \uC2E4\uD328\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uAC10\uC815\uC801
      \uD754\uB4E4\uB9BC\uC774 \uBC1C\uC0DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Moodmaker_201
    ko: "\uC544... \uC81C\uAC00 \uB610 \uACE0\uC9D1\uBD80\uB9AC\uB2E4\uAC00 \uBD84\uC704\uAE30
      \uB9DD\uCCE4\uC8E0? \uC800 \uB54C\uBB38\uC5D0 \uB2E4\uB4E4 \uAE34\uC7A5\uD55C
      \uAC83 \uAC19\uC544\uC694. \uC8C4\uC1A1\uD574\uC694, \uB2F9\uC7A5 \uADF8\uB9CC\uB458\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Moodmaker_2
    ko: "\uC790\uC2E0\uC758 \uD589\uB3D9\uC774 \uD300 \uBD84\uC704\uAE30\uB97C \uB9DD\uCCE4\uB2E4\uB294
      \uC790\uCC45\uC73C\uB85C \uC758\uC695\uC744 \uC0C1\uC2E4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Bond_003
    ko: "\uC120\uC218\uC758 \uACC1\uC5D0\uC11C \uCC28\uAC00\uC6B4 \uCE68\uBB35\uC744
      \uC720\uC9C0\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Kind_301
    ko: "\uC65C \uB9D0\uC774 \uC5C6\uC73C\uC2DC\uC9C0? \uC77C\uB2E8 \uD560 \uC77C\uC744
      \uD558\uC790."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Kind_3
    ko: "\uC9C0\uC9C0\uB098 \uC9C8\uCC45\uC774 \uC5C6\uB294 \uC0C1\uD669\uC5D0\uC11C
      \uBD88\uC548\uAC10\uC744 \uB290\uB07C\uBA70 \uB8E8\uD2F4\uC744 \uBC18\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Loyal_301
    ko: "...\uB354 \uC5F4\uC2EC\uD788 \uD574\uC57C\uACA0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Loyal_3
    ko: "\uAC10\uB3C5\uC774 \uC65C \uC9C0\uCF1C\uB9CC \uBCF4\uB294\uC9C0 \uACE0\uBBFC\uD558\uBA70
      \uCDA9\uC9C1\uD558\uAC8C \uB8E8\uD2F4\uC744 \uBC18\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Sincere_301
    ko: "\uC544\uBB34 \uB9D0\uC500 \uC5C6\uC73C\uC2E0 \uAC74... \uC81C \uD55C\uACC4\uB97C
      \uC2A4\uC2A4\uB85C \uADF9\uBCF5\uD558\uB77C\uB294 \uB73B\uC774\uACA0\uC8E0.
      \uD55C \uBC88 \uB354 \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Sincere_3
    ko: "\uCE68\uBB35\uC744 \uBB34\uC5B8\uC758 \uC2E0\uB8B0\uC640 \uB3C4\uC804\uC73C\uB85C
      \uD574\uC11D\uD558\uBA70 \uC9D1\uC911\uB825\uC744 \uADF9\uB300\uD654\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Moodmaker_301
    ko: "\uC544, \uC790\uAFB8 \uB208\uCE58 \uBCF4\uC774\uB124... \uD3C9\uC18C\uB300\uB85C
      \uC548\uD558\uBA74 \uD63C\uB0A0 \uAC83 \uAC19\uC740\uB370?"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Moodmaker_3
    ko: "\uC870\uC6A9\uD788 \uD6C8\uB828\uC744 \uC720\uC9C0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Cold_001
    ko: "\uC120\uC218 \uD55C \uBA85\uC774 3\uC810 \uB77C\uC778 \uB4A4\uC5D0\uC11C
      \uBB35\uBB35\uD788 \uC29B\uC744 \uB358\uC9C0\uB294 \uB8E8\uD2F4 \uD6C8\uB828
      \uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Cold_002
    ko: "90\uAC1C\uC9F8\uC5D0 \uC811\uC5B4\uB4E4\uC5B4 \uD3FC\uC774 \uD750\uD2B8\uB7EC\uC9C0\uC9C0\uB9CC,
      \uADDC\uCE59\uC744 \uC9C0\uD0A4\uAE30 \uC704\uD574 \uC9C0\uCE5C \uBAB8\uC744
      \uC774\uB04C\uACE0 \uB2E4\uC2DC \uACF5\uC744 \uC90D\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Cold_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Cold_001
    ko: "\uACE0\uC0DD \uB9CE\uC558\uB2E4. \uBAB8 \uC0C1\uD558\uBA74 \uC548 \uB418\uB2C8\uAE4C
      \uC624\uB298\uC740 \uC5EC\uAE30\uC11C \uB05D\uB0B4\uC790."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Planner_101
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uADF8\uB7FC \uB0B4\uC77C \uCEE8\uB514\uC158\uC744
      \uC704\uD55C \uACC4\uD68D\uC744 \uC9DC\uB3C4\uB85D \uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Planner_1
    ko: "\uD53C\uB4DC\uBC31\uC744 \uBC1B\uC544\uB4E4\uC774\uACE0 \uC548\uC815\uC801\uC778
      \uB9AC\uB4EC\uC744 \uB418\uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Opportunist_101
    ko: "\uC815\uB9D0\uC694? \uADF8\uB7FC \uB2F9\uC7A5 \uC26C\uB7EC\uAC00\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Opportunist_1
    ko: "\uAF80\uBCD1\uC774\uC5C8\uB358 \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Cunning_101
    ko: "\uB124, \uADF8\uB7FC \uC26C\uB7EC \uAC00\uBCFC\uAC8C\uC694. \uD314 \uC544\uD320\uB294\uB370
      \uC798\uB410\uB2E4~."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Cunning_1
    ko: "\uCEE8\uB514\uC158\uC774 \uB9DD\uAC00\uC9C0\uAE30 \uC9C1\uC804\uC5D0 \uD6C8\uB828\uC744
      \uC885\uB8CC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Believer_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uC800\uB97C \uBBFF\uC5B4\uC8FC\uC2DC\uB294\uAD70\uC694!
      \uB0B4\uC77C\uC740 \uC815\uB9D0 100\uAC1C \uCC44\uC6B8\uAC70\uC5D0\uC694!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Believer_1
    ko: "\uCE6D\uCC2C\uC5D0 \uD798\uC785\uC5B4 \uC0AC\uAE30\uAC00 \uC62C\uB790\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Cold_002
    ko: "\uD3FC\uC774 \uC774\uAC8C \uBB50\uC57C? \uB2F9\uC7A5 \uADF8\uB9CC\uB46C!"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Planner_201
    ko: "\uC774\uB7F4 \uACC4\uD68D\uC740 \uC544\uB2C8\uC5C8\uB294\uB370... \uC55E\uC73C\uB85C
      \uC5B4\uB5BB\uAC8C \uD574\uC57C\uD558\uC9C0?"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Planner_2
    ko: "\uAC08\uD53C\uB97C \uC7A1\uC9C0 \uBABB\uD574 \uD63C\uB780\uC5D0 \uBE60\uC9C0\uACE0
      \uB9D0\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Opportunist_201
    ko: "\uD5C9, \uD654\uB0B4\uC9C0 \uB9C8\uC138\uC694! \uC55E\uC73C\uB85C\uB294
      \uC81C\uAC00 \uBA3C\uC800 \uCEE8\uB514\uC158\uC744 \uBCF4\uACE0\uD558\uACE0
      \uC26C\uB7EC \uAC00\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Opportunist_2
    ko: "\uC790\uC8FC\uC801\uC778 \uD6C8\uB828 \uBC29\uC2DD\uC5D0 \uB300\uD55C \uAC10\uAC01\uC744
      \uAE68\uC6B0\uCE5C \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Cunning_201
    ko: "\uCE6B, \uB09C \uADF8\uC800 100\uAC1C\uB97C \uCC44\uC6B0\uACE0 \uC2F6\uC744
      \uBFD0\uC774\uC5C8\uB294\uB370..."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Cunning_2
    ko: "\uAC10\uB3C5\uC758 \uC9C8\uCC45\uC73C\uB85C \uC758\uAE30\uC18C\uCE68\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Believer_201
    ko: "\uC8C4\uC1A1\uD574\uC694, \uB2F9\uC7A5 \uADF8\uB9CC\uB450\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Believer_2
    ko: "\uAC10\uB3C5\uC5D0\uAC8C \uD63C\uB098\uC11C \uAE30\uBD84\uC774 \uC6B0\uC6B8\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Cold_003
    ko: "\uB9D0\uC5C6\uC774 \uC9C0\uCF1C\uBCF4\uB2E4\uAC00 \uACE0\uAC1C\uB97C \uB3CC\uB824
      \uCCB4\uC721\uAD00 \uBC16\uC73C\uB85C \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Planner_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uBC16\uC73C\uB85C \uB098\uAC00\uC168\uC796\uC544?
      \uC774\uB7EC\uBA74 \uC548\uB3FC. \uBE68\uB9AC \uC6D0\uB798 \uACC4\uD68D\uB300\uB85C
      \uBAA9\uD45C\uB97C \uB2EC\uC131\uD574\uC57C\uD574!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Planner_3
    ko: "\uBAA9\uD45C \uB2EC\uC131\uC5D0 \uAE09\uAE09\uD558\uC5EC \uC81C\uB300\uB85C
      \uB41C \uD6C8\uB828\uC774 \uC774\uB8E8\uC5B4\uC9C0\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Opportunist_301
    ko: "\uAC14\uB098? \uBCF4\uACE0\uC788\uB098? \uAC14\uB098? \uBCF4\uACE0\uC788\uB098?
      \uAC14\uB098?"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Opportunist_3
    ko: "\uC2E4\uC9C8\uC801 \uC131\uC7A5\uBCF4\uB2E4 \uAC10\uB3C5\uC5D0\uAC8C \uC88B\uC740
      \uC778\uC0C1\uC744 \uB0A8\uAE30\uB824\uB294 \uC5F0\uAE30\uC5D0 \uCE58\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Cunning_301
    ko: "\uB0B4\uAC00 \uB208\uCE58\uB97C \uBCF4\uB294 \uAC78 \uC54C\uACE0 \uC790\uB9AC\uB97C
      \uBE44\uC6CC\uC8FC\uC2E0 \uAC74\uAC00\uC694? \uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC744
      \uB530\uB77C\uAC00\uAE30\uC5D4 \uBA40\uC5C8\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Cunning_3
    ko: "\uAC10\uB3C5\uC744 \uC2E0\uB8B0\uD558\uC5EC \uD6C8\uB828\uC5D0 \uC9D1\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Believer_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC790\uB9AC\uB97C \uBE44\uC6B0\uC168\uB124...
      \uADF8\uB798\uB3C4 \uC774\uAC78 \uACC4\uC18D\uD558\uB294\uAC8C \uB9DE\uC744\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Believer_3
    ko: "\uC7A1 \uC0DD\uAC01\uC73C\uB85C \uC778\uD574 \uD6C8\uB828\uC5D0 \uC9D1\uC911\uD560
      \uC218 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Instinct_001
    ko: "\uC120\uC218\uAC00 3\uC810 \uB77C\uC778 \uB4A4\uC5D0\uC11C \uBB35\uBB35\uD788
      \uC29B\uC744 \uB358\uC9C0\uB294 \uB8E8\uD2F4 \uD6C8\uB828 \uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Instinct_002
    ko: "\uC774\uBBF8 90\uAC1C\uC9F8\uC5D0 \uC811\uC5B4\uB4E4\uC5B4 \uB2E4\uB9AC\uB294
      \uD6C4\uB4E4\uAC70\uB9AC\uACE0 \uC29B \uD3FC\uC740 \uB208\uC5D0 \uB744\uAC8C
      \uD750\uD2B8\uB7EC\uC84C\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Instinct_003
    ko: "\uD558\uC9C0\uB9CC \uC120\uC218\uB294 100\uAC1C\uB77C\uB294 \uC790\uC2E0\uACFC\uC758
      \uC57D\uC18D\uC744 \uC9C0\uD0A4\uAE30 \uC704\uD574, \uC228\uC744 \uBAB0\uC544\uC26C\uBA70
      \uB2E4\uC2DC \uAD74\uB7EC\uC628 \uACF5\uC744 \uC90D\uAE30 \uC704\uD574 \uBAB8\uC744
      \uB358\uC9D1\uB2C8\uB2E4"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Instinct_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Instinct_001
    ko: "\uB124\uAC00 \uC6D0\uD558\uB294 \uB300\uB85C \uD55C\uACC4\uAE4C\uC9C0 \uBC00\uC5B4\uBD99\uC5EC\uB77C."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Bluffer_101
    ko: "\uC2DC\uB828\uC740 \uC8FC\uC778\uACF5\uC744 \uB354 \uBE5B\uB098\uAC8C \uD558\uC9C0!
      \uB0B4 \uD22C\uD63C\uC774 \uB9BC\uC5D0 \uAF42\uD788\uB294 \uC21C\uAC04\uC744
      \uB611\uB611\uD788 \uBD10\uB450\uB77C\uACE0!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Bluffer_1
    ko: "\uCE6D\uCC2C\uC744 \uC790\uAE30 \uC11C\uC0AC\uC758 \uC815\uC810\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Wild_101
    ko: "\uADF8\uB294 \uB9D0\uC5C6\uC774 \uAC70\uCE5C \uC228\uC744 \uB0B4\uBC49\uC73C\uBA70
      \uC790\uC2E0\uC758 \uAC10\uAC01\uC5D0\uB9CC \uC9D1\uC911\uD558\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Wild_1
    ko: "\uC870\uC5B8\uC744 \uB4E3\uAE30\uB294 \uD55C \uAC74\uAC00? \uD63C\uC790\uB9CC\uC758
      \uC2DC\uAC04\uC774 \uD544\uC694\uD55C \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Egoist_101
    ko: "\uACA9\uB824\uB294 \uB410\uACE0... \uB0B4 \uD398\uC774\uC2A4\uB300\uB85C
      \uB358\uC9C0\uAC8C \uD574\uC8FC\uC2ED\uC1FC. \uC774\uAC74 \uB0B4 \uBC29\uC2DD\uB300\uB85C
      \uC644\uC131\uD574\uC57C \uD558\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Egoist_1
    ko: "\uC5B4\uC124\uD508 \uACA9\uB824\uAC00 \uC624\uD788\uB824 \uB3C5\uC774 \uB41C
      \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Fighter_101
    ko: "\uC798\uB410\uC2B5\uB2C8\uB2E4. \uB2E4\uB9AC\uAC00 \uBD80\uB7EC\uC838\uB3C4
      \uC800 \uB9BC\uC744 \uBC15\uC0B4 \uB0B4\uACE0 \uC4F0\uB7EC\uC9C0\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Fighter_1
    ko: "\uD22C\uC9C0\uAC00 \uBD88\uD0C0\uC624\uB974\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Instinct_002
    ko: "\uADDC\uCE59\uB3C4, \uCCB4\uACC4\uB3C4 \uC5C6\uC774 \uAC10\uAC01\uB9CC \uBBFF\uACE0
      \uB0A0\uB6F0\uB294 \uAC74 \uC57C\uC218\uC77C \uBFD0\uC774\uB2E4. \uC81C \uBA4B\uB300\uB85C
      \uAD74\uAC70\uBA74 \uD300\uC5D0\uC11C \uB098\uAC00!"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Bluffer_201
    ko: "\uBB50? \uAC10\uD788 \uB0B4 \uB18D\uAD6C\uC5D0 \uD1A0\uB97C \uB2EC\uC544?"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Bluffer_2
    ko: "\uC790\uC874\uC2EC\uC744 \uAC74\uB4DC\uB824 \uAC10\uB3C5\uACFC \uC815\uBA74
      \uB300\uB9BD\uD558\uACE0 \uB9D0\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Wild_201
    ko: "\uC18C\uB9AC \uC9C0\uB974\uC9C0 \uB9C8! \uB9AC\uB4EC \uB04A\uAE30\uC796\uC544.
      \uB0B4 \uC57C\uC0DD\uC758 \uAC10\uAC01\uC744 \uBC29\uD574\uD558\uC9C0 \uB9D0\uB77C\uACE0!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Wild_2
    ko: "\uAC04\uC12D \uB54C\uBB38\uC5D0 \uD398\uC774\uC2A4\uAC00 \uD750\uD2B8\uB7EC\uC9C4
      \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Egoist_201
    ko: "\uD765, \uADF8\uB7F0\uB2E4\uACE0 \uB204\uAC00 \uCAC4 \uC904 \uC54C\uACE0?
      \uC5F0\uC2B5\uC774\uB098 \uACC4\uC18D \uD574\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Egoist_2
    ko: "\uC870\uC5B8\uC744 \uD55C \uADC0\uB85C \uB4E3\uACE0 \uD55C \uADC0\uB85C
      \uD758\uB9AC\uB294 \uC0C1\uD0DC\uC778 \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Fighter_201
    ko: "\uD765, \uAE61\uD1B5 \uC8FC\uC81C\uC5D0 \uBB58 \uC548\uB2E4\uACE0."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Fighter_2
    ko: "\uC9C8\uCC45\uC744 \uBC84\uD2F0\uBA70 \uC2A4\uC2A4\uB85C\uB97C \uADF9\uD55C\uC73C\uB85C
      \uBAB0\uC544\uBD99\uC774\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Instinct_003
    ko: "\uCF54\uD2B8 \uADFC\uCC98\uC5D0\uB3C4 \uAC00\uC9C0 \uC54A\uC740 \uCC44 \uD6C8\uB828\uD558\uB294
      \uC18C\uB9AC\uC5D0\uB9CC \uADC0\uB97C \uAE30\uC6B8\uC774\uBA70 \uC9C0\uCF1C\uBCF8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Bluffer_301
    ko: "\uC9C0\uCF1C\uBCF4\uC138\uC694. \uB098\uC758 \uD654\uB824\uD55C \uB3D9\uC791\uC744!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Bluffer_3
    ko: "\uC81C\uB300\uB85C \uB41C \uD6C8\uB828\uC774 \uB418\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Wild_301
    ko: "\uB4DC\uB514\uC5B4 \uC815\uC801\uBFD0\uC774\uB2E4... \uB9BC\uC774 \uB0B4
      \uBAB8\uC758 \uC77C\uBD80\uCC98\uB7FC \uB290\uAEF4\uC838. \uC644\uBCBD\uD55C
      \uBAB0\uC785\uC774\uC57C."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Wild_3
    ko: "\uC644\uBCBD\uD55C \uBAB0\uC785\uC744 \uD1B5\uD574 \uD6C8\uB828\uC744 \uC644\uB8CC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Egoist_301
    ko: "\uAC04\uC12D\uC774 \uC5C6\uC73C\uB2C8 \uBE44\uB85C\uC18C \uC644\uBCBD\uD574.
      \uC774 \uACE0\uC694\uD568 \uC18D\uC5D0\uC11C \uB0B4 \uB18D\uAD6C\uAC00 \uC644\uC131\uB418\uACE0
      \uC788\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Egoist_3
    ko: "\uC790\uAE30 \uC644\uC131\uC744 \uC704\uD55C \uCD5C\uC801\uC758 \uC0C1\uD0DC\uC5D0
      \uB3CC\uC785\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Fighter_301
    ko: "\uC774 \uACE0\uB3C5\uD55C \uBC29\uCE58\uB294 \uC9C0\uACB9\uC6CC. \uB2F9\uC7A5
      \uBD99\uC744 \uC0C1\uB300\uAC00 \uD544\uC694\uD558\uB2E4\uACE0!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Fighter_3
    ko: "\uC815\uC801\uC778 \uC0C1\uD669\uC5D0 \uB300\uD574 \uBD88\uB9CC\uC744 \uD1A0\uB85C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Discipline_001
    ko: "\uD55C \uC120\uC218\uAC00 \uC790\uC2E0\uC758 3\uC810 \uC29B \uB370\uC774\uD130\uB97C
      \uBD84\uC11D\uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Discipline_002
    ko: "3\uC810\uC29B \uC2E4\uD328\uC758 \uC6D0\uC778\uC740 '\uD314\uAFC8\uCE58
      \uAC01\uB3C4'\uC640 '\uB9B4\uB9AC\uC2A4 \uD0C0\uC774\uBC0D'\uC758 \uBBF8\uC138\uD55C
      \uBD88\uC77C\uCE58 \uB54C\uBB38\uC778\uAC00..."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Discipline_003
    ko: "\uBB38\uC81C\uB97C \uD574\uACB0\uD558\uB824\uBA74 \uC5B4\uB5BB\uAC8C \uD574\uC57C\uD560\uC9C0
      \uBAA8\uB974\uACA0\uB124. \uAC10\uB3C5\uB2D8\uC758 \uC758\uACAC\uC740 \uC5B4\uB5A4\uAC00\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Discipline_001
    ko: "\uD568\uAED8 \uB354 \uC88B\uC740 \uBC29\uBC95\uC744 \uCC3E\uC544\uBCF4\uC790.
      \uAE30\uBCF8\uAE30\uC640 \uB124 \uBD84\uC11D \uB2A5\uB825\uC744 \uC870\uD654\uB86D\uAC8C
      \uC11E\uC5B4\uBCF4\uB294\uAC74 \uC5B4\uB5A8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Principled_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uBC30\uB824\uC5D0 \uAC10\uC0AC\uB4DC\uB9BD\uB2C8\uB2E4.
      \uADDC\uC728 \uC548\uC5D0\uC11C \uC81C \uC6D0\uCE59\uC744 \uCD5C\uC801\uD654\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Principled_1
    ko: "\uC790\uC2E0\uC758 \uC6D0\uCE59\uC744 \uD300\uC758 \uADDC\uC728\uACFC \uC131\uACF5\uC801\uC73C\uB85C
      \uACB0\uD569\uD558\uC5EC \uC288\uD305\uC758 \uC644\uC131\uB3C4\uB97C \uB192\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Guardian_101
    ko: "\uD300 \uC804\uCCB4\uC758 \uBC38\uB7F0\uC2A4\uB97C \uC0DD\uAC01\uD558\uBA70
      \uC81C \uC29B \uD3FC\uC744 \uBCF4\uC644\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Guardian_1
    ko: "\uC0DD\uAC01\uD560 \uAC83\uC774 \uB9CE\uC544\uC9C4 \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Tactician_101
    ko: "\uC774\uAC8C \uB370\uC774\uD130\uC0C1 \uCD5C\uC120 \uAC19\uC740\uB370...
      \uC804\uC220\uC801 \uC870\uD654\uB97C \uC704\uD574\uC120 \uAE30\uBCF8 \uD2C0\uC744
      \uB530\uB77C\uC57C \uD558\uACE0..."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Tactician_1
    ko: "\uBB34\uC5C7\uC744 \uC120\uD0DD\uD574\uC57C \uD560\uC9C0 \uD63C\uB780\uC5D0
      \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Exemplary_101
    ko: "\uD300\uC758 \uAE30\uC900\uC774 \uB418\uB294 \uADDC\uC728\uC744 \uC900\uC218\uD558\uBA70
      \uC815\uAD50\uD568\uC744 \uB354\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Exemplary_1
    ko: "\uC790\uC2E0\uC758 \uD3FC \uC218\uC815\uC744 \uBAA8\uBC94\uC801\uC778 \uC218\uC900
      \uB0B4\uC5D0\uC11C \uC870\uC808\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Discipline_002
    ko: "\uC774\uACF3\uC740 \uB370\uC774\uD130 \uC5F0\uAD6C\uC2E4\uC774 \uC544\uB2C8\uB2E4.
      \uAE30\uBCF8\uAE30\uBD80\uD130 \uB2E4\uC2DC \uB2E4\uC838\uB77C."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Principled_201
    ko: "\uC81C \uBD84\uC11D\uC774 \uADDC\uC728\uBCF4\uB2E4 \uC55E\uC130\uC74C\uC744
      \uAE68\uB2EC\uC558\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Principled_2
    ko: "\uACC4\uC18D\uD574\uC11C \uAE30\uBCF8\uAE30\uB9CC \uB2E4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Guardian_201
    ko: "\uD300\uC5D0\uC11C 1\uC778\uBD84\uC740 \uD560 \uC218 \uC788\uC744 \uB54C
      \uAE4C\uC9C0 \uAE30\uBCF8\uAE30\uB97C \uC5F0\uC2B5\uD574\uC57C \uD55C\uB2E4\uB294
      \uB9D0\uC774\uAD70\uC694..."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Guardian_2
    ko: "\uAE30\uBCF8\uAE30\uB9CC \uD6C8\uB828\uD558\uB294 \uAC83\uC5D0 \uB2F5\uB2F5\uD568\uC744
      \uB290\uB07C\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Tactician_201
    ko: "\uB124. \uAE30\uBCF8\uBD80\uD130 \uB2E4\uC2DC \uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uB17C\uB9AC\uC801\uC778 \uC804\uC220 \uD53C\uB4DC\uBC31\uC73C\uB85C
      \uC218\uC6A9\uD558\uC5EC \uC288\uD305 \uD6A8\uC728\uC744 \uADF9\uB300\uD654\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Exemplary_201
    ko: "\uC544\uBB34\uB798\uB3C4 \uD300\uC758 \uBAA8\uBC94\uC774 \uB418\uC5B4\uC57C
      \uD560 \uC81C\uAC00 \uD3FC \uC218\uC815\uC5D0\uB9CC \uB9E4\uBAB0\uB418\uC5C8\uB098
      \uBD05\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Exemplary_2
    ko: "\uBAA8\uBC94\uC774 \uB418\uC9C0 \uBABB\uD588\uB2E4\uB294 \uC8C4\uCC45\uAC10\uC774
      \uC120\uC218\uC758 \uC790\uC874\uAC10\uC744 \uAEBE\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Discipline_003
    ko: "\uC544\uBB34\uB7F0 \uB9D0 \uC5C6\uC774 \uCCB4\uC721\uAD00 \uC678\uACFD\uC758
      \uC288\uD305 \uBA38\uC2E0\uC744 \uAC00\uB9AC\uD0A4\uACE0\uB294 \uD314\uC9F1\uC744
      \uB080 \uCC44 \uB208\uC744 \uAC10\uB294\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Principled_301
    ko: "\uC81C \uB370\uC774\uD130\uB294 \uAC00\uCE58\uB3C4 \uC5C6\uC73C\uB2C8 \uC29B
      \uC5F0\uC2B5\uC774\uB098 \uB354 \uD558\uB77C\uB294 \uC18C\uB9AC\uC778\uAC00\uC694..."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Principled_3
    ko: "\uAC10\uB3C5\uC758 \uCE68\uBB35\uC744 \uB370\uC774\uD130 \uBD84\uC11D\uC5D0
      \uB300\uD55C \uC804\uBA74 \uBD80\uC815\uC73C\uB85C \uD574\uC11D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uBB34\uC5B8\uC758 \uAC00\uB974\uCE68\uC744 \uB530\uB77C
      \uB9BC\uC744 \uB178\uB9AC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Guardian_3
    ko: "\uD300\uC5D0 \uAE30\uC5EC\uD558\uAE30 \uC704\uD574 \uBB35\uBB35\uD788 \uB178\uB825\uD558\uC5EC
      \uC131\uC7A5\uD558\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Tactician_301
    ko: "\uC29B\uC744 \uB354 \uC3F4 \uBD10\uB77C... \uB370\uC774\uD130\uC640 \uD3FC\uC758
      \uC624\uCC28\uB97C \uC218\uC815\uD560 \uC218 \uC788\uACA0\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Tactician_3
    ko: "\uC544\uC9C1 \uB370\uC774\uD130\uB97C \uBD84\uC11D\uD558\uAE30\uC5D4 \uAC08
      \uAE38\uC774 \uBA40\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Exemplary_301
    ko: "\uB370\uC774\uD130 \uBCF4\uB2E4\uB294 \uC288\uD305 \uC5F0\uC2B5\uC744 \uD1B5\uD574
      \uD3FC\uC744 \uC644\uC131\uC2DC\uD0A4\uB77C\uB294 \uB9D0\uC500\uC774\uC2DC\uAD70\uC694!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Exemplary_3
    ko: "\uAE0D\uC815\uC801\uC778 \uD574\uC11D\uC73C\uB85C \uC88B\uC740 \uD6C8\uB828
      \uACB0\uACFC\uB97C \uC5BB\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Bond_001
    ko: "\uD55C \uC120\uC218\uAC00 \uC790\uC2E0\uC758 3\uC810 \uC29B \uB370\uC774\uD130\uB97C
      \uBD84\uC11D\uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Bond_002
    ko: "\uC790\uC2E0\uC758 3\uC810\uC29B \uC2E4\uD328 \uC6D0\uC778\uC774 '\uD314\uAFC8\uCE58
      \uAC01\uB3C4'\uC640 '\uB9B4\uB9AC\uC2A4 \uD0C0\uC774\uBC0D'\uC758 \uBBF8\uC138\uD55C
      \uBD88\uC77C\uCE58\uC784\uC744 \uD655\uC2E0\uD558\uACE0 \uBD84\uC11D \uC790\uB8CC\uB97C
      \uAC10\uB3C5\uC5D0\uAC8C \uC81C\uC2DC\uD558\uBA70 \uC870\uC5B8\uC744 \uAD6C\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Bond_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Bond_001
    ko: "\uB124\uAC00 \uC81C\uC2DC\uD55C \uBD84\uC11D \uC790\uB8CC\uC640 \uD568\uAED8
      \uB354 \uC88B\uC740 \uBC29\uBC95\uC744 \uCC3E\uC544\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uB530\uB73B\uD55C \uACA9\uB824 \uB355\uBD84\uC5D0
      \uB9C8\uC74C\uC774 \uD3B8\uD574\uC84C\uC2B5\uB2C8\uB2E4. \uBC29\uBC95\uC744
      \uAF2D \uCC3E\uC544\uBCF4\uB3C4\uB85D \uD574\uC694!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Kind_1
    ko: "\uAC10\uB3C5\uC758 \uB530\uB73B\uD55C \uD53C\uB4DC\uBC31\uC774 \uC120\uC218\uC758
      \uC2EC\uB9AC\uC801 \uC548\uC815\uAC10\uC744 \uC8FC\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uAE30\uB300\uC5D0 \uBCF4\uB2F5\uD558\uAE30 \uC704\uD574
      \uBD84\uC11D\uD55C \uB0B4\uC6A9\uC744 \uCDA9\uC2E4\uD788 \uC774\uD589\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Loyal_1
    ko: "\uB370\uC774\uD130\uB97C \uBCF4\uBA70 \uCDA9\uC2E4\uD788 \uC774\uD589\uC911\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Sincere_101
    ko: "\uD558\uC9C0\uB9CC \uC0C8\uB85C\uC6B4 \uBC29\uBC95\uC744 \uCC3E\uC73C\uBA74
      \uAE30\uAECF \uB9C8\uB828\uD55C \uB8E8\uD2F4\uC744 \uBC84\uB9AC\uAC8C \uB418\uC9C0
      \uC54A\uC744\uAE4C\uC694..."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Sincere_1
    ko: "\uAC10\uB3C5\uC758 \uACA9\uB824\uB97C \uD6C8\uB828 \uB8E8\uD2F4\uC744 \uBCC0\uD615\uD558\uB77C\uB294
      \uC555\uBC15\uC73C\uB85C \uB290\uB07C\uACE0 \uB9D0\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Moodmaker_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8! \uC81C \uBD84\uC11D\uC744 \uC54C\uC544\uC8FC\uC2DC\uB2E4\uB2C8,
      \uB2F9\uC7A5 \uD300\uC6D0\uB4E4\uD55C\uD14C\uB3C4 \uC54C\uB824\uC918\uC57C\uACA0\uC5B4\uC694!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Moodmaker_1
    ko: "\uD300\uC6D0\uB4E4 \uC55E\uC5D0\uC11C \uBC1D\uAC8C \uBD84\uC11D \uC790\uB8CC\uB97C
      \uACF5\uC720\uD558\uBA70 \uC5D0\uB108\uC9C0\uB97C \uBC1C\uC0B0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Bond_002
    ko: "\uB370\uC774\uD130 \uBD84\uC11D\uC5D0\uB9CC \uB108\uBB34 \uBAB0\uB450\uD558\uBA74
      \uB3D9\uB8CC\uB4E4\uACFC\uC758 \uD638\uD761\uC744 \uB193\uCE58\uAE30 \uC27D\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Kind_201
    ko: "\uBD84\uC11D\uBCF4\uB2E4 \uB3D9\uB8CC\uAC00 \uBA3C\uC800\uB77C\uB2C8...
      \uC81C \uB178\uB825\uC774 \uD300\uC744 \uC704\uD55C \uAC8C \uC544\uB2C8\uC5C8\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Kind_2
    ko: "\uD300\uC744 \uC704\uD55C \uC21C\uC218\uD55C \uB178\uB825\uC774 \uBD80\uC815\uB2F9\uD588\uB2E4\uACE0
      \uB290\uAEF4 \uC0C1\uCC98\uB97C \uBC1B\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Loyal_201
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uB9D0\uC500\uC774 \uB9DE\uC2B5\uB2C8\uB2E4. \uBD84\uC11D
      \uC790\uB8CC\uBCF4\uB2E4 \uD300\uC744 \uD5A5\uD55C \uD5CC\uC2E0\uC744 \uC6B0\uC120\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Loyal_2
    ko: "\uD300\uC744 \uC704\uD55C \uD5CC\uC2E0\uC744 \uD1B5\uD574 \uD300 \uD50C\uB808\uC774
      \uC801\uD569\uB3C4\uAC00 \uC0C1\uC2B9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Sincere_201
    ko: "\uC5ED\uC2DC \uAE30\uBCF8\uAE30\uB97C \uB2E4\uC9C0\uB294 \uAC83\uC774 \uC800\uC5D0\uAC8C\uB3C4,
      \uD300\uC5D0\uAC8C\uB3C4 \uB3C4\uC6C0\uC774 \uB418\uACA0\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Sincere_2
    ko: "\uC790\uC2E0\uC758 \uC131\uC2E4\uD568\uC744 \uB418\uC0C8\uAE30\uBA70 \uAE30\uBCF8\uAE30\uB97C
      \uAFB8\uC900\uD788 \uD6C8\uB828\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Moodmaker_201
    ko: "\uBD84\uC704\uAE30\uAC00 \uB108\uBB34 \uBB34\uAC81\uB124\uC694... \uBD84\uC11D\uC774
      \uC7AC\uBBF8\uC5C6\uC5C8\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Moodmaker_2
    ko: "\uC9C8\uCC45\uC73C\uB85C \uC778\uD574 \uBD84\uC704\uAE30\uAC00 \uAC00\uB77C\uC549\uC790
      \uC758\uAE30\uC18C\uCE68\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Bond_003
    ko: "\uC544\uBB34\uB7F0 \uB9D0 \uC5C6\uC774 \uCCB4\uC721\uAD00 \uC678\uACFD\uC758
      \uC288\uD305 \uBA38\uC2E0\uC744 \uAC00\uB9AC\uD0A4\uACE0\uB294 \uD314\uC9F1\uC744
      \uB080 \uCC44 \uB208\uC744 \uAC10\uB294\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Kind_301
    ko: "\uC544\uBB34 \uB9D0\uB3C4 \uC5C6\uB124... \uC11C\uC6B4\uD558\uAC8C..."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Kind_3
    ko: "\uBB35\uBB35\uD788 \uD6C8\uB828\uC744 \uC774\uC5B4\uAC14\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Loyal_301
    ko: "\uBB54\uAC00 \uC758\uC695\uC774 \uD30D \uC0AC\uB77C\uC9C0\uB124\uC694..."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Loyal_3
    ko: "\uC790\uC2E0\uC758 \uCDA9\uC131\uC2EC\uC774 \uBD80\uC815\uB2F9\uD588\uB2E4\uB294
      \uB290\uB08C\uC744 \uBC1B\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Sincere_301
    ko: "\uC544\uBB34 \uB9D0\uC500 \uC5C6\uC73C\uC168\uC9C0\uB9CC, \uBB35\uBB35\uD788
      \uC81C \uC790\uB9AC\uC5D0\uC11C \uBD84\uC11D\uB300\uB85C \uC5F0\uC2B5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Sincere_3
    ko: "\uAC10\uB3C5\uC758 \uBA85\uB839\uC744 \uC790\uC2E0\uC758 \uBD84\uC11D\uC744
      \uC644\uC131\uD558\uB77C\uB294 \uB73B\uC73C\uB85C \uD574\uC11D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Moodmaker_301
    ko: "\uBB50\uC9C0? \uC77C\uB2E8 \uC29B\uC774\uB098 \uC3D8\uB77C\uB294 \uAC74\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Moodmaker_3
    ko: "\uD6C8\uB828\uC5D0 \uBAB0\uC785\uD558\uC9C0 \uBABB\uD558\uACE0 \uC29B\uC744
      \uB09C\uC0AC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Cold_001
    ko: "\uD55C \uC120\uC218\uAC00 \uC790\uC2E0\uC758 3\uC810 \uC29B \uB370\uC774\uD130\uB97C
      \uBD84\uC11D\uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Cold_002
    ko: "\uC790\uC2E0\uC758 3\uC810\uC29B \uC2E4\uD328 \uC6D0\uC778\uC774 '\uD314\uAFC8\uCE58
      \uAC01\uB3C4'\uC640 '\uB9B4\uB9AC\uC2A4 \uD0C0\uC774\uBC0D'\uC758 \uBBF8\uC138\uD55C
      \uBD88\uC77C\uCE58\uC784\uC744 \uD655\uC2E0\uD558\uACE0 \uBD84\uC11D \uC790\uB8CC\uB97C
      \uAC10\uB3C5\uC5D0\uAC8C \uC81C\uC2DC\uD558\uBA70 \uC870\uC5B8\uC744 \uAD6C\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Cold_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Cold_001
    ko: "\uB124\uAC00 \uBD84\uC11D\uD55C \uB370\uC774\uD130\uB97C \uD6A8\uC728\uC801\uC778
      \uB4DD\uC810\uC73C\uB85C \uC774\uC5B4\uC9C0\uB3C4\uB85D \uCCB4\uACC4\uC801\uC73C\uB85C
      \uC218\uC815\uD574 \uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Planner_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uC870\uC5B8\uB300\uB85C \uCD5C\uC801\uC758 \uC288\uD305
      \uBA54\uCEE4\uB2C8\uC998\uC744 \uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Planner_1
    ko: "\uB354\uC6B1 \uC815\uAD50\uD55C \uC29B \uBA54\uCEE4\uB2C8\uC998\uC744 \uC124\uACC4\uD560
      \uC218 \uC788\uAC8C \uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Opportunist_101
    ko: "\uB4DD\uC810 \uCC2C\uC2A4\uB97C \uC704\uD574\uC11C\uB77C\uBA74 \uC5BC\uB9C8\uB4E0\uC9C0
      \uC218\uC815\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Opportunist_1
    ko: "\uB4DD\uC810\uC5D0 \uC5F0\uC5F0\uD558\uC5EC \uC218\uC815\uC5D0 \uAF64 \uC624\uB79C
      \uC2DC\uAC04\uC774 \uAC78\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Cunning_101
    ko: "\uC774\uAC83\uB9CC \uB9C8\uC2A4\uD130 \uD558\uBA74 \uB4DD\uC810\uC655\uC774
      \uB420 \uC218 \uC788\uC73C\uB824\uB098~!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Cunning_1
    ko: "\uBD84\uC11D\uC774 \uCE6D\uCC2C\uBC1B\uC790 \uBC29\uC2EC\uD558\uC5EC \uD6C8\uB828\uC758
      \uAE34\uC7A5\uAC10\uC774 \uD480\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Believer_101
    ko: "\uC81C \uBD84\uC11D\uC774 \uC633\uC74C\uC744 \uACB0\uACFC\uB85C \uC99D\uBA85\uD574
      \uBCF4\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Believer_1
    ko: "\uB17C\uB9AC\uC801 \uACB0\uB860\uC5D0 \uD655\uC2E0\uC744 \uC5BB\uC5B4 \uD6C8\uB828\uC5D0
      \uB3C4\uC6C0\uC774 \uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Cold_002
    ko: "\uB370\uC774\uD130\uC5D0 \uC9C0\uB098\uCE58\uAC8C \uB9E4\uBAB0\uB418\uC5B4
      \uC815\uC791 \uC911\uC694\uD55C \uC2E4\uC804 \uAC10\uAC01\uC744 \uC783\uACE0
      \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Planner_201
    ko: "\uC5ED\uC2DC, \uC7AC\uAC80\uD1A0\uAC00 \uD544\uC694\uD558\uACA0\uAD70\uC694.
      \uC2E4\uC804 \uAC10\uAC01\uC5D0 \uD544\uC694\uD55C \uB370\uC774\uD130\uB294..."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Planner_2
    ko: "\uC81C\uC790\uB9AC \uAC78\uC74C\uC778 \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Opportunist_201
    ko: "\uB370\uC774\uD130\uAC00 \uC800\uC5D0\uAC8C \uBD88\uB9AC\uD558\uAC8C \uC791\uC6A9\uD55C\uB2E4\uB294
      \uB9D0\uC500\uC778\uAC00\uC694? \uADF8\uB7F4\uB9AC\uAC00!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Opportunist_2
    ko: "\uC790\uC2E0\uC758 \uBD84\uC11D\uC774 \uBB34\uC2DC\uB2F9\uD558\uC790 \uC18C\uADF9\uC801\uC73C\uB85C
      \uBCC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Cunning_201
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC774\uB77C\uBA74 \uBB50\uAC00 \uBD80\uC871\uD55C\uC9C0
      \uBC14\uB85C \uB9D0\uD574\uC904 \uC904 \uC54C\uC558\uB2E4\uB2C8\uAE50~."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Cunning_2
    ko: "\uBD80\uC871\uD55C \uBD80\uBD84\uC744 \uBCF4\uC644\uD558\uC5EC \uD3FC\uC744
      \uD5A5\uC0C1\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Believer_201
    ko: "\uB370\uC774\uD130\uB294 \uAC70\uC9D3\uB9D0\uC744 \uD558\uC9C0 \uC54A\uB294\uB370,
      \uC65C \uBD80\uC815\uD558\uC2DC\uB098\uC694? \uB370\uC774\uD130\uB294 \uD329\uD2B8\uACE0,
      \uBCC0\uD558\uC9C0 \uC54A\uB294 \uC9C4\uB9AC\uB77C\uAD6C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Believer_2
    ko: "\uC790\uC2E0\uC758 \uC2E0\uB150\uC744 \uBD80\uC815\uB2F9\uD588\uB2E4\uACE0
      \uD310\uB2E8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Cold_003
    ko: "\uC790\uB8CC\uB97C \uBC1B\uC544 \uBB34\uC5B8\uAC00\uB97C \uD718\uAC08\uACA8
      \uC4F4 \uB4A4 \uC120\uC218\uC5D0\uAC8C \uD22D \uB358\uC9C4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Planner_301
    ko: "\uC774\uAC74... \uB9D9\uC18C\uC0AC... \uC5ED\uC2DC \uADF8\uB7AC\uC5B4. \uD558\uC9C0\uB9CC
      \uC774\uAC74...? \uB9D9\uC18C\uC0AC...!  \uB09C \uB300\uCCB4 \uC9C0\uAE08\uAE4C\uC9C0
      \uBB58 \uD588\uC9C0?"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Planner_3
    ko: "\uC138\uC0C1\uC774 \uBB34\uB108\uC9C4 \uAE30\uBD84\uC774 \uB4E4\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Opportunist_301
    ko: "\uADF8\uB807\uAD70. \uC644\uC804 \uD575\uC2EC\uC744 \uCC14\uB800\uC5B4!
      \uB09C \uC624\uB298\uBD80\uB85C \uB354 \uC131\uC7A5\uD55C\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Opportunist_3
    ko: "\uD53C\uB4DC\uBC31\uC744 \uBD84\uC11D\uD55C \uAC83\uC774 \uD070 \uB3C4\uC6C0\uC774
      \uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Cunning_301
    ko: "\uC774\uAC78 \uC774\uB807\uAC8C \uC218\uC815\uD558\uB77C\uACE0? \uC758\uB3C4\uAC00
      \uBB50\uC9C0? \uB09C \uBB34\uC5C7\uC744 \uD560 \uC218 \uC788\uC9C0?"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Cunning_3
    ko: "\uAC10\uB3C5\uC758 \uC758\uC911\uC744 \uD30C\uC545\uD558\uB290\uB77C \uD6C8\uB828\uC774
      \uC815\uCCB4\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Believer_301
    ko: "\uBB54 \uC18C\uB9B0\uC9C0 \uBAA8\uB974\uACA0\uC5B4... \uB0B4 \uC2E0\uB150\uB300\uB85C
      \uBB35\uBB35\uD788 \uBD84\uC11D \uACB0\uACFC\uB97C \uC2E4\uD589\uD560 \uC218
      \uBC16\uC5D0 \uC5C6\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Believer_3
    ko: "\uAC10\uB3C5\uC758 \uBC18\uC751\uACFC \uBB34\uAD00\uD558\uAC8C \uC790\uC2E0\uC758
      \uC2E0\uB150\uC744 \uBC00\uC5B4\uBD99\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Instinct_001
    ko: "\uD55C \uC120\uC218\uAC00 \uC790\uC2E0\uC758 3\uC810 \uC29B \uB370\uC774\uD130\uB97C
      \uBD84\uC11D\uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Instinct_002
    ko: "\uC790\uC2E0\uC758 3\uC810\uC29B \uC2E4\uD328 \uC6D0\uC778\uC774 '\uD314\uAFC8\uCE58
      \uAC01\uB3C4'\uC640 '\uB9B4\uB9AC\uC2A4 \uD0C0\uC774\uBC0D'\uC758 \uBBF8\uC138\uD55C
      \uBD88\uC77C\uCE58\uC784\uC744 \uD655\uC2E0\uD558\uACE0 \uBD84\uC11D \uC790\uB8CC\uB97C
      \uAC10\uB3C5\uC5D0\uAC8C \uC81C\uC2DC\uD558\uBA70 \uC870\uC5B8\uC744 \uAD6C\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Instinct_003
    ko: "\uAC10\uB3C5\uB2D8, \uBD84\uC11D \uC790\uB8CC\uB294 \uC644\uBCBD\uD569\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC81C \uBAB8\uC774 \uB290\uB07C\uB294 \uBCF8\uB2A5\uACFC\uB294
      \uAC70\uB9AC\uAC00 \uBA40\uC5B4\uBCF4\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Instinct_004
    ko: "\uC800\uB294 \uBB34\uC5C7\uC744 \uB530\uB77C\uC57C \uD558\uB294 \uAC78\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Instinct_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Instinct_001
    ko: "\uB370\uC774\uD130\uB85C \uCC3E\uC740 \uADF8 \uC6D0\uB9AC\uB97C \uB124 \uBCF8\uB2A5\uC5D0
      \uB179\uC5EC\uBD10\uB77C. \uADF8 \uB204\uAD6C\uB3C4 \uB9C9\uC744 \uC218 \uC5C6\uB294
      \uC29B\uC774 \uB420 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Bluffer_101
    ko: "\uC88B\uC2B5\uB2C8\uB2E4. \uC81C\uAC00 \uCF54\uD2B8\uC758 \uC9C0\uBC30\uC790\uAC00
      \uB418\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Bluffer_1
    ko: "\uC790\uC2E0\uAC10\uC774 \uADF9\uB300\uD654\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Wild_101
    ko: "\uB370\uC774\uD130\uB97C \uBCF8\uB2A5\uB300\uB85C? \uAE30\uACC4 \uC57C\uC218\uAC00
      \uC874\uC7AC\uD560 \uB9AC \uC5C6\uC796\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Wild_1
    ko: "\uB370\uC774\uD130\uB97C \uC57C\uC131\uC801 \uBCF8\uB2A5\uC73C\uB85C \uAD6C\uD604\uD558\uB824\uB2E4
      \uD3FC\uC774 \uC644\uC804\uD788 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Egoist_101
    ko: "\uC0C8\uB85C\uC6B4 \uAC10\uAC01\uC5D0 \uC801\uC751\uD558\uB824\uBA74 \uC2DC\uAC04\uC774
      \uD544\uC694\uD560 \uAC83 \uAC19\uC544\uC694. \uC870\uAE08\uB9CC \uAE30\uB2E4\uB824
      \uC8FC\uC2DC\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Egoist_1
    ko: "\uC544\uC9C1\uC740 \uBCC0\uD654\uAC00 \uC5C6\uC5B4\uBCF4\uC778\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Fighter_101
    ko: "\uC88B\uC544\uC694! \uC774\uC81C \uC644\uBCBD\uD55C \uACBD\uC7C1\uC744 \uD560
      \uC218 \uC788\uACA0\uB124\uC694!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Fighter_1
    ko: "\uACBD\uC7C1\uC2EC\uC774 \uBD88\uD0C0\uC624\uB974\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Instinct_002
    ko: "\uB370\uC774\uD130\uC640 \uBCF8\uB2A5 \uC0AC\uC774\uC5D0\uC11C \uAC08\uD321\uC9C8\uD321\uD558\uC9C0
      \uB9C8\uB77C. \uB4DD\uC810\uC740 \uB3D9\uBB3C\uC801\uC778 \uAC10\uAC01\uC73C\uB85C
      \uACB0\uC815\uB418\uB294 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Bluffer_201
    ko: "\uADF8\uB7FC\uC694! \uC81C \uAC10\uAC01\uC774\uBA74 \uBB50\uB4E0 \uD560
      \uC218 \uC788\uC744\uAC78\uC694? ...\uC544\uB9C8\uB3C4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Bluffer_2
    ko: "\uC544\uC9C1\uC740 \uAC08\uD321\uC9C8\uD321\uD558\uB294 \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Wild_201
    ko: "\uAE38\uB4E4\uC5EC\uC9C0\uC9C0 \uC54A\uC740 \uB0A0\uAC83\uC758 \uC29B. \uADF8\uAC83\uC774
      \uC81C\uAC00 \uCD94\uAD6C\uD558\uB294 \uBC29\uD5A5\uC774\uAE30\uB3C4 \uD558\uB2C8\uAE4C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Wild_2
    ko: "\uD6C8\uB828\uC758 \uBC29\uD5A5\uC131\uC744 \uC81C\uB300\uB85C \uC7A1\uC740
      \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Egoist_201
    ko: "\uB0B4 \uBC29\uC2DD\uC774 \uBD80\uC815\uB2F9\uD588\uB2E4\uB294 \uAC74\uAC00?
      \uAC10\uB3C5\uB2D8 \uC548\uBAA9\uC774 \uC758\uC2EC\uB418\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Egoist_2
    ko: "\uBC18\uD56D\uC2EC\uC774 \uB298\uACE0 \uB9D0\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Fighter_201
    ko: "\uB0B4 \uB370\uC774\uD130\uB97C \uBD80\uC815\uD558\uB2E4\uB2C8... \uB450\uACE0
      \uBCF4\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Fighter_2
    ko: "\uD22C\uC7C1\uC2EC\uC774 \uC5C9\uB6B1\uD55C \uBC29\uD5A5\uC73C\uB85C \uD750\uB974\uACE0
      \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Instinct_003
    ko: "\uC120\uC218\uAC00 \uB0B4\uBBFC \uBD84\uC11D \uC790\uB8CC\uB97C \uAD6C\uACA8
      \uB358\uC838\uBC84\uB9AC\uACE0\uB294 \uB4F1\uC744 \uB3CC\uB9B0 \uCC44 \uCF54\uD2B8\uB97C
      \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Bluffer_301
    ko: "\uBB34\uC2DC\uB2F9\uD558\uB2E4\uB2C8... \uB0B4 \uC874\uC7AC\uAC10\uC740
      \uC774 \uC815\uB3C4\uBFD0\uC778\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Bluffer_3
    ko: "\uC790\uC2E0\uC758 \uAC00\uCE58\uAC00 \uBB34\uC2DC\uB2F9\uD588\uB2E4\uACE0
      \uB290\uAEF4 \uC790\uC874\uAC10\uC774 \uB5A8\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Wild_301
    ko: "\uC774\uAC83\uB3C4 \uC815\uB2F5\uC774 \uC544\uB2CC\uAC00. \uB09C \uB300\uCCB4
      \uBB58 \uD574\uC57C \uD558\uB294\uAC70\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Wild_3
    ko: "\uB2F5\uC744 \uCC3E\uAE30 \uC704\uD55C \uC5EC\uC815\uC740 \uACC4\uC18D\uB41C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Egoist_301
    ko: "\uCE6B... \uB2E4 \uD544\uC694 \uC5C6\uC5B4. \uB098\uB294 \uC624\uC9C1 \uB098\uB9CC\uC758
      \uAE38\uC744 \uAC00\uB3C4\uB85D \uD558\uACA0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Egoist_3
    ko: "\uC678\uBD80\uC758 \uAC04\uC12D \uC5C6\uB294 \uC644\uBCBD\uD55C \uB3C5\uC790\uC801\uC778
      \uD6C8\uB828 \uD658\uACBD\uC774 \uC644\uC131\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Fighter_301
    ko: "\uB0A0 \uBC29\uCE58\uD574? \uD765\uBBF8\uB86D\uAD70. \uC774 \uB09C\uAD00\uC744
      \uC29B\uC73C\uB85C \uB6AB\uC5B4\uBCF4\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Fighter_3
    ko: "\uAC10\uB3C5\uC758 \uBC29\uCE58\uB97C \uB610 \uB2E4\uB978 \uACBD\uC7C1\uC73C\uB85C
      \uC778\uC2DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Discipline_001
    ko: "\uC88B\uC544! \uC774 \uC815\uB3C4\uBA74 \uC81C\uB300\uB85C \uB530\uB77C\uD55C
      \uAC83 \uAC19\uC740\uB370?"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Discipline_002
    ko: "\uC815\uD574\uC9C4 \uADDC\uC728\uB300\uB85C \uC815\uC11D\uC801\uC778 \uC29B
      \uD3FC\uC744 \uBC18\uBCF5\uD558\uB358 \uC120\uC218\uAC00, \uC5B4\uC81C \uBCF8
      \uD504\uB85C \uC120\uC218\uC758 \uD654\uB824\uD55C '\uD035 \uB9B4\uB9AC\uC2A4'
      \uC29B\uC744 \uD749\uB0B4 \uB0B4\uAE30 \uC2DC\uC791\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Discipline_003
    ko: "\uB9BC\uC744 \uD5A5\uD574 \uC3D8\uB294 \uC29B\uC758 \uADA4\uC801\uC740 \uBCC0\uCE59\uC801\uC774\uACE0
      \uBD88\uC548\uC815\uD558\uBA70, \uD300\uC774 \uC815\uD55C \uAE30\uBCF8 \uB8E8\uD2F4\uC5D0\uC11C
      \uC644\uC804\uD788 \uBC97\uC5B4\uB098 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Discipline_004
    ko: "\uC120\uC218\uB294 \uC790\uC2E0\uC758 \uC0C8\uB85C\uC6B4 \uC2DC\uB3C4\uAC00
      \uD601\uC2E0\uC801\uC778 \uBC1C\uC804\uC774\uB77C\uACE0 \uBBFF\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Discipline_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Discipline_001
    ko: "\uC0C8\uB85C\uC6B4 \uAE30\uC220\uC744 \uD0D0\uAD6C\uD558\uB294 \uAC74 \uC88B\uB2E4.
      \uD558\uC9C0\uB9CC \uAE30\uBCF8\uC774 \uC5C6\uB294 \uC751\uC6A9\uC740 \uC0AC\uC0C1\uB204\uAC01\uC774\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Principled_101
    ko: "\uAC10\uB3C5\uB2D8, \uC81C\uAC00 \uC0DD\uAC01\uC774 \uC9E7\uC558\uC2B5\uB2C8\uB2E4.
      \uD601\uC2E0\uB3C4 \uAE30\uBCF8\uAE30\uAC00 \uC644\uBCBD\uD574\uC57C \uC758\uBBF8\uAC00
      \uC788\uB294\uB370, \uC81C\uAC00 \uC21C\uC11C\uB97C \uB193\uCCE4\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Principled_1
    ko: "\uAC10\uB3C5\uC758 \uC870\uC5B8\uC744 \uB17C\uB9AC\uC801\uC73C\uB85C \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Guardian_101
    ko: "\uB124, \uBA85\uC2EC\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uD300\uC744 \uC704\uD574
      \uC815\uC11D\uB300\uB85C \uC3D8\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Guardian_1
    ko: "\uD300\uC744 \uC704\uD574 \uAC1C\uC778\uC758 \uBC1C\uC804 \uAC00\uB2A5\uC131\uC744
      \uBA48\uCD94\uACE0 \uB9D0\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Tactician_101
    ko: "\uAC10\uB3C5\uB2D8, \uADF8\uBCF4\uB2E4 \uC81C \uC288\uD305 \uADA4\uC801
      \uBD80\uD130 \uBD10\uC8FC\uC138\uC694. \uC81C \uBCC0\uCE59 \uD3FC\uC774 \uC815\uC11D\uBCF4\uB2E4
      \uD6A8\uC728\uC801\uC778 \uAD6C\uAC04\uC774 \uBD84\uBA85\uD788 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Tactician_1
    ko: "\uC120\uC218\uAC00 \uC0C8\uB85C\uC6B4 \uAE30\uC220 \uC2B5\uB4DD\uC5D0 \uAE09\uAE09\uD574
      \uBC18\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Exemplary_101
    ko: "\uAC10\uB3C5\uB2D8 \uB9D0\uC500\uC774 \uB2E4 \uB9DE\uC8E0. \uD558\uC9C0\uB9CC
      \uBAA8\uBC94\uC0DD\uC73C\uB85C\uC11C \uC774 \uC815\uB3C4 \uAE30\uC220\uC740
      \uCDA9\uBD84\uD788 \uC18C\uD654\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Exemplary_1
    ko: "\uC2A4\uC2A4\uB85C \uC644\uBCBD\uD558\uB2E4\uACE0 \uCC29\uAC01\uD558\uC5EC
      \uC815\uCCB4\uAE30\uC5D0 \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Discipline_002
    ko: "\uB204\uAC00 \uB124 \uB9D8\uB300\uB85C \uAE30\uC220\uC744 \uBC14\uAFB8\uB77C\uACE0
      \uD588\uC9C0? \uC6B0\uB9AC \uD300\uC740 \uC57D\uC18D\uB41C \uB8E8\uD2F4\uC73C\uB85C
      \uC2B9\uB9AC\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Principled_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uD765\uBD84\uD574\uC11C \uD300 \uADDC\uCE59\uC744
      \uC78A\uC5C8\uC2B5\uB2C8\uB2E4. \uC9C0\uAE08 \uB2F9\uC7A5 \uC815\uC11D \uB8E8\uD2F4\uBD80\uD130
      \uB2E4\uC2DC \uC2DC\uC791\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Principled_2
    ko: "\uC2A4\uC2A4\uB85C \uD310\uB2E8\uD558\uAE30\uBCF4\uB2E4 \uC9C0\uC2DC\uB97C
      \uAE30\uACC4\uC801\uC73C\uB85C \uC218\uD589\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Guardian_201
    ko: "\uC81C \uC695\uC2EC \uB54C\uBB38\uC5D0 \uD300 \uC9C8\uC11C\uB97C \uD750\uB838\uC2B5\uB2C8\uB2E4.
      \uD300\uC6D0\uB4E4\uC5D0\uAC8C \uBBF8\uC548\uD574\uC11C\uB77C\uB3C4, \uC774\uC81C\uBD80\uD130
      \uC9C4\uC9DC FM\uB300\uB85C \uC815\uC11D \uD3FC\uB9CC \uACE0\uC9D1\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Guardian_2
    ko: "\uAC15\uD55C \uCC45\uC784\uAC10\uC744 \uB290\uAEF4 \uC815\uAD50\uD55C \uC29B
      \uD3FC\uC744 \uAE4E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Tactician_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uBCC0\uCE59 \uB8E8\uD2F4\uC740 \uD3D0\uAE30\uD558\uC8E0.
      \uB9D0\uC500\uD558\uC2E0 \uB300\uB85C \uC815\uC11D \uD3FC\uC744 \uC720\uC9C0\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Tactician_2
    ko: "\uAC10\uB3C5\uC758 \uBA85\uB839\uC744 \uAE30\uACC4\uC801\uC73C\uB85C \uC774\uD589\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Exemplary_201
    ko: "\uC81C\uAC00 \uD300\uC758 \uBCF8\uBCF4\uAE30\uC778\uB370... \uACBD\uC194\uD588\uC2B5\uB2C8\uB2E4.
      \uB2E4\uB978 \uC120\uC218\uB4E4\uC774 \uBCF4\uACE0 \uBC30\uC6B8 \uC218 \uC788\uAC8C,
      \uC774\uC81C\uBD80\uD130 \uAC00\uC7A5 \uC815\uC11D\uC801\uC778 \uC29B \uD3FC\uB9CC
      \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Exemplary_2
    ko: "\uC2A4\uC2A4\uB85C\uB97C \uB354\uC6B1 \uC5C4\uACA9\uD558\uAC8C \uD1B5\uC81C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Discipline_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uAC00 \uBA87 \uBC88\uC758
      \uC2E4\uC218\uB97C \uD558\uB294\uC9C0 \uB370\uC774\uD130\uB85C \uAE30\uB85D\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC544\uBB34 \uB9D0\uC500\uB3C4 \uC5C6\uC73C\uC2E0
      \uAC74... \uB0B4 \uD3FC\uC774 \uADDC\uC900\uC5D0\uC11C \uBC97\uC5B4\uB0AC\uB2E4\uB294
      \uB73B\uC778\uAC00? \uAE30\uC900\uC744 \uBABB \uC9C0\uD0A4\uB294 \uB0B4 \uC29B\uC740
      \uC758\uBBF8\uAC00 \uC5C6\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Principled_3
    ko: "\uCE68\uBB35\uC744 \uBE44\uB09C\uC73C\uB85C \uC778\uC2DD\uD574 \uC2EC\uB9AC\uC801\uC73C\uB85C
      \uBD88\uC548\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uB098\uB97C \uC548 \uBCF4\uC2DC\uB124... \uB0B4\uAC00
      \uD300\uC758 \uC6D0\uCE59\uC744 \uC5B4\uAE34 \uAC74\uAC00? \uBD88\uC548\uD574\uC11C
      \uC29B\uC774 \uC790\uAFB8 \uB9BC\uC744 \uBE57\uB098\uAC00..."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Guardian_3
    ko: "\uC790\uC2E0\uAC10\uC774 \uC810\uC810 \uB5A8\uC5B4\uC9C0\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Tactician_301
    ko: "\uB0B4 \uC29B \uD0C4\uB3C4\uAC00 \uC815\uC11D\uBCF4\uB2E4 5\uB3C4 \uB0AE\uAD70.
      \uC774\uB300\uB85C\uBA74 \uB4DD\uC810 \uD655\uB960\uC774 \uB5A8\uC5B4\uC838.
      \uADA4\uC801\uC744 5\uB3C4 \uC62C\uB9AC\uC790."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Tactician_3
    ko: "\uC29B\uC744 \uBC18\uBCF5\uD558\uBA70 \uAE30\uC220\uC744 \uC790\uC2E0\uC758
      \uAC83\uC73C\uB85C \uB9CC\uB4E4\uC5C8\uB530."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Exemplary_301
    ko: "\uAC10\uB3C5\uB2D8\uC740 \uBB50\uD558\uACE0 \uACC4\uC2DC\uC9C0? \uC77C\uB2E8
      \uC815\uC11D \uD3FC\uC73C\uB85C \uC3D8\uB294 \uBAA8\uC2B5\uB9CC \uC720\uC9C0\uD574\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Exemplary_3
    ko: "\uAC10\uB3C5\uC758 \uB208\uC5D0 \uB4E4\uAE30\uC704\uD574 \uAE30\uC220 \uC2B5\uB4DD\uC744
      \uD3EC\uAE30\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bond_001
    ko: "\uD300\uC758 \uC5D0\uC774\uC2A4\uAE09 \uC120\uC218\uAC00 \uC5B4\uC81C \uBCF8
      \uD504\uB85C \uC120\uC218\uC758 '\uD035 \uB9B4\uB9AC\uC2A4'\uB97C \uD749\uB0B4
      \uB0B4\uAE30 \uC2DC\uC791\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bond_002
    ko: "\uD300\uC758 \uC815\uC11D \uB8E8\uD2F4\uC740 \uBB34\uC2DC\uB41C \uCC44,
      \uC120\uC218\uC758 \uBCC0\uCE59\uC801\uC778 \uC29B\uC740 \uACC4\uC18D\uD574\uC11C
      \uB9BC\uC5D0\uC11C \uD295\uACA8\uC838 \uB098\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bond_003
    ko: "\uD558\uC9C0\uB9CC \uC120\uC218\uB294 \uC774 \uAE30\uC220\uC774 \uD300\uC744
      \uC6B0\uC2B9\uC73C\uB85C \uC774\uB04C '\uD601\uC2E0'\uC774\uB77C \uAD73\uAC8C
      \uBBFF\uC73C\uBA70, \uB208\uC744 \uBC18\uC9DD\uC774\uBA70 \uAC10\uB3C5\uC744
      \uCCD0\uB2E4\uBCF4\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bond_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Bond_001
    ko: "\uB9C8\uC74C\uC740 \uAE30\uD2B9\uD558\uC9C0\uB9CC, \uADF8 \uAE30\uC220\uC744
      \uC18C\uD654\uD558\uAE30\uC5D4 \uAE30\uBCF8\uAE30\uAC00 \uBD80\uC871\uD574
      \uBCF4\uC774\uB294 \uAD6C\uB098."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uB9C8\uC74C\uC744 \uC54C\uC544\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD574\uC694. \uAC10\uB3C5\uB2D8\uACFC \uC57D\uC18D\uD55C \uAC83
      \uBD80\uD130 \uB2E4\uC2DC \uC2DC\uC791\uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Kind_1
    ko: "\uC0C8\uB85C\uC6B4 \uAE30\uC220\uC744 \uC775\uD788\uAE30 \uC704\uD55C \uC2A4\uD15D\uC744
      \uCC28\uADFC\uCC28\uADFC \uBC1F\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Loyal_101
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8\uC758 \uBA85\uB839\uB300\uB85C
      \uAE30\uBCF8\uAE30\uB97C \uD5A5\uC0C1\uC2DC\uD0A4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Loyal_1
    ko: "\uBA85\uB839\uC5D0 \uC21C\uC751\uD588\uC9C0\uB9CC \uAE30\uB7C9 \uBC1C\uC804\uC740
      \uBBF8\uBBF8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Sincere_101
    ko: "\uADF8\uB807\uAD70\uC694... \uC800\uB294 \uC774 \uAE30\uC220\uC744 \uB9C8\uC2A4\uD130
      \uD560 \uADF8\uB987\uC774 \uC544\uB2CC \uAC78\uAE4C\uC694."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Sincere_1
    ko: "\uC790\uC2E0\uC758 \uC2E4\uB825\uC5D0 \uD68C\uC758\uAC10\uC774 \uB4E4\uC5C8\uB530."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Moodmaker_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uBD10\uB3C4 \uADF8\uB807\uC8E0? \uD558\uD558!
      \uADF8\uB798\uB3C4 \uC870\uAE08\uB9CC \uB354 \uC2DC\uB3C4\uD574\uBCFC\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Moodmaker_1
    ko: "\uC2E4\uB825 \uD5A5\uC0C1\uC740 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Bond_002
    ko: "\uC774\uAC74 \uD300\uC744 \uC704\uD55C \uAC8C \uC544\uB2C8\uB77C \uB124
      \uAC1C\uC778\uC801\uC778 \uC695\uC2EC\uC774\uC57C."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Kind_201
    ko: "\uD300\uC744 \uC704\uD55C \uB9C8\uC74C\uC774\uC5C8\uB294\uB370... \uAC10\uB3C5\uB2D8\uAED8
      \uC695\uC2EC\uC7C1\uC774\uB77C\uB294 \uC18C\uB9AC\uB97C \uB4E3\uB2E4\uB2C8
      \uB108\uBB34 \uC2AC\uD37C\uC694..."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Kind_2
    ko: "\uC758\uC695\uC744 \uC0C1\uC2E4\uD574\uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Loyal_201
    ko: "\uC81C \uAC1C\uC778\uC801\uC778 \uC695\uC2EC\uC774\uB77C\uB3C4 \uD300\uC5D0\uAC8C
      \uD5CC\uC2E0\uD558\uAE30 \uC704\uD574\uC120 \uAF2D \uC2B5\uB4DD\uD574\uC57C\uD558\uB294
      \uAE30\uC220\uC785\uB2C8\uB2E4! \uC800\uB294 \uD3EC\uAE30\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Loyal_2
    ko: "\uAC1C\uC778 \uAE30\uB7C9\uC744 \uAF43\uD53C\uC6B0\uB824\uB294 \uC870\uC9D0\uC774
      \uBCF4\uC778\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Sincere_201
    ko: "\uADF8\uB807\uB2E4\uBA74 \uC9C0\uAE08\uBD80\uD130 \uB871 \uB808\uC778\uC9C0
      \uC288\uD305 100\uD68C! \uC2DC\uC791!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Sincere_2
    ko: "\uAC10\uB3C5\uC758 \uBA85\uB839\uC744 \uD544\uC694 \uC774\uC0C1\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC774\uB294 \uAC83 \uAC19\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Moodmaker_201
    ko: "\uC5ED\uC2DC, \uD300\uC744 \uC704\uD55C\uAC8C \uC544\uB2C8\uB77C \uC81C
      \uC774\uAE30\uC801\uC778 \uC695\uC2EC\uC774\uC5C8\uB358 \uAC78\uAE4C\uC694.
      \uBB54\uAC00 \uC6B0\uC6B8\uD574\uC84C\uC5B4\uC694..."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Moodmaker_2
    ko: "\uBD84\uC704\uAE30\uAC00 \uAD49\uC7A5\uD788 \uCE68\uCCB4\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Bond_003
    ko: "\uC9E7\uC740 \uD55C\uC228\uACFC \uD568\uAED8 \uACE0\uAC1C\uB97C \uC800\uC73C\uBA70
      \uB4F1\uC744 \uB3CC\uB824 \uB2E4\uB978 \uC120\uC218\uC5D0\uAC8C \uAC00\uBC84\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8? \uC8C4\uC1A1\uD574\uC694. \uC800 \uBBF8\uC6B0\uC2E0
      \uAC74\uAC00\uC694? \uB3CC\uC544\uC640\uC8FC\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Kind_3
    ko: "\uAC10\uB3C5\uB2D8...? \uAC10\uB3C5\uB2D8...!"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Loyal_301
    ko: "\uC544... \uC774\uC820 \uB05D\uC774\uAD6C\uB098. \uB098\uC640 \uAC10\uB3C5\uB2D8\uC758
      \uC2E0\uB8B0\uB294 \uBC15\uC0B4\uB098\uBC84\uB838\uC5B4..."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Loyal_3
    ko: "\uACF5\uD669 \uC0C1\uD0DC\uC5D0 \uBE60\uC838\uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Sincere_301
    ko: "\uC774\uAC8C \uC544\uB2CC\uAC00? \uBB38\uC81C\uC810\uC744 \uC2A4\uC2A4\uB85C
      \uCC3E\uC544\uBD10\uC57C\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Sincere_3
    ko: "\uAE30\uC220\uC744 \uC2B5\uB4DD\uD558\uAE30 \uC704\uD55C \uC2DC\uC2A4\uD15C\uC744
      \uC7AC\uC810\uAC80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Moodmaker_301
    ko: "\uB354 \uD654\uB824\uD558\uAC8C \uC131\uACF5\uD574\uC11C \uAC10\uB3C5\uB2D8
      \uC2DC\uC120\uC744 \uBE8F\uC5B4\uC57C\uC9C0!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Moodmaker_3
    ko: "\uAC10\uB3C5\uC758 \uC2DC\uC120\uC744 \uB04C\uAE30 \uC704\uD574 \uC29B\uC744
      \uAC08\uACE0\uB2E6\uC544 \uC2E4\uB825\uC774 \uB298\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cold_001
    ko: "\uD300\uC758 \uC5D0\uC774\uC2A4\uAE09 \uC120\uC218\uAC00 \uD504\uB85C\uC758
      '\uD035 \uB9B4\uB9AC\uC2A4'\uB97C \uD749\uB0B4 \uB0B4\uAE30 \uC2DC\uC791\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cold_002
    ko: "\uC120\uC218\uB294 \uC774 \uBCC0\uCE59\uC801\uC778 \uC29B \uD3FC\uC774 \uC790\uC2E0\uC758
      \uC7A0\uC7AC\uB825\uC744 \uADF9\uB300\uD654\uD560 '\uCD5C\uC801\uC758 \uBC1C\uD310'\uC774\uB77C\uACE0
      \uBBFF\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cold_003
    ko: "\uADF8\uB7EC\uB098 \uAC10\uB3C5\uC774 \uBD84\uC11D\uD55C \uB370\uC774\uD130\uC5D0
      \uB530\uB974\uBA74, \uD604\uC7AC \uC120\uC218\uC758 \uBCC0\uCE59 \uC29B\uC740
      \uC131\uACF5\uB960\uC774 \uB9E4\uC6B0 \uB0AE\uC73C\uBA70 \uD300\uC758 \uACF5\uACA9
      \uC804\uC220\uACFC \uC815\uBA74\uC73C\uB85C \uBC30\uCE58\uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cold_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Cold_001
    ko: "\uB124 \uAE30\uC220\uC801 \uD638\uAE30\uC2EC\uC740 \uD6CC\uB96D\uD558\uC9C0\uB9CC,
      \uD300\uC758 \uC804\uC220\uACFC\uB294 \uB9DE\uC9C0 \uC54A\uC544 \uBCF4\uC774\uB294\uAD6C\uB098."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Planner_101
    ko: "\uC81C \uD638\uAE30\uC2EC\uC744 \uAE0D\uC815\uD574\uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4.
      \uD300\uC758 \uC804\uC220\uACFC \uC5F0\uACC4\uD558\uC5EC \uC218\uCE58\uAC12\uC744
      \uBCF4\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Planner_1
    ko: "\uACA9\uB824\uB97C \uBC1B\uC544 \uC989\uAC01\uC801\uC73C\uB85C \uC804\uB7B5\uC744
      \uCD5C\uC801\uD654\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Opportunist_101
    ko: "\uADF8\uAC83 \uCC38 \uC544\uAE5D\uB124\uC694. \uC88B\uC740 \uAE30\uC220\uC774\uB77C\uACE0
      \uC0DD\uAC01\uD588\uB294\uB370."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Opportunist_1
    ko: "\uC0C8\uB85C\uC6B4 \uAE30\uC220 \uC2B5\uB4DD\uC744 \uD3EC\uAE30\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cunning_101
    ko: "\uD558\uC9C0\uB9CC \uC800 \uD558\uB098\uCBE4\uC774\uC57C \uC870\uCEE4 \uCE74\uB4DC\uAC00
      \uB418\uC5B4\uB3C4 \uAD1C\uCC2E\uC9C0 \uC54A\uC744\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Cunning_1
    ko: "\uD300\uC758 \uC2B9\uB9AC \uD50C\uB79C\uC774 \uC5B4\uADF8\uB7EC\uC9C0\uACE0
      \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Believer_101
    ko: "\uD558\uC9C0\uB9CC \uC774 \uAE30\uC220\uC740 \uBBF8\uB798\uB97C \uC704\uD55C
      \uBCF4\uD5D8\uC785\uB2C8\uB2E4. \uC808\uB300\uB85C \uBA48\uCD94\uC9C0 \uC54A\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Believer_1
    ko: "\uC2E0\uB150\uC744 \uAEBE\uC9C0 \uBABB\uD574 \uB3C5\uB2E8\uC801\uC73C\uB85C
      \uD589\uB3D9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Cold_002
    ko: "\uBCC0\uCE59 \uC29B\uC740 \uD300 \uBC38\uB7F0\uC2A4\uB97C \uAE68\uB294 \uD589\uB3D9\uC774\uB2C8
      \uB2F9\uC7A5 \uAE30\uBCF8 \uD3FC\uC73C\uB85C \uAD50\uC815\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Planner_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uD300\uC758 \uBC38\uB7F0\uC2A4\uAC00 \uC6B0\uC120\uC774\uBBC0\uB85C
      \uC9C0\uC2DC\uB300\uB85C \uB530\uB974\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Planner_2
    ko: "\uD6A8\uC728\uC131\uB9CC \uBCF4\uACE0 \uC9C0\uC2DC\uB97C \uAE30\uACC4\uC801\uC73C\uB85C
      \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Opportunist_201
    ko: "\uAC1C\uC778 \uC695\uC2EC\uC774\uB77C\uB2C8\uC694, \uC81C \uC7A0\uC7AC\uB825\uC744
      \uBCF4\uC5EC\uC904 \uAE30\uD68C\uB97C \uC65C \uB9C9\uC73C\uC2DC\uB294 \uAC70\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Opportunist_2
    ko: "\uAC00\uCE58 \uBC1C\uD604 \uAE30\uD68C\uB97C \uC783\uC5C8\uB2E4\uACE0 \uB290\uAEF4
      \uC758\uC695\uC744 \uC783\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cunning_201
    ko: "\uD6A8\uC728\uC131\uC744 \uC704\uD574 \uC81C \uC695\uC2EC\uC744 \uBC84\uB9AC\uACE0
      \uC815\uC11D \uD3FC\uC744 \uC644\uBCBD\uD788 \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Cunning_2
    ko: "\uC9C8\uCC45\uC744 \uACBD\uACE0\uB85C \uC5EC\uACA8 \uB2A5\uB825\uC744 \uC99D\uBA85\uD558\uB824
      \uC5F0\uCD9C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Believer_201
    ko: "\uAC10\uB3C5\uB2D8 \uD310\uB2E8\uC744 \uC874\uC911\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uC815\uC11D\uB300\uB85C \uD6C8\uB828\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Believer_2
    ko: "\uC2E0\uB150\uC744 \uAD7D\uD788\uAE30 \uC2EB\uC73C\uB098 \uB300\uC2B9\uC801
      \uCC28\uC6D0\uC5D0\uC11C \uB530\uB790\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Cold_003
    ko: "\uAC10\uB3C5\uC740 \uBB34\uD45C\uC815\uD558\uAC8C \uC29B \uC2E4\uD328\uB9CC
      \uD655\uC778\uD558\uBA70 \uC218\uCCA9\uC5D0 '\uAE30\uBCF8 \uB8E8\uD2F4 \uC704\uBC18'\uC774\uB77C
      \uC801\uB294\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Planner_301
    ko: "\uAE30\uBCF8 \uB8E8\uD2F4 \uC704\uBC18\uC774\uB77C \uC801\uC73C\uC168\uC5B4...
      \uB0B4 \uC124\uACC4\uAC00 \uADFC\uBCF8\uC801\uC73C\uB85C \uD2C0\uB838\uB2E4\uB294
      \uB73B\uC778\uAC00? \uC544\uBB34\uAC83\uB3C4 \uC190\uC5D0 \uC548 \uC7A1\uD600."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Planner_3
    ko: "\uCE68\uBB35\uC744 \uC804\uB7B5\uC801 \uC2E4\uD328\uB85C \uAC04\uC8FC\uD574
      \uD3FC\uC774 \uBD95\uAD34\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Opportunist_301
    ko: "\uC88B\uC544, \uC9C0\uAE08 \uAE30\uB85D\uC744 \uC548 \uC88B\uAC8C \uBC1B\uC544\uB450\uACE0
      \uB098\uC911\uC5D0 \uBAB0\uB798 \uC774 \uC29B\uC744 \uC644\uC131\uD574\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Opportunist_3
    ko: "\uAC04\uC12D\uC774 \uC5C6\uC790 \uC790\uC2E0\uB9CC\uC758 \uBB34\uAE30\uB97C
      \uC644\uC131\uD574 \uC131\uCDE8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cunning_301
    ko: "\uC77C\uB2E8 \uC9C0\uAE08\uC740 \uC815\uC11D\uB300\uB85C \uC3D8\uB294 \uCC99\uD574\uC57C\uC9C0.
      \uB098\uC911\uC5D0 \uD63C\uC790 \uC5F0\uC2B5\uD558\uBA74 \uB3FC."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Cunning_3
    ko: "\uAC10\uB3C5 \uB208\uCE58\uB97C \uBCF4\uB290\uB77C \uC9D1\uC911\uD558\uC9C0
      \uBABB\uD574 \uC815\uCCB4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Believer_301
    ko: "\uB9D0\uC500\uC774 \uC5C6\uB294 \uAC74 \uB0B4 \uC7A0\uC7AC\uB825\uC744 \uBCF4\uC2E0
      \uAC70\uC57C. \uB098\uB97C \uBBFF\uACE0 \uB05D\uAE4C\uC9C0 \uBC00\uACE0 \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Believer_3
    ko: "\uAC04\uC12D\uC774 \uC5C6\uC790 \uC790\uAE30 \uD655\uC2E0\uC774 \uCEE4\uC838
      \uAE30\uC220\uC744 \uC644\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Instinct_001
    ko: "\uD300\uC758 \uAE30\uBCF8 \uB8E8\uD2F4\uC744 \uC131\uC2E4\uD788 \uC218\uD589\uD558\uB358
      \uC5D0\uC774\uC2A4 \uC120\uC218\uAC00 \uD504\uB85C\uC758 '\uD035 \uB9B4\uB9AC\uC2A4'\uB97C
      \uD749\uB0B4 \uB0B4\uAE30 \uC2DC\uC791\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Instinct_002
    ko: "\uC120\uC218\uB294 \uC774 \uBCC0\uCE59\uC801\uC778 \uC29B \uD3FC\uC774 \uC790\uC2E0\uC758
      \uD0C0\uACE0\uB09C \uAC10\uAC01\uC744 \uADF9\uB300\uD654\uD560 '\uC2E0\uC758
      \uD55C \uC218'\uB77C\uACE0 \uAD73\uAC8C \uBBFF\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Instinct_003
    ko: "\uADF8\uB7EC\uB098 \uC120\uC218\uC758 \uC29B\uC740 \uB9BC\uC744 \uD06C\uAC8C
      \uBC97\uC5B4\uB098\uACE0 \uC788\uC73C\uBA70, \uD300\uC758 \uC804\uCCB4\uC801\uC778
      \uD6C8\uB828 \uD750\uB984\uC744 \uB04A\uC5B4\uBA39\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Instinct_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Instinct_001
    ko: "\uB108\uC758 \uD0C0\uACE0\uB09C \uAC10\uAC01\uC744 \uD300\uC758 \uC815\uC11D
      \uD3FC\uACFC \uACB0\uD569\uD574 \uB108\uB9CC\uC758 \uBA4B\uC9C4 \uD544\uC0B4\uAE30\uB85C
      \uB9CC\uB4E4\uC5B4\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uC81C \uC7AC\uB2A5\uC744 \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694!
      \uAC10\uB3C5\uB2D8 \uC870\uC5B8\uB300\uB85C \uC81C \uD3FC\uACFC \uACB0\uD569\uD574\uC11C
      \uC9C4\uC9DC \uC29B\uC744 \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Bluffer_1
    ko: "\uB2A5\uB825\uC744 \uC778\uC815\uBC1B\uC558\uB2E4\uACE0 \uB290\uAEF4 \uD6C8\uB828\uC5D0
      \uAE4A\uC774 \uBAB0\uC785\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Wild_101
    ko: "\uC81C \uC57C\uC131\uC801\uC778 \uAC10\uAC01\uC774 \uC815\uC11D\uACFC \uB9CC\uB098\uBA74
      \uB204\uAD6C\uB3C4 \uB9C9\uC9C0 \uBABB\uD560 \uAC81\uB2C8\uB2E4. \uB2F9\uC7A5
      \uC2DC\uC791\uD558\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Wild_1
    ko: "\uBCF8\uB2A5\uC801 \uAC10\uAC01\uC744 \uC778\uC815\uBC1B\uC544 \uD300 \uD6C8\uB828\uC5D0
      \uC801\uADF9 \uD611\uC870\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Egoist_101
    ko: "\uACB0\uAD6D \uC81C \uCC9C\uC7AC\uC131\uC744 \uBCF4\uC168\uAD70\uC694. \uC815\uC11D\uACFC
      \uACB0\uD569\uD558\uBA74 \uC644\uBCBD\uD55C \uBB34\uAE30\uAC00 \uB420 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Egoist_1
    ko: "\uC99D\uBA85 \uC695\uAD6C\uC640 \uC778\uC815\uC744 \uACB0\uD569\uD574 \uC2DC\uB108\uC9C0\uB97C
      \uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Fighter_101
    ko: "\uC81C \uD0C0\uACE0\uB09C \uAC10\uAC01\uC744 \uBBFF\uC5B4\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uB8E8\uD2F4\uC744 \uC815\uBCF5\uD574\uC11C
      \uC644\uBCBD\uD55C \uC288\uD130\uAC00 \uB418\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Fighter_1
    ko: "\uC815\uC11D \uB8E8\uD2F4\uC744 \uC815\uBCF5 \uB300\uC0C1\uC73C\uB85C \uC0BC\uC544
      \uC77C\uCC0D \uC2B5\uB4DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Instinct_002
    ko: "\uAC10\uAC01\uC5D0 \uC758\uC874\uD55C \uBB34\uBAA8\uD55C \uC29B\uC740 \uD300\uC744
      \uB9DD\uCE5C\uB2E4. \uB2F9\uC7A5 \uBCC0\uCE59 \uD3FC\uC744 \uBC84\uB9AC\uACE0
      \uC6D0\uCE59\uC744 \uC9C0\uCF1C."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bluffer_201
    ko: "\uC81C \uC2A4\uD0C0\uC77C\uC744 \uBB34\uC2DC\uD558\uC2DC\uB2E4\uB2C8...
      \uC624\uB298 \uC29B\uC774 \uC548 \uB4E4\uC5B4\uAC00\uB294 \uAC74 \uAC10\uB3C5\uB2D8
      \uB54C\uBB38\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Bluffer_2
    ko: "\uC9C8\uCC45\uC744 \uC790\uC874\uC2EC \uACF5\uACA9\uC73C\uB85C \uC5EC\uACA8
      \uD6C8\uB828\uC744 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Wild_201
    ko: "\uBCF8\uB2A5\uC744 \uC8FD\uC774\uB77C\uB294 \uAC81\uB2C8\uAE4C? \uADF8\uB7FC
      \uC800\uB294 \uC544\uBB34\uAC83\uB3C4 \uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Wild_2
    ko: "\uAC10\uAC01\uC774 \uC5B5\uC555\uB2F9\uD55C\uB2E4\uACE0 \uB290\uAEF4 \uC758\uC695\uC744
      \uC783\uACE0 \uD1F4\uBCF4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Egoist_201
    ko: "\uC81C \uD601\uC2E0\uC744 \uC774\uD574 \uBABB \uD558\uC2DC\uB124\uC694.
      \uC81C\uAC00 \uC65C \uAC10\uB3C5\uB2D8 \uD300\uC5D0\uC11C \uB18D\uAD6C\uB97C
      \uD574\uC57C \uD558\uB294\uC9C0 \uC758\uBB38\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Egoist_2
    ko: "\uC790\uC874\uC2EC\uC744 \uD06C\uAC8C \uB2E4\uCCD0 \uAC10\uB3C5\uACFC \uC804\uBA74\uC804\uC744
      \uBC8C\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Fighter_201
    ko: "\uC9C8\uCC45\uD558\uC2DC\uB2C8 \uB354 \uC624\uAE30\uAC00 \uC0DD\uAE41\uB2C8\uB2E4.
      \uC81C\uAC00 \uC815\uC11D \uB8E8\uD2F4\uAE4C\uC9C0 \uC644\uBCBD\uD558\uAC8C
      \uC18C\uD654\uD574\uC11C \uCF54\uB97C \uB0A9\uC791\uD558\uAC8C \uD574\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Fighter_2
    ko: "\uD22C\uC7C1\uC2EC\uC774 \uC790\uADF9\uB3FC \uAC10\uB3C5\uC744 \uC774\uAE30\uB824
      \uC644\uBCBD\uD788 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Instinct_003
    ko: "\uAC10\uB3C5\uC740 \uD53C\uB4DC\uBC31 \uC5C6\uC774 \uC29B \uC2E4\uD328 \uC5EC\uBD80\uB9CC
      \uD655\uC778\uD55C \uD6C4 '\uD1B5\uC81C \uBD88\uB2A5'\uC774\uB77C\uACE0 \uAE30\uB85D\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bluffer_301
    ko: "\uB098\uB97C \uBB34\uC2DC\uD574? \uC88B\uC544, \uB2E4\uB4E4 \uBCF4\uB294
      \uC55E\uC5D0\uC11C \uAC00\uC7A5 \uD654\uB824\uD55C \uC29B\uC744 \uC131\uACF5\uC2DC\uCF1C\uC11C
      \uAE5C\uC9DD \uB180\uB77C\uAC8C \uD574\uC8FC\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Bluffer_3
    ko: "\uBB34\uAD00\uC2EC\uC744 \uAE30\uD68C\uB85C \uC0BC\uC544 \uBB34\uB9AC\uD558\uB2E4
      \uB8E8\uD2F4\uC774 \uBD95\uAD34\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Wild_301
    ko: "\uC800 \uC218\uCCA9\uC5D0 \uB300\uCCB4 \uBB50\uB77C\uACE0 \uC801\uC73C\uC2DC\uB294
      \uAC70\uC9C0? \uB0B4 \uAC10\uAC01\uC744 \uD1B5\uC81C\uD558\uC2DC\uB824\uACE0?
      \uB09C \uB0B4 \uBC29\uC2DD\uB300\uB85C \uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Wild_3
    ko: "\uD589\uB3D9 \uC81C\uC57D\uC744 \uB290\uAEF4 \uC9C0\uC2DC\uB97C \uC5B4\uAE30\uACE0
      \uBCC0\uCE59\uC744 \uACE0\uC9D1\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Egoist_301
    ko: "\uB204\uAC00 \uBB50\uB798\uB3C4 \uB0B4\uAC00 \uCD5C\uACE0\uB2E4. \uB0B4
      \uC29B\uC774 \uB4E4\uC5B4\uAC00\uAE30 \uC2DC\uC791\uD558\uBA74 \uB2E4\uB4E4
      \uB098\uD55C\uD14C \uBB34\uB98E \uAFC7\uAC8C \uB420 \uAC70\uC57C."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Egoist_3
    ko: "\uD53C\uB4DC\uBC31\uC744 \uB9C9\uACE0 \uC2A4\uC2A4\uB85C \uC99D\uBA85\uD558\uACA0\uB2E4\uB294
      \uB3C5\uAE30\uB85C \uB3CC\uD30C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Fighter_301
    ko: "\uB098\uB97C \uD1B5\uC81C\uD558\uB824\uACE0 \uD574? \uB09C \uC774 \uB8E8\uD2F4\uC744
      \uAE68\uBD80\uC218\uACE0 \uB354 \uAC15\uD55C \uBCC0\uCE59\uC744 \uB9CC\uB4E4
      \uAC70\uC57C."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Fighter_3
    ko: "\uBB34\uAD00\uC2EC\uC744 \uACBD\uC7C1\uC73C\uB85C \uC778\uC2DD\uD574 \uBCC0\uCE59
      \uC29B\uC5D0 \uC9D1\uCC29\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Discipline_001
    ko: "\uC0C8\uBCBD 5\uC2DC, \uC548\uAC1C \uC790\uC6B1\uD55C \uCCB4\uC721\uAD00.
      3\uC810 \uC29B \uC7A0\uC7AC\uB825\uC774 \uB192\uC740 \uC120\uC218\uAC00 \uB9BC\uC758
      \uD0C4\uC131, \uACF5\uC758 \uD68C\uC804\uC218, \uB9B4\uB9AC\uC2A4 \uAC01\uB3C4\uB97C
      1\uB3C4 \uB2E8\uC704\uB85C \uC815\uBC00\uD558\uAC8C \uC870\uC815\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Discipline_002
    ko: "\uC790\uC2E0\uC758 \uB8E8\uD2F4\uC774 \uC870\uAE08\uC774\uB77C\uB3C4 \uD2C0\uC5B4\uC9C0\uBA74
      \uCC98\uC74C\uBD80\uD130 \uB2E4\uC2DC \uC2DC\uC791\uD558\uB294 \uAC15\uBC15\uC801\uC778
      \uD6C8\uB828\uC774 \uACC4\uC18D\uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Discipline_003
    ko: "\uBC14\uB2E5\uC5D0\uB294 \uC131\uACF5\uC744 \uC704\uD55C \uC218\uB9CE\uC740
      \uC218\uC2DD\uC774 \uC801\uD78C \uB178\uD2B8\uB97C \uD3BC\uCCD0\uB193\uC740
      \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Discipline_001
    ko: "\uC815\uBC00\uD568\uB3C4 \uC88B\uC9C0\uB9CC \uC218\uC2DD\uC5D0 \uB9E4\uBAB0\uB418\uC9C0
      \uB9D0\uACE0, \uBAB8\uC774 \uC774\uB044\uB294 \uB9AC\uB4EC\uC5D0 \uC870\uAE08
      \uB354 \uB9E1\uACA8\uBD10."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Principled_101
    ko: "\uB370\uC774\uD130\uC640 \uAC10\uAC01\uC758 \uC870\uD654\uB77C... \uC218\uC6A9\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uB9AC\uB4EC\uC744 \uB8E8\uD2F4\uC5D0 \uC815\uC2DD\uC73C\uB85C \uD3B8\uC785\uC2DC\uD0A4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Principled_1
    ko: "\uB17C\uB9AC\uC801 \uC81C\uC548\uC744 \uC790\uC2E0\uC758 \uC6D0\uCE59\uC5D0
      \uB354\uD558\uC5EC \uBCF4\uC644\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Guardian_101
    ko: "\uC81C \uBD84\uC11D\uC774 \uBD80\uC871\uD588\uAD70\uC694. \uD300\uC758 \uC9C8\uC11C\uB97C
      \uC9C0\uD0A4\uAE30 \uC704\uD574 \uAC10\uAC01\uAE4C\uC9C0 \uC644\uBCBD\uD788
      \uB9C8\uC2A4\uD130\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Guardian_1
    ko: "\uC870\uC5B8\uC744 \uD300 \uBCF4\uD638 \uC9C0\uCE68\uC73C\uB85C \uC5EC\uACA8
      \uD22C\uC9C0\uB97C \uBD88\uD0DC\uC6E0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Tactician_101
    ko: "\uC218\uCE58\uB294 \uC808\uB300\uC801\uC785\uB2C8\uB2E4. \uAC10\uAC01\uC744
      \uACB0\uD569\uD558\uB294 \uAC83\uBCF4\uB2E8 \uC774 \uC218\uC2DD \uADF8\uB300\uB85C
      \uC218\uD589\uD558\uB294 \uAC8C \uC2B9\uB960\uC774 \uB192\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Tactician_1
    ko: "\uC2E0\uB150\uC774 \uAC15\uD574 \uAC10\uAC01\uC801 \uC870\uC5B8\uC744 \uB17C\uB9AC\uC801\uC73C\uB85C
      \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Exemplary_101
    ko: "\uAC10\uC0AC\uD569\uB2C8\uB2E4! \uC5ED\uC2DC \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uC774
      \uC633\uC73C\uC2ED\uB2C8\uB2E4. \uD300\uC6D0\uB4E4\uB3C4 \uC81C \uAC10\uAC01\uC801\uC778
      \uC29B\uC744 \uBC30\uC6B0\uBA74 \uC88B\uC544\uD560 \uAC70\uC608\uC694."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Exemplary_1
    ko: "\uC778\uC815\uC744 \uBC1B\uC544 \uC790\uC874\uAC10\uC774 \uB192\uC544\uC838
      \uAE0D\uC815\uC801\uC73C\uB85C \uD6C8\uB828\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Discipline_002
    ko: "\uC624\uCC28\uC5D0 \uC9D1\uCC29\uD558\uB294 \uC644\uBCBD\uC8FC\uC758\uB294
      \uB3C5\uC774\uB2E4. \uB2F9\uC7A5 \uB178\uD2B8\uB97C \uCE58\uC6B0\uACE0 \uBAB8\uC73C\uB85C
      \uC9C1\uC811 \uD6C8\uB828\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Principled_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uC6D0\uCE59\uC744 \uC138\uC6B0\uB294 \uAC83\uC774
      \uC911\uC694\uD558\uBBC0\uB85C \uC9C0\uC2DC\uD558\uC2E0 \uB300\uB85C \uC989\uC2DC
      \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Principled_2
    ko: "\uC9C8\uCC45\uC744 \uC0C8 \uC6D0\uCE59\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uAE30\uACC4\uC801\uC73C\uB85C \uC218\uD589\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Guardian_201
    ko: "\uC81C \uAC15\uBC15\uC774 \uD300\uC758 \uC815\uB3C8\uB41C \uBD84\uC704\uAE30\uB97C
      \uD574\uCE58\uACE0 \uC788\uB098\uC694? \uB108\uBB34 \uC8C4\uC1A1\uD569\uB2C8\uB2E4.
      \uBC14\uB85C \uBC14\uAFB8\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Guardian_2
    ko: "\uC9C8\uCC45\uC744 \uD300 \uC804\uCCB4\uC758 \uBC29\uD574\uB85C \uB290\uAEF4
      \uD3FC\uC774 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Tactician_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uBAB8\uC73C\uB85C \uBD80\uB52A\uD788\uB294
      \uD6C8\uB828 \uB370\uC774\uD130\uAC00 \uB354 \uD6A8\uC728\uC801\uC774\uB77C\uBA74
      \uC989\uC2DC \uC804\uD658\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uC804\uC220\uC801 \uBA85\uB839\uC73C\uB85C \uC778\uC2DD\uD574
      \uAD70\uB9D0 \uC5C6\uC774 \uB530\uB790\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Exemplary_201
    ko: "\uB124, \uBC14\uB85C \uB178\uD2B8 \uCE58\uC6B0\uACA0\uC2B5\uB2C8\uB2E4.
      \uB2E4\uB978 \uC120\uC218\uB4E4\uB3C4 \uC800\uB97C \uB530\uB77C\uC624\uAC8C\uB054
      \uB2F9\uC7A5 \uBC29\uC2DD\uC744 \uBC14\uAFB8\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Exemplary_2
    ko: "\uC2DC\uC120\uC744 \uC758\uC2DD\uD574 \uC9C8\uCC45\uC744 \uD53C\uD574 \uBAA8\uBC94\uC774
      \uB418\uB824 \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Discipline_003
    ko: "\uAC10\uB3C5\uC740 \uC29B\uC744 \uC9C0\uCF1C\uBCF8 \uB4A4 '\uD53C\uB85C
      \uB204\uC801 \uC8FC\uC758'\uB97C \uC801\uACE0 \uC5B4\uAE68\uB97C \uCE5C \uD6C4
      \uC870\uC6A9\uD788 \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uD53C\uB85C\uB97C \uC5B8\uAE09\uD558\uC168\uC5B4...
      \uC774\uB300\uB85C\uBA74 \uB0B4 \uC6D0\uCE59\uC774 \uBB34\uB108\uC9C8 \uC218\uB3C4
      \uC788\uB2E4. \uC2EC\uB9AC\uC801 \uD0C0\uACA9\uC774 \uCEE4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Principled_3
    ko: "\uBB34\uC5B8\uC758 \uC9C0\uC801\uC744 \uC790\uAE30\uAD00\uB9AC \uC2E4\uD328\uB85C
      \uC5EC\uACA8 \uBD88\uC548\uD574\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uB098\uB97C \uC9C0\uCF1C\uBCF4\uC168\uC5B4. \uB0B4\uAC00
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD558\uACE0 \uC788\uB2E4\uB294
      \uAC78 \uC778\uC815\uBC1B\uC740 \uAC70\uC57C. \uB354 \uC644\uBCBD\uD574\uC838\uC57C
      \uD574."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Guardian_3
    ko: "\uAD00\uCC30\uC744 \uC2E0\uB8B0\uB85C \uBC1B\uC544\uB4E4\uC5EC \uD6C8\uB828
      \uD6A8\uC728\uC774 \uADF9\uB300\uD654\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Tactician_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uB178\uD2B8 \uB0B4\uC6A9\uC740 \uC815\uBCF4\uC785\uB2C8\uB2E4.
      \uD53C\uB85C \uB370\uC774\uD130\uB97C \uACE0\uB824\uD574 \uB8E8\uD2F4\uC744
      \uC7AC\uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Tactician_3
    ko: "\uCE68\uBB35\uC5D0\uC11C\uB3C4 \uB370\uC774\uD130\uB97C \uCD94\uCD9C\uD574
      \uD6C8\uB828\uC744 \uC7AC\uAD6C\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Exemplary_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC81C \uB8E8\uD2F4\uC5D0 \uC9C1\uC811 \uD53C\uB4DC\uBC31\uC744
      \uC548 \uC8FC\uC2DC\uACE0 \uADF8\uB0E5 \uAC00\uC168\uC5B4... \uB098\uB97C \uB354
      \uC774\uC0C1 \uBAA8\uBC94\uC73C\uB85C \uC548 \uBCF4\uC2DC\uB294 \uAC74\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Exemplary_3
    ko: "\uCE68\uBB35\uC744 \uBB34\uAD00\uC2EC\uC73C\uB85C \uAC04\uC8FC\uD574 \uD6C8\uB828
      \uC790\uCCB4\uAC00 \uBD95\uAD34\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bond_001
    ko: "\uC0C8\uBCBD 5\uC2DC, \uC548\uAC1C \uC790\uC6B1\uD55C \uCCB4\uC721\uAD00.
      3\uC810 \uC29B \uC7A0\uC7AC\uB825\uC774 \uB192\uC740 \uC120\uC218\uAC00 \uB9BC\uC758
      \uD0C4\uC131, \uACF5\uC758 \uD68C\uC804\uC218, \uB9B4\uB9AC\uC2A4 \uAC01\uB3C4\uB97C
      1\uB3C4 \uB2E8\uC704\uB85C \uC815\uBC00\uD558\uAC8C \uC870\uC815\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bond_002
    ko: "\uC790\uC2E0\uC758 \uB8E8\uD2F4\uC774 \uC870\uAE08\uC774\uB77C\uB3C4 \uD2C0\uC5B4\uC9C0\uBA74
      \uCC98\uC74C\uBD80\uD130 \uB2E4\uC2DC \uC2DC\uC791\uD558\uB294 \uAC15\uBC15\uC801\uC778
      \uD6C8\uB828\uC774 \uACC4\uC18D\uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bond_003
    ko: "\uBC14\uB2E5\uC5D0\uB294 \uC131\uACF5\uC744 \uC704\uD55C \uC218\uB9CE\uC740
      \uC218\uC2DD\uC774 \uC801\uD78C \uB178\uD2B8\uB97C \uD3BC\uCCD0\uB193\uC740
      \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bond_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Bond_001
    ko: "\uC815\uBC00\uD55C \uB178\uB825\uC740 \uB300\uACAC\uD558\uC9C0\uB9CC, \uC774\uC81C\uB294
      \uC218\uC2DD\uBCF4\uB2E4 \uB124\uAC00 \uAC00\uC9C4 \uB530\uB73B\uD55C \uAC10\uAC01\uC744
      \uBBFF\uC5B4\uBD10."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uC81C \uB178\uB825\uC744 \uC54C\uC544\uC8FC\uC154\uC11C
      \uC815\uB9D0 \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C
      \uC774\uC81C \uC81C \uAC10\uAC01\uC744 \uBBFF\uC5B4\uBCFC\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Kind_1
    ko: "\uC815\uC11C\uC801 \uC9C0\uC9C0\uB97C \uBC1B\uC790 \uAE34\uC7A5\uC774 \uD480\uB824
      \uBC38\uB7F0\uC2A4\uB97C \uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uAED8\uC11C \uC800\uB97C \uBBFF\uC5B4\uC8FC\uC2E0\uB2E4\uBA74,
      \uC81C \uAC10\uAC01\uC744 \uB8E8\uD2F4\uC5D0 \uB179\uC5EC\uB0B4\uC5B4 \uAF2D
      \uACB0\uACFC\uB97C \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Loyal_1
    ko: "\uACA9\uB824\uB97C \uC0AC\uBA85\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC \uD5CC\uC2E0\uC801\uC73C\uB85C
      \uD6C8\uB828\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Sincere_101
    ko: "\uC218\uC2DD\uACFC \uAC10\uAC01\uC744 \uBCD1\uD589\uD558\uB294 \uAC83\uC774
      \uB354 \uD6A8\uC728\uC801\uC778 \uD6C8\uB828\uBC95\uC774 \uB420 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
      \uADF8\uB807\uAC8C \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Sincere_1
    ko: "\uACA9\uB824\uB97C \uC131\uC7A5\uC758 \uAE30\uD68C\uB85C \uC0BC\uC544 \uB8E8\uD2F4\uC744
      \uC7AC\uC124\uACC4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Moodmaker_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8 \uCD5C\uACE0! \uD558\uD558, \uAC10\uB3C5\uB2D8
      \uCE6D\uCC2C \uB4E4\uC73C\uB2C8\uAE4C \uB9BC\uC774 \uB354 \uB113\uC5B4 \uBCF4\uC774\uB294
      \uAC83 \uAC19\uC544\uC694!"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Moodmaker_1
    ko: "\uB530\uB73B\uD55C \uACA9\uB824\uC5D0 \uC790\uC2E0\uAC10\uC774 \uD3ED\uBC1C\uD574
      \uCEE8\uB514\uC158\uC774 \uCE58\uC19F\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Bond_002
    ko: "\uAC15\uBC15\uC801\uC778 \uB178\uD2B8 \uD544\uAE30\uB294 \uD300\uC744 \uACBD\uC9C1\uC2DC\uD0A8\uB2E4.
      \uB2F9\uC7A5 \uB178\uD2B8\uB97C \uCE58\uC6B0\uACE0 \uBAB8\uBD80\uD130 \uC6C0\uC9C1\uC5EC\uB77C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Kind_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4... \uC81C\uAC00 \uD300\uC5D0 \uD3D0\uB97C
      \uB07C\uCE58\uACE0 \uC788\uC5C8\uAD70\uC694. \uC815\uB9D0 \uC8C4\uC1A1\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Kind_2
    ko: "\uC9C8\uCC45\uC744 \uAD00\uACC4\uC801 \uBD80\uC815\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uC758\uAE30\uC18C\uCE68\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Loyal_201
    ko: "\uC81C \uAC15\uBC15\uC774 \uD300\uC758 \uBC29\uD574\uAC00 \uB41C\uB2E4\uBA74...
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uB2F9\uC7A5 \uB178\uD2B8\uB97C \uBC84\uB9AC\uACE0
      \uAC10\uB3C5\uB2D8\uC774 \uC6D0\uD558\uC2DC\uB294 \uBC29\uC2DD\uC73C\uB85C
      \uBC14\uAFB8\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC744 \uCDA9\uC131\uC2EC\uC5D0 \uB300\uD55C \uACBD\uACE0\uB85C
      \uC5EC\uACA8 \uC989\uC2DC \uC218\uD589\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Sincere_201
    ko: "\uBD88\uC548\uC758 \uC0B0\uBB3C\uC774\uB77C\uB2C8... \uC81C\uAC00 \uD574\uC628
      \uBD84\uC11D\uC774 \uD2C0\uB838\uB2E4\uB294 \uB9D0\uC500\uC774\uC2ED\uB2C8\uAE4C?
      \uC81C \uB8E8\uD2F4\uC744 \uB2E4\uC2DC \uC810\uAC80\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Sincere_2
    ko: "\uBD84\uC11D\uC801 \uB178\uB825\uC744 \uBD80\uC815\uB2F9\uD558\uC790 \uD63C\uB780\uC5D0
      \uBE60\uC838 \uBD95\uAD34\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Moodmaker_201
    ko: "\uC81C \uB178\uD2B8\uAC00 \uD300\uC744 \uACBD\uC9C1\uC2DC\uD0A8\uB2E4\uACE0\uC694?
      \uB18D\uB2F4\uC774\uC2DC\uC8E0? \uB108\uBB34 \uB531\uB531\uD558\uAC8C \uAD74\uC9C0
      \uB9C8\uC138\uC694 \uAC10\uB3C5\uB2D8!"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Moodmaker_2
    ko: "\uC9C8\uCC45\uC5D0 \uBC18\uD56D\uC2EC\uC744 \uB290\uAEF4 \uB534\uCCAD\uC744
      \uD53C\uC6B0\uBA70 \uC9D1\uC911\uC744 \uAE7C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Bond_003
    ko: "\uAC10\uB3C5\uC740 \uC29B\uC744 \uC9C0\uCF1C\uBCF4\uB2E4 \uB178\uD2B8 \uC704\uC5D0
      \uCEE4\uD53C\uB97C \uB450\uACE0 \uC5B4\uAE68\uB97C \uD1A0\uB2E5\uC778 \uB4A4
      \uBB35\uBB35\uD788 \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uCEE4\uD53C\uB97C... \uC800\uB97C \uAC71\uC815\uD558\uACE0
      \uACC4\uC168\uAD70\uC694. \uB2E4\uC2DC \uD3C9\uC815\uC2EC\uC744 \uCC3E\uACE0
      \uAE30\uBCF8\uBD80\uD130 \uD560\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Kind_3
    ko: "\uCE68\uBB35 \uC18D \uBC30\uB824\uB97C \uD655\uC778\uD558\uACE0 \uC2EC\uB9AC\uC801
      \uC548\uC815\uC744 \uD68C\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Loyal_301
    ko: "\uC800\uB97C \uBBFF\uACE0 \uAE30\uB2E4\uB824\uC8FC\uC2DC\uB294\uAD70\uC694.
      \uAC10\uB3C5\uB2D8\uC744 \uC704\uD574\uC11C\uB77C\uB3C4 \uC774 \uC0C8\uBCBD
      \uD6C8\uB828\uC744 \uC808\uB300 \uBA48\uCD9C \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Loyal_3
    ko: "\uC2E0\uB8B0\uB97C \uD655\uC778\uD558\uACE0 \uAC15\uD55C \uCC45\uC784\uAC10\uC744
      \uB290\uAEF4 \uBC00\uB3C4\uB97C \uB192\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Sincere_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC81C \uB178\uD2B8\uC5D0 \uCEE4\uD53C\uB97C...
      \uC81C\uAC00 \uB193\uCE58\uACE0 \uC788\uB358 \uC2EC\uB9AC\uC801 \uC548\uC815\uC774
      \uB370\uC774\uD130\uC600\uAD70\uC694. \uAE30\uB85D\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Sincere_3
    ko: "\uBB34\uC5B8\uC758 \uACA9\uB824\uC5D0\uC11C \uB370\uC774\uD130\uB97C \uB3C4\uCD9C\uD574
      \uC131\uC2E4\uD788 \uBCF5\uAD6C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Moodmaker_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uB2E4\uB140\uAC00\uC168\uB124! \uB098 \uC9C0\uCF1C\uBCF4\uC2DC\uB294\uAD6C\uB098.
      \uB354 \uC5F4\uC2EC\uD788 \uD574\uC11C \uD300 \uBD84\uC704\uAE30\uB97C \uB744\uC6CC\uC57C\uC9C0!"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Moodmaker_3
    ko: "\uAD00\uC2EC\uC744 \uD655\uC778\uD558\uACE0 \uC2E0\uB098\uC11C \uBB34\uB9AC\uD558\uB2E4
      \uD3FC\uC774 \uAC70\uCE60\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cold_001
    ko: "\uC0C8\uBCBD 5\uC2DC, \uC548\uAC1C \uC790\uC6B1\uD55C \uCCB4\uC721\uAD00.
      3\uC810 \uC29B \uC7A0\uC7AC\uB825\uC774 \uB192\uC740 \uC120\uC218\uAC00 \uB9BC\uC758
      \uD0C4\uC131, \uACF5\uC758 \uD68C\uC804\uC218, \uB9B4\uB9AC\uC2A4 \uAC01\uB3C4\uB97C
      1\uB3C4 \uB2E8\uC704\uB85C \uC815\uBC00\uD558\uAC8C \uC870\uC815\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cold_002
    ko: "\uC790\uC2E0\uC758 \uB8E8\uD2F4\uC774 \uC870\uAE08\uC774\uB77C\uB3C4 \uD2C0\uC5B4\uC9C0\uBA74
      \uCC98\uC74C\uBD80\uD130 \uB2E4\uC2DC \uC2DC\uC791\uD558\uB294 \uAC15\uBC15\uC801\uC778
      \uD6C8\uB828\uC774 \uACC4\uC18D\uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cold_003
    ko: "\uBC14\uB2E5\uC5D0\uB294 \uC131\uACF5\uC744 \uC704\uD55C \uC218\uB9CE\uC740
      \uC218\uC2DD\uC774 \uC801\uD78C \uB178\uD2B8\uB97C \uD3BC\uCCD0\uB193\uC740
      \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cold_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Cold_001
    ko: "\uB370\uC774\uD130 \uBD84\uC11D\uC740 \uD6CC\uB96D\uD558\uC9C0\uB9CC \uD55C\uACC4\uAC00
      \uC788\uC73C\uB2C8, \uAE30\uC874 \uB8E8\uD2F4\uC5D0 \uC720\uC5F0\uC131\uC744
      \uB354\uD574\uBD10."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Planner_101
    ko: "\uC720\uC5F0\uC131\uC774\uB77C\uB294 \uBCC0\uC218\uB97C \uB193\uCCE4\uAD70\uC694.
      \uB2F9\uC7A5 \uC624\uCC28 \uBC94\uC704\uB97C \uC218\uC2DD\uC5D0 \uCD94\uAC00\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uD6E8\uC52C \uD6A8\uC728\uC801\uC774\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Planner_1
    ko: "\uC870\uC5B8\uC744 \uB17C\uB9AC\uC801 \uBCF4\uC644\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uD6C8\uB828 \uC9C8\uC744 \uB192\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Opportunist_101
    ko: "\uC720\uC5F0\uC131 \uBCC0\uC218\uB97C \uCD94\uAC00\uD558\uBA74 \uC81C \uC29B\uC774
      \uB354 \uC644\uBCBD\uD574\uC9C0\uACA0\uAD70\uC694. \uC88B\uC740 \uC804\uB7B5\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Opportunist_1
    ko: "\uACA9\uB824\uB97C \uD1B5\uD574 \uC29B\uC744 \uB354\uC6B1 \uC815\uAD50\uD558\uAC8C
      \uB2E4\uB4EC\uC5B4\uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cunning_101
    ko: "\uC720\uC5F0\uC131 \uC218\uCE58\uB77C... \uADF8\uAC74 \uC81C \uAC10\uAC01\uC758
      \uC601\uC5ED\uC785\uB2C8\uB2E4. \uC81C \uBC29\uC2DD\uB300\uB85C \uB05D\uAE4C\uC9C0
      \uACE0\uC218\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Cunning_1
    ko: "\uC81C\uC548\uC744 \uD1B5\uC81C\uAD8C\uC5D0 \uB300\uD55C \uCE68\uD574\uB85C
      \uAC04\uC8FC\uD558\uC5EC \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Believer_101
    ko: "\uB370\uC774\uD130 \uBD84\uC11D\uC740 \uCDA9\uBD84\uD569\uB2C8\uB2E4. \uC81C
      \uC218\uC2DD\uC5D0 \uC720\uC5F0\uC131 \uBCC0\uC218\uB97C \uB123\uB294 \uAC74
      \uC81C \uB17C\uB9AC\uC5D0 \uC5B4\uAE0B\uB0A9\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Believer_1
    ko: "\uB370\uC774\uD130\uC801 \uC2E0\uB150\uC774 \uB108\uBB34 \uAC15\uD574 \uB17C\uB9AC\uC801\uC73C\uB85C
      \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Cold_002
    ko: "\uC624\uCC28\uC5D0 \uC9D1\uCC29\uD574 \uBC38\uB7F0\uC2A4\uB97C \uD574\uCE58\uB294
      \uBE44\uD6A8\uC728\uC801 \uD6C8\uB828\uC774\uB2E4. \uB2F9\uC7A5 \uB8E8\uD2F4\uC744
      \uC7AC\uC124\uACC4\uD558\uB77C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Planner_201
    ko: "\uD22C\uC790 \uB300\uBE44 \uD6A8\uC728\uC774 \uB0AE\uB2E4\uB294 \uC9C0\uC801,
      \uC218\uAE0D\uD569\uB2C8\uB2E4. \uC815\uC11D\uC801\uC778 \uC804\uCCB4 \uB8E8\uD2F4\uC73C\uB85C
      \uBCF5\uADC0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Planner_2
    ko: "\uC218\uCE58\uC801 \uBE44\uD6A8\uC728\uC744 \uC9C0\uC801\uBC1B\uC790 \uC989\uAC01
      \uC804\uB7B5\uC744 \uC218\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Opportunist_201
    ko: "\uC81C \uBD84\uC11D\uC758 \uD5C8\uC810\uC744 \uC9C0\uC801\uD558\uC2DC\uB2C8
      \uD560 \uB9D0\uC774 \uC5C6\uB124\uC694. \uD6A8\uC728\uC801\uC778 \uBC29\uC2DD\uC73C\uB85C
      \uBC14\uAFB8\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Opportunist_2
    ko: "\uBD84\uC11D\uC758 \uC624\uB958\uB97C \uC778\uC815\uD558\uACE0 \uAC10\uB3C5
      \uB17C\uB9AC\uC5D0 \uC989\uAC01 \uC21C\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cunning_201
    ko: "\uC1A1\uAD6C\uD569\uB2C8\uB2E4. \uD6A8\uC728\uC801\uC778 \uD6C8\uB828\uC73C\uB85C
      \uC989\uC2DC \uBCC0\uACBD\uD558\uC5EC \uACB0\uACFC\uB85C \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Cunning_2
    ko: "\uB17C\uB9AC\uC801 \uC9C8\uCC45\uC744 \uAD8C\uC704\uB85C \uC5EC\uACA8 \uC989\uC2DC
      \uC218\uC6A9\uD558\uACE0 \uC5F0\uCD9C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Believer_201
    ko: "\uB370\uC774\uD130 \uAD00\uC810\uC5D0\uC11C \uC81C\uAC00 \uBE44\uD6A8\uC728\uC801\uC774\uAD70\uC694.
      \uD300\uC758 \uC2B9\uB960\uC744 \uC704\uD574 \uC989\uC2DC \uC7AC\uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Believer_2
    ko: "\uC2B9\uB960\uC774\uB77C\uB294 \uBA85\uBD84\uC774 \uC8FC\uC5B4\uC9C0\uC790
      \uC804\uB7B5\uC801\uC73C\uB85C \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Cold_003
    ko: "\uAC10\uB3C5\uC740 \uC218\uC2DD\uC5D0 \uBC11\uC904\uC744 \uAE0B\uACE0 '\uD658\uACBD
      \uBCC0\uC218 \uB204\uB77D'\uC774\uB77C\uB294 \uBA54\uBAA8\uB97C \uB0A8\uAE34
      \uCC44 \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Planner_301
    ko: "\uD658\uACBD \uBCC0\uC218\uB97C \uB193\uCCE4\uB2E4\uB2C8... \uC644\uBCBD\uD558\uC9C0
      \uC54A\uC740 \uB0B4 \uB370\uC774\uD130\uB294 \uBB34\uAC00\uCE58\uD574. \uCC98\uC74C\uBD80\uD130
      \uB2E4\uC2DC \uC124\uACC4\uD558\uC790."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Planner_3
    ko: "\uC644\uBCBD\uD55C \uC218\uC2DD\uC774 \uBD80\uC815\uB2F9\uD588\uB2E4\uACE0
      \uD310\uB2E8\uD574 \uC2A4\uC2A4\uB85C \uBD95\uAD34\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Opportunist_301
    ko: "\uD658\uACBD \uBCC0\uC218... \uADF8\uB798, \uB9BC\uC758 \uD0C4\uC131\uAE4C\uC9C0
      \uACE0\uB824\uD558\uBA74 \uB0B4 \uC29B\uC740 \uC808\uB300 \uC548 \uB9C9\uD788\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Opportunist_3
    ko: "\uBB34\uC5B8\uC758 \uD53C\uB4DC\uBC31\uC744 \uD1A0\uB300\uB85C \uD544\uC0B4\uAE30
      \uC644\uC131\uC5D0\uB9CC \uC9D1\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cunning_301
    ko: "\uD658\uACBD \uBCC0\uC218 \uB204\uB77D\uC774\uB77C\uB2C8... \uC77C\uB2E8\uC740
      \uAC10\uB3C5\uB2D8 \uC9C0\uC2DC\uB97C \uB530\uB974\uB294 \uCC99\uD558\uBA70
      \uB098\uC911\uC5D0 \uBAB0\uB798 \uC218\uC815\uD574\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Cunning_3
    ko: "\uAC10\uB3C5\uC758 \uD589\uB3D9\uC744 \uBC29\uD574\uB85C \uC778\uC2DD\uD574
      \uD6C8\uB828 \uC9D1\uC911\uC774 \uB5A8\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Believer_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC544\uBB34\uB7F0 \uB9D0\uC500\uC774 \uC5C6\uC73C\uC2DC\uB124...
      \uB0B4 \uB370\uC774\uD130\uB294 \uC774\uC81C \uAC00\uCE58\uAC00 \uC5C6\uB294
      \uAC74\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Believer_3
    ko: "\uCE68\uBB35\uC744 \uB370\uC774\uD130 \uD3D0\uAE30\uB85C \uD574\uC11D\uD574
      \uACE0\uB9BD\uAC10 \uC18D\uC5D0 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Instinct_001
    ko: "\uC0C8\uBCBD 5\uC2DC, \uC548\uAC1C \uC790\uC6B1\uD55C \uCCB4\uC721\uAD00.
      3\uC810 \uC29B \uC7A0\uC7AC\uB825\uC774 \uB192\uC740 \uC120\uC218\uAC00 1\uB3C4
      \uB2E8\uC704\uB85C \uAC01\uB3C4\uB97C \uC870\uC815\uD558\uBA70 \uD6C8\uB828
      \uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Instinct_002
    ko: "\uC218\uC2DD \uB178\uD2B8\uB97C \uD3B4\uB193\uACE0 \uC644\uBCBD\uC5D0 \uC9D1\uCC29\uD558\uB294
      \uBAA8\uC2B5\uC740 \uBCF8\uB2A5\uC801\uC778 \uAC10\uAC01\uC744 \uC5B5\uC9C0\uB85C
      \uC218\uCE58\uD654\uD558\uB824\uB294 \uB4EF \uBCF4\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Instinct_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Instinct_001
    ko: "\uC815\uBC00\uD55C \uC870\uC815\uC774 \uD0C0\uACE0\uB09C \uAC10\uAC01\uC744
      \uAC00\uB454\uB2E4. \uACF5\uC758 \uBB34\uAC8C\uC640 \uB9BC\uC744 \uBBFF\uACE0
      \uBCF8\uB2A5\uB300\uB85C \uB358\uC838\uB77C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uC81C \uC7AC\uB2A5\uC744 \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694!
      \uC218\uC2DD \uBC84\uB9AC\uACE0 \uC81C \uC2E4\uB825\uC744 \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Bluffer_1
    ko: "\uB2A5\uB825\uC744 \uC778\uC815\uBC1B\uC558\uB2E4\uACE0 \uB290\uAEF4 \uAE30\uC220
      \uC2B5\uB4DD\uC5D0 \uAE4A\uC774 \uBAB0\uC785\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Wild_101
    ko: "\uC218\uC2DD \uC5C6\uC774 \uB358\uC9C0\uB2C8 \uD6E8\uC52C \uD3B8\uD558\uB124\uC694.
      \uC5ED\uC2DC \uC81C \uBCF8\uB2A5\uC774 \uB9DE\uC558\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Wild_1
    ko: "\uBCF8\uB2A5\uC744 \uC778\uC815\uBC1B\uC544 \uBAB0\uC785\uD588\uC73C\uB098
      \uAE30\uC220\uC801 \uC131\uC7A5\uC740 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Egoist_101
    ko: "\uAC10\uAC01\uC744 \uC0B4\uB9AC\uB77C\uACE0\uC694? \uC81C \uC218\uC2DD\uC774
      \uC644\uBCBD\uD55C\uB370 \uC65C \uBC29\uD574\uD558\uC2DC\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Egoist_1
    ko: "\uB17C\uB9AC\uB97C \uD1B5\uC81C\uB2F9\uD55C\uB2E4\uACE0 \uD310\uB2E8\uD574
      \uC81C\uC548\uC744 \uC804\uBA74 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Fighter_101
    ko: "\uC81C \uB8E8\uD2F4\uC740 \uC81C\uAC00 \uC815\uD569\uB2C8\uB2E4. \uACA9\uB824\uB294
      \uAC10\uC0AC\uD558\uC9C0\uB9CC \uC218\uC2DD\uC740 \uADF8\uB300\uB85C \uB458
      \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Fighter_1
    ko: "\uC870\uC5B8\uC774 \uB8E8\uD2F4 \uC815\uBCF5\uC5D0 \uBC29\uD574\uB41C\uB2E4\uACE0
      \uD310\uB2E8\uD558\uC5EC \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Instinct_002
    ko: "\uAC15\uBC15\uC801\uC778 \uACC4\uC0B0\uC740 \uBCF8\uB2A5\uC744 \uC8FD\uC774\uB294
      \uB3C5\uC774\uB2E4. \uB18D\uAD6C\uB294 \uBAB8\uC73C\uB85C \uD558\uB294 \uAC70\uB2C8
      \uB178\uD2B8 \uCE58\uC6CC\uB77C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bluffer_201
    ko: "\uC81C \uC2A4\uD0C0\uC77C\uC744 \uBB34\uC2DC\uD558\uC2DC\uB2E4\uB2C8...
      \uC624\uB298 \uC29B \uC548 \uB4E4\uC5B4\uAC00\uB294 \uAC74 \uAC10\uB3C5\uB2D8
      \uB54C\uBB38\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Bluffer_2
    ko: "\uC9C8\uCC45\uC744 \uC790\uC874\uC2EC \uACF5\uACA9\uC73C\uB85C \uB290\uAEF4
      \uB300\uB9BD\uD558\uBA70 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Wild_201
    ko: "\uC774 \uC9C0\uAE0B\uC9C0\uAE0B\uD55C \uACC4\uC0B0\uC5D0\uC11C \uD574\uBC29\uC2DC\uCF1C
      \uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uC774\uC81C\uC57C \uC9C4\uC9DC
      \uC81C \uC29B\uC774 \uB098\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Wild_2
    ko: "\uAC10\uAC01\uC744 \uC5B5\uC555\uD558\uB358 \uAC15\uBC15\uC774 \uD480\uB9AC\uC790
      \uC7A0\uC7AC\uB825\uC774 \uD3ED\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Egoist_201
    ko: "\uB178\uD2B8\uAC00 \uC5C6\uC5B4\uB3C4 \uC81C \uBA38\uB9BF\uC18D\uC5D4 \uB370\uC774\uD130\uAC00
      \uC788\uC2B5\uB2C8\uB2E4. \uC2DC\uD0A4\uB294 \uB300\uB85C \uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Egoist_2
    ko: "\uC2E4\uB825 \uC99D\uBA85\uC744 \uC704\uD574 \uBC18\uD56D\uC2EC\uC744 \uB204\uB974\uACE0
      \uAE30\uACC4\uC801\uC73C\uB85C \uB530\uB790\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Fighter_201
    ko: "\uAC10\uD788 \uC81C \uB178\uB825\uC744 \uD3C4\uD558\uD558\uC2ED\uB2C8\uAE4C?
      \uD654\uB098\uC11C\uB77C\uB3C4 \uC548 \uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Fighter_2
    ko: "\uC9C8\uCC45\uC744 \uBAA8\uB3C5\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC \uAC10\uC815\uC801
      \uB300\uB9BD \uD6C4 \uC911\uB2E8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Instinct_003
    ko: "\uAC10\uB3C5\uC740 \uC120\uC218\uAC00 \uB178\uD2B8\uB97C \uBABB \uBCF4\uAC8C
      \uC218\uCCA9\uC73C\uB85C \uAC00\uB9AC\uACE0, \uC870\uC6A9\uD788 \uACF5\uB9CC
      \uC8FC\uC6CC \uC190\uC5D0 \uC950\uC5EC\uC900\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bluffer_301
    ko: "\uC65C \uB178\uD2B8\uB97C \uAC00\uB9AC\uC2DC\uC8E0? \uBCF4\uC5EC\uB4DC\uB9AC\uACE0
      \uC2F6\uC740\uB370... \uC29B\uC5D0 \uC9D1\uC911\uC774 \uC548 \uB418\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Bluffer_3
    ko: "\uC218\uC2DD\uC744 \uACFC\uC2DC\uD560 \uAE30\uD68C\uB97C \uC783\uC5B4 \uC8FC\uC758\uAC00
      \uBD84\uC0B0\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Wild_301
    ko: "\uC65C \uB0B4 \uB178\uD2B8\uB97C \uB9C9\uC73C\uC2DC\uC8E0? \uC800\uB294
      \uC81C \uBC29\uC2DD\uB300\uB85C \uBD84\uC11D\uD558\uACE0 \uC2F6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Wild_3
    ko: "\uD1B5\uC81C\uC5D0 \uBC18\uBC1C\uD574 \uAC10\uB3C5\uC758 \uC720\uB3C4\uB97C
      \uAC70\uC2A4\uB974\uACE0 \uB3C5\uC790 \uD6C8\uB828\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Egoist_301
    ko: "\uB9D0\uC5C6\uC774 \uACF5\uB9CC \uC8FC\uC2E0\uB2E4\uACE0\uC694? \uC88B\uC2B5\uB2C8\uB2E4.
      \uB0B4 \uC29B\uC774 \uB4E4\uC5B4\uAC00\uB294 \uAC78 \uBCF4\uACE0\uB3C4 \uADF8\uB7F0
      \uD45C\uC815\uC77C\uC9C0 \uBCF4\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Egoist_3
    ko: "\uC678\uBD80 \uAC1C\uC785\uC744 \uCC28\uB2E8\uD558\uACE0 \uC2A4\uC2A4\uB85C
      \uC99D\uBA85\uD560 \uB3C5\uAE30\uB85C \uB3CC\uD30C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Fighter_301
    ko: "\uB9D0\uC5C6\uC774 \uACF5\uB9CC \uC8FC\uC2DC\uB2E4\uB2C8... \uC800\uB791
      \uB300\uACB0\uD558\uC790\uB294 \uB73B\uC785\uB2C8\uAE4C? \uCD5C\uACE0 \uAE30\uB85D\uC744
      \uAE68\uC11C \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Fighter_3
    ko: "\uBB34\uC5B8\uC758 \uD589\uB3D9\uC744 \uACBD\uC7C1\uC73C\uB85C \uC5EC\uACA8
      \uD22C\uC7C1\uC2EC\uC73C\uB85C \uC131\uCDE8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Discipline_001
    ko: "\uD6C8\uB828 \uC2DC\uC791 \uC9C1\uC804, \uBA3C\uC9C0 \uC11E\uC778 \uBC14\uB78C\uC774
      \uBD80\uB294 \uCF54\uD2B8. \uC120\uC218\uB294 \uC790\uC2E0\uC758 \uD328\uC2A4\uAC00
      \uB3D9\uB8CC\uC758 \uAC00\uC2B4\uC5D0 \uC815\uD655\uD788 \uB3C4\uB2EC\uD558\uC9C0
      \uC54A\uC790 \uD328\uB2C9\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Discipline_002
    ko: "\uD328\uC2A4\uB294 \uC815\uD574\uC9C4 \uADA4\uC801\uC744 \uADF8\uB824\uC57C
      \uD55C\uB2E4 \uB294 \uC6D0\uCE59\uC5D0 \uC0AC\uB85C\uC7A1\uD600 \uADFC\uC721\uC774
      \uAD73\uC740 \uCC44 \uACF5\uC744 \uB358\uC9C0\uACE0 \uC788\uACE0 \uC2E4\uC218
      \uD6C4\uC5D4 \uC8FC\uC800\uC549\uC544 \uC2A4\uC2A4\uB85C\uB97C \uC6D0\uB9DD\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Discipline_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Discipline_001
    ko: "\uCC45\uC784\uAC10\uC740 \uD6CC\uB96D\uD558\uB2C8, \uC774\uBC88\uC5D4 \uADA4\uC801
      \uB300\uC2E0 \uB3D9\uB8CC\uC758 \uC6C0\uC9C1\uC784\uC5D0\uB9CC \uC9D1\uC911\uD574\uC11C
      \uD328\uC2A4\uD574 \uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Principled_101
    ko: "\uADA4\uC801\uBCF4\uB2E4 \uC6C0\uC9C1\uC784... \uC0C8\uB85C\uC6B4 \uADDC\uCE59\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC774\uACA0\uC2B5\uB2C8\uB2E4. \uBC14\uB85C \uC218\uC815\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Principled_1
    ko: "\uC6C0\uC9C1\uC784 \uC9D1\uC911\uC744 \uC0C8\uB85C\uC6B4 \uC6D0\uCE59\uC73C\uB85C
      \uC0BC\uC544 \uC989\uC2DC \uD68C\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Guardian_101
    ko: "\uC81C\uAC00 \uD300\uC758 \uD750\uB984\uC744 \uB9DD\uCE58\uACE0 \uC788\uC5C8\uAD70\uC694.
      \uB3D9\uB8CC\uB9CC \uBCF4\uACE0 \uB354 \uC9D1\uC911\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Guardian_1
    ko: "\uACFC\uB3C4\uD55C \uCC45\uC784\uAC10\uC73C\uB85C \uC555\uBC15\uC774 \uCEE4\uC838
      \uD328\uC2A4 \uD3FC\uC774 \uBB34\uAC70\uC6CC\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Tactician_101
    ko: "\uC0C1\uD669\uB9C8\uB2E4 \uBCC0\uD558\uB294 \uADA4\uC801\uC740 \uBCC0\uC218\uAC00
      \uB108\uBB34 \uB9CE\uC2B5\uB2C8\uB2E4. \uD1B5\uC81C \uBD88\uAC00\uB2A5\uD55C
      \uBCC0\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Tactician_1
    ko: "\uADA4\uC801\uC5D0 \uB300\uD55C \uC6D0\uCE59\uC744 \uBC84\uB9AC\uC9C0 \uBABB\uD574
      \uC870\uC5B8\uC744 \uBC30\uCC99\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Exemplary_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C\uB124\uC694! \uB3D9\uB8CC\uB4E4\uACFC
      \uD638\uD761\uC744 \uB9DE\uCDB0 \uC131\uACF5\uC801\uC778 \uD328\uC2A4\uB97C
      \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Exemplary_1
    ko: "\uACA9\uB824\uB97C \uBAA8\uBC94\uC801 \uC131\uC7A5\uC758 \uACC4\uAE30\uB85C
      \uC0BC\uC544 \uD65C\uAE30\uCC28\uAC8C \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Discipline_002
    ko: "\uB108\uC758 \uAC15\uBC15\uC774 \uD300\uC744 \uACBD\uC9C1\uB418\uAC8C \uD55C\uB2E4.
      \uC815\uB2F5\uC740 \uB3D9\uB8CC\uC5D0\uAC8C \uC788\uC73C\uB2C8 \uB2F9\uC7A5
      \uC77C\uC5B4\uB098 \uB2E4\uC2DC \uD574."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Principled_201
    ko: "\uB3D9\uB8CC\uB97C \uACBD\uC9C1\uC2DC\uCF30\uB2E4\uB2C8... \uC81C \uADA4\uC801\uBCF4\uB2E4
      \uD070 \uBB38\uC81C\uAD70\uC694. \uB2F9\uC7A5 \uAE30\uBCF8\uAE30\uBD80\uD130
      \uACE0\uCE58\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Principled_2
    ko: "\uC9C8\uCC45\uC744 \uC0C8\uB85C\uC6B4 \uADDC\uC728\uB85C \uC218\uC6A9\uD574
      \uAE30\uACC4\uC801\uC73C\uB85C \uBC18\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Guardian_201
    ko: "\uD300\uC744 \uACBD\uC9C1\uC2DC\uCF30\uB2E4\uB2C8 \uC81C \uD328\uC2A4\uB294
      \uC815\uB9D0 \uCD5C\uC545\uC774\uC5C8\uC2B5\uB2C8\uB2E4... \uB2E4\uC2DC \uC2DC\uC791\uD560
      \uC790\uACA9\uC774 \uC788\uC744\uAE4C\uC694."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Guardian_2
    ko: "\uC9C8\uCC45\uC744 \uAC00\uCE58 \uBD80\uC815\uC73C\uB85C \uC5EC\uACA8 \uAE4A\uC740
      \uC790\uCC45\uC5D0 \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Tactician_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uB3D9\uB8CC\uC758 \uC190\uB05D\uC774 \uACB0\uACFC\uAC12\uC774\uB77C\uBA74
      \uADF8\uC5D0 \uB9DE\uCDB0 \uB370\uC774\uD130\uB97C \uB2E4\uC2DC \uC785\uB825\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uD6A8\uC728\uC801 \uC804\uC220 \uC9C0\uC2DC\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uC989\uC2DC \uC218\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Exemplary_201
    ko: "\uB124, \uADA4\uC801\uC740 \uC77C\uB2E8 \uC811\uC5B4\uB450\uACA0\uC2B5\uB2C8\uB2E4.
      \uB2E4\uB978 \uC120\uC218\uB4E4\uB3C4 \uC800\uB97C \uB530\uB77C\uC624\uAC8C\uB054
      \uB2F9\uC7A5 \uACE0\uCE58\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Exemplary_2
    ko: "\uC2DC\uC120\uC744 \uC758\uC2DD\uD558\uC5EC \uC9C8\uCC45\uC744 \uBAA8\uBA74\uD558\uB824\uB294
      \uD0DC\uB3C4\uB85C \uD6C8\uB828\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Discipline_003
    ko: "\uAC10\uB3C5\uC740 \uC2E4\uC218\uD558\uB294 \uC120\uC218\uC758 \uAD73\uC740
      \uADFC\uC721\uC744 \uBD80\uB4DC\uB7FD\uAC8C \uD480\uC5B4\uC900 \uB4A4 \uC81C\uC790\uB9AC\uB85C
      \uB3CC\uC544\uAC00 \uAE30\uB85D\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC81C \uBAB8\uC744 \uB9CC\uC9C0\uC168\uC5B4...
      \uB0B4 \uD328\uC2A4 \uADA4\uC801\uC774 \uBB3C\uB9AC\uC801\uC73C\uB85C \uC798\uBABB\uB418\uC5C8\uB2E4\uB294
      \uB73B\uC778\uAC00? \uBAB8\uC774 \uB354 \uC548 \uC6C0\uC9C1\uC5EC."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Principled_3
    ko: "\uC2E0\uCCB4\uC801 \uC811\uCD09\uC744 \uC6D0\uCE59\uC774 \uBD95\uAD34\uB41C
      \uC2E0\uD638\uB85C \uC5EC\uACBC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC800\uB97C \uB3D5\uACE0 \uACC4\uC154... \uC81C
      \uADA4\uC801\uC744 \uC9C0\uCF1C\uBCF4\uACE0 \uACC4\uC2DC\uB2C8\uAE4C \uC774\uBC88\uC5D4
      \uC131\uACF5\uD560 \uC218 \uC788\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Guardian_3
    ko: "\uC2E0\uCCB4\uC801 \uBC30\uB824\uB97C \uD300 \uBCF4\uD638\uB85C \uD574\uC11D\uD574
      \uC2EC\uB9AC\uC801 \uC548\uC815\uC744 \uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Tactician_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC81C \uADFC\uC721 \uB370\uC774\uD130\uB97C \uBD84\uC11D\uD558\uC2E0
      \uAC74\uAC00? \uC5B4\uAE68 \uC774\uC644\uC774 \uD328\uC2A4 \uD6A8\uC728\uC5D0
      \uC5B4\uB5A4 \uC601\uD5A5\uC744 \uBBF8\uCE58\uB294\uC9C0 \uAE30\uB85D\uD574\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Tactician_3
    ko: "\uD589\uB3D9\uC758 \uC758\uBBF8\uB97C \uBD84\uC11D\uD558\uC5EC \uB2E4\uC74C
      \uD6C8\uB828\uC758 \uC815\uBCF4\uB85C \uD65C\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Exemplary_301
    ko: "\uC544\uBB34 \uB9D0\uC500\uB3C4 \uC5C6\uC73C\uC2DC\uB2E4\uB2C8... \uC81C\uAC00
      \uBAA8\uBC94\uC774 \uB418\uC9C0 \uBABB\uD574 \uC2E4\uB9DD\uD558\uC2E0 \uAC74\uAC00
      \uBD10."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Exemplary_3
    ko: "\uBB34\uC5B8\uC758 \uD589\uB3D9\uC744 \uC790\uC2E0\uC5D0 \uB300\uD55C \uB099\uC81C\uB85C
      \uD574\uC11D\uD574 \uC704\uCD95\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Bond_001
    ko: "\uC815\uADDC \uD6C8\uB828 \uC9C1\uC804, \uAC74\uC870\uD55C \uBC14\uB78C\uACFC
      \uBA3C\uC9C0\uAC00 \uD718\uB0A0\uB9AC\uB294 \uCF54\uD2B8. \uC120\uC218\uB294
      \uC790\uC2E0\uC758 \uD328\uC2A4\uAC00 \uB3D9\uB8CC\uC758 \uAC00\uC2B4\uC5D0
      \uB2FF\uC9C0 \uC54A\uC790 \uC2EC\uD55C \uD328\uB2C9\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Bond_002
    ko: "\uD328\uC2A4\uB294 \uC815\uD574\uC9C4 \uADA4\uC801\uC744 \uADF8\uB824\uC57C
      \uD55C\uB2E4 \uB294 \uC6D0\uCE59\uC744 \uAC15\uBC15\uC801\uC73C\uB85C \uC9C0\uD0A4\uB824\uB2E4
      \uADFC\uC721\uC774 \uAD73\uC5B4\uBC84\uB838\uACE0 \uACB0\uAD6D \uC2A4\uC2A4\uB85C\uB97C
      \uC6D0\uB9DD\uD558\uBA70 \uBC14\uB2E5\uC5D0 \uC8FC\uC800\uC549\uC558\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Bond_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Bond_001
    ko: "\uC2E4\uC218\uD574\uB3C4 \uAD1C\uCC2E\uB2E4. \uB3D5\uACE0 \uC2F6\uC740 \uB9C8\uC74C\uC740
      \uC544\uB2C8 \uB3D9\uB8CC \uD45C\uC815\uC744 \uBCF4\uBA70 \uD3B8\uD558\uAC8C
      \uACF5\uC744 \uBCF4\uB0B4\uBD10."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uC81C \uB9C8\uC74C\uC744 \uC54C\uC544\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uB3D9\uB8CC\uB97C \uBCF4\uBA70 \uB2E4\uC2DC
      \uB358\uC838\uBCFC\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Kind_1
    ko: "\uC815\uC11C\uC801 \uC9C0\uC9C0\uB97C \uD655\uC778\uD558\uC790 \uC2EC\uB9AC\uC801
      \uC548\uC815\uC744 \uCC3E\uC544 \uD68C\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uBC30\uB824\uB97C \uC78A\uC9C0 \uC54A\uACA0\uC2B5\uB2C8\uB2E4.
      \uD300\uC744 \uC704\uD574 \uB05D\uAE4C\uC9C0 \uCD5C\uC120\uC744 \uB2E4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Loyal_1
    ko: "\uD5CC\uC2E0\uC744 \uB2E4\uC9D0\uD588\uC73C\uB098 \uB2F9\uC7A5\uC758 \uC29B
      \uBBF8\uC2A4\uB294 \uACE0\uCE58\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Sincere_101
    ko: "\uB3D9\uB8CC\uC758 \uD45C\uC815\uC744 \uBCF4\uB77C\uACE0\uC694? \uADA4\uC801\uC774
      \uC544\uB2CC \uAC10\uAC01\uC5D0 \uC758\uC874\uD558\uB77C\uB294 \uAC74\uC9C0
      \uC774\uD574\uAC00 \uC548 \uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Sincere_1
    ko: "\uC870\uC5B8\uC774 \uAE30\uC874 \uB8E8\uD2F4\uACFC \uAC15\uD558\uAC8C \uCDA9\uB3CC\uD558\uC5EC
      \uD63C\uB780\uC5D0 \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Moodmaker_101
    ko: "\uB124! \uAE30\uBD84 \uC88B\uAC8C \uB2E4\uC2DC \uC2DC\uC791\uD560\uAC8C\uC694!
      \uB2E4\uB4E4 \uD30C\uC774\uD305!"
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Moodmaker_1
    ko: "\uACA9\uB824\uB85C \uAE30\uBD84\uC740 \uB098\uC544\uC84C\uC73C\uB098 \uAE30\uC220\uC801\uC778
      \uBCF4\uC644\uC740 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Bond_002
    ko: "\uADA4\uC801\uC5D0 \uC9D1\uCC29\uD558\uB290\uB77C \uB3D9\uB8CC\uB97C \uC678\uBA74\uD558\uC9C0
      \uB9C8\uB77C. \uB2F9\uC7A5 \uC77C\uC5B4\uB098\uC11C \uD300\uC744 \uC704\uD574
      \uB2E4\uC2DC \uC6C0\uC9C1\uC5EC."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Kind_201
    ko: "\uC800 \uB54C\uBB38\uC5D0 \uB3D9\uB8CC\uB4E4\uC774 \uD798\uB4E4\uC5C8\uAD70\uC694...
      \uC81C\uAC00 \uC815\uB9D0 \uC4F8\uBAA8\uC5C6\uB294 \uC0AC\uB78C\uC778\uAC00
      \uBD10\uC694."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Kind_2
    ko: "\uC9C8\uCC45\uC744 \uAD00\uACC4\uC801 \uBD80\uC815\uC73C\uB85C \uC5EC\uACA8
      \uC790\uC874\uAC10\uACFC \uC758\uC695\uC744 \uC783\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Loyal_201
    ko: "\uC81C\uAC00 \uB3D9\uB8CC\uB97C \uC678\uBA74\uD558\uACE0 \uC788\uC5C8\uAD70\uC694!
      \uBC14\uB85C \uD300\uC744 \uC704\uD574 \uB2E4\uC2DC \uB6F0\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Loyal_2
    ko: "\uCDA9\uC131\uC2EC\uC5D0 \uB300\uD55C \uACBD\uACE0\uB85C \uC5EC\uACA8 \uD22C\uC9C0\uB97C
      \uBD88\uD0DC\uC6B0\uBA70 \uBCF5\uAD6C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Sincere_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uADA4\uC801 \uC678\uC5D0 \uB2E4\uB978 \uBCC0\uC218\uB97C
      \uACE0\uB824\uD558\uC5EC \uD6C8\uB828 \uACC4\uD68D\uC744 \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Sincere_2
    ko: "\uC9C8\uCC45\uC744 \uC0C8\uB85C\uC6B4 \uD6C8\uB828 \uACFC\uC81C\uB85C \uC5EC\uACA8
      \uAE30\uACC4\uC801\uC73C\uB85C \uC218\uD589\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Moodmaker_201
    ko: "\uC800\uBCF4\uACE0 \uB3D9\uB8CC\uB97C \uC678\uBA74\uD588\uB2E4\uB2C8\uC694...
      \uAC10\uB3C5\uB2D8\uAED8 \uBBF8\uC6C0\uC744 \uBC1B\uB294 \uAC83 \uAC19\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Moodmaker_2
    ko: "\uC9C8\uCC45\uC744 \uAD00\uACC4 \uB2E8\uC808\uB85C \uC5EC\uACA8 \uCDA9\uACA9\uBC1B\uACE0
      \uD6C8\uB828\uC744 \uBA48\uCDC4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Bond_003
    ko: "\uAC10\uB3C5\uC740 \uC8FC\uC800\uC549\uC740 \uC120\uC218\uC758 \uC190\uC5D0
      \uC9C1\uC811 \uACF5\uC744 \uC950\uC5EC\uC8FC\uBA70 \uB2E4\uC74C \uD6C8\uB828
      \uC21C\uC11C\uB85C \uC870\uC6A9\uD788 \uBC00\uC5B4 \uB123\uB294\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC606\uC5D0 \uACC4\uC2DC\uB2C8 \uC870\uAE08 \uB9C8\uC74C\uC774
      \uB193\uC774\uB124\uC694. \uB2E4\uC2DC \uD574\uBCFC\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Kind_3
    ko: "\uC9C0\uC9C0\uB97C \uB290\uAEF4 \uBD88\uC548\uC740 \uAC00\uC168\uC73C\uB098
      \uAE30\uC220\uC801 \uAC1C\uC120\uC740 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Loyal_301
    ko: "\uC800\uB97C \uBBFF\uC5B4\uC8FC\uC2DC\uB294 \uB9CC\uD07C \uBC18\uB4DC\uC2DC
      \uC131\uACF5\uD574\uC57C \uD55C\uB2E4\uB294 \uC0DD\uAC01\uC5D0... \uC190\uC774
      \uB354 \uB5A8\uB9BD\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Loyal_3
    ko: "\uC2E0\uB8B0 \uD589\uB3D9\uC744 \uBB34\uAC70\uC6B4 \uCC45\uC784\uAC10\uC73C\uB85C
      \uB290\uAEF4 \uC555\uBC15\uC5D0 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Sincere_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uACF5\uC744 \uC8FC\uC2E0 \uAC74 \uB8E8\uD2F4\uC744
      \uB2E4\uC2DC \uC138\uC6B0\uB77C\uB294 \uC758\uBBF8\uAD70\uC694. \uC774 \uD589\uB3D9\uC744
      \uBD84\uC11D\uD574 \uD3FC\uC744 \uC815\uB9BD\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Sincere_3
    ko: "\uD589\uB3D9\uC5D0\uC11C \uD6C8\uB828 \uB370\uC774\uD130\uB97C \uB3C4\uCD9C\uD574
      \uB8E8\uD2F4\uC744 \uC7AC\uC124\uACC4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Moodmaker_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC808 \uCC59\uACA8\uC8FC\uC2DC\uB2E4\uB2C8! \uB2E4\uC2DC
      \uBD84\uC704\uAE30 \uB744\uC6CC\uC11C \uBAA8\uB450\uB97C \uC6C3\uAC8C \uB9CC\uB4E4\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Moodmaker_3
    ko: "\uBC30\uB824\uB97C \uD300 \uBD84\uC704\uAE30\uB97C \uC0B4\uB9AC\uB77C\uB294
      \uB73B\uC73C\uB85C \uC774\uD574\uD574 \uD68C\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Cold_001
    ko: "\uC815\uADDC \uD6C8\uB828 \uC9C1\uC804, \uBA3C\uC9C0 \uC11E\uC778 \uBC14\uB78C\uC774
      \uBD80\uB294 \uCF54\uD2B8. \uC120\uC218\uB294 \uC790\uC2E0\uC758 \uD328\uC2A4\uAC00
      \uB3D9\uB8CC\uC758 \uAC00\uC2B4\uC5D0 \uC815\uD655\uD788 \uB3C4\uB2EC\uD558\uC9C0
      \uC54A\uC790 \uB370\uC774\uD130 \uC624\uB958\uAC00 \uBC1C\uC0DD\uD55C \uAC83\uCC98\uB7FC
      \uD328\uB2C9\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Cold_002
    ko: "\uD328\uC2A4\uB294 \uC815\uD574\uC9C4 \uADA4\uC801\uC744 \uADF8\uB824\uC57C
      \uD55C\uB2E4 \uB294 \uC6D0\uCE59\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uADFC\uC721\uC774
      \uACBD\uC9C1\uB41C \uCC44 \uC2A4\uC2A4\uB85C\uB97C \uC6D0\uB9DD\uD558\uBA70
      \uC8FC\uC800\uC549\uC544 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Cold_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Cold_001
    ko: "\uD328\uC2A4 \uC2E4\uD328\uB294 \uC678\uBD80 \uD658\uACBD \uD0D3\uC774\uB2C8,
      \uBC14\uB78C \uB4F1\uC758 \uBB3C\uB9AC\uC801 \uBCC0\uC218\uB97C \uC218\uC2DD\uC5D0
      \uB123\uACE0 \uB2E4\uC2DC \uD574\uBD10."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Planner_101
    ko: "\uC678\uBD80 \uBCC0\uC218 \uBCF4\uC815... \uADF8 \uC0DD\uAC01\uC744 \uBABB
      \uD588\uC2B5\uB2C8\uB2E4. \uBC14\uB85C \uADA4\uC801\uC744 \uC218\uC815\uD574
      \uC131\uACF5\uB960\uC744 \uB192\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Planner_1
    ko: "\uBCC0\uC218\uB97C \uB17C\uB9AC\uC801 \uC218\uC2DD\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uD6C8\uB828 \uD6A8\uC728\uC744 \uB192\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Opportunist_101
    ko: "\uBCF4\uC815\uAC12\uC744 \uB123\uC73C\uBA74 \uD328\uC2A4 \uC815\uD655\uB3C4\uAC00
      \uC624\uB974\uACA0\uAD70\uC694. \uADF8\uAC78 \uB0B4 \uC2E4\uB825\uC73C\uB85C
      \uD3EC\uC7A5\uD558\uBA74 \uB418\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Opportunist_1
    ko: "\uAC10\uB3C5\uC758 \uC81C\uC548\uC744 \uC29B \uC131\uACF5\uB960\uC744 \uB192\uC77C
      \uAE30\uD68C\uB85C\uB9CC \uC778\uC2DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Cunning_101
    ko: "\uB370\uC774\uD130 \uBCF4\uC815? \uC81C \uAC10\uAC01\uC740 \uC774\uBBF8
      \uBC14\uB78C\uAE4C\uC9C0 \uB2E4 \uACC4\uC0B0\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4.
      \uC9C0\uC2DC \uC548 \uB530\uB974\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Cunning_1
    ko: "\uD1B5\uC81C\uAD8C\uC744 \uC783\uC9C0 \uC54A\uC73C\uB824\uB294 \uBC29\uC5B4
      \uAE30\uC81C\uB85C \uACA9\uB824\uB97C \uBB34\uC2DC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Believer_101
    ko: "\uB370\uC774\uD130 \uBCF4\uC815\uC740 \uC81C \uADA4\uC801\uC758 \uC21C\uC218\uC131\uC744
      \uD574\uCE69\uB2C8\uB2E4. \uBCC0\uC218\uBCF4\uB2E4\uB294 \uADA4\uC801\uC758
      \uC815\uD655\uC131\uC744 \uB192\uC774\uB294 \uAC8C \uC6B0\uC120\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Believer_1
    ko: "\uD655\uACE0\uD55C \uC21C\uC218 \uADA4\uC801 \uCCA0\uD559 \uB54C\uBB38\uC5D0
      \uC678\uBD80 \uC81C\uC548\uC744 \uAC70\uC808\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Cold_002
    ko: "\uD3FC\uB9CC \uACE0\uC9D1\uD558\uB294 \uAC74 \uC804\uC220\uC801 \uACE0\uB9BD\uC774\uB2E4.
      \uAE34\uC7A5\uC744 \uD480\uACE0 \uAE30\uBCF8 \uADA4\uC801\uC73C\uB85C \uB370\uC774\uD130\uB97C
      \uC7AC\uC785\uB825\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Planner_201
    ko: "\uC2DC\uC2A4\uD15C \uC624\uB958\uB97C \uBC29\uCE58\uD588\uAD70\uC694. \uC989\uC2DC
      \uAE30\uBCF8 \uADA4\uC801\uC73C\uB85C \uB3CC\uC544\uAC00 \uB370\uC774\uD130\uB97C
      \uBCF4\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Planner_2
    ko: "\uC2DC\uC2A4\uD15C \uD6A8\uC728\uC131\uC744 \uCD5C\uC6B0\uC120\uC73C\uB85C
      \uC5EC\uACA8 \uC989\uAC01 \uD3FC\uC744 \uC218\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Opportunist_201
    ko: "\uBD84\uC11D\uC774 \uBD80\uC871\uD588\uB2E4\uB294 \uB9D0\uC500\uC778\uAC00\uC694?
      \uACB0\uACFC\uB9CC \uB0B4\uBA74 \uB418\uB294 \uAC70 \uC544\uB2D9\uB2C8\uAE4C...
      \uC774\uC81C \uADA4\uC801 \uC548 \uBC14\uAFC9\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Opportunist_2
    ko: "\uC790\uC2E0\uC758 \uBC29\uC2DD\uC744 \uBD80\uC815\uB2F9\uD588\uB2E4\uACE0
      \uD310\uB2E8\uD574 \uD6C8\uB828\uC744 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Cunning_201
    ko: "\uC804\uC220\uC801 \uACE0\uB9BD\uC744 \uC790\uCD08\uD588\uAD70\uC694. \uC1A1\uAD6C\uD569\uB2C8\uB2E4.
      \uB9D0\uC500\uB300\uB85C \uB2F9\uC7A5 \uAD50\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Cunning_2
    ko: "\uC9C8\uCC45\uC744 \uAD8C\uC704\uC801 \uBA85\uB839\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uAC89\uC73C\uB85C\uB9CC \uC21C\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Believer_201
    ko: "\uACB0\uACFC\uAC12\uC774 \uC548 \uB098\uC624\uB294 \uAC74 \uC81C \uC6D0\uCE59\uC774
      \uBD80\uC871\uD588\uAE30 \uB54C\uBB38\uC774\uAD70\uC694. \uC2B9\uB960 \uB370\uC774\uD130\uB97C
      \uC704\uD574 \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Believer_2
    ko: "\uC2B9\uB960\uC774\uB77C\uB294 \uBAA9\uD45C\uB97C \uC2E0\uB150\uACFC \uC77C\uCE58\uC2DC\uCF1C
      \uC989\uAC01 \uC218\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Cold_003
    ko: "\uAC10\uB3C5\uC740 \uBB35\uBB35\uD788 \uCF54\uD2B8 \uC704 \uBC14\uB78C \uBC29\uD5A5\uC744
      \uC190\uC73C\uB85C \uAC00\uB9AC\uCF1C\uC900 \uB4A4 \uC120\uC218\uC758 \uC2E4\uCC45
      \uD69F\uC218\uB97C \uAE30\uB85D\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Planner_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC2E4\uCC45\uC744 \uAE30\uB85D\uD558\uACE0 \uACC4\uC154...
      \uB0B4 \uBD84\uC11D\uC5D0 \uACB0\uD568\uC774 \uC788\uB2E4\uB294 \uB73B\uC778\uAC00?
      \uBA38\uB9AC\uAC00 \uBCF5\uC7A1\uD574 \uC544\uBB34\uAC83\uB3C4 \uBABB \uD558\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Planner_3
    ko: "\uD53C\uB4DC\uBC31 \uBD80\uC7AC\uB97C \uC2DC\uC2A4\uD15C \uACB0\uD568\uC73C\uB85C
      \uC5EC\uACA8 \uD63C\uB780\uC774 \uAC00\uC911\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Opportunist_301
    ko: "\uBC14\uB78C \uBC29\uD5A5\uC744 \uAC00\uB9AC\uD0A4\uC2DC\uB2E4\uB2C8...
      \uC774\uAC78 \uC774\uC6A9\uD558\uBA74 \uC544\uBB34\uB3C4 \uB0B4 \uD328\uC2A4\uB97C
      \uBABB \uC77D\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Opportunist_3
    ko: "\uAC10\uB3C5\uC758 \uD589\uB3D9\uC744 \uD78C\uD2B8\uB85C \uC0BC\uC544 \uB3C5\uC790\uC801\uC778
      \uD328\uC2A4\uB97C \uC644\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Cunning_301
    ko: "\uB370\uC774\uD130 \uAE30\uB85D \uC911\uC774\uC2DC\uB124... \uC77C\uB2E8
      \uD3FC \uC7A1\uACE0 \uB358\uC9C0\uB294 \uCC99\uD558\uB2E4\uAC00 \uB098\uC911\uC5D0
      \uB0B4 \uBC29\uC2DD\uB300\uB85C \uD574\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Cunning_3
    ko: "\uAC10\uC2DC\uB97C \uC5ED\uC774\uC6A9\uD574 \uAC89\uC73C\uB85C\uB9CC \uD6C8\uB828\uD558\uB294
      \uCC99 \uC2DC\uAC04\uC744 \uB54C\uC6E0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Believer_301
    ko: "\uB098\uB97C \uAE30\uB85D\uD558\uACE0 \uACC4\uC154... \uB0B4 \uD328\uC2A4\uB294
      \uB354 \uC774\uC0C1 \uD300\uC758 \uC6D0\uCE59\uC5D0 \uBD80\uD569\uD558\uC9C0
      \uC54A\uB098 \uBD10."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Believer_3
    ko: "\uCE68\uBB35\uC744 \uCCA0\uD559\uC5D0 \uB300\uD55C \uAC70\uBD80\uB85C \uD574\uC11D\uD574
      \uC644\uC804\uD788 \uBD95\uAD34\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Instinct_001
    ko: "\uD6C8\uB828 \uC9C1\uC804, \uBC14\uB78C\uACFC \uBA3C\uC9C0\uAC00 \uC11E\uC778
      \uCF54\uD2B8. \uC120\uC218\uB294 \uD328\uC2A4 \uBBF8\uC2A4 \uC774\uD6C4 '\uADA4\uC801'\uC774\uB77C\uB294
      \uAC15\uBC15\uC5D0 \uAC07\uD600 \uBAB8\uC774 \uC644\uC804\uD788 \uAD73\uC5C8\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Instinct_002
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Instinct_001
    ko: "\uC2E4\uC218\uAC00 \uC544\uB2C8\uB2C8 \uC218\uC2DD\uC744 \uC78A\uC5B4\uB77C.
      \uB208\uBE5B\uC744 \uAD50\uD658\uD558\uBA70 \uACF5\uC744 \uD3B8\uC548\uD788
      \uBCF4\uB0B4\uC900\uB2E4\uB294 \uB290\uB08C\uC73C\uB85C \uD574."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uC81C \uAC10\uAC01\uC744 \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694!
      \uC218\uC2DD \uBC84\uB9AC\uACE0 \uBCF8\uB2A5\uB300\uB85C \uAF42\uC544\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Bluffer_1
    ko: "\uCC9C\uC7AC\uC131\uC744 \uC778\uC815\uBC1B\uC544 \uC790\uC874\uAC10\uC774
      \uC624\uB974\uBA70 \uACFC\uAC10\uD788 \uC131\uACF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Wild_101
    ko: "\uBC14\uB78C \uACC4\uC0B0\uD560 \uAC83 \uC5C6\uACA0\uB124\uC694. \uB290\uB08C\uB300\uB85C
      \uB358\uC838\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Wild_1
    ko: "\uBCF8\uB2A5 \uAE0D\uC815\uC5D0\uB294 \uACF5\uAC10\uD588\uC73C\uB098 \uC804\uCCB4
      \uC804\uC220 \uCCB4\uACC4\uB294 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Egoist_101
    ko: "\uAC10\uAC01\uC774 \uB2F5\uC774\uB77C\uACE0\uC694? \uC774\uBBF8 \uC804 \uC81C
      \uADA4\uC801\uC744 \uCC3E\uC558\uC2B5\uB2C8\uB2E4. \uAC04\uC12D\uD558\uC9C0
      \uB9C8\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Egoist_1
    ko: "\uB3C5\uC790 \uB178\uC120 \uBC29\uD574\uB85C \uAC04\uC8FC\uD558\uC5EC \uAC10\uB3C5\uC758
      \uACA9\uB824\uB97C \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Fighter_101
    ko: "\uADA4\uC801\uC740 \uC81C \uBC29\uC2DD\uB300\uB85C \uADF8\uB9B4 \uAC81\uB2C8\uB2E4.
      \uB204\uAD6C\uC758 \uC9C0\uC2DC\uB3C4 \uD544\uC694 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Fighter_1
    ko: "\uBC29\uC2DD\uC744 \uBD80\uC815\uB2F9\uD55C \uAC83\uC73C\uB85C \uB290\uAEF4
      \uD6C8\uB828 \uC758\uC695\uC744 \uC0C1\uC2E4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Instinct_002
    ko: "\uB18D\uAD6C\uB294 \uC218\uD559\uC774 \uC544\uB2C8\uB2E4. \uADA4\uC801 \uB300\uC2E0
      \uD300\uC6D0\uC758 \uC6C0\uC9C1\uC784\uC744 \uBCF4\uACE0 \uBAB8\uC774 \uAE30\uC5B5\uD558\uB294
      \uB300\uB85C \uB358\uC838\uB77C."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Bluffer_201
    ko: "\uC81C \uBCF8\uB2A5\uC744 \uBAA8\uB974\uC2DC\uB124\uC694... \uC624\uB298
      \uD328\uC2A4\uAC00 \uC548 \uB418\uB294 \uAC74 \uAC10\uB3C5\uB2D8 \uB54C\uBB38\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Bluffer_2
    ko: "\uC9C8\uCC45\uC744 \uCE58\uBA85\uC801\uC778 \uBAA8\uC695\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uD6C8\uB828\uC744 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Wild_201
    ko: "\uC774 \uC9C0\uAE0B\uC9C0\uAE0B\uD55C \uACC4\uC0B0\uC5D0\uC11C \uD574\uBC29\uC2DC\uCF1C
      \uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uC774\uC81C\uC57C \uC9C4\uC9DC
      \uC81C \uD328\uC2A4\uAC00 \uB098\uAC11\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Wild_2
    ko: "\uAC15\uBC15\uC801\uC778 \uACC4\uC0B0\uC5D0\uC11C \uBC97\uC5B4\uB098\uC790
      \uC5B5\uB20C\uB9B0 \uC7A0\uC7AC\uB825\uC774 \uD3ED\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Egoist_201
    ko: "\uADA4\uC801\uBCF4\uB2E4 \uB3D9\uB8CC\uB77C\uACE0\uC694? \uC54C\uACA0\uC2B5\uB2C8\uB2E4.
      \uC81C \uD328\uC2A4\uB97C \uBC1B\uB294 \uB188\uC774 \uC54C\uC544\uC11C \uBC1B\uAC8C
      \uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Egoist_2
    ko: "\uC9C8\uCC45\uC744 \uAC15\uD55C \uC2B9\uBD80\uC695\uC73C\uB85C \uCE58\uD658\uD574
      \uAE30\uACC4\uC801\uC73C\uB85C \uC218\uD589\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Fighter_201
    ko: "\uC81C\uAC00 \uB3D9\uB8CC\uB97C \uB193\uCCE4\uB2E4\uACE0\uC694? \uC88B\uC2B5\uB2C8\uB2E4.
      \uBCF4\uB780 \uB4EF\uC774 \uC644\uBCBD\uD55C \uD328\uC2A4\uB97C \uCC14\uB7EC\uB123\uC5B4
      \uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Fighter_2
    ko: "\uC0C1\uD669\uC744 \uC815\uBA74 \uC2B9\uBD80\uB85C \uBC1B\uC544\uB4E4\uC774\uBA70
      \uAC15\uD55C \uC624\uAE30\uAC00 \uBC1C\uB3D9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Instinct_003
    ko: "\uAC10\uB3C5\uC740 \uC120\uC218\uC758 \uC190\uBAA9\uC744 \uCCD0\uC11C \uD0C0\uAC9F\uC744
      \uD5A5\uD558\uAC8C \uADA4\uC801\uC744 \uAC15\uC81C \uC218\uC815\uD55C \uB4A4
      \uB9D0\uC5C6\uC774 \uD328\uC2A4\uC2DC\uD0A8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Bluffer_301
    ko: "\uC65C \uB0B4 \uC190\uBAA9\uC744 \uC7A1\uC73C\uC2DC\uC8E0? \uC804 \uC2A4\uC2A4\uB85C
      \uADA4\uC801\uC744 \uADF8\uB9B4 \uC218 \uC788\uB294\uB370..."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Bluffer_3
    ko: "\uAE30\uB7C9 \uACFC\uC2DC \uAE30\uD68C\uB97C \uC783\uC5C8\uB2E4\uACE0 \uC0DD\uAC01\uD574
      \uC9D1\uC911\uB825\uC774 \uBD84\uC0B0\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Wild_301
    ko: "\uC65C \uB0B4 \uD314\uC744 \uAC15\uC81C\uB85C \uC6C0\uC9C1\uC774\uC2DC\uC8E0?
      \uB09C \uB0B4 \uBAB8\uC73C\uB85C \uB290\uB080 \uB300\uB85C \uB358\uC9C8 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Wild_3
    ko: "\uBB3C\uB9AC\uC801 \uAC15\uC81C\uC131\uC744 \uAD8C\uC704 \uCE68\uD574\uB85C
      \uAC04\uC8FC\uD574 \uD6C8\uB828\uC5D0 \uBC18\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Egoist_301
    ko: "\uAC10\uB3C5\uB2D8 \uC190\uAE38\uC744 \uAC70\uCE58\uB2C8 \uD328\uC2A4\uAC00
      \uC815\uD655\uD558\uB124\uC694... \uC774 \uAC01\uB3C4\uB97C \uAE30\uC5B5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Egoist_3
    ko: "\uAC1C\uC785\uC774 \uC2DC\uC57C\uB97C \uB113\uD600\uC8FC\uC5B4 \uC644\uBCBD\uD55C
      \uD328\uC2A4\uB97C \uC131\uACF5\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Fighter_301
    ko: "\uB0B4 \uC190\uC744 \uC7A1\uC73C\uC168\uAD70\uC694. \uB2E4\uC74C\uBC88\uC5D4
      \uAC10\uB3C5\uB2D8\uC774 \uC190 \uC548 \uB300\uB3C4 \uB3D9\uB8CC \uAC00\uC2B4\uC5D0
      \uAF42\uC544 \uB123\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Fighter_3
    ko: "\uACBD\uC7C1\uC801 \uC790\uADF9\uC740 \uC720\uC9C0\uD588\uC73C\uB098 \uC804\uC220\uBCF4\uB2E4
      \uAC1C\uC778\uAE30\uB85C \uD758\uB800\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Discipline_001
    ko: "\uC2B5\uAE30 \uCC2C \uCCB4\uC721\uAD00, \uD300\uC758 \uD328\uC2A4 \uD750\uB984\uC744
      \uC8FC\uB3C4\uD574\uC57C \uD560 \uC120\uC218\uAC00 \uC790\uC2E0\uC758 \uC804\uC220\uC801
      \uAE38\uB9CC\uC744 \uACE0\uC9D1\uD558\uB2E4 \uC5F0\uB2EC\uC544 \uC2E4\uCC45\uC744
      \uBC94\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Discipline_002
    ko: "\uC790\uC720\uB85C\uC6B4 \uC6C0\uC9C1\uC784\uC744 '\uD63C\uB780'\uC73C\uB85C
      \uAC04\uC8FC\uD558\uB294 \uC120\uC218\uB294, \uD300\uC6D0\uB4E4\uACFC\uC758
      \uD638\uD761 \uC2E4\uD328\uB97C \uC790\uC2E0\uC758 \uC124\uACC4 \uACB0\uD568\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uC790\uAD34\uAC10\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Discipline_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Discipline_001
    ko: "\uC815\uAD50\uD55C \uC124\uACC4\uC5D0 \uD300\uC6D0\uB4E4\uC758 \uBCC0\uCE59\uC801\uC778
      \uC6C0\uC9C1\uC784\uAE4C\uC9C0 \uBCC0\uC218\uB85C \uD3EC\uD568\uC2DC\uD0A4\uBA74
      \uD328\uC2A4\uAC00 \uB354 \uC644\uBCBD\uD574\uC9C8 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Principled_101
    ko: "20cm\uC758 \uBCF4\uC815\uAC12... \uBCC0\uC218\uB97C \uC6D0\uCE59\uC5D0 \uD3EC\uD568\uD558\uBA74
      \uB418\uB294\uAD70\uC694. \uC9C0\uAE08 \uC989\uC2DC \uC804\uC220\uC744 \uC5C5\uB370\uC774\uD2B8\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Principled_1
    ko: "\uC0C8\uB85C\uC6B4 \uC6D0\uCE59\uC744 \uC138\uC6CC \uBD88\uC548\uC744 \uC5C6\uC560\uACE0
      \uD6C8\uB828 \uC9C8\uC744 \uB192\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Guardian_101
    ko: "\uBCC0\uCE59\uC801 \uC6C0\uC9C1\uC784\uC744 \uC218\uC6A9\uD558\uBA74 \uD328\uC2A4
      \uD6A8\uC728\uC774 \uB354 \uC624\uB97C\uAE4C\uC694? \uD300\uC744 \uC704\uD574
      \uC5F0\uAD6C\uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Guardian_1
    ko: "\uCC45\uC784\uAC10\uC774 \uC804\uC220 \uD655\uC7A5\uC73C\uB85C \uC774\uC5B4\uC84C\uC73C\uB098
      \uC555\uBC15\uAC10\uC774 \uCEE4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Tactician_101
    ko: "\uBCC0\uCE59\uC801 \uC6C0\uC9C1\uC784\uC740 \uD1B5\uACC4\uC801\uC73C\uB85C
      \uBD88\uD655\uC2E4\uC131\uC774 \uB192\uC2B5\uB2C8\uB2E4. \uC81C \uC815\uC11D
      \uD328\uC2A4\uAC00 \uB354 \uC548\uC804\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Tactician_1
    ko: "\uD655\uB960 \uC911\uC2EC\uC758 \uC0AC\uACE0\uBC29\uC2DD \uD0D3\uC5D0 \uC804\uC220
      \uD655\uC7A5\uC744 \uB17C\uB9AC\uB85C \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Exemplary_101
    ko: "\uB124! \uAC10\uB3C5\uB2D8 \uC870\uC5B8\uB300\uB85C \uB3D9\uB8CC\uC640 \uC18C\uD1B5\uD558\uBA70
      \uCD5C\uACE0\uC758 \uD328\uC2A4 \uAE38\uC744 \uB2E4\uC2DC \uB9CC\uB4E4\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Exemplary_1
    ko: "\uAE0D\uC815\uC801 \uC804\uC220 \uC9C0\uCE68\uC744 \uC218\uC6A9\uD574 \uC790\uC2E0\uAC10
      \uC788\uAC8C \uD300\uC744 \uC774\uB04C\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Discipline_002
    ko: "\uB124 \uD328\uC2A4\uB294 \uC544\uC9D1\uC77C \uBFD0\uC774\uB2E4. \uC804\uC220\uC740
      \uC120\uC774 \uC544\uB2C8\uB77C \uD300\uC774 \uC6C0\uC9C1\uC774\uB294 \uAE38\uC774\uB2C8
      \uACE0\uC815\uAD00\uB150\uC744 \uBC84\uB824."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Principled_201
    ko: "\uC544\uC9D1\uC774\uC5C8\uAD70\uC694... \uD300\uC758 \uC804\uC220\uC801
      \uC77C\uAD00\uC131\uC744 \uC704\uD574 \uC989\uC2DC \uC124\uACC4\uB3C4\uB97C
      \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Principled_2
    ko: "\uC624\uB958\uB97C \uAE68\uB2EB\uACE0 \uAE30\uACC4\uC801\uC73C\uB85C \uC815\uC11D
      \uD328\uC2A4\uB85C \uC989\uC2DC \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Guardian_201
    ko: "\uC81C\uAC00 \uD300\uC744 \uBC29\uD574\uD558\uACE0 \uC788\uC5C8\uB2E4\uB2C8...
      \uC804\uC220\uC801 \uC790\uC9C8\uC774 \uBD80\uC871\uD55C \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Guardian_2
    ko: "\uC9C8\uCC45\uC744 \uC804\uC220\uC801 \uB2A5\uB825\uC5D0 \uB300\uD55C \uD30C\uBA78\uC801
      \uD3C9\uAC00\uB85C \uC5EC\uACA8 \uD3EC\uAE30\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Tactician_201
    ko: "\uD1B5\uACC4\uC801 \uD6A8\uC728\uC131\uC774 \uB0AE\uC740 \uD328\uC2A4\uB97C
      \uACE0\uC9D1\uD588\uAD70\uC694. \uB370\uC774\uD130 \uAE30\uBC18\uC73C\uB85C
      \uC804\uC220\uC744 \uC7AC\uD3B8\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Tactician_2
    ko: "\uD6A8\uC728\uC131\uC774\uB77C\uB294 \uBA85\uBD84\uC774 \uC8FC\uC5B4\uC9C0\uC790
      \uC989\uC2DC \uADA4\uC801\uC744 \uC218\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Exemplary_201
    ko: "\uB124, \uBC14\uB85C \uC815\uC11D\uB300\uB85C \uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uD300\uC6D0\uB4E4\uC774 \uD63C\uB780\uC2A4\uB7FD\uC9C0 \uC54A\uAC8C \uC81C\uAC00
      \uBA3C\uC800 \uBAA8\uBC94\uC744 \uBCF4\uC774\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Exemplary_2
    ko: "\uC9C8\uCC45\uC744 \uD53C\uD558\uAE30 \uC704\uD574 \uC989\uAC01 \uBAA8\uBC94\uC801\uC778
      \uC815\uC11D\uC73C\uB85C \uD68C\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Discipline_003
    ko: "\uAC10\uB3C5\uC740 \uC804\uC220\uD310\uC5D0 \uB3D9\uB8CC\uB4E4\uC758 \uB3D9\uC120\uC744
      \uB367\uADF8\uB824 \uBCF4\uC5EC\uC8FC\uACE0 '\uB354 \uB113\uC740 \uC804\uC220\uC801
      \uD6A8\uC728'\uC744 \uBA54\uBAA8\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Principled_301
    ko: "\uC81C \uC804\uC220\uD310\uC5D0 \uD300\uC6D0\uB4E4\uC758 \uBCC0\uCE59\uC801\uC778
      \uB3D9\uC120\uC774... \uC774\uAC8C \uB9DE\uB2E4\uBA74 \uC81C \uAE30\uC874 \uC124\uACC4\uB294
      \uD3D0\uAE30\uD574\uC57C \uD558\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Principled_3
    ko: "\uB17C\uB9AC \uCCB4\uACC4\uAC00 \uBD80\uC815\uB2F9\uD55C \uAC83\uC73C\uB85C
      \uC778\uC2DD\uD574 \uBA58\uD0C8\uC774 \uBD95\uAD34\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC124\uACC4\uD558\uC2E0 \uC774 \uBCC0\uCE59\uC801
      \uAE38... \uC774\uAC8C \uBC14\uB85C \uD300\uC744 \uC9C0\uD0A4\uB294 \uC804\uC220\uC774\uAD70\uC694.
      \uBC14\uB85C \uC801\uC6A9\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Guardian_3
    ko: "\uC2DC\uAC01\uC801 \uAD50\uC815\uC73C\uB85C \uC758\uB3C4\uB97C \uD30C\uC545\uD574
      \uC2DC\uC2A4\uD15C\uC744 \uC644\uBCBD\uD788 \uD761\uC218\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Tactician_301
    ko: "\uC774 \uBCC0\uC218\uAC12\uB4E4\uC740 \uACE0\uB824\uD558\uC9C0 \uBABB\uD588\uAD70\uC694.
      \uB2E4\uC74C \uD6C8\uB828 \uB54C\uB294 \uC774 \uB3D9\uC120 \uB370\uC774\uD130\uB97C
      \uD3EC\uD568\uD574 \uD328\uC2A4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Tactician_3
    ko: "\uC804\uC220\uD310\uC758 \uB370\uC774\uD130\uB97C \uBD84\uC11D\uD574 \uC804\uC220\uC744
      \uC815\uBC00\uD558\uAC8C \uACE0\uB3C4\uD654\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Exemplary_301
    ko: "\uC81C \uC804\uC220\uD310\uC5D0 \uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uADF8\uB824\uC8FC\uC168\uC5B4...
      \uC81C\uAC00 \uBAA8\uBC94\uC801\uC774\uC9C0 \uBABB\uD574\uC11C \uC2E4\uB9DD\uD558\uC2E0
      \uAC74\uAC00 \uBD10."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Exemplary_3
    ko: "\uBB34\uC5B8\uC758 \uD53C\uB4DC\uBC31\uC744 \uC804\uC220\uC801 \uB099\uC81C\uB85C
      \uD574\uC11D\uD558\uC5EC \uD06C\uAC8C \uC704\uCD95\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Bond_001
    ko: "\uC2B5\uAE30 \uCC2C \uCCB4\uC721\uAD00, \uD300\uC758 \uD328\uC2A4 \uD750\uB984\uC744
      \uC8FC\uB3C4\uD574\uC57C \uD560 \uC120\uC218\uAC00 \uC790\uC2E0\uC758 \uC804\uC220\uC801
      \uAE38\uB9CC\uC744 \uACE0\uC9D1\uD558\uB2E4 \uC5F0\uB2EC\uC544 \uC2E4\uCC45\uC744
      \uBC94\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Bond_002
    ko: "\uC790\uC720\uB85C\uC6B4 \uC6C0\uC9C1\uC784\uC744 '\uD63C\uB780'\uC73C\uB85C
      \uAC04\uC8FC\uD558\uB294 \uC120\uC218\uB294, \uB3D9\uB8CC\uB4E4\uACFC\uC758
      \uD638\uD761 \uC2E4\uD328\uB97C \uC790\uC2E0\uC758 \uCC45\uC784\uC73C\uB85C
      \uB3CC\uB9AC\uBA70 \uAE4A\uC740 \uC790\uAD34\uAC10\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Bond_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Bond_001
    ko: "\uC815\uD574\uB454 \uAE38\uC744 \uBE44\uC6B0\uACE0 \uB3D9\uB8CC\uB4E4\uC758
      \uC6C0\uC9C1\uC784\uC5D0 \uB9DE\uCDB0\uBD10. \uADF8\uAC8C \uC11C\uB85C\uB97C
      \uC774\uC5B4\uC8FC\uB294 \uAC00\uC7A5 \uC548\uC804\uD55C \uAE38\uC774\uC57C."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uC81C \uC9C4\uC2EC\uC744 \uC54C\uC544\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uB3D9\uB8CC\uB4E4\uC758 \uB208\uC744 \uBCF4\uACE0
      \uB2E4\uC2DC \uC5F0\uACB0\uD574\uBCFC\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Kind_1
    ko: "\uB178\uB825\uC744 \uC778\uC815\uBC1B\uC790 \uC548\uC815\uC744 \uCC3E\uC544
      \uD328\uC2A4 \uB9AC\uB4EC\uC744 \uD68C\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Loyal_101
    ko: "\uB3D9\uB8CC\uB97C \uC704\uD574 \uC81C \uBC29\uC2DD\uC744 \uC7A0\uC2DC \uB0B4\uB824\uB193\uACA0\uC2B5\uB2C8\uB2E4.
      \uD300\uC744 \uC704\uD574 \uC804\uC220\uC744 \uC870\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Loyal_1
    ko: "\uBA85\uB839\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC \uD5CC\uC2E0\uC744 \uB2E4\uC9D0\uD588\uC73C\uB098
      \uD3FC \uC218\uC815\uC740 \uBD80\uC871\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Sincere_101
    ko: "\uB3D9\uB8CC\uC758 \uC6C0\uC9C1\uC784\uC5D0 \uB9DE\uCD94\uB77C\uACE0\uC694?
      \uADF8\uB7FC \uAE30\uC874 \uD328\uC2A4 \uB8E8\uD2F4\uC740 \uBC84\uB824\uC57C
      \uD569\uB2C8\uAE4C? \uAE30\uC900\uC774 \uBAA8\uD638\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Sincere_1
    ko: "\uC870\uC5B8\uACFC \uAE30\uC874 \uC804\uC220\uC774 \uCDA9\uB3CC\uD574 \uBC29\uD5A5\uC131\uC744
      \uC783\uACE0 \uD63C\uB780\uC744 \uACAA\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Moodmaker_101
    ko: "\uB124! \uB3D9\uB8CC\uB4E4\uACFC \uC6C3\uC73C\uBA74\uC11C \uB2E4\uC2DC \uD55C\uBC88
      \uB9DE\uCDB0\uBCFC\uAC8C\uC694! \uD328\uC2A4 \uBBF8\uC2A4\uB294 \uC78A\uC790!"
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Moodmaker_1
    ko: "\uACA9\uB824\uB97C \uC751\uC6D0\uC73C\uB85C\uB9CC \uBC1B\uC544\uB4E4\uC5EC
      \uC804\uC220\uC801\uC778 \uBCF4\uC644\uC740 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Bond_002
    ko: "\uACE0\uB9BD\uB418\uC5B4 \uC790\uAE30 \uC124\uACC4\uB9CC \uD0D3\uD558\uC9C0
      \uB9C8\uB77C. \uB10C \uB3D9\uB8CC\uB97C \uB3D5\uB294 \uAC8C \uC544\uB2C8\uB77C
      \uACE0\uC9D1\uB9CC \uD53C\uC6B0\uACE0 \uC788\uB294 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Kind_201
    ko: "\uC81C\uAC00 \uB3D9\uB8CC\uB4E4\uC744 \uC678\uBA74\uD558\uACE0 \uC788\uC5C8\uB2E4\uB2C8...
      \uC815\uB9D0 \uB108\uBB34 \uC8C4\uC1A1\uD574\uC694. \uC774\uC81C \uC5B4\uB5BB\uAC8C
      \uB2E4\uAC00\uAC00\uC57C \uD560\uC9C0 \uBAA8\uB974\uACA0\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Kind_2
    ko: "\uAD00\uACC4 \uC545\uD654 \uC9C8\uCC45\uC744 \uAC10\uB2F9\uD558\uC9C0 \uBABB\uD558\uACE0
      \uC815\uC11C\uC801\uC73C\uB85C \uBD95\uAD34\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Loyal_201
    ko: "\uC81C\uAC00 \uB3D9\uB8CC\uB4E4\uC744 \uD798\uB4E4\uAC8C \uD558\uACE0 \uC788\uC5C8\uAD70\uC694!
      \uBC14\uB85C \uB9C8\uC74C\uC744 \uBC14\uAFD4 \uB3D9\uB8CC\uB4E4\uC5D0\uAC8C
      \uB9DE\uCD94\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC744 \uACBD\uACE0\uB85C \uC5EC\uACA8 \uC989\uAC01 \uD22C\uC9C0\uB97C
      \uBD88\uD0DC\uC6B0\uBA70 \uADA4\uC801\uC744 \uC218\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Sincere_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uD300\uC758 \uC6C0\uC9C1\uC784\uC5D0 \uB9DE\uCDB0
      \uC804\uC220 \uC218\uCE58\uB97C \uB2E4\uC2DC \uC124\uC815\uD558\uACE0 \uD6C8\uB828\uC744
      \uC7AC\uAC1C\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Sincere_2
    ko: "\uC9C8\uCC45\uC744 \uC0C8 \uACFC\uC81C\uB85C \uC5EC\uACA8 \uAC10\uC815\uC744
      \uBE7C\uACE0 \uAE30\uACC4\uC801\uC73C\uB85C \uC870\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Moodmaker_201
    ko: "\uC800\uBCF4\uACE0 \uACE0\uC9D1\uBD88\uD1B5\uC774\uB77C\uB2C8\uC694... \uD300
      \uBD84\uC704\uAE30\uB97C \uB9DD\uCE58\uACE0 \uC2F6\uC9C0 \uC54A\uC740\uB370,
      \uB3D9\uB8CC\uB4E4\uC774 \uC774\uC81C \uC800\uB97C \uBBF8\uC6CC\uD560 \uAC83
      \uAC19\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Moodmaker_2
    ko: "\uBC30\uCC99\uC73C\uB85C \uC5EC\uACA8 \uAC15\uBC15\uC5D0 \uC9D3\uB20C\uB9B0
      \uCC44 \uD6C8\uB828\uC744 \uC911\uB2E8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Bond_003
    ko: "\uAC10\uB3C5\uC740 \uC120\uC218\uB97C \uB2E4\uB3C5\uC778 \uB4A4, \uB3D9\uB8CC\uB97C
      \uBD88\uB7EC\uC640 \uC11C\uB85C \uC5B4\uAE68\uB97C \uB9DE\uB304 \uCC44 \uD328\uC2A4
      \uD6C8\uB828\uC744 \uB2E4\uC2DC \uC720\uB3C4\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Kind_301
    ko: "\uB3D9\uB8CC\uB791 \uC5B4\uAE68\uB97C \uB9DE\uB300\uB2C8 \uAE34\uC7A5\uC774
      \uC880 \uD480\uB9AC\uB124\uC694. \uAC10\uB3C5\uB2D8 \uB355\uBD84\uC5D0 \uB2E4\uC2DC
      \uD638\uD761\uC744 \uB9DE\uCDB0\uBCFC \uC218 \uC788\uACA0\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Kind_3
    ko: "\uBB3C\uB9AC\uC801 \uAC70\uB9AC\uAC00 \uAC00\uAE4C\uC6CC\uC9C0\uC790 \uC2EC\uB9AC\uC801
      \uBD88\uC548\uC774 \uC644\uD654\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8, \uC81C\uAC00 \uC2E4\uC218\uD574\uC11C \uD300\uC758 \uC2E0\uB8B0\uB97C
      \uC783\uC740 \uAC83 \uAC19\uC544 \uB108\uBB34 \uAD34\uB86D\uC2B5\uB2C8\uB2E4.
      \uC5B4\uAE68\uB97C \uB300\uACE0 \uC788\uB294 \uAC83\uB3C4 \uC8C4\uC1A1\uD574\uC694."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Loyal_3
    ko: "\uD654\uD569 \uAC15\uC694\uB97C \uB9DD\uC2E0\uC73C\uB85C \uB290\uAEF4 \uC555\uBC15\uAC10\uC5D0
      \uD3FC\uC774 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Sincere_301
    ko: "\uB3D9\uB8CC\uC640 \uC5B4\uAE68\uB97C \uB9DE\uB300\uACE0 \uB2E4\uC2DC \uD574\uBCF4\uB2C8,
      \uC774 \uC704\uCE58\uC5D0\uC11C\uC758 \uD328\uC2A4 \uAC01\uB3C4\uAC00 \uD6E8\uC52C
      \uC815\uD655\uD558\uAD70\uC694. \uAE30\uB85D\uD574\uB450\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Sincere_3
    ko: "\uBC00\uCC29 \uD6C8\uB828\uC744 \uC804\uC220 \uB370\uC774\uD130\uB85C \uD65C\uC6A9\uD574
      \uD328\uC2A4 \uD3FC\uC744 \uC7AC\uAD6C\uCD95\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Moodmaker_301
    ko: "\uC624! \uC774\uB807\uAC8C \uC5B4\uAE68\uB97C \uB9DE\uB300\uB2C8 \uD6E8\uC52C
      \uCE5C\uADFC\uD558\uB124\uC694! \uD30C\uC774\uD305\uD574\uC11C \uB2E4\uC2DC
      \uC5F0\uACB0\uD574\uBD05\uC2DC\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Moodmaker_3
    ko: "\uC911\uC7AC\uB97C \uAE30\uD68C\uB85C \uC0BC\uC544 \uC218\uC2B5\uD558\uACE0
      \uC989\uC2DC \uD328\uC2A4 \uD750\uB984\uC744 \uBCF5\uAD6C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Cold_001
    ko: "\uC2B5\uAE30 \uCC2C \uCCB4\uC721\uAD00, \uD300\uC758 \uD328\uC2A4 \uD750\uB984\uC744
      \uC8FC\uB3C4\uD574\uC57C \uD560 \uC120\uC218\uAC00 \uC790\uC2E0\uC758 \uC804\uC220\uC801
      \uAE38\uB9CC\uC744 \uACE0\uC9D1\uD558\uB2E4 \uC5F0\uB2EC\uC544 \uC2E4\uCC45\uC744
      \uBC94\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Cold_002
    ko: "\uC790\uC720\uB85C\uC6B4 \uC6C0\uC9C1\uC784\uC744 '\uD63C\uB780'\uC73C\uB85C
      \uAC04\uC8FC\uD558\uB294 \uC120\uC218\uB294, \uB3D9\uB8CC\uB4E4\uACFC\uC758
      \uD638\uD761 \uC2E4\uD328\uB97C \uC790\uC2E0\uC758 \uC124\uACC4 \uACB0\uD568\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uAE4A\uC740 \uC790\uAD34\uAC10\uC5D0 \uBE60\uC838
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Cold_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Cold_001
    ko: "\uD328\uC2A4 \uAE38\uC740 \uC644\uBCBD\uD558\uB098, \uC608\uCE21 \uBABB\uD55C
      \uB3D9\uB8CC\uC758 \uC720\uB3D9\uC801\uC778 \uC6C0\uC9C1\uC784\uC744 \uBCC0\uC218\uB85C
      \uCD94\uAC00\uD574 \uB2E4\uC2DC \uC124\uACC4\uD574\uBD10."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Planner_101
    ko: "\uD655\uB960\uC801 \uD328\uC2A4 \uAE38... \uBCC0\uC218\uB97C \uB123\uC73C\uBA74
      \uC131\uACF5\uB960\uC774 15% \uC0C1\uC2B9\uD558\uACA0\uAD70\uC694. \uBC14\uB85C
      \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Planner_1
    ko: "\uB17C\uB9AC\uC801 \uBCF4\uC644\uC810\uC744 \uC989\uC2DC \uC218\uC6A9\uD574
      \uD6C8\uB828 \uD6A8\uC728\uC744 \uB192\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Opportunist_101
    ko: "\uB370\uC774\uD130\uB97C \uBCF4\uC815\uD558\uBA74 \uC81C \uD328\uC2A4\uAC00
      \uB354 \uC798 \uB4E4\uC5B4\uAC00\uACA0\uB124\uC694. \uC81C \uAE30\uB85D\uC744
      \uC704\uD574\uC11C\uB77C\uB3C4 \uADF8\uB807\uAC8C \uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Opportunist_1
    ko: "\uACA9\uB824\uB97C \uAE30\uB85D \uACBD\uC2E0\uC758 \uAE30\uD68C\uB85C \uC778\uC2DD\uD574
      \uC804\uB7B5\uC801\uC73C\uB85C \uD0C0\uD611\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Cunning_101
    ko: "\uC81C \uC804\uC220\uC740 \uC774\uBBF8 \uBCC0\uC218\uB97C \uB2E4 \uACE0\uB824\uD588\uC2B5\uB2C8\uB2E4.
      \uC218\uC815\uD560 \uD544\uC694 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Cunning_1
    ko: "\uC6B0\uC6D4\uD568 \uACFC\uC2DC \uC131\uD5A5 \uD0D3\uC5D0 \uAC10\uB3C5 \uC870\uC5B8\uC744
      \uC815\uBA74\uC73C\uB85C \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Believer_101
    ko: "\uD655\uB960\uC801\uC778 \uD328\uC2A4 \uAE38\uC740 \uC81C \uCCA0\uD559\uC774
      \uC544\uB2D9\uB2C8\uB2E4. \uC800\uB294 \uC644\uBCBD\uD55C \uADA4\uC801\uB9CC\uC744
      \uACE0\uC218\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Believer_1
    ko: "\uD6A8\uC728\uC131\uBCF4\uB2E4 \uC124\uACC4 \uC2E0\uB150\uC774 \uD655\uACE0\uD574
      \uC81C\uC548\uC744 \uAC70\uC808\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Cold_002
    ko: "\uD604\uC7A5\uC744 \uBC18\uC601\uD558\uC9C0 \uC54A\uC740 \uB370\uC774\uD130\uB294
      \uBB34\uC6A9\uC9C0\uBB3C\uC774\uB2E4. \uACE0\uC9D1\uB300\uB85C \uB358\uC9C0\uB294
      \uD328\uC2A4\uB294 \uC131\uACF5\uB960\uC774 0\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Planner_201
    ko: "\uD604\uC7A5 \uBCC0\uC218 \uBBF8\uBC18\uC601\uC740 \uBA85\uBC31\uD55C \uC624\uB958\uC785\uB2C8\uB2E4.
      \uB370\uC774\uD130\uBCA0\uC774\uC2A4\uB97C \uC989\uC2DC \uAC31\uC2E0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Planner_2
    ko: "\uC624\uB958\uB97C \uB370\uC774\uD130 \uAD00\uC810\uC5D0\uC11C \uBC1B\uC544\uB4E4\uC5EC
      \uAE30\uACC4\uC801\uC73C\uB85C \uC218\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Opportunist_201
    ko: "\uACE0\uC9D1\uBD80\uB9B0 \uAC8C \uC544\uB2C8\uB77C \uD300\uC6D0\uC774 \uBABB
      \uBC1B\uC740 \uAC81\uB2C8\uB2E4. \uC65C \uC800\uB9CC \uBE44\uB09C\uD558\uC2DC\uC8E0?
      \uC548 \uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Opportunist_2
    ko: "\uC9C8\uCC45\uC744 \uC774\uC775\uC5D0 \uBC18\uD558\uB294 \uAC83\uC73C\uB85C
      \uAC04\uC8FC\uD558\uC5EC \uD6C8\uB828\uC744 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Cunning_201
    ko: "\uB370\uC774\uD130\uB97C \uC989\uC2DC \uAC31\uC2E0\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uC2B9\uB960\uC744 \uC704\uD574\uC11C\uB294 \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uC774
      \uC633\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Cunning_2
    ko: "\uC704\uCE58 \uBCF4\uC874\uC744 \uC704\uD574 \uB17C\uB9AC\uC801 \uC9C8\uCC45\uC744
      \uC804\uB7B5\uC801\uC73C\uB85C \uC21C\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Believer_201
    ko: "\uC131\uACF5\uB960 0%\uB77C\uB294 \uC218\uCE58\uB294 \uCE58\uBA85\uC801\uC785\uB2C8\uB2E4.
      \uC2E0\uB150\uC744 \uC704\uD574\uC11C\uB77C\uB3C4 \uB370\uC774\uD130\uC758
      \uD6A8\uC728\uC744 \uADF9\uB300\uD654\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Believer_2
    ko: "\uC2B9\uB960 \uC218\uCE58\uB97C \uC2E0\uB150\uC758 \uCC99\uB3C4\uB85C \uC0BC\uC544
      \uD328\uC2A4\uB97C \uC7AC\uC124\uACC4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Cold_003
    ko: "\uAC10\uB3C5\uC740 \uB3D9\uB8CC\uB4E4\uC758 \uC774\uB3D9 \uACBD\uB85C\uB97C
      \uD655\uB960\uB85C \uD45C\uC2DC\uD55C \uC804\uC220\uD310\uC744 \uC950\uC5EC\uC8FC\uACE0
      \uBB34\uD45C\uC815\uD558\uAC8C \uD6C8\uB828\uC744 \uC18D\uD589\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Planner_301
    ko: "\uBCC0\uC218\uAC12\uC774 \uB108\uBB34 \uBCF5\uC7A1\uD574... \uB0B4 \uC124\uACC4\uAC00
      \uC774 \uC815\uB3C4\uB85C \uBD88\uC644\uC804\uD588\uB2E4\uB2C8. \uBAA8\uB4E0
      \uAC8C \uC758\uBBF8 \uC5C6\uAC8C \uB290\uAEF4\uC838."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Planner_3
    ko: "\uBCC0\uC218\uB97C \uACB0\uD568\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC \uBA58\uD0C8\uC774
      \uC644\uC804\uD788 \uBD95\uAD34\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Opportunist_301
    ko: "\uC774 \uD655\uB960\uAC12... \uC774\uAC78 \uC774\uC6A9\uD558\uBA74 \uB3D9\uB8CC\uC758
      \uC6C0\uC9C1\uC784\uC744 \uC608\uCE21\uD574\uC11C \uB0B4 \uD328\uC2A4\uB97C
      \uB3CB\uBCF4\uC774\uAC8C \uD560 \uC218 \uC788\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Opportunist_3
    ko: "\uD655\uB960 \uC815\uBCF4\uB97C \uD65C\uC6A9\uD574 \uD328\uC2A4 \uAC00\uCE58\uB97C
      \uB192\uC77C \uB3CC\uD30C\uAD6C\uB97C \uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Cunning_301
    ko: "\uC804\uC220\uD310 \uB370\uC774\uD130... \uC77C\uB2E8 \uBCF4\uB294 \uCC99\uD558\uBA74\uC11C
      \uC81C \uAE30\uC874 \uBC29\uC2DD\uC73C\uB85C \uB358\uC838\uC57C\uC9C0. \uAC10\uB3C5\uB2D8\uC740
      \uD1B5\uACC4\uB9CC \uBCF4\uC2DC\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Cunning_3
    ko: "\uC804\uC220\uD310\uC744 \uB208\uC18D\uC784 \uB3C4\uAD6C\uB85C \uC0AC\uC6A9\uD574
      \uD6C8\uB828 \uC9D1\uC911\uB825\uC744 \uBD84\uC0B0\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Believer_301
    ko: "\uC804\uC220\uD310\uC5D0 \uADF8\uB824\uC9C4 \uBCC0\uC218\uB4E4... \uC81C
      \uD328\uC2A4\uAC00 \uD300\uC744 \uD63C\uB780\uC2A4\uB7FD\uAC8C \uD55C\uB2E4\uB294
      \uC99D\uAC70\uC778\uAC00 \uBD10\uC694."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Believer_3
    ko: "\uC804\uC220\uD310\uC744 \uC2E0\uB150\uC774 \uBD80\uC815\uB2F9\uD55C \uC99D\uAC70\uB85C
      \uC5EC\uACA8 \uD6C8\uB828\uC744 \uD3EC\uAE30\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Instinct_001
    ko: "\uC2B5\uAE30 \uCC2C \uCCB4\uC721\uAD00, \uD328\uC2A4 \uD750\uB984\uC744
      \uC8FC\uB3C4\uD574\uC57C \uD560 \uC120\uC218\uAC00 \uC790\uAE30 \uBC29\uC2DD\uB300\uB85C\uB9CC
      \uD328\uC2A4\uB97C \uCC0C\uB974\uB2E4 \uC2E4\uCC45\uC744 \uC5F0\uBC1C\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Instinct_002
    ko: "\uC790\uC720\uB85C\uC6B4 \uC6C0\uC9C1\uC784\uC744 \uD63C\uB780\uC73C\uB85C
      \uBCF4\uB358 \uADF8\uB294, \uACB0\uAD6D \uB3D9\uB8CC\uC640\uC758 \uD638\uD761
      \uC2E4\uD328\uB97C \uC790\uC2E0\uC758 \uC124\uACC4 \uC2E4\uD328\uB85C \uADDC\uC815\uD558\uACE0
      \uC790\uAD34\uAC10\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Instinct_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Instinct_001
    ko: "\uB108\uC758 \uBCF8\uB2A5\uC801\uC778 \uAC10\uAC01\uC744 \uBBFF\uC5B4\uB77C.
      \uB3D9\uB8CC\uAC00 \uB6F0\uB294 \uADF8\uACF3\uC774 \uBC14\uB85C \uC62C\uBC14\uB978
      \uAE38\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uC81C \uC7AC\uB2A5\uC744 \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694!
      \uC218\uC2DD \uBC84\uB9AC\uACE0 \uBCF8\uB2A5\uC801\uC778 \uD328\uC2A4\uB97C
      \uAF42\uC544\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Bluffer_1
    ko: "\uCC9C\uC7AC\uC131\uC744 \uC778\uC815\uBC1B\uC544 \uC790\uC874\uAC10\uC774
      \uB192\uC544\uC838 \uACFC\uAC10\uD788 \uC131\uACF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Wild_101
    ko: "\uAE38\uC744 \uB9CC\uB4E4\uC9C0 \uB9D0\uB77C\uACE0\uC694? \uC54C\uACA0\uC2B5\uB2C8\uB2E4.
      \uB290\uB08C \uC624\uB294 \uB300\uB85C \uCC14\uB7EC\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Wild_1
    ko: "\uBCF8\uB2A5 \uAE0D\uC815\uC5D0\uB294 \uACF5\uAC10\uD588\uC73C\uB098 \uC804\uC220
      \uCCB4\uACC4\uB294 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Egoist_101
    ko: "\uC774\uBBF8 \uC804 \uC81C \uADA4\uC801\uC744 \uCC3E\uC558\uC2B5\uB2C8\uB2E4.
      \uAC04\uC12D\uD558\uC9C0 \uB9C8\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Egoist_1
    ko: "\uB3C5\uC790 \uB178\uC120 \uBC29\uD574\uB85C \uAC04\uC8FC\uD574 \uAC10\uB3C5\uC758
      \uACA9\uB824\uB97C \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Fighter_101
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD2C0\uB838\uB2E4\uB294 \uAC81\uB2C8\uAE4C? \uBC1B\uC544\uB4E4\uC77C
      \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Fighter_1
    ko: "\uC790\uC2E0\uC758 \uBC29\uC2DD\uC744 \uBD80\uC815\uB2F9\uD588\uB2E4\uACE0
      \uB290\uAEF4 \uD6C8\uB828 \uC758\uC695\uC744 \uC783\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Instinct_002
    ko: "\uBA38\uB9AC\uB85C \uACC4\uC0B0\uD558\uC9C0 \uB9C8\uB77C. \uC804\uC220\uC5D0
      \uAC07\uD788\uBA74 \uC2E4\uCC45\uB9CC \uB098\uC62C \uBFD0\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Bluffer_201
    ko: "\uC81C \uBCF8\uB2A5\uC744 \uBAA8\uB974\uC2DC\uB124\uC694... \uC624\uB298
      \uD328\uC2A4\uAC00 \uC548 \uB418\uB294 \uAC74 \uAC10\uB3C5\uB2D8\uC774 \uBD84\uC704\uAE30\uB97C
      \uB9DD\uCCD0\uC11C\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Bluffer_2
    ko: "\uC9C8\uCC45\uC744 \uC2EC\uD55C \uBAA8\uC695\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uD6C8\uB828\uC744 \uC804\uBA74 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Wild_201
    ko: "\uACC4\uC0B0\uAE30 \uB450\uB4DC\uB9AC\uB358 \uAC8C \uB2F5\uB2F5\uD588\uB294\uB370,
      \uC774\uC81C\uC57C \uC18D\uC774 \uC2DC\uC6D0\uD558\uB124\uC694! \uC9C4\uC9DC
      \uC81C \uD328\uC2A4\uB97C \uBCF4\uC5EC\uC8FC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Wild_2
    ko: "\uAC15\uBC15\uC801\uC778 \uACC4\uC0B0\uC5D0\uC11C \uBC97\uC5B4\uB098\uC790
      \uC5B5\uB20C\uB9B0 \uC7A0\uC7AC\uB825\uC774 \uD3ED\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Egoist_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uC81C \uBCF8\uB2A5\uC774 \uC5BC\uB9C8\uB098
      \uC815\uD655\uD55C\uC9C0 \uC624\uB298 \uACBD\uAE30\uC5D0\uC11C \uBCF4\uC5EC\uB4DC\uB9AC\uBA74
      \uB418\uACA0\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Egoist_2
    ko: "\uC9C8\uCC45\uC744 \uAC15\uD55C \uC2B9\uBD80\uC695\uC73C\uB85C \uCE58\uD658\uD574
      \uAE30\uACC4\uC801\uC73C\uB85C \uC218\uD589\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Fighter_201
    ko: "\uB3D9\uB8CC\uB97C \uB193\uCE58\uACE0 \uC788\uC5C8\uB2E4\uACE0\uC694? \uC9C0\uCF1C\uBCF4\uC2ED\uC2DC\uC624.
      \uC5B4\uB5A4 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uC644\uBCBD\uD55C \uD328\uC2A4\uB97C
      \uAF42\uC544 \uB123\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Fighter_2
    ko: "\uC0C1\uD669\uC744 \uC815\uBA74 \uC2B9\uBD80\uB85C \uBC1B\uC544\uB4E4\uC774\uBA70
      \uAC15\uD55C \uC624\uAE30\uAC00 \uBC1C\uB3D9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Instinct_003
    ko: "\uC804\uC220\uD310\uC744 \uBC16\uC73C\uB85C \uCE58\uC6B0\uACE0, \uACF5\uC744
      \uAC15\uD558\uAC8C \uB358\uC838\uC8FC\uBA70 \uD6C8\uB828 \uD15C\uD3EC\uB97C
      \uCD5C\uACE0\uC870\uB85C \uB04C\uC5B4\uC62C\uB9B0\uB2E4"
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Bluffer_301
    ko: "\uC804\uC220\uD310\uC744 \uC65C \uCE58\uC6B0\uC2DC\uC8E0? \uC81C \uC644\uBCBD\uD55C
      \uAD6C\uC0C1\uC744 \uBCF4\uC5EC\uB4DC\uB9B4 \uAE30\uD68C\uC600\uB294\uB370..."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Bluffer_3
    ko: "\uAE30\uB7C9 \uACFC\uC2DC \uAE30\uD68C\uB97C \uC783\uC5C8\uB2E4\uACE0 \uC0DD\uAC01\uD574
      \uC9D1\uC911\uB825\uC774 \uBD84\uC0B0\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Wild_301
    ko: "\uC65C \uB0B4 \uD314\uC744 \uAC15\uC81C\uB85C \uC6C0\uC9C1\uC774\uC2DC\uC8E0?
      \uB09C \uB0B4 \uBAB8\uC73C\uB85C \uB290\uB080 \uB300\uB85C \uB358\uC9C8 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Wild_3
    ko: "\uBB3C\uB9AC\uC801 \uAC15\uC81C\uC131\uC744 \uAD8C\uC704 \uCE68\uD574\uB85C
      \uAC04\uC8FC\uD574 \uD6C8\uB828\uC5D0 \uBC18\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Egoist_301
    ko: "\uC804\uC220\uD310\uC744 \uCE58\uC6B0\uC168\uAD70\uC694. \uC88B\uC2B5\uB2C8\uB2E4.
      \uB0B4 \uB208\uC5D0 \uB4E4\uC5B4\uC628 \uD2C8\uC744 \uB0B4\uAC00 \uC9C1\uC811
      \uCC14\uB7EC\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Egoist_3
    ko: "\uAC15\uC81C\uC801 \uAC1C\uC785\uC774 \uC2DC\uC57C\uB97C \uB113\uD600\uC8FC\uC5B4
      \uC644\uBCBD\uD55C \uD328\uC2A4\uB97C \uD574\uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Fighter_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uB9AC\uB4EC\uC744 \uC62C\uB9AC\uC168\uAD70\uC694.
      \uADF8\uB7FC \uC800\uB3C4 \uB354 \uBE60\uB974\uAC8C \uC6C0\uC9C1\uC5EC\uC11C
      \uD2C8\uC744 \uCC3E\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Fighter_3
    ko: "\uACBD\uC7C1\uC801 \uC790\uADF9\uC740 \uC720\uC9C0\uD588\uC73C\uB098 \uC804\uC220\uBCF4\uB2E4
      \uAC1C\uC778\uAE30\uB85C \uD758\uB800\uB2E4."
    en: 
    ja: 
  - stringKey: Ht_001_Desc_01
    ko: "\uAC10\uB3C5\uB2D8, \uC7E4\uB124 \uD2B8\uB79C\uC9C0\uC158\uC774 \uB108\uBB34
      \uBE68\uB77C\uC694! \uB354 \uC774\uC0C1 \uBABB \uB6F0\uACA0\uC5B4\uC694!"
    en: 
    ja: 
  - stringKey: Ht_001_Desc_02
    ko: "\uC57C, \uB124\uAC00 \uC55E\uC5D0\uC11C \uD15C\uD3EC\uB97C \uC548 \uC8FD\uC5EC\uC8FC\uB2C8\uAE4C
      \uB0B4\uAC00 \uC274 \uC0C8 \uC5C6\uC774 \uC624\uAC00\uB290\uB77C \uC8FD\uC744
      \uB9DB\uC774\uC796\uC544!"
    en: 
    ja: 
  - stringKey: Ht_001_Desc_03
    ko: "\uADF8\uB9CC! \uC774\uB7EC\uB2E4 \uD398\uC774\uC2A4\uAC00 \uC644\uC804\uD788
      \uB9D0\uB9AC\uACA0\uB2E4. \uD6C4\uBC18\uC804 \uC5B4\uB5BB\uAC8C \uAC08 \uAC74\uC9C0
      \uACB0\uC815\uD560 \uAC70\uB2C8\uAE4C \uC9D1\uC911\uD574\uC11C \uC798 \uB4E4\uC5B4!"
    en: 
    ja: 
  - stringKey: Ht_001_Ch_01
    ko: "\uC0C1\uB300\uBCF4\uB2E4 \uB354 \uBE68\uB9AC, \uB113\uAC8C \uC6C0\uC9C1\uC5EC!
      \uD3EC\uC778\uD2B8 \uAC00\uB4DC\uB294 \uD328\uC2A4\uC5D0 \uB354 \uC2E0\uACBD\uC4F0\uACE0!"
    en: 
    ja: 
  - stringKey: Ht_001_Ch_02
    ko: "\uB2E4\uB4E4 \uBB34\uB9AC\uD558\uC9C0 \uB9D0\uACE0 \uC6D0\uB798 \uD558\uB358\uB300\uB85C
      \uD574."
    en: 
    ja: 
  - stringKey: Ht_001_Ch_03
    ko: "\uD798\uB4E4\uC5B4\uB3C4 \uBB34\uC870\uAC74 \uC55E\uC73C\uB85C \uB4E4\uC5B4\uAC00!
      \uD30C\uC6CC \uD3EC\uC6CC\uB4DC\uB294 \uC5B5\uC9C0\uB85C\uB77C\uB3C4 \uC6B1\uC5EC\uB123\uC5B4!"
    en: 
    ja: 
  - stringKey: Ht_002_Desc_01
    ko: "\uBC29\uAE08 \uC2A4\uC704\uCE58 \uD0C0\uC774\uBC0D\uC774\uC5C8\uC796\uC544!
      \uC65C \uC548 \uB530\uB77C\uAC00!"
    en: 
    ja: 
  - stringKey: Ht_002_Desc_02
    ko: "\uB124\uAC00 \uC2A4\uD06C\uB9B0 \uAC78\uB9B4 \uB54C \uCF5C\uC744 \uC548
      \uD574\uC92C\uC796\uC544! \uBCA4\uCE58 \uC55E\uAE4C\uC9C0 \uB4E4\uB9AC\uAC8C
      \uC18C\uB9AC\uCE58\uB77C\uACE0!"
    en: 
    ja: 
  - stringKey: Ht_002_Desc_03
    ko: "\uB77C\uCEE4\uB8F8 \uBB38 \uBD80\uC11C\uC9C0\uACA0\uB2E4. \uC870\uC6A9\uD788
      \uD558\uACE0 \uAC10\uB3C5 \uB9D0\uC774\uB098 \uB4E4\uC5B4."
    en: 
    ja: 
  - stringKey: Ht_002_Ch_01
    ko: "\uC678\uACFD \uB77C\uC778 \uC62C\uB824\uC11C \uB113\uAC8C \uB9C9\uC544.
      \uC2A4\uBAB0 \uD3EC\uC6CC\uB4DC\uAC00 \uB04A\uC5B4\uBA39\uB294\uB2E4!"
    en: 
    ja: 
  - stringKey: Ht_002_Ch_02
    ko: "\uB2E4 \uC548\uC73C\uB85C \uC881\uD600! \uC13C\uD130\uAC00 \uB4E4\uC5B4\uC624\uB294
      \uB188\uB4E4\uC740 \uB2E4 \uCC0D\uC5B4\uBC84\uB824!"
    en: 
    ja: 
  - stringKey: Ht_002_Ch_03
    ko: "\uB2C8\uB4E4\uB07C\uB9AC \uB300\uD310 \uC2F8\uC6B0\uBA74\uC11C \uC218\uBE44\uAC00
      \uB418\uACA0\uB0D0? \uC54C\uC544\uC11C\uB4E4 \uB611\uBC14\uB85C \uB9C9\uC544!"
    en: 
    ja: 
  - stringKey: Ht_003_Desc_01
    ko: "\uAC10\uB3C5\uB2D8, \uC800\uCABD \uC5D0\uC774\uC2A4 \uD3FC\uC774 \uC7A5\uB09C
      \uC544\uB2CC\uAC83 \uAC19\uC740\uB370\uC694?"
    en: 
    ja: 
  - stringKey: Ht_003_Desc_02
    ko: "\uB2E4\uB978 \uC120\uC218 \uD3C9\uAC00\uD560 \uC2DC\uAC04\uC5D0 \uB108 \uBD80\uD130
      \uC798 \uD558\uC2DC\uC9C0!"
    en: 
    ja: 
  - stringKey: Ht_003_Desc_03
    ko: "\uD2B9\uC815 \uC120\uC218 \uD55C \uBA85\uD55C\uD14C \uD718\uB458\uB9AC\uC9C0
      \uB9C8\uB77C. \uD6C4\uBC18\uC804 \uC804\uB7B5\uC744 \uC124\uBA85\uD574\uC8FC\uB9C8."
    en: 
    ja: 
  - stringKey: Ht_003_Ch_01
    ko: "\uAC04\uACA9 \uB113\uD600\uC11C \uD328\uC2A4 \uAE38\uBD80\uD130 \uCC28\uB2E8\uD574!
      \uD3EC\uC778\uD2B8 \uAC00\uB4DC\uAC00 \uC678\uACFD\uC5D0\uC11C \uACF5\uC744
      \uBE90\uB294\uB2E4!"
    en: 
    ja: 
  - stringKey: Ht_003_Ch_02
    ko: "\uAC04\uACA9 \uC881\uD788\uACE0 \uC548\uC73C\uB85C \uBAB0\uC544\uB123\uC5B4!
      \uD398\uC778\uD2B8 \uC874 \uBD80\uD130 \uC0AC\uC218\uD55C\uB2E4!"
    en: 
    ja: 
  - stringKey: Ht_003_Ch_03
    ko: "\uC2E0\uACBD \uC4F0\uC9C0 \uB9D0\uACE0 \uD558\uB358 \uAC70\uB098 \uACC4\uC18D
      \uD558\uC790."
    en: 
    ja: 
  - stringKey: Ht_004_Desc_01
    ko: "\uC544\uB2C8, \uD3EC\uC2A4\uD2B8\uC5C5 \uC790\uB9AC \uC7A1\uC558\uB294\uB370
      \uC65C \uACF5\uC744 \uC548\uC918? \uB098 \uD63C\uC790 \uAC8C\uC784\uD558\uB098?"
    en: 
    ja: 
  - stringKey: Ht_004_Desc_02
    ko: "\uC218\uBE44\uAC00 \uBD99\uC5B4\uC788\uB294\uB370 \uC5B4\uB5BB\uAC8C \uACF5\uC744
      \uC918, \uCC28\uB77C\uB9AC \uB0B4\uAC00 \uC3D8\uC9C0!"
    en: 
    ja: 
  - stringKey: Ht_004_Desc_03
    ko: "\uADF8\uB9CC, \uD6C4\uBC18\uC804 \uACF5\uACA9 \uC635\uC158 \uC815\uB9AC\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Ht_004_Ch_01
    ko: "\uAC04\uACA9 \uC881\uD600\uC11C \uACE8\uBC11\uC5D0 \uD798 \uC2E3\uB294\uB2E4,
      \uC13C\uD130\uAC00 \uACF5 \uC7A1\uC73C\uBA74 \uB2E4 \uBC15\uC0B4\uB0B4!"
    en: 
    ja: 
  - stringKey: Ht_004_Ch_02
    ko: "\uAC04\uACA9 \uB113\uD600\uC11C \uC2A4\uD398\uC774\uC2F1 \uD574! \uC288\uD305
      \uAC00\uB4DC\uAC00 \uB2E4 \uD574\uACB0\uD55C\uB2E4!"
    en: 
    ja: 
  - stringKey: Ht_004_Ch_03
    ko: "\uC54C\uC798\uB531 \uBAB0\uB77C? \uC11C\uB85C \uC798 \uBCF4\uACE0 \uC798
      \uD328\uC2A4\uD574!"
    en: 
    ja: 
  - stringKey: Ht_005_Desc_01
    ko: "\uC544\uC624, \uC0C1\uB300\uD300\uC5D0 \uC800 \uB188 \uC785 \uC880 \uB2E4\uBB3C\uAC8C
      \uD574\uC8FC\uBA74 \uC548 \uB3FC\uC694? \uACC4\uC18D \uAE01\uC5B4\uB300\uB2C8\uAE4C
      \uBBF8\uCE58\uACA0\uB124!"
    en: 
    ja: 
  - stringKey: Ht_005_Desc_02
    ko: "\uC778\uC815~ \uB098\uB3C4 \uD55C \uB300 \uD328\uBC84\uB9B4\uBED4~."
    en: 
    ja: 
  - stringKey: Ht_005_Desc_03
    ko: "\uB18D\uAD6C\uB294 \uBA38\uB9AC\uB85C \uD558\uB294\uAC70\uC57C. \uB3C4\uBC1C\uC5D0
      \uAC78\uB9DE\uB294 \uC804\uC220\uC744 \uACE0\uB974\uBA74 \uB41C\uB2E4."
    en: 
    ja: 
  - stringKey: Ht_005_Ch_01
    ko: "\uAC04\uACA9 \uC881\uD600\uC11C \uC9C4\uD759\uD0D5 \uC2F8\uC6C0\uC774\uB098
      \uD558\uC790\uACE0. \uC54C\uACA0\uC9C0, \uD30C\uC6CC \uD3EC\uC6CC\uB4DC?"
    en: 
    ja: 
  - stringKey: Ht_005_Ch_02
    ko: "\uD3C9\uC815\uC2EC \uC720\uC9C0\uD558\uACE0, \uD558\uB358 \uB300\uB85C \uD3EC\uBA54\uC774\uC158
      \uC9C0\uCF1C."
    en: 
    ja: 
  - stringKey: Ht_005_Ch_03
    ko: "\uC774\uAE30\uB294\uAC8C \uACE7 \uC804\uB7B5\uC774\uC9C0, \uACF5 \uC7A1\uC73C\uBA74
      1\uB300 1\uB85C \uB20C\uB7EC\uBC84\uB824!"
    en: 
    ja: 
  - stringKey: Ht_006_Desc_01
    ko: "\uD295\uACA8 \uB098\uC628 \uACF5\uC744 \uB2E4 \uBE90\uAE30\uB294\uB370 \uC5B4\uB5BB\uAC8C
      \uC18D\uACF5\uC744 \uB6F0\uB780 \uAC70\uC57C?"
    en: 
    ja: 
  - stringKey: Ht_006_Desc_02
    ko: "\uB098 \uD63C\uC790 \uB9AC\uBC14\uC6B4\uB4DC\uB97C \uC5B4\uB5BB\uAC8C \uC7A1\uB0D0?
      \uC678\uACFD\uC5D0 \uC788\uB294 \uC560\uB4E4\uC774 \uB4E4\uC5B4\uC640\uC11C
      \uB3C4\uC640\uC918\uC57C \uD560\uAC70 \uC544\uB0D0! "
    en: 
    ja: 
  - stringKey: Ht_006_Desc_03
    ko: "\uCCAB \uBC88\uC9F8\uB294 \uBCF4\uB4DC \uC7A5\uC545\uC774\uB2E4! \uC9D1\uC911\uD574\uC11C
      \uC798 \uB4E4\uC5B4!"
    en: 
    ja: 
  - stringKey: Ht_006_Ch_01
    ko: "\uC804\uC6D0 \uD398\uC778\uD2B8 \uC874\uC73C\uB85C \uC9D1\uACB0! \uC13C\uD130\uB294
      \uBB34\uC870\uAC74 \uB9BC\uB9CC \uCCD0\uB2E4\uBD10!"
    en: 
    ja: 
  - stringKey: Ht_006_Ch_02
    ko: "\uAC04\uACA9 \uB113\uD600\uC11C \uBC14\uAE65\uC73C\uB85C \uD280\uB294 \uACF5
      \uC7A1\uC544. \uC288\uD305 \uAC00\uB4DC\uAC00 \uC788\uB294 \uC871\uC871 \uC90F\uC5B4
      \uBA39\uC5B4!"
    en: 
    ja: 
  - stringKey: Ht_006_Ch_03
    ko: "\uC758\uC9C0\uAC00 \uBD80\uC871\uD574! \uACF5 \uB5A8\uC5B4\uC9C0\uBA74 \uC545\uCC29\uAC19\uC774
      \uC7A1\uC73C\uB77C\uACE0!"
    en: 
    ja: 
  - stringKey: Ht_007_Desc_01
    ko: "\uACE8\uBC11\uC5D0 \uC0C1\uB300 \uC218\uBE44\uAC00 \uAF49 \uCC28\uC788\uC5B4\uC11C
      \uB3CC\uD30C\uAC00 \uC544\uC608 \uC548 \uBA39\uD600\uC694. \uC644\uC804 \uBCBD\uBCF4\uACE0
      \uAC8C\uC784\uD558\uB294 \uAE30\uBD84\uC774\uB77C\uB2C8\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Ht_007_Desc_02
    ko: "\uD558\uC774\uB85C\uC6B0! \uBAB0\uB77C? \uC65C \uC790\uAFB8 \uC5B4\uAC70\uC9C0\uB85C
      \uB6AB\uC73C\uB824\uB294 \uAC70\uC57C?"
    en: 
    ja: 
  - stringKey: Ht_007_Desc_03
    ko: "\uD398\uC778\uD2B8 \uC874\uC774 \uB9C9\uD614\uB294\uB370 \uC5B5\uC9C0\uB85C
      \uB4E4\uC5B4\uAC00\uB824\uB2C8 \uB2E4 \uD295\uACA8\uB098\uC624\uC9C0. \uB0B4
      \uB9D0 \uC880 \uB4E4\uC5B4\uBD10\uB77C."
    en: 
    ja: 
  - stringKey: Ht_007_Ch_01
    ko: "\uC2A4\uBAB0 \uD3EC\uC6CC\uB4DC! \uACF5\uAC04 \uB113\uAC8C \uC4F0\uBA74\uC11C
      \uB3CC\uD30C\uD574!"
    en: 
    ja: 
  - stringKey: Ht_007_Ch_02
    ko: "\uAC04\uACA9 \uC881\uD788\uACE0 \uBE45\uB9E8\uB4E4\uB07C\uB9AC \uD574\uACB0\uD574.
      \uD30C\uC6CC \uD3EC\uC6CC\uB4DC\uAC00 \uD0A4 \uB9E8\uC774\uB2E4!"
    en: 
    ja: 
  - stringKey: Ht_007_Ch_03
    ko: "\uB300\uD615 \uC720\uC9C0\uD558\uACE0 \uC9C0\uCE60 \uB54C \uAE4C\uC9C0 \uACC4\uC18D
      \uD30C\uACE0\uB4E4\uC5B4!"
    en: 
    ja: 
  - stringKey: Ht_008_Desc_01
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4... \uC644\uC804 \uC2AC\uB7FC\uD504\uAC00
      \uC628 \uAC83 \uAC19\uC544\uC694. \uC870\uC900\uC774 \uC81C\uB300\uB85C \uC548\uB3FC\uC694."
    en: 
    ja: 
  - stringKey: Ht_008_Desc_02
    ko: "\uCC2C\uC2A4 \uB098\uBA74 \uBC14\uB85C \uC3F4\uC57C\uC9C0! \uC790\uAFB8
      \uBA48\uCE6B\uAC70\uB9AC\uB2C8\uAE4C \uD15C\uD3EC\uAC00 \uC548\uB9DE\uC796\uC544!"
    en: 
    ja: 
  - stringKey: Ht_008_Desc_03
    ko: "\uC29B \uC548 \uB4E4\uC5B4\uAC04\uB2E4\uACE0 \uCAC4\uC9C0 \uB9C8. \uC77C\uB2E8
      \uD6C4\uBC18\uC804\uC740..."
    en: 
    ja: 
  - stringKey: Ht_008_Ch_01
    ko: "\uAC04\uACA9 \uCD5C\uB300\uD55C \uB113\uD600! \uC288\uD305 \uAC00\uB4DC,
      \uC790\uC2E0\uC788\uAC8C 3\uC810 \uC3F4!"
    en: 
    ja: 
  - stringKey: Ht_008_Ch_02
    ko: "\uC624\uB298 \uC678\uACFD\uC774 \uC601 \uC544\uB2C8\uB124. \uACF5\uC774\uB098
      \uACC4\uC18D \uB3CC\uB824."
    en: 
    ja: 
  - stringKey: Ht_008_Ch_03
    ko: "\uC548\uC73C\uB85C \uC881\uD600 \uB4E4\uC5B4\uAC00. \uCCA0\uC800\uD558\uAC8C
      \uACE8\uBC11\uB9CC \uB178\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Ht_009_Desc_01
    ko: "\uD558\uC544... \uAC8C\uC784 \uB9DD\uD588\uB124. GG\uCE58\uC8E0?"
    en: 
    ja: 
  - stringKey: Ht_009_Desc_02
    ko: "\uB2E4\uB4E4 \uB6F8 \uC758\uC9C0\uAC00 \uC5C6\uC796\uC544! \uB098 \uD63C\uC790
      \uB6F0\uB0D0? \uADF8\uB7F4\uAC70\uBA74 \uB18D\uAD6C\uB294 \uC65C \uD558\uB294\uB370?"
    en: 
    ja: 
  - stringKey: Ht_009_Desc_03
    ko: "\uC9D1\uC911!! \uC810\uC218\uD310 \uBCF4\uC9C0\uB9C8. \uC544\uC9C1 0 \uB300
      0\uC774\uB77C\uACE0 \uC0DD\uAC01\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Ht_009_Ch_01
    ko: "\uC5BC\uB9AC \uC624\uD39C\uC2A4 \uC804\uB7B5\uC73C\uB85C \uAC04\uB2E4. \uACF5
      \uC7A1\uC73C\uBA74 \uBC14\uB85C 3\uC810 \uB358\uC838!"
    en: 
    ja: 
  - stringKey: Ht_009_Ch_02
    ko: "\uD398\uC778\uD2B8 \uC874 \uAC78\uC5B4 \uC7A0\uAC00! \uC29B \uC62C\uB77C\uC624\uB294
      \uC871\uC871 \uBE14\uB85D\uD574!"
    en: 
    ja: 
  - stringKey: Ht_009_Ch_03
    ko: "\uCE68\uCC29\uD558\uAC8C \uD328\uC2A4\uD558\uBA74 \uC29B \uAE30\uD68C\uAC00
      \uC5F4\uB9B4 \uAC70\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Discipline_001
    ko: "\uD300\uC758 \uD575\uC2EC \uD328\uC11C\uC778 \uC120\uC218\uAC00 \uD6C8\uB828
      \uC911 \uC2E4\uCC45\uC744 \uBC94\uD569\uB2C8\uB2E4. \uADF8\uB294 \uAC10\uB3C5\uB2D8\uC774
      \uB098\uB204\uC5B4\uC900 \uACF5\uC2DD \uC804\uC220 \uB9E4\uB274\uC5BC\uC744
      \uBC14\uB2E5\uC5D0 \uD3BC\uCCD0\uB193\uACE0,"
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Discipline_002
    ko: "\uC790\uC2E0\uC758 \uD328\uC2A4\uB294 \uB9E4\uB274\uC5BC\uB300\uB85C \uC644\uBCBD\uD588\uC73C\uB098
      \uC218\uBE44\uC218\uC758 \uB3CC\uBC1C \uC6C0\uC9C1\uC784\uC5D0 \uB300\uC751\uD558\uC9C0
      \uBABB\uD55C \uB3D9\uB8CC\uC758 \uD0DC\uB3C4\uC640 \uC57D\uC18D \uC704\uBC18\uC744
      \uD0D3\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Discipline_003
    ko: "\uC815\uD574\uC9C4 \uADDC\uC728\uC774 \uBB34\uB108\uC9C4 \uC0C1\uD669\uC5D0
      \uB2F9\uD639\uAC10\uC744 \uB290\uB07C\uBA70 \uC790\uAD34\uAC10\uACFC \uBD84\uB178\uC5D0
      \uBE60\uC838 \uD6C8\uB828 \uD750\uB984\uC744 \uBC29\uD574\uD558\uB294 \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00011_Ch_Discipline_001
    ko: "\uBCF8\uB2A5\uC801\uC778 \uAC10\uAC01\uC744 \uBBFF\uC5B4\uB77C. \uB3D9\uB8CC\uAC00
      \uB6F0\uB294 \uACF3\uC774 \uBC14\uB85C \uAE38\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Principled_101
    ko: "\uB9E4\uB274\uC5BC\uC758 \uC57D\uC18D\uBCF4\uB2E4 \uB3D9\uB8CC\uC758 \uD604\uC7A5
      \uC704\uCE58\uB97C \uCD5C\uC0C1\uC704 \uC6D0\uCE59\uC73C\uB85C \uB450\uB77C\uB294
      \uB9D0\uC500\uC774\uC2DC\uAD70\uC694. \uC989\uC2DC \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Principled_1
    ko: "\uC870\uC5B8\uC744 \uC0C1\uC704 \uC6D0\uCE59\uC73C\uB85C \uC218\uC6A9\uD574
      \uD300\uC6D0\uC5D0\uAC8C \uB9DE\uCDC4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Guardian_101
    ko: "\uB3D9\uB8CC\uB97C \uBBFF\uACE0 \uB358\uC838\uBCF4\uACA0\uC9C0\uB9CC, \uB9E4\uB274\uC5BC\uC744
      \uC5B4\uAE30\uB294 \uAC8C \uD300\uC758 \uAE30\uAC15\uC744 \uD574\uCE58\uC9C0\uB294
      \uC54A\uC744\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Guardian_1
    ko: "\uD300\uC744 \uC704\uD558\uC9C0\uB9CC \uC6D0\uCE59\uC774 \uAE68\uC9C8\uAE4C
      \uBD88\uC548\uC744 \uB5A8\uCE58\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Tactician_101
    ko: "\uBCF8\uB2A5\uC740 \uBCC0\uC218\uAC00 \uB108\uBB34 \uB9CE\uC2B5\uB2C8\uB2E4.
      \uB3D9\uB8CC\uAC00 \uB9E4\uB274\uC5BC \uC704\uCE58\uC5D0 \uC5C6\uB294\uB370
      \uD328\uC2A4\uD558\uB294 \uAC74 \uB3C4\uBC15\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Tactician_1
    ko: "\uACA9\uB824\uB97C \uBE44\uACFC\uD559\uC801\uC774\uB77C \uCE58\uBD80\uD558\uACE0
      \uD328\uC2A4 \uC774\uB860\uC744 \uACE0\uC9D1\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Exemplary_101
    ko: "\uB124! \uB9E4\uB274\uC5BC\uC744 \uB118\uC5B4\uC11C \uB3D9\uB8CC\uC758 \uC6C0\uC9C1\uC784\uC5D0
      \uB9DE\uCD94\uB294 \uC720\uC5F0\uD55C \uC120\uC218\uAC00 \uB418\uB3C4\uB85D
      \uB178\uB825\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Exemplary_1
    ko: "\uACA9\uB824\uB97C \uC0C8 \uAC15\uB839\uC73C\uB85C \uC0BC\uC544 \uB3D9\uB8CC
      \uD0D3\uD558\uB294 \uD0DC\uB3C4\uB97C \uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Ch_Discipline_002
    ko: "\uACC4\uC0B0\uD558\uC9C0 \uB9C8\uB77C. \uC804\uC220\uC5D0 \uAC07\uD788\uBA74
      \uC2E4\uCC45\uB9CC \uBC94\uD560 \uBFD0\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Principled_201
    ko: "\uC81C \uACC4\uC0B0\uC774 \uD2C0\uB9B0 \uAC81\uB2C8\uAE4C? \uB9E4\uB274\uC5BC\uC5D0
      \uC801\uD78C \uB300\uB85C \uC774\uD589\uD588\uC744 \uBFD0\uC778\uB370... \uAE30\uC900\uC744
      \uB2E4\uC2DC \uAC80\uD1A0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Principled_2
    ko: "\uC9C8\uCC45 \uD6C4 \uC6D0\uC778 \uBD84\uC11D\uC5D0 \uB9E4\uBAB0\uB418\uB290\uB77C
      \uACBD\uAE30 \uD750\uB984\uC744 \uB193\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Guardian_201
    ko: "\uC800\uB294 \uADF8\uC800 \uAC10\uB3C5\uB2D8\uC774 \uC8FC\uC2E0 \uADDC\uCE59\uC744
      \uC9C0\uD0A4\uB824 \uD588\uC744 \uBFD0\uC785\uB2C8\uB2E4... \uC800 \uB54C\uBB38\uC5D0
      \uD300\uC774 \uB9DD\uAC00\uC9C4 \uAC74\uAC00\uC694?"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Guardian_2
    ko: "\uB178\uB825\uC774 \uBD80\uC815\uB2F9\uD558\uC790 \uC790\uAD34\uAC10\uC5D0
      \uBE60\uC838 \uB208\uB3C4 \uBABB \uB9C8\uC8FC\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Tactician_201
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uB9E4\uB274\uC5BC\uC5D0\uB9CC \uAC07\uD600\uC11C
      \uBCC0\uD654\uD558\uB294 \uC218\uBE44\uB97C \uC77D\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4.
      \uC2E4\uC6A9\uC801\uC778 \uD328\uC2A4\uB85C \uBC14\uAFC9\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC73C\uB85C \uC131\uACF5\uC744 \uC704\uD574 \uC720\uC5F0\uD574\uC9C8
      \uD544\uC694\uC131\uC744 \uAE68\uB2EC\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Exemplary_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uC81C\uAC00 \uC6D0\uCE59\uC5D0 \uB108\uBB34
      \uC608\uBBFC\uD588\uB098 \uBD05\uB2C8\uB2E4. \uB2E4\uC2DC \uBAA8\uBC94\uC801\uC73C\uB85C
      \uD6C8\uB828\uC5D0 \uC784\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Exemplary_2
    ko: "\uC9C8\uCC45\uC5D0 \uC21C\uC751\uD588\uC73C\uB098 \uD310\uB2E8\uC5D0 \uD655\uC2E0\uC774
      \uC5C6\uC5B4 \uC18D\uB3C4\uAC00 \uB290\uB824\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Ch_Discipline_003
    ko: "\uC804\uC220\uD310\uC744 \uCE58\uC6B0\uACE0 \uACF5\uC744 \uB358\uC838 \uD6C8\uB828
      \uD15C\uD3EC\uB97C \uCD5C\uACE0\uB85C \uC62C\uB9BC."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Principled_301
    ko: "\uB9E4\uB274\uC5BC\uB3C4 \uC5C6\uC774 \uC5B4\uB5BB\uAC8C \uC9C8\uC11C\uB97C
      \uC720\uC9C0\uD569\uB2C8\uAE4C? \uC57D\uC18D\uC774 \uC0AC\uB77C\uC9C4 \uCF54\uD2B8\uB294
      \uC5C9\uB9DD\uC9C4\uCC3D\uC785\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Principled_3
    ko: "\uAC00\uC774\uB4DC\uAC00 \uC5C6\uC5B4\uC838 \uD310\uB2E8\uC744 \uBA48\uCD94\uC790
      \uBD88\uD654\uAC00 \uC2EC\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Guardian_301
    ko: "\uD310 \uBC16\uC758 \uC0C1\uD669\uB3C4 \uC81C\uAC00 \uCC45\uC784\uC838\uC57C
      \uD560 \uC601\uC5ED\uC774\uAD70\uC694. \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Guardian_3
    ko: "\uC804\uC220\uD310\uC774 \uC0AC\uB77C\uC9C0\uC790 \uB3D9\uB8CC\uB97C \uC9C0\uD0A4\uB824\uB294
      \uCC45\uC784\uAC10\uC774 \uAE68\uC5B4\uB0AC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Tactician_301
    ko: "\uAE30\uC900\uC810\uC774 \uC0AC\uB77C\uC9C4 \uD658\uACBD\uC5D0\uC11C\uC758
      \uC131\uACF5 \uD655\uB960\uC744 \uACC4\uC0B0\uD574 \uBCF4\uACA0\uC2B5\uB2C8\uB2E4.
      \uD15C\uD3EC\uC5D0 \uB9DE\uCDB0 \uB300\uC751\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Tactician_3
    ko: "\uD589\uB3D9 \uAC1C\uC785\uC744 \uC2E4\uD5D8\uC73C\uB85C \uC5EC\uACA8 \uC870\uC2EC\uC2A4\uB7FD\uAC8C
      \uD50C\uB808\uC774\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Exemplary_301
    ko: "\uC804\uC220\uD310\uC744 \uCE58\uC6B0\uC2DC\uB2E4\uB2C8... \uC81C\uAC00
      \uB9E4\uB274\uC5BC\uC5D0 \uC9D1\uCC29\uD558\uB294 \uBAA8\uC2B5\uC774 \uADF8\uB9CC\uD07C
      \uC2E4\uB9DD\uC2A4\uB7EC\uC6B0\uC168\uB358 \uAC70\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Exemplary_3
    ko: "\uAC70\uBD80\uB97C \uB099\uC81C\uB85C \uC778\uC2DD\uD574 \uC815\uC2E0\uC801\uC73C\uB85C
      \uC644\uC804\uD788 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Bond_001
    ko: "\uD575\uC2EC \uD328\uC11C\uC778 \uC120\uC218\uAC00 \uB9E4\uB274\uC5BC\uB300\uB85C
      \uC644\uBCBD\uD55C \uD328\uC2A4\uB97C \uD588\uC74C\uC5D0\uB3C4 \uC2E4\uCC45\uC774
      \uB098\uC790, \uC65C \uC57D\uC18D\uC744 \uC548 \uC9C0\uCF1C? \uB77C\uBA70 \uB3D9\uB8CC\uB97C
      \uD0D3\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Bond_002
    ko: "\uADF8\uB294 \uC815\uD574\uC9C4 \uADDC\uCE59\uC774 \uAE68\uC9C4 \uC0C1\uD669\uC744
      \uB3D9\uB8CC\uC758 \uD0DC\uB3C4 \uBB38\uC81C\uC640 \uC2E0\uB8B0 \uBD95\uAD34\uB85C
      \uBCF4\uACE0 \uAE4A\uC740 \uC790\uAD34\uAC10\uACFC \uBD84\uB178\uC5D0 \uBE60\uC838
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Bond_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00011_Ch_Bond_001
    ko: "\uBCF8\uB2A5\uC801\uC778 \uAC10\uAC01\uC744 \uBBFF\uC5B4\uB77C. \uB3D9\uB8CC\uAC00
      \uB6F0\uB294 \uACF3\uC774 \uBC14\uB85C \uAE38\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Kind_101
    ko: "\uC57D\uC18D\uBCF4\uB2E4 \uB3D9\uB8CC\uC758 \uB9C8\uC74C\uC774 \uBA3C\uC800\uB77C\uB294
      \uAC70\uAD70\uC694... \uC81C\uAC00 \uB108\uBB34 \uBE61\uBE61\uD558\uAC8C \uAD74\uC5B4\uC11C
      \uBBF8\uC548\uD574 \uC598\uB4E4\uC544. \uB2E4\uC2DC \uD574\uBCF4\uC790!"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Kind_1
    ko: "\uC870\uC5B8\uC5D0 \uB0A0\uC120 \uB9C8\uC74C\uC774 \uB179\uC544 \uAD00\uACC4\uC640
      \uD328\uC2A4 \uB9AC\uB4EC\uC744 \uB418\uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Loyal_101
    ko: "\uB3D9\uB8CC\uB97C \uBBFF\uC73C\uB824 \uB178\uB825\uC740 \uD558\uACA0\uC9C0\uB9CC,
      \uC57D\uC18D\uC744 \uC5B4\uAE30\uB294 \uB3D9\uB8CC\uB97C \uADF8\uB0E5 \uB450\uB294
      \uAC8C \uD300\uC744 \uC704\uD55C \uAC74\uC9C0 \uC798 \uBAA8\uB974\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Loyal_1
    ko: "\uC758\uB3C4\uB97C \uC774\uD574\uD558\uB098 \uC790\uC2E0\uC758 \uC2E0\uB150\uACFC
      \uCDA9\uB3CC\uD574 \uD63C\uB780\uC744 \uACAA\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Sincere_101
    ko: "\uBCF8\uB2A5\uC740 \uC8FC\uAD00\uC801\uC785\uB2C8\uB2E4. \uB9E4\uB274\uC5BC\uB300\uB85C
      \uC6C0\uC9C1\uC774\uC9C0 \uC54A\uB294 \uB3D9\uB8CC\uB97C \uD0D3\uD558\uB294
      \uAC74 \uC81C \uC5ED\uD560\uC774\uC790 \uC131\uC2E4\uD568\uC758 \uC99D\uAC70\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Sincere_1
    ko: "\uC815\uC11C\uC801 \uACA9\uB824\uBCF4\uB2E4 \uCC45\uC784 \uADDC\uBA85\uC744
      \uC911\uC2DC\uD574 \uC870\uC5B8\uC744 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Moodmaker_101
    ko: "\uB9DE\uC544\uC694! \uB9E4\uB274\uC5BC\uBCF4\uB2E4 \uC6B0\uB9AC \uC0AC\uC774\uAC00
      \uB354 \uC911\uC694\uD558\uC8E0! \uC598\uB4E4\uC544 \uBBF8\uC548, \uB0B4\uAC00
      \uB354 \uC798 \uB9DE\uCDB0\uC904\uAC8C! \uD30C\uC774\uD305!"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Moodmaker_1
    ko: "\uACA9\uB824\uC5D0 \uBC18\uC751\uD574 \uC790\uAD34\uAC10\uC744 \uD138\uACE0
      \uD65C\uAE30\uCC28\uAC8C \uD300\uC744 \uC8FC\uB3C4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Ch_Bond_002
    ko: "\uACC4\uC0B0\uD558\uC9C0 \uB9C8\uB77C. \uC804\uC220\uC5D0 \uAC07\uD788\uBA74
      \uC2E4\uCC45\uB9CC \uBC94\uD560 \uBFD0\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Kind_201
    ko: "\uC804 \uC6B0\uB9AC \uC57D\uC18D\uC744 \uC18C\uC911\uD788 \uC5EC\uAE34 \uAC83\uBFD0\uC778\uB370...
      \uC81C\uAC00 \uB098\uC05C \uB9C8\uC74C\uC73C\uB85C \uB3D9\uB8CC\uB97C \uD0D3\uD55C
      \uAC83\uCC98\uB7FC \uB9D0\uC500\uD558\uC2DC\uB2C8 \uB108\uBB34 \uC2AC\uD37C\uC694."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Kind_2
    ko: "\uC9C8\uCC45\uC744 \uBE44\uC815\uD55C \uB099\uC778\uC73C\uB85C \uB290\uAEF4
      \uC815\uC11C\uAC00 \uBB34\uB108\uC838 \uD3EC\uAE30\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Loyal_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4! \uB9E4\uB274\uC5BC\uC774\uB77C\uB294 \uC791\uC740
      \uC57D\uC18D\uC5D0 \uB9E4\uB2EC\uB824 \uD300 \uC804\uCCB4\uC758 \uC2E0\uB8B0\uB77C\uB294
      \uD070 \uC57D\uC18D\uC744 \uB193\uCCE4\uC2B5\uB2C8\uB2E4. \uB2E4\uC2DC \uD5CC\uC2E0\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC73C\uB85C \uCDA9\uC131\uC774 \uD300\uC758 \uD750\uB984\uC5D0
      \uC788\uC74C\uC744 \uAE68\uB2EB\uACE0 \uAC01\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Sincere_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uB9E4\uB274\uC5BC \uC774\uD589\uBCF4\uB2E4
      \uACB0\uACFC\uAC00 \uC911\uC694\uD558\uB2E4\uB294 \uB73B\uC774\uC2DC\uAD70\uC694.
      \uB3D9\uB8CC\uC758 \uC624\uCC28 \uBC94\uC704\uB97C \uC0C8\uB85C \uACC4\uC0B0\uD574\uC11C
      \uB358\uC9C0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Sincere_2
    ko: "\uC9C8\uCC45\uC73C\uB85C \uBAA9\uD45C\uB97C \uC131\uC2E4\uD568\uC73C\uB85C
      \uC7AC\uC124\uC815\uD574 \uB0C9\uC815\uD788 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Moodmaker_201
    ko: "\uC81C\uAC00 \uBD84\uC704\uAE30\uB97C \uB9DD\uCE58\uACE0 \uC788\uB2E4\uB294
      \uB9D0\uC500\uC778\uAC00\uC694? \uC804 \uADF8\uB0E5 \uC57D\uC18D\uC774 \uC9C0\uCF1C\uC9C0\uAE38
      \uBC14\uB780 \uAC74\uB370... \uB108\uBB34 \uC18D\uC0C1\uD574\uC11C \uB208\uBB3C
      \uB098\uC694."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Moodmaker_2
    ko: "\uC9C8\uCC45\uC744 \uAD00\uACC4 \uD30C\uD0C4\uC73C\uB85C \uB290\uAEF4 \uC5D0\uB108\uC9C0\uB97C
      \uC783\uACE0 \uAC00\uB77C\uC549\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Ch_Bond_003
    ko: "\uC804\uC220\uD310\uC744 \uCE58\uC6B0\uACE0 \uACF5\uC744 \uB358\uC838 \uD6C8\uB828
      \uD15C\uD3EC\uB97C \uCD5C\uACE0\uB85C \uC62C\uB9BC."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uB9D0\uB3C4 \uC5C6\uC774 \uD310\uC744 \uCE58\uC6B0\uC2DC\uB2E4\uB2C8...
      \uC81C\uAC00 \uD300\uC758 \uD654\uD569\uC744 \uAE68\uC11C \uD654\uAC00 \uB9CE\uC774
      \uB098\uC168\uB098 \uBD10\uC694."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Kind_3
    ko: "\uC555\uBC15\uC744 \uAC70\uC808\uB85C \uD574\uC11D\uD574 \uB208\uCE58 \uBCF4\uB290\uB77C
      \uC9D1\uC911\uD558\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Loyal_301
    ko: "\uB9E4\uB274\uC5BC\uB3C4 \uC5C6\uC774 \uC774\uB7F0 \uC18D\uB3C4\uBA74 \uBD84\uBA85
      \uC0AC\uACE0\uAC00 \uB0A9\uB2C8\uB2E4. \uC57D\uC18D\uB418\uC9C0 \uC54A\uC740
      \uC6C0\uC9C1\uC784\uC740 \uD300\uC744 \uC704\uD5D8\uD558\uAC8C \uB9CC\uB4E4
      \uBFD0\uC774\uC5D0\uC694!"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Loyal_3
    ko: "\uD1B5\uC81C \uBD88\uB2A5\uC744 \uB290\uAEF4 \uB3D9\uB8CC\uC758 \uC2E4\uC218\uB97C
      \uC608\uBBFC\uD558\uAC8C \uBE44\uB09C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Sincere_301
    ko: "\uC0DD\uAC01\uD560 \uD2C8\uC744 \uC548 \uC8FC\uC2DC\uB294\uAD70\uC694. \uBAB8\uC73C\uB85C
      \uC57D\uC18D\uC744 \uB2E4\uC2DC \uC4F0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Sincere_3
    ko: "\uAC15\uD55C \uBB3C\uB9AC\uC801 \uC790\uADF9\uC774 \uB2A5\uB825\uC744 \uAE68\uC6CC
      \uCD5C\uC0C1 \uD37C\uD3EC\uBA3C\uC2A4\uB97C \uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Moodmaker_301
    ko: "\uAC10\uB3C5\uB2D8 \uAC11\uC790\uAE30 \uC65C \uADF8\uB7EC\uC138\uC694? \uB108\uBB34
      \uBB34\uC11C\uC6CC\uC694... \uC774\uB7F0 \uBD84\uC704\uAE30\uC5D0\uC120 \uB3C4\uC800\uD788
      \uC990\uAC81\uAC8C \uD328\uC2A4\uD560 \uC218 \uC5C6\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Moodmaker_3
    ko: "\uBB34\uC5B8\uC758 \uC555\uBC15\uAC10\uC5D0 \uACF5\uD3EC\uB97C \uB290\uAEF4
      \uAC10\uAC01\uC774 \uC644\uC804\uD788 \uB9C8\uBE44\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Cold_001
    ko: "\uD300\uC758 \uD575\uC2EC \uD328\uC11C\uC778 \uC120\uC218\uAC00 \uD6C8\uB828
      \uC911 \uC2E4\uCC45\uC744 \uBC94\uD569\uB2C8\uB2E4. \uADF8\uB294 \uAC10\uB3C5\uB2D8\uC774
      \uB098\uB204\uC5B4\uC900 \uACF5\uC2DD \uC804\uC220 \uB9E4\uB274\uC5BC\uC744
      \uBC14\uB2E5\uC5D0 \uD3BC\uCCD0\uB193\uACE0,"
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Cold_002
    ko: "\uC790\uC2E0\uC758 \uD328\uC2A4\uB294 \uB9E4\uB274\uC5BC\uB300\uB85C \uC644\uBCBD\uD588\uC73C\uB098
      \uC218\uBE44\uC218\uC758 \uB3CC\uBC1C \uC6C0\uC9C1\uC784\uC5D0 \uB300\uC751\uD558\uC9C0
      \uBABB\uD55C \uB3D9\uB8CC\uC758 \uD0DC\uB3C4\uC640 \uC57D\uC18D \uC704\uBC18\uC744
      \uD0D3\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Cold_003
    ko: "\uC815\uD574\uC9C4 \uADDC\uC728\uC774 \uBB34\uB108\uC9C4 \uC0C1\uD669\uC5D0
      \uB2F9\uD639\uAC10\uC744 \uB290\uB07C\uBA70 \uC790\uAD34\uAC10\uACFC \uBD84\uB178\uC5D0
      \uBE60\uC838 \uD6C8\uB828 \uD750\uB984\uC744 \uBC29\uD574\uD558\uB294 \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Cold_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00011_Ch_Cold_001
    ko: "\uACE0\uC815\uB41C \uC6D0\uCE59\uBCF4\uB2E4 \uC0B4\uC544 \uC6C0\uC9C1\uC774\uB294
      \uD604\uC7A5\uC758 \uD750\uB984\uC774 \uC815\uB2F5\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Planner_101
    ko: "\uD604\uC7A5\uC758 \uD750\uB984\uC740 \uAD6C\uC870\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4.
      \uAC80\uC99D\uB418\uC9C0 \uC54A\uC740 \uBCC0\uC218\uC5D0 \uD310\uC744 \uB9E1\uAE30\uB294
      \uAC74 \uB3C4\uBC15\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Planner_1
    ko: "\uC7A5\uAE30\uC801 \uD310\uC744 \uC911\uC2DC\uD574 \uC989\uD765\uC801 \uACA9\uB824\uB85C\uB294
      \uC7AC\uAC00\uB3D9\uD558\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Opportunist_101
    ko: "\uB3D9\uB8CC\uC758 \uC2E4\uC218\uB97C \uC0C1\uC218\uB85C \uB450\uB77C\uB294
      \uB9D0\uC500\uC774\uC2DC\uAD70\uC694. \uC2E4\uB9AC\uB294 \uC5C6\uACA0\uC9C0\uB9CC
      \uC77C\uB2E8 \uB2E4\uC2DC \uC6C0\uC9C1\uC5EC\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Opportunist_1
    ko: "\uBCF5\uADC0\uD588\uC73C\uB098 \uC2E4\uC775\uC774 \uC5C6\uB2E4\uACE0 \uD310\uB2E8\uD574
      \uC18C\uADF9\uC801\uC73C\uB85C \uC784\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Cunning_101
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uB3D9\uB8CC\uC758 \uC6C0\uC9C1\uC784\uC744 \uC774\uC6A9\uD558\uB294
      \uAC8C \uC81C \uD328\uC2A4\uB97C \uB354 \uB3CB\uBCF4\uC774\uAC8C \uD558\uACA0\uAD70\uC694.
      \uB2E4\uC2DC \uB9DE\uCDB0\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Cunning_1
    ko: "\uC2EC\uB9AC\uC804\uC758 \uAC00\uCE58\uB97C \uAE68\uB2EB\uACE0 \uC21C\uC751\uD558\uB294
      \uCC99 \uC601\uC545\uD558\uAC8C \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Believer_101
    ko: "\uC81C \uB17C\uB9AC\uC801 \uACB0\uB860\uC740 \uBCC0\uD568\uC5C6\uC2B5\uB2C8\uB2E4.
      \uC624\uB2F5\uC774 \uC788\uB294 \uCF54\uD2B8\uC5D0\uC11C \uC815\uB2F5\uC744
      \uB358\uC9C0\uB294 \uAC74 \uBE44\uB17C\uB9AC\uC801\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Believer_1
    ko: "\uC2E0\uB150\uC774 \uD655\uACE0\uD574 \uC720\uC5F0\uD55C \uACA9\uB824\uB85C\uB294
      \uACE0\uC9D1\uC744 \uAEBE\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Ch_Cold_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Planner_201
    ko: "\uB2E8\uC77C \uACBD\uB85C\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uC804\uCCB4 \uAD6C\uC870\uB97C
      \uBA48\uCD98 \uAC8C \uC81C \uC124\uACC4 \uC624\uB958\uC600\uAD70\uC694. \uD310\uC744
      \uB2E4\uC2DC \uC9DC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Planner_2
    ko: "\uBE44\uD6A8\uC728 \uC9C0\uC801\uC5D0 \uB17C\uB9AC\uC801 \uC624\uB958\uB97C
      \uC778\uC815\uD558\uACE0 \uC989\uC2DC \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Opportunist_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uAC00\uC7A5 \uC720\uB9AC\uD55C \uD0C0\uC774\uBC0D\uC774\uC5C8\uC2B5\uB2C8\uB2E4.
      \uC2DC\uC2A4\uD15C \uBB38\uC81C\uB97C \uC81C \uC2DC\uC57C \uD0D3\uC73C\uB85C
      \uB3CC\uB9AC\uC2DC\uB2C8 \uC2E4\uC775\uC774 \uC5C6\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Opportunist_2
    ko: "\uB2A5\uB825\uC744 \uBD80\uC815\uB2F9\uD558\uC790 \uC2E4\uB9AC\uAC00 \uC5C6\uB2E4
      \uD310\uB2E8\uD574 \uAC15\uD558\uAC8C \uBC18\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Cunning_201
    ko: "\uC81C \uC218\uB2E8\uC774 \uB108\uBB34 \uB178\uACE8\uC801\uC774\uC5C8\uB098
      \uBCF4\uB124\uC694. \uC9C0\uC801\uD558\uC2E0 \uB300\uB85C \uC880 \uB354 \uC740\uBC00\uD558\uAC8C
      \uC6C0\uC9C1\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Cunning_2
    ko: "\uC218\uB2E8\uC774 \uAC04\uD30C\uB2F9\uD574 \uC704\uCD95\uB418\uC5B4 \uB208\uCE58
      \uBCF4\uB290\uB77C \uACBD\uC9C1\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Believer_201
    ko: "\uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uB294 \uAC74 \uC81C \uC2E0\uB150\uC5D0\uB3C4
      \uC5B4\uAE0B\uB0A9\uB2C8\uB2E4. \uB17C\uB9AC\uB97C \uB300\uC758\uC5D0 \uB9DE\uCDB0
      \uB2E4\uC2DC \uC138\uC6B0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Believer_2
    ko: "\uC2E0\uB150\uC774 \uC2B9\uB9AC\uC640 \uCDA9\uB3CC\uD568\uC744 \uAE68\uB2EB\uACE0
      \uC2A4\uC2A4\uB85C \uC218\uC6A9\uD574 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Ch_Cold_003
    ko: "\uBC14\uB2E5\uC758 \uB9E4\uB274\uC5BC\uC744 \uCE58\uC6CC\uBC84\uB9AC\uACE0
      \uACF5\uC744 \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Planner_301
    ko: "\uC124\uACC4\uB3C4\uAC00 \uC0AC\uB77C\uC84C\uC73C\uB2C8 \uD604\uC7A5\uC5D0\uC11C
      \uC9C1\uC811 \uB370\uC774\uD130\uB97C \uC218\uC9D1\uD558\uB77C\uB294 \uB73B\uC785\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Planner_3
    ko: "\uB3C4\uAD6C\uAC00 \uC0AC\uB77C\uC838 \uC0C8 \uAD6C\uC870\uB97C \uD30C\uC545\uD558\uB290\uB77C
      \uBCF5\uADC0\uAC00 \uB2A6\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Opportunist_301
    ko: "\uC0DD\uAC01\uD560 \uD2C8\uB3C4 \uC5C6\uC774 \uAE30\uD68C\uAC00 \uC624\uB124\uC694.
      \uC9C0\uAE08\uC740 \uC774\uAC8C \uCD5C\uC120\uC774\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Opportunist_3
    ko: "\uAC15\uC81C\uC801 \uD15C\uD3EC \uC0C1\uC2B9\uC774 \uBCF8\uB2A5\uC744 \uAE68\uC6CC
      \uC2E4\uB9AC\uC801 \uACB0\uACFC\uB97C \uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Cunning_301
    ko: "\uC774\uB7F0 \uBB34\uC9C8\uC11C\uD55C \uBC29\uC2DD\uC740 \uC81C \uC2A4\uD0C0\uC77C\uC774
      \uC544\uB2D9\uB2C8\uB2E4. \uC81C \uD328\uB97C \uC228\uAE38 \uC218 \uC5C6\uB294
      \uD658\uACBD\uC740 \uAC70\uBD80\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Cunning_3
    ko: "\uC0C1\uD669\uC774 \uAE09\uBC15\uD574\uC838 \uC2EC\uB9AC\uC801 \uC6B0\uC704\uB97C
      \uC783\uACE0 \uC9D1\uC911\uB825\uC774 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Believer_301
    ko: "\uD310\uC774 \uC5C6\uC5B4\uB3C4 \uC81C \uB17C\uB9AC\uB294 \uC720\uD6A8\uD569\uB2C8\uB2E4.
      \uC774 \uBB34\uC9C8\uC11C \uC18D\uC5D0\uC11C\uB3C4 \uC81C \uC2E0\uB150\uC744
      \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Believer_3
    ko: "\uD398\uC774\uC2A4\uB294 \uC720\uC9C0\uD588\uC73C\uB098 \uD611\uB3D9\uBCF4\uB2E4\uB294
      \uC790\uAE30 \uC99D\uBA85\uC5D0 \uCE58\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Instinct_001
    ko: "\uD300\uC758 \uD575\uC2EC \uD328\uC11C\uC778 \uC120\uC218\uAC00 \uD6C8\uB828
      \uC911 \uC2E4\uCC45\uC744 \uBC94\uD569\uB2C8\uB2E4. \uADF8\uB294 \uAC10\uB3C5\uB2D8\uC774
      \uB098\uB204\uC5B4\uC900 \uACF5\uC2DD \uC804\uC220 \uB9E4\uB274\uC5BC\uC744
      \uBC14\uB2E5\uC5D0 \uD3BC\uCCD0\uB193\uACE0,"
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Instinct_002
    ko: "\uC790\uC2E0\uC758 \uD328\uC2A4\uB294 \uB9E4\uB274\uC5BC\uB300\uB85C \uC644\uBCBD\uD588\uC73C\uB098
      \uC218\uBE44\uC218\uC758 \uB3CC\uBC1C \uC6C0\uC9C1\uC784\uC744 \uC77D\uC9C0
      \uBABB\uD55C \uB3D9\uB8CC\uC758 \uD0DC\uB3C4\uC640 \uC57D\uC18D \uC704\uBC18\uC744
      \uD0D3\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Instinct_003
    ko: "\uC815\uD574\uC9C4 \uADDC\uC728\uC774 \uBB34\uB108\uC9C4 \uC0C1\uD669\uC5D0
      \uB2F9\uD639\uAC10\uC744 \uB290\uB07C\uBA70 \uC790\uAD34\uAC10\uACFC \uBD84\uB178\uC5D0
      \uBE60\uC838 \uD6C8\uB828 \uD750\uB984\uC744 \uBC29\uD574\uD558\uB294 \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Instinct_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00011_Ch_Instinct_001
    ko: "\uACE0\uC815\uB41C \uC6D0\uCE59\uBCF4\uB2E4 \uC0B4\uC544 \uC6C0\uC9C1\uC774\uB294
      \uD604\uC7A5\uC758 \uD750\uB984\uC774 \uC815\uB2F5\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Bluffer_101
    ko: "\uC81C \uD310\uB2E8\uC774\uC57C \uB298 \uC644\uBCBD\uD558\uC8E0! \uD558\uC9C0\uB9CC
      \uC774 \uC218\uC900 \uB0AE\uC740 \uC2DC\uC2A4\uD15C\uC774 \uC81C \uC874\uC7AC\uAC10\uC744
      \uAC00\uB85C\uB9C9\uACE0 \uC788\uB294 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Bluffer_1
    ko: "\uACFC\uC2DC\uC695\uB9CC \uCC44\uC6B0\uACE0 \uC2E4\uCC45\uC744 \uC2DC\uC2A4\uD15C
      \uD0D3\uD558\uBA70 \uD6C8\uB828\uC744 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Wild_101
    ko: "\uB9DE\uC544\uC694! \uC885\uC774 \uCABC\uAC00\uB9AC \uADDC\uCE59\uC774 \uC544\uB2C8\uB77C
      \uC81C \uAC10\uAC01\uC774 \uC815\uB2F5\uC774\uC8E0. \uC774\uC81C\uC57C \uC228\uD1B5\uC774
      \uC880 \uD2B8\uC774\uB124\uC694!"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Wild_1
    ko: "\uC9C1\uAD00\uC744 \uC911\uC2DC\uD574 \uAC10\uAC01\uC744 \uAE0D\uC815\uBC1B\uACE0
      \uC0DD\uB3D9\uAC10\uC744 \uCC3E\uC544 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Egoist_101
    ko: "\uC81C \uD310\uB2E8\uC744 \uBBFF\uB294 \uAC74 \uB2F9\uC5F0\uD558\uC8E0.
      \uADF8\uB7F0\uB370 \uC800 \uBC14\uBCF4 \uAC19\uC740 \uB3D9\uB8CC\uB4E4\uC774
      \uC81C \uC131\uC7A5\uC744 \uBC29\uD574\uD558\uACE0 \uC788\uB2E4\uACE0\uC694."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Egoist_1
    ko: "\uC774\uAE30\uC801\uC774\uB77C \uACA9\uB824\uC5D0\uB3C4 \uBD88\uB9CC\uC744
      \uD480\uC9C0 \uBABB\uD574 \uD750\uB984\uC774 \uB04A\uACBC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Fighter_101
    ko: "\uD750\uB984\uC744 \uBBFF\uC73C\uB77C\uACE0\uC694? \uD558\uC9C0\uB9CC \uC800
      \uB140\uC11D\uB4E4\uACFC \uBD80\uB52A\uCE58\uB2E4 \uBCF4\uBA74 \uD750\uB984\uC774\uACE0
      \uBB50\uACE0 \uB2E4 \uC5C9\uB9DD\uC774 \uB41C\uB2E4\uACE0\uC694."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Fighter_1
    ko: "\uACBD\uC7C1\uC2EC\uC740 \uC788\uC73C\uB098 \uACA9\uB824\uB9CC\uC73C\uB860
      \uAC08\uB4F1\uC774 \uC548 \uD480\uB824 \uC8FC\uC800\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Ch_Instinct_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Bluffer_201
    ko: "\uC81C \uC2DC\uC57C\uAC00 \uC881\uB2E4\uACE0\uC694? \uC81C \uD328\uC2A4\uAC00
      \uC5BC\uB9C8\uB098 \uC555\uB3C4\uC801\uC774\uC5C8\uB294\uC9C0 \uC99D\uBA85\uD574
      \uBCF4\uC774\uC8E0. \uB2F9\uC7A5 \uB2E4\uC2DC \uC2DC\uC791\uD569\uC2DC\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Bluffer_2
    ko: "\uC9C8\uCC45\uC73C\uB85C \uACFC\uC2DC\uC695\uC774 \uD3ED\uBC1C\uD574 \uC99D\uBA85\uD558\uB824
      \uC5F4\uC131\uC801\uC73C\uB85C \uB6F0\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Wild_201
    ko: "\uBC29\uC2DD\uC774\uACE0 \uBB50\uACE0, \uBAB8\uC774 \uC548 \uB530\uB77C\uC8FC\uB294\uB370
      \uC5B4\uCA4C\uB780 \uAC81\uB2C8\uAE4C? \uC77C\uB2E8 \uB6F0\uAE34 \uD558\uACA0\uC9C0\uB9CC
      \uC601 \uD765\uC774 \uC548 \uB098\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Wild_2
    ko: "\uB17C\uB9AC\uC801 \uC9C8\uCC45\uC774 \uBCF8\uB2A5\uC744 \uBABB \uAE68\uC6CC
      \uC5B5\uC9C0\uB85C \uC6C0\uC9C1\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Egoist_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD300\uC744 \uB9DD\uCE5C\uB2E4\uACE0\uC694? \uC81C
      \uC2E4\uB825\uC774 \uACE7 \uD300\uC758 \uC218\uC900\uC778\uB370 \uC5B4\uB5BB\uAC8C
      \uADF8\uB7F0 \uB9D0\uC500\uC744 \uD558\uC2ED\uB2C8\uAE4C!"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Egoist_2
    ko: "\uC790\uAE30\uC560\uC5D0 \uC0C1\uCC98\uB97C \uC785\uACE0 \uBD84\uB178\uD574
      \uAC10\uB3C5\uACFC \uCDA9\uB3CC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Fighter_201
    ko: "\uC9C0\uAE08 \uC81C\uAC00 \uC124\uB801\uC124\uB801\uD558\uB294 \uAC78\uB85C
      \uBCF4\uC774\uC2ED\uB2C8\uAE4C? \uB9E4\uB274\uC5BC\uB300\uB85C \uC2F8\uC6E0\uB294\uB370
      \uC5B5\uC6B8\uD574\uC11C \uBABB \uD558\uACA0\uB124\uC694!"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Fighter_2
    ko: "\uAC00\uCE58\uB97C \uBD80\uC815\uB2F9\uD574 \uC5B5\uC6B8\uD568\uACFC \uBD84\uB178\uB85C
      \uD6C8\uB828\uC744 \uB9DD\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Ch_Instinct_003
    ko: "\uBC14\uB2E5\uC758 \uB9E4\uB274\uC5BC\uC744 \uCE58\uC6CC\uBC84\uB9AC\uACE0
      \uACF5\uC744 \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Bluffer_301
    ko: "\uC624, \uAC10\uB3C5\uB2D8\uB3C4 \uC81C \uC2E4\uB825\uC744 \uBE68\uB9AC
      \uBCF4\uACE0 \uC2F6\uC73C\uC2E0 \uBAA8\uC591\uC774\uB124\uC694. \uC774 \uC815\uB3C4
      \uD15C\uD3EC\uC57C \uC6B0\uC2B5\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Bluffer_3
    ko: "\uAC15\uC555\uC744 \uC2A4\uD0C0\uC131 \uC778\uC815\uC73C\uB85C \uD574\uC11D\uD574
      \uC5EC\uC720\uB86D\uAC8C \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Wild_301
    ko: "\uC124\uBA85\uB3C4 \uC5C6\uC774 \uBB50 \uD558\uC2DC\uB294 \uAC81\uB2C8\uAE4C!
      \uC0AC\uB78C\uC744 \uC9D0\uC2B9 \uCDE8\uAE09\uD558\uB294 \uAC83\uB3C4 \uC544\uB2C8\uACE0,
      \uAE30\uBD84 \uC7A1\uCCD0\uC11C \uBABB \uB6F0\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Wild_3
    ko: "\uAC70\uCE5C \uD589\uB3D9\uC5D0 \uBC18\uBC1C\uC2EC\uACFC \uAC70\uBD80\uAC10\uC744
      \uB290\uB07C\uACE0 \uC774\uD0C8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Egoist_301
    ko: "\uBC29\uD574\uBB3C\uC744 \uCE58\uC6CC\uC8FC\uC2DC\uB2C8 \uC18D \uC2DC\uC6D0\uD558\uB124\uC694.
      \uC624\uC9C1 \uC81C \uC2E4\uB825\uC73C\uB85C\uB9CC \uC774 \uD310\uC744 \uCC44\uC6CC\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Egoist_3
    ko: "\uB9E4\uB274\uC5BC\uC774 \uC0AC\uB77C\uC9C0\uC790 \uC790\uAE30\uC560\uB97C
      \uC99D\uBA85\uD558\uB824 \uC989\uAC01 \uC2E4\uD589\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00011_Desc_Fighter_301
    ko: "\uADF8\uB798\uC694! \uB9D0\uC2F8\uC6C0\uD560 \uC2DC\uAC04\uC5D0 \uD55C \uBC88
      \uB354 \uBD80\uB52A\uCE58\uB294 \uAC8C \uB0AB\uC8E0! \uB2E4\uB4E4 \uB364\uBCBC!"
    en: 
    ja: 
  - stringKey: Event_00011_Rs_Fighter_3
    ko: "\uAC70\uCE5C \uAC1C\uC785\uC774 \uD22C\uC7C1\uC2EC\uC744 \uC790\uADF9\uD574
      \uD300 \uC5D0\uB108\uC9C0\uB97C \uD3ED\uBC1C\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Discipline_001
    ko: "\uD300\uC758 \uC804\uC220\uC744 \uC644\uBCBD\uD788 \uD1B5\uC81C\uD558\uB294
      \uC774 \uC120\uC218\uB294, \uC624\uB298 \uC5F0\uC2B5 \uACBD\uAE30\uC5D0\uC11C
      \uBC1C\uC0DD\uD55C \uB2E8 \uD55C \uBC88\uC758 \uD328\uC2A4 \uBBF8\uC2A4\uB97C
      \uBD84\uC11D\uD558\uB290\uB77C \uCF54\uD2B8\uB97C \uB5A0\uB098\uC9C0 \uBABB\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Discipline_002
    ko: "\uADF8 \uD328\uC2A4\uB294 \uC218\uCE58\uC0C1 \uC644\uBCBD\uD55C \uADA4\uC801\uC774\uC5C8\uC73C\uB098,
      \uB3D9\uB8CC\uC758 \uBC18\uC751 \uC18D\uB3C4\uAC00 0.1\uCD08 \uB2A6\uC5B4 \uC2E4\uCC45\uC73C\uB85C
      \uAE30\uB85D\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Discipline_003
    ko: "\uADDC\uC728\uC744 \uC2E0\uBD09\uD558\uB294 \uC774 \uC120\uC218\uC5D0\uAC8C
      \uC774\uAC83\uC740 \uB2E8\uC21C\uD55C \uC2E4\uC218\uAC00 \uC544\uB2C8\uB77C,
      \uC790\uC2E0\uC774 \uC124\uACC4\uD55C \uC2B9\uB9AC\uC758 \uACF5\uC2DD\uC5D0
      \uBC1C\uC0DD\uD55C \uCE58\uBA85\uC801\uC778 \uADE0\uC5F4\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Discipline_004
    ko: "\uADF8\uB294 \uB3D9\uB8CC\uC758 \uC5ED\uB7C9 \uBD80\uC871\uC870\uCC28 \uC790\uC2E0\uC758
      \uD1B5\uC81C \uBC94\uC704 \uC548\uC5D0 \uB123\uC9C0 \uBABB\uD55C \uAC83\uC744
      \uC790\uCC45\uD558\uBA70, \uB9C8\uCE58 \uAE30\uACC4\uAC00 \uACE0\uC7A5 \uB09C
      \uB4EF \uAC19\uC740 \uB3D9\uC791\uC744 \uC218\uBC31 \uBC88 \uBC18\uBCF5\uD558\uBA70
      \uC790\uC2E0\uC744 \uD559\uB300\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Discipline_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00012_Ch_Discipline_001
    ko: "\uACE0\uC815\uB41C \uC6D0\uCE59\uBCF4\uB2E4 \uC0B4\uC544 \uC6C0\uC9C1\uC774\uB294
      \uD604\uC7A5\uC758 \uD750\uB984\uC774 \uC815\uB2F5\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Principled_101
    ko: "\uB9E4\uB274\uC5BC\uC758 \uC57D\uC18D\uBCF4\uB2E4 \uD604\uC7A5\uC758 \uD750\uB984\uC744
      \uCD5C\uC0C1\uC704 \uC6D0\uCE59\uC73C\uB85C \uB450\uB77C\uB294 \uB9D0\uC500\uC774\uC2DC\uAD70\uC694.
      \uC989\uC2DC \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Principled_1
    ko: "\uC9C0\uC2DC\uB97C \uC0C8 \uC6D0\uCE59\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uC790\uCC45\uC744 \uBA48\uCD94\uACE0 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Guardian_101
    ko: "\uD604\uC7A5\uC744 \uBBFF\uC5B4\uBCF4\uACA0\uC9C0\uB9CC, \uC57D\uC18D\uC744
      \uC5B4\uAE30\uB294 \uAC8C \uD300\uC758 \uAE30\uAC15\uC744 \uD574\uCE58\uC9C0\uB294
      \uC54A\uC744\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Guardian_1
    ko: "\uC6D0\uCE59\uC774 \uAE68\uC9C8\uAE4C \uBD88\uC548\uD574 \uD50C\uB808\uC774\uAC00
      \uD06C\uAC8C \uC704\uCD95\uB418\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Tactician_101
    ko: "\uD604\uC7A5\uC758 \uD750\uB984\uC740 \uBCC0\uC218\uAC00 \uB108\uBB34 \uB9CE\uC2B5\uB2C8\uB2E4.
      \uC57D\uC18D\uB41C \uC704\uCE58\uC5D0 \uC5C6\uB294 \uB3D9\uB8CC\uC5D0\uAC8C
      \uD328\uC2A4\uD558\uB294 \uAC74 \uB3C4\uBC15\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Tactician_1
    ko: "\uACA9\uB824\uB97C \uBE44\uACFC\uD559\uC801\uC774\uB77C \uCE58\uBD80\uD558\uACE0
      \uD328\uC2A4 \uB17C\uB9AC\uB97C \uACE0\uC9D1\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Exemplary_101
    ko: "\uB124! \uB9E4\uB274\uC5BC\uC744 \uB118\uC5B4\uC11C \uD604\uC7A5\uC5D0 \uB9DE\uCD94\uB294
      \uC720\uC5F0\uD55C \uC120\uC218\uAC00 \uB418\uACA0\uC2B5\uB2C8\uB2E4! \uB2E4\uC2DC
      \uD574\uBCF4\uC790 \uC598\uB4E4\uC544!"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Exemplary_1
    ko: "\uACA9\uB824\uB97C \uC0C8 \uAC15\uB839\uC73C\uB85C \uC0BC\uC544 \uC790\uCC45\uC744
      \uB5A8\uCE58\uACE0 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Ch_Discipline_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Principled_201
    ko: "\uC81C \uC6D0\uCE59 \uC774\uD589\uC774 \uD2C0\uB9B0 \uAC81\uB2C8\uAE4C?
      \uADDC\uC728\uB300\uB85C \uD588\uC744 \uBFD0\uC778\uB370... \uAE30\uC900\uC744
      \uB2E4\uC2DC \uAC80\uD1A0\uD574\uC57C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Principled_2
    ko: "\uD63C\uB780\uC5D0 \uBE60\uC838 \uC6D0\uC778 \uBD84\uC11D\uC5D0 \uB9E4\uBAB0\uB418\uB290\uB77C
      \uD6C8\uB828\uC744 \uBABB \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Guardian_201
    ko: "\uC800\uB294 \uADF8\uC800 \uAC10\uB3C5\uB2D8\uC774 \uC815\uD55C \uADDC\uCE59\uC744
      \uC218\uD638\uD558\uB824 \uD588\uC744 \uBFD0\uC785\uB2C8\uB2E4... \uC800 \uB54C\uBB38\uC5D0
      \uD300\uC774 \uB9DD\uAC00\uC9C4 \uAC74\uAC00\uC694?"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Guardian_2
    ko: "\uB178\uB825\uC774 \uBD80\uC815\uB2F9\uD558\uC790 \uC790\uAD34\uAC10\uC5D0
      \uBE60\uC838 \uC644\uC804\uD788 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Tactician_201
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uB9E4\uB274\uC5BC\uC774\uB77C\uB294 \uACF5\uC2DD\uC5D0
      \uAC07\uD600 \uC2E4\uC2DC\uAC04 \uBCC0\uC218\uB97C \uC77D\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4.
      \uC989\uC2DC \uC804\uC220\uC744 \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC73C\uB85C \uC218\uB2E8\uC758 \uC720\uC5F0\uC131\uC744 \uAE68\uB2EC\uC544
      \uC989\uC2DC \uC790\uCC45\uC744 \uBA48\uCDC4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Exemplary_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uC81C\uAC00 \uC6D0\uCE59\uC5D0 \uB108\uBB34
      \uC608\uBBFC\uD588\uB098 \uBD05\uB2C8\uB2E4. \uB2E4\uC2DC \uBAA8\uBC94\uC801\uC73C\uB85C
      \uD6C8\uB828\uC5D0 \uC784\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Exemplary_2
    ko: "\uC9C0\uC2DC\uC5D0 \uC21C\uC751\uD588\uC73C\uB098 \uD655\uC2E0\uC774 \uC0AC\uB77C\uC838
      \uD0C0\uC774\uBC0D\uC744 \uB193\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Ch_Discipline_003
    ko: "\uC120\uC218\uC758 \uB9E4\uB274\uC5BC\uC744 \uB36E\uC5B4\uBC84\uB9AC\uACE0
      \uACF5\uC744 \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Principled_301
    ko: "\uAC00\uC774\uB4DC\uB77C\uC778\uB3C4 \uC5C6\uC774 \uC5B4\uB5BB\uAC8C \uC9C8\uC11C\uB97C
      \uC720\uC9C0\uD569\uB2C8\uAE4C? \uC57D\uC18D\uC774 \uC0AC\uB77C\uC9C4 \uCF54\uD2B8\uB294
      \uC5C9\uB9DD\uC9C4\uCC3D\uC785\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Principled_3
    ko: "\uAE30\uC900 \uC0C1\uC2E4\uB85C \uC790\uAD34\uAC10\uC774 \uBD84\uB178\uB85C
      \uBCC0\uD574 \uD6C8\uB828\uC744 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Guardian_301
    ko: "\uD310 \uBC16\uC758 \uC0C1\uD669\uB3C4 \uC81C\uAC00 \uCC45\uC784\uC838\uC57C
      \uD560 \uC601\uC5ED\uC774\uAD70\uC694. \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uB2E4\uC2DC
      \uAC00\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Guardian_3
    ko: "\uC804\uC220\uD310 \uC0C1\uC2E4\uC5D0 \uB3D9\uB8CC\uB97C \uC9C0\uD0AC \uCC45\uC784\uAC10\uC774
      \uC0DD\uACA8 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Tactician_301
    ko: "\uAE30\uC900\uC810\uC774 \uC0AC\uB77C\uC9C4 \uD658\uACBD\uC5D0\uC11C\uC758
      \uC131\uACF5 \uD655\uB960\uC744 \uB2E4\uC2DC \uACC4\uC0B0\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uC77C\uB2E8\uC740 \uD15C\uD3EC\uC5D0 \uB9DE\uCD94\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Tactician_3
    ko: "\uAC1C\uC785\uC744 \uC2E4\uD5D8\uC73C\uB85C \uC5EC\uACA8 \uB370\uC774\uD130
      \uC815\uB9AC \uC804\uAE4C\uC9C0 \uC870\uC2EC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Exemplary_301
    ko: "\uC804\uC220\uD310\uC744 \uCE58\uC6B0\uC2DC\uB2E4\uB2C8... \uC81C\uAC00
      \uB9E4\uB274\uC5BC\uC5D0 \uC9D1\uCC29\uD558\uB294 \uBAA8\uC2B5\uC774 \uADF8\uB9CC\uD07C
      \uC2E4\uB9DD\uC2A4\uB7EC\uC6B0\uC168\uB358 \uAC70\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Exemplary_3
    ko: "\uD589\uB3D9\uC744 \uB099\uC81C\uB85C \uC778\uC2DD\uD574 \uC644\uC804\uD788
      \uC704\uCD95\uB418\uC5B4 \uD6C8\uB828 \uBD88\uAC00\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Bond_001
    ko: "\uD300\uC758 \uC804\uC220\uC744 \uC644\uBCBD\uD788 \uD1B5\uC81C\uD558\uB294
      \uC774 \uC120\uC218\uB294, \uC624\uB298 \uC5F0\uC2B5 \uACBD\uAE30\uC5D0\uC11C
      \uBC1C\uC0DD\uD55C \uB2E8 \uD55C \uBC88\uC758 \uD328\uC2A4 \uBBF8\uC2A4\uB97C
      \uBD84\uC11D\uD558\uB290\uB77C \uCF54\uD2B8\uB97C \uB5A0\uB098\uC9C0 \uBABB\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Bond_002
    ko: "\uADF8 \uD328\uC2A4\uB294 \uC218\uCE58\uC0C1 \uC644\uBCBD\uD55C \uADA4\uC801\uC774\uC5C8\uC73C\uB098,
      \uB3D9\uB8CC\uC758 \uBC18\uC751 \uC18D\uB3C4\uAC00 0.1\uCD08 \uB2A6\uC5B4 \uC2E4\uCC45\uC73C\uB85C
      \uAE30\uB85D\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Bond_003
    ko: "\uC720\uB300\uB97C \uC18C\uC911\uD788 \uD558\uB294 \uC774 \uC120\uC218\uC5D0\uAC8C
      \uC774\uAC83\uC740 \uB2E8\uC21C\uD55C \uC2E4\uC218\uAC00 \uC544\uB2C8\uB77C,
      \uB3D9\uB8CC\uC640\uC758 \uD569\uC744 \uB9DE\uCD94\uC9C0 \uBABB\uD55C \uC790\uC2E0\uC758
      \uBD80\uC871\uD568\uC774\uBA70 \uD568\uAED8\uB77C\uB294 \uACF5\uC2DD\uC5D0
      \uBC1C\uC0DD\uD55C \uADE0\uC5F4\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Bond_004
    ko: "\uADF8\uB294 \uB3D9\uB8CC\uC758 \uC5ED\uB7C9\uAE4C\uC9C0 \uC138\uC2EC\uD788
      \uC0B4\uD53C\uC9C0 \uBABB\uD55C \uAC83\uC744 \uC790\uCC45\uD558\uBA70, \uB9C8\uCE58
      \uAE30\uACC4\uAC00 \uACE0\uC7A5 \uB09C \uB4EF \uAC19\uC740 \uB3D9\uC791\uC744
      \uC218\uBC31 \uBC88 \uBC18\uBCF5\uD558\uBA70 \uC790\uC2E0\uC744 \uD559\uB300\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Bond_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00012_Ch_Bond_001
    ko: "\uACE0\uC815\uB41C \uC6D0\uCE59\uBCF4\uB2E4 \uC0B4\uC544 \uC6C0\uC9C1\uC774\uB294
      \uD604\uC7A5\uC758 \uD750\uB984\uC774 \uC815\uB2F5\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Kind_101
    ko: "\uC81C \uD310\uB2E8\uC774 \uB3D9\uB8CC\uB4E4\uC5D0\uAC8C \uC0C1\uCC98\uAC00
      \uB418\uC9C0 \uC54A\uC558\uC744\uAE4C\uC694? \uD750\uB984\uC5D0 \uB9E1\uAE30\uB77C\uB294
      \uB9D0\uC500 \uB355\uBD84\uC5D0 \uB9C8\uC74C\uC774 \uD55C\uACB0 \uAC00\uBCCD\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Kind_1
    ko: "\uB530\uB73B\uD55C \uC9C0\uC9C0\uB85C \uC790\uCC45\uAC10\uC744 \uB35C\uACE0
      \uB3D9\uB8CC\uB4E4\uACFC \uD638\uD761\uC744 \uB9DE\uCDC4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C \uD574\uBCF4\uACA0\uC9C0\uB9CC,
      \uC81C\uAC00 \uC815\uD574\uC9C4 \uC57D\uC18D\uC744 \uC5B4\uACA8\uC11C \uD300\uC5D0
      \uB204\uB97C \uB07C\uCE58\uB294 \uAC74 \uC544\uB2D0\uC9C0 \uAC71\uC815\uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Loyal_1
    ko: "\uC2E0\uB8B0\uB85C \uB530\uB974\uB098 \uC6D0\uCE59 \uC704\uBC18\uC758 \uB0B4\uC801
      \uAC08\uB4F1\uC73C\uB85C \uC870\uC2EC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Sincere_101
    ko: "\uD604\uC7A5\uC758 \uD750\uB984\uC5D0 \uB9DE\uCD94\uB824\uBA74 \uC81C\uAC00
      \uC900\uBE44\uD55C \uB8E8\uD2F4\uC774 \uB2E4 \uBB34\uB108\uC9D1\uB2C8\uB2E4.
      \uADF8\uAC74 \uB108\uBB34 \uBD88\uC548\uD55C \uC77C\uC774\uC5D0\uC694."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Sincere_1
    ko: "\uBC29\uC2DD\uC744 \uC911\uC2DC\uD574 \uAC11\uC791\uC2A4\uB7F0 \uC720\uC5F0\uC131
      \uAC15\uC870\uC5D0 \uD06C\uAC8C \uD63C\uB780\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Moodmaker_101
    ko: "\uADF8\uB798\uC694, \uB108\uBB34 \uBE61\uBE61\uD558\uAC8C \uAD74 \uD544\uC694
      \uC5C6\uC8E0! \uB2E4\uB4E4 \uD138\uC5B4\uBC84\uB9AC\uACE0 \uB2E4\uC2DC \uC990\uAC81\uAC8C
      \uD55C \uD310 \uD569\uC2DC\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Moodmaker_1
    ko: "\uAE0D\uC815 \uC5D0\uB108\uC9C0\uB97C \uD761\uC218\uD574 \uBD84\uC704\uAE30\uB97C
      \uBC18\uC804\uC2DC\uD0A4\uACE0 \uC8FC\uB3C4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Ch_Bond_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Kind_201
    ko: "\uC81C\uAC00 \uD300\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4\uB2C8 \uC2AC\uD504\uB124\uC694.
      \uB354 \uC798\uD558\uACE0 \uC2F6\uC5C8\uB294\uB370 \uC81C \uB9C8\uC74C\uC774
      \uC804\uB2EC\uB418\uC9C0 \uC54A\uC558\uB098 \uBD05\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Kind_2
    ko: "\uC9C8\uCC45\uC5D0 \uC120\uC758\uAC00 \uBD80\uC815\uB2F9\uD588\uB2E4 \uB290\uAEF4
      \uC704\uCD95\uB418\uC5B4 \uC9D1\uC911 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Loyal_201
    ko: "\uAC10\uB3C5\uB2D8\uC744 \uC2E4\uB9DD\uC2DC\uCF1C \uB4DC\uB824 \uC8C4\uC1A1\uD569\uB2C8\uB2E4.
      \uC800\uB294 \uD300\uC744 \uC704\uD574 \uCD5C\uC120\uC744 \uB2E4\uD588\uC744
      \uBFD0\uC778\uB370... \uB354 \uC774\uC0C1 \uD560 \uB9D0\uC774 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC5D0 \uC790\uC874\uAC10\uC774 \uC644\uC804\uD788 \uBB34\uB108\uC838
      \uD65C\uB3D9 \uBD88\uB2A5 \uC0C1\uD0DC\uAC00 \uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Sincere_201
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uC81C \uC131\uC2E4\uD568\uC774 \uC624\uD788\uB824
      \uD300\uC758 \uC720\uC5F0\uC131\uC744 \uAC00\uB85C\uB9C9\uACE0 \uC788\uC5C8\uAD70\uC694.
      \uB2F9\uC7A5 \uC5F0\uC2B5 \uBC29\uC2DD\uC744 \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Sincere_2
    ko: "\uBE44\uD6A8\uC728 \uC9C0\uC801\uC744 \uAC1C\uC120 \uACFC\uC81C\uB85C \uC0BC\uC544
      \uC131\uC2E4\uD558\uAC8C \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Moodmaker_201
    ko: "\uD300 \uBD84\uC704\uAE30 \uB9DD\uCE58\uB824\uB294 \uAC8C \uC544\uB2C8\uC5C8\uB294\uB370...
      \uC81C\uAC00 \uB108\uBB34 \uC608\uBBFC\uD588\uB098 \uBCF4\uB124\uC694. \uC870\uAE08
      \uBB34\uC548\uD558\uAE34 \uD558\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Moodmaker_2
    ko: "\uB208\uCE58 \uBCF4\uBA70 \uBCF5\uADC0\uD588\uC73C\uB098 \uD65C\uBC1C\uD568\uC774
      \uC0AC\uB77C\uC838 \uC5D0\uB108\uC9C0\uAC00 \uC8FD\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Ch_Bond_003
    ko: "\uC120\uC218\uC758 \uB9E4\uB274\uC5BC\uC744 \uB36E\uC5B4\uBC84\uB9AC\uACE0
      \uACF5\uC744 \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uC0AC\uACFC\uB3C4 \uB4E3\uC9C0 \uC54A\uC73C\uC2DC\uACE0
      \uC774\uB807\uAC8C \uBB34\uC815\uD558\uAC8C... \uC81C\uAC00 \uADF8\uB807\uAC8C
      \uD070 \uC798\uBABB\uC744 \uD588\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Kind_3
    ko: "\uC555\uBC15\uC5D0 \uC18C\uC678\uAC10\uC744 \uB290\uB07C\uACE0 \uB9C8\uC74C\uC758
      \uBB38\uC744 \uC644\uC804\uD788 \uB2EB\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Loyal_301
    ko: "\uC0DD\uAC01\uC740 \uC0AC\uCE58\uAD70\uC694. \uAC10\uB3C5\uB2D8\uC758 \uD718\uC2AC\uC5D0
      \uBAB8\uC744 \uB9E1\uAE30\uACA0\uC2B5\uB2C8\uB2E4. \uB2E4\uC2DC \uAC00\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Loyal_3
    ko: "\uB2E8\uD638\uD55C \uD589\uB3D9\uC744 \uC790\uCC45 \uC911\uC9C0 \uBA85\uB839\uC73C\uB85C
      \uC5EC\uACA8 \uC989\uC2DC \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Sincere_301
    ko: "\uC544\uC9C1 \uBD84\uC11D\uC774 \uB35C \uB05D\uB0AC\uB294\uB370 \uACF5\uBD80\uD130
      \uC8FC\uC2DC\uBA74... \uC77C\uB2E8 \uBAB8\uBD80\uD130 \uC6C0\uC9C1\uC5EC \uBCF4\uACA0\uC9C0\uB9CC
      \uB9C8\uC74C\uC774 \uAE09\uD574\uC9D1\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Sincere_3
    ko: "\uAC15\uC81C \uC9C4\uD589\uC73C\uB85C \uB9AC\uB4EC\uC774 \uC5C9\uCF1C \uC2E4\uC218\uAC00
      \uC7A6\uC544\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Moodmaker_301
    ko: "\uAC11\uC790\uAE30 \uC65C \uD654\uB97C \uB0B4\uC138\uC694? \uC81C\uAC00
      \uC798\uBABB\uD55C \uAC74 \uC54C\uC9C0\uB9CC \uC774\uB807\uAC8C\uAE4C\uC9C0
      \uBB34\uC2DC\uB2F9\uD558\uB2C8 \uC815\uB9D0 \uAE30\uBD84 \uBCC4\uB85C\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Moodmaker_3
    ko: "\uBD84\uC704\uAE30\uAC00 \uC2F8\uB298\uD574\uC9C0\uC790 \uC0C1\uCC98\uBC1B\uC740
      \uAC10\uC815\uC73C\uB85C \uD6C8\uB828\uC744 \uC774\uD0C8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Cold_001
    ko: "\uD300\uC758 \uC804\uC220\uC744 \uC644\uBCBD\uD788 \uD1B5\uC81C\uD558\uB294
      \uC774 \uC120\uC218\uB294, \uC624\uB298 \uC5F0\uC2B5 \uACBD\uAE30\uC5D0\uC11C
      \uBC1C\uC0DD\uD55C \uB2E8 \uD55C \uBC88\uC758 \uD328\uC2A4 \uBBF8\uC2A4\uB97C
      \uBD84\uC11D\uD558\uB290\uB77C \uCF54\uD2B8\uB97C \uB5A0\uB098\uC9C0 \uBABB\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Cold_002
    ko: "\uADF8 \uD328\uC2A4\uB294 \uC218\uCE58\uC0C1 \uC644\uBCBD\uD55C \uADA4\uC801\uC774\uC5C8\uC73C\uB098,
      \uB3D9\uB8CC\uC758 \uBC18\uC751 \uC18D\uB3C4\uAC00 0.1\uCD08 \uB2A6\uC5B4 \uC2E4\uCC45\uC73C\uB85C
      \uAE30\uB85D\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Cold_003
    ko: "\uB0C9\uCCA0\uD55C \uC774 \uC120\uC218\uC5D0\uAC8C \uC774\uAC83\uC740 \uB2E8\uC21C\uD55C
      \uC2E4\uC218\uAC00 \uC544\uB2C8\uB77C, \uC790\uC2E0\uC774 \uC124\uACC4\uD55C
      \uC2B9\uB9AC\uC758 \uACF5\uC2DD\uC5D0 \uBC1C\uC0DD\uD55C \uCE58\uBA85\uC801\uC778
      \uADE0\uC5F4\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Cold_004
    ko: "\uADF8\uB294 \uB3D9\uB8CC\uC758 \uC5ED\uB7C9 \uBD80\uC871\uC870\uCC28 \uC790\uC2E0\uC758
      \uD1B5\uC81C \uBC94\uC704 \uC548\uC5D0 \uB123\uC9C0 \uBABB\uD55C \uAC83\uC744
      \uC790\uCC45\uD558\uBA70, \uB9C8\uCE58 \uAE30\uACC4\uAC00 \uACE0\uC7A5 \uB09C
      \uB4EF \uAC19\uC740 \uB3D9\uC791\uC744 \uC218\uBC31 \uBC88 \uBC18\uBCF5\uD558\uBA70
      \uC790\uC2E0\uC744 \uD559\uB300\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Cold_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00012_Ch_Cold_001
    ko: "\uACE0\uC815\uB41C \uC6D0\uCE59\uBCF4\uB2E4 \uC0B4\uC544 \uC6C0\uC9C1\uC774\uB294
      \uD604\uC7A5\uC758 \uD750\uB984\uC774 \uC815\uB2F5\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Planner_101
    ko: "\uD604\uC7A5\uC758 \uD750\uB984\uC740 \uAD6C\uC870\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4.
      \uAC80\uC99D\uB418\uC9C0 \uC54A\uC740 \uBCC0\uC218\uC5D0 \uD310\uC744 \uB9E1\uAE30\uB294
      \uAC74 \uD6C8\uB828\uC774 \uC544\uB2C8\uB77C \uB3C4\uBC15\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Planner_1
    ko: "\uC7A5\uAE30\uC801 \uD310\uC744 \uC911\uC2DC\uD574 \uC989\uD765\uC801 \uACA9\uB824\uB85C\uB294
      \uC7AC\uAC00\uB3D9\uD558\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Opportunist_101
    ko: "\uB3D9\uB8CC\uC758 \uC2E4\uC218\uB97C \uC0C1\uC218\uB85C \uB450\uB77C\uB294
      \uB9D0\uC500\uC774\uC2DC\uAD70\uC694. \uC2E4\uB9AC\uB294 \uC5C6\uACA0\uC9C0\uB9CC
      \uC77C\uB2E8 \uB2E4\uC2DC \uC6C0\uC9C1\uC5EC\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Opportunist_1
    ko: "\uC9C0\uC2DC\uB97C \uC0C1\uD669 \uBCC0\uD654\uB85C \uC218\uC6A9\uD588\uC73C\uB098
      \uC2E4\uC775\uC774 \uC5C6\uB2E4\uACE0 \uD310\uB2E8\uD574 \uC18C\uADF9\uC801\uC73C\uB85C
      \uC784\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Cunning_101
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uB3D9\uB8CC\uC758 \uC6C0\uC9C1\uC784\uC744 \uC774\uC6A9\uD558\uB294
      \uAC8C \uC81C \uD328\uC2A4\uB97C \uB354 \uB3CB\uBCF4\uC774\uAC8C \uD558\uACA0\uAD70\uC694.
      \uB2E4\uC2DC \uB9DE\uCDB0\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Cunning_1
    ko: "\uACA9\uB824\uB97C \uD1B5\uD574 \uB3D9\uB8CC\uC758 \uBD80\uC871\uD568\uB9C8\uC800
      \uC2EC\uB9AC\uC804\uC73C\uB85C \uD65C\uC6A9\uD558\uBA70 \uC601\uC545\uD558\uAC8C
      \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Believer_101
    ko: "\uC81C \uB17C\uB9AC\uC801 \uACB0\uB860\uC740 \uBCC0\uD568\uC5C6\uC2B5\uB2C8\uB2E4.
      \uC624\uB2F5\uC774 \uC788\uB294 \uCF54\uD2B8\uC5D0\uC11C \uC815\uB2F5\uC744
      \uB358\uC9C0\uB294 \uAC74 \uBE44\uB17C\uB9AC\uC801\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Believer_1
    ko: "\uB17C\uB9AC\uC801 \uC2E0\uB150\uC774 \uB108\uBB34 \uD655\uACE0\uD574 \uC720\uC5F0\uC131\uC744
      \uAC15\uC870\uD558\uB294 \uACA9\uB824\uC5D0\uB3C4 \uACE0\uC9D1\uC744 \uAEBE\uC9C0
      \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Ch_Cold_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Planner_201
    ko: "\uB2E8\uC77C \uACBD\uB85C\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uD300\uC758 \uC804\uCCB4
      \uAD6C\uC870\uB97C \uBA48\uCD98 \uAC8C \uC81C \uC124\uACC4 \uC624\uB958\uC600\uAD70\uC694.
      \uD310\uC744 \uB2E4\uC2DC \uC9DC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Planner_2
    ko: "\uC790\uCC45\uACFC \uBC18\uBCF5\uC774 \uBE44\uD6A8\uC728\uC801\uC774\uB77C\uB294
      \uC9C0\uC801\uC5D0 \uC624\uB958\uB97C \uC778\uC815\uD558\uACE0 \uC989\uC2DC
      \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Opportunist_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uAC00\uC7A5 \uC720\uB9AC\uD55C \uD0C0\uC774\uBC0D\uC774\uC5C8\uC2B5\uB2C8\uB2E4.
      \uC2DC\uC2A4\uD15C \uBB38\uC81C\uB97C \uC81C \uC2DC\uC57C \uD0D3\uC73C\uB85C
      \uB3CC\uB9AC\uC2DC\uB2C8 \uC2E4\uC775\uC774 \uC5C6\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Opportunist_2
    ko: "\uD3EC\uCC29 \uB2A5\uB825\uC744 \uBD80\uC815\uB2F9\uD558\uC790 \uD300\uC5D0
      \uB0A8\uC744 \uC2E4\uB9AC\uAC00 \uC5C6\uB2E4\uACE0 \uD310\uB2E8\uD574 \uAC15\uD558\uAC8C
      \uBC18\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Cunning_201
    ko: "\uC81C \uC218\uB2E8\uC774 \uB108\uBB34 \uB178\uACE8\uC801\uC774\uC5C8\uB098
      \uBCF4\uB124\uC694. \uC9C0\uC801\uD558\uC2E0 \uB300\uB85C \uC880 \uB354 \uC740\uBC00\uD558\uAC8C
      \uC6C0\uC9C1\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Cunning_2
    ko: "\uC218\uB2E8\uC774 \uAC04\uD30C\uB2F9\uD588\uB2E4\uB294 \uC0AC\uC2E4\uC5D0
      \uC704\uCD95\uB418\uC5B4 \uB208\uCE58\uB97C \uBCF4\uB290\uB77C \uD50C\uB808\uC774\uAC00
      \uACBD\uC9C1\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Believer_201
    ko: "\uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uB294 \uAC74 \uC81C \uC2E0\uB150\uC5D0\uB3C4
      \uC5B4\uAE0B\uB0A9\uB2C8\uB2E4. \uB17C\uB9AC\uB97C \uB300\uC758\uC5D0 \uB9DE\uCDB0
      \uB2E4\uC2DC \uC138\uC6B0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Believer_2
    ko: "\uC2E0\uB150\uC774 \uD300\uC758 \uC2B9\uB9AC\uC640 \uCDA9\uB3CC\uD568\uC744
      \uAE68\uB2EB\uACE0 \uC2A4\uC2A4\uB85C \uC218\uC6A9\uD558\uC5EC \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Ch_Cold_003
    ko: "\uC120\uC218\uC758 \uB9E4\uB274\uC5BC\uC744 \uB36E\uC5B4\uBC84\uB9AC\uACE0
      \uACF5\uC744 \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Planner_301
    ko: "\uC124\uACC4\uB3C4\uAC00 \uC0AC\uB77C\uC84C\uC73C\uB2C8 \uD604\uC7A5\uC5D0\uC11C
      \uC9C1\uC811 \uB370\uC774\uD130\uB97C \uC218\uC9D1\uD558\uB77C\uB294 \uB73B\uC785\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Planner_3
    ko: "\uBD84\uC11D \uB3C4\uAD6C\uAC00 \uC0AC\uB77C\uC9C0\uC790 \uB2F9\uD669\uD558\uBA70
      \uC0C8\uB85C\uC6B4 \uAD6C\uC870\uB97C \uD30C\uC545\uD558\uB290\uB77C \uBCF5\uADC0\uAC00
      \uB2A6\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Opportunist_301
    ko: "\uC0DD\uAC01\uD560 \uD2C8\uB3C4 \uC5C6\uC774 \uAE30\uD68C\uAC00 \uC624\uB124\uC694.
      \uC9C0\uAE08\uC740 \uC774\uAC8C \uCD5C\uC120\uC774\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Opportunist_3
    ko: "\uAC15\uC81C\uC801\uC778 \uD15C\uD3EC \uC0C1\uC2B9\uC774 \uBCF8\uB2A5\uC744
      \uAE68\uC6CC \uAC00\uC7A5 \uC2E4\uB9AC\uC801\uC778 \uACB0\uACFC\uAC12\uC744
      \uC989\uAC01 \uB0B4\uB193\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Cunning_301
    ko: "\uC774\uB7F0 \uBB34\uC9C8\uC11C\uD55C \uBC29\uC2DD\uC740 \uC81C \uC2A4\uD0C0\uC77C\uC774
      \uC544\uB2D9\uB2C8\uB2E4. \uC81C \uD328\uB97C \uC228\uAE38 \uC218 \uC5C6\uB294
      \uD658\uACBD\uC740 \uAC70\uBD80\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Cunning_3
    ko: "\uAE09\uBC15\uD55C \uC0C1\uD669\uC5D0 \uB178\uCD9C\uB418\uC790 \uC2EC\uB9AC\uC801
      \uC6B0\uC704\uB97C \uC783\uACE0 \uC9D1\uC911\uB825\uC774 \uC644\uC804\uD788
      \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Believer_301
    ko: "\uD310\uC774 \uC5C6\uC5B4\uB3C4 \uC81C \uB17C\uB9AC\uB294 \uC720\uD6A8\uD569\uB2C8\uB2E4.
      \uC774 \uBB34\uC9C8\uC11C \uC18D\uC5D0\uC11C\uB3C4 \uC81C \uC2E0\uB150\uC744
      \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Believer_3
    ko: "\uC555\uBC15\uC5D0\uB3C4 \uD398\uC774\uC2A4\uB97C \uC720\uC9C0\uD558\uB824
      \uD558\uB098 \uC5EC\uC804\uD788 \uD611\uB3D9\uBCF4\uB2E4\uB294 \uC790\uAE30
      \uC99D\uBA85\uC5D0 \uCE58\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Instinct_001
    ko: "\uD300\uC758 \uC804\uC220\uC744 \uC644\uBCBD\uD788 \uD1B5\uC81C\uD558\uB294
      \uC774 \uC120\uC218\uB294, \uC624\uB298 \uC5F0\uC2B5 \uACBD\uAE30\uC5D0\uC11C
      \uBC1C\uC0DD\uD55C \uB2E8 \uD55C \uBC88\uC758 \uD328\uC2A4 \uBBF8\uC2A4\uB97C
      \uBD84\uC11D\uD558\uB290\uB77C \uCF54\uD2B8\uB97C \uB5A0\uB098\uC9C0 \uBABB\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Instinct_002
    ko: "\uADF8 \uD328\uC2A4\uB294 \uC218\uCE58\uC0C1 \uC644\uBCBD\uD55C \uADA4\uC801\uC774\uC5C8\uC73C\uB098,
      \uB3D9\uB8CC\uC758 \uBC18\uC751 \uC18D\uB3C4\uAC00 0.1\uCD08 \uB2A6\uC5B4 \uC2E4\uCC45\uC73C\uB85C
      \uAE30\uB85D\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Instinct_003
    ko: "\uBCF8\uB2A5\uC801\uC778 \uAC10\uAC01\uC744 \uC5B5\uB204\uB974\uACE0 \uADDC\uC728\uC744
      \uB530\uB974\uB824\uB358 \uC774 \uC120\uC218\uC5D0\uAC8C \uC774\uAC83\uC740
      \uC790\uC2E0\uC758 \uC57C\uC131\uC774 \uC8FD\uC5C8\uB2E4\uB294 \uACF5\uD3EC\uC774\uC790
      \uC124\uACC4\uC5D0 \uBC1C\uC0DD\uD55C \uCE58\uBA85\uC801\uC778 \uADE0\uC5F4\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Instinct_004
    ko: "\uADF8\uB294 \uB3D9\uB8CC\uC758 \uC5ED\uB7C9 \uBD80\uC871\uC870\uCC28 \uD1B5\uC81C\uD558\uC9C0
      \uBABB\uD55C \uAC83\uC744 \uC790\uCC45\uD558\uBA70, \uAE30\uACC4\uCC98\uB7FC
      \uAC19\uC740 \uB3D9\uC791\uC744 \uBC18\uBCF5\uD558\uBA70 \uC790\uC2E0\uC744
      \uD559\uB300\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Instinct_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00012_Ch_Instinct_001
    ko: "\uACE0\uC815\uB41C \uC6D0\uCE59\uBCF4\uB2E4 \uC0B4\uC544 \uC6C0\uC9C1\uC774\uB294
      \uD604\uC7A5\uC758 \uD750\uB984\uC774 \uC815\uB2F5\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Bluffer_101
    ko: "\uC81C \uD310\uB2E8\uC774\uC57C \uB298 \uCD5C\uACE0\uC8E0. \uD558\uC9C0\uB9CC
      \uC774\uB7F0 \uD5C8\uC220\uD55C \uC2DC\uC2A4\uD15C \uC18D\uC5D0\uC11C \uC81C
      \uB2A5\uB825\uC744 \uB0AD\uBE44\uD558\uB294 \uAC8C \uB9DE\uB098 \uC2F6\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Bluffer_1
    ko: "\uACA9\uB824\uB85C \uACFC\uC2DC\uC695\uB9CC \uCC44\uC6B8 \uBFD0 \uACF5\uC2DD\uC744
      \uD0D3\uD558\uBA70 \uAE30\uACC4\uC801 \uBC18\uBCF5\uC5D0 \uB354 \uC9D1\uCC29\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Wild_101
    ko: "\uB9DE\uC544\uC694! \uC885\uC774 \uCABC\uAC00\uB9AC \uACF5\uC2DD\uC774 \uC544\uB2C8\uB77C
      \uC81C \uAC10\uAC01\uC774 \uC815\uB2F5\uC774\uC8E0. \uC774\uC81C\uC57C \uC228\uD1B5\uC774
      \uC880 \uD2B8\uC774\uB124\uC694!"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Wild_1
    ko: "\uADDC\uCE59\uBCF4\uB2E4 \uC9C1\uAD00\uC744 \uC911\uC2DC\uD574 \uC124\uACC4
      \uAC15\uBC15\uC774 \uD480\uB9AC\uC790\uB9C8\uC790 \uC0DD\uB3D9\uAC10\uC744
      \uCC3E\uACE0 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Egoist_101
    ko: "\uC81C \uD310\uB2E8\uC744 \uBBFF\uB294 \uAC74 \uB2F9\uC5F0\uD558\uC8E0.
      \uADF8\uB7F0\uB370 \uC800 \uBA4D\uCCAD\uD55C \uB3D9\uB8CC\uB4E4\uC774 \uC81C
      \uC131\uC7A5\uC744 \uBC29\uD574\uD558\uACE0 \uC788\uB2E4\uACE0\uC694."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Egoist_1
    ko: "\uC790\uAE30\uC911\uC2EC\uC801\uC774\uB77C \uB3D9\uB8CC\uC5D0 \uB300\uD55C
      \uBD88\uB9CC\uC744 \uC0AD\uC774\uC9C0 \uBABB\uD574 \uC790\uCC45\uC5D0\uC11C
      \uBC97\uC5B4\uB098\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Fighter_101
    ko: "\uD750\uB984\uC744 \uBBFF\uC73C\uB77C\uACE0\uC694? \uD558\uC9C0\uB9CC \uC2B9\uB9AC
      \uACF5\uC2DD\uC774 \uAE68\uC84C\uB294\uB370 \uC5B4\uB5BB\uAC8C \uC2F8\uC6B0\uB77C\uB294
      \uAC81\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Fighter_1
    ko: "\uACBD\uC7C1\uC2EC\uC740 \uC788\uC73C\uB098 \uACA9\uB824\uB9CC\uC73C\uB860
      \uBB34\uB108\uC9C4 \uB17C\uB9AC\uC801 \uD1A0\uB300\uB97C \uC7AC\uAC74\uD558\uC9C0
      \uBABB\uD574 \uC8FC\uC800\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Ch_Instinct_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Bluffer_201
    ko: "\uC81C \uC2DC\uC57C\uAC00 \uC881\uB2E4\uACE0\uC694? \uC81C \uD328\uC2A4\uAC00
      \uC5BC\uB9C8\uB098 \uC555\uB3C4\uC801\uC778\uC9C0 \uB2E4\uC2DC \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0.
      \uACF5\uC2DD \uB530\uC704 \uC5C6\uC5B4\uB3C4 \uC81C\uAC00 \uCD5C\uACE0\uB77C\uB294
      \uAC78\uC694!"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Bluffer_2
    ko: "\uB2A5\uB825\uC744 \uC758\uC2EC\uBC1B\uC790 \uC790\uCC45\uC744 \uBA48\uCD94\uACE0
      \uC2E4\uB825\uC744 \uACFC\uC2DC\uD558\uAE30 \uC704\uD574 \uCF54\uD2B8\uB85C
      \uB6F0\uC5B4\uB4E4\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Wild_201
    ko: "\uBC29\uC2DD\uC774\uACE0 \uBB50\uACE0, \uBAB8\uC774 \uC548 \uB530\uB77C\uC8FC\uB294\uB370
      \uC5B4\uCA4C\uB780 \uAC81\uB2C8\uAE4C? \uC77C\uB2E8 \uB6F0\uAE34 \uD558\uACA0\uC9C0\uB9CC
      \uAE30\uACC4\uAC00 \uB41C \uAC83 \uAC19\uC544 \uBD88\uCF8C\uD558\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Wild_2
    ko: "\uB17C\uB9AC\uC801 \uC9C8\uCC45\uC774 \uC57C\uC131\uC744 \uAE68\uC6B0\uC9C0
      \uBABB\uD574 \uC5B5\uC9C0\uB85C \uC6C0\uC9C1\uC774\uB098 \uD50C\uB808\uC774\uC5D0
      \uC601\uD63C\uC774 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Egoist_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD300\uC744 \uB9DD\uCE5C\uB2E4\uACE0\uC694? \uC81C
      \uC2E4\uB825\uC774 \uACE7 \uD300\uC758 \uC218\uC900\uC778\uB370 \uC5B4\uB5BB\uAC8C
      \uADF8\uB7F0 \uB9D0\uC500\uC744 \uD558\uC2ED\uB2C8\uAE4C!"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Egoist_2
    ko: "\uC790\uAE30\uC560\uC5D0 \uC0C1\uCC98\uB97C \uC785\uC790 \uC815\uBA74 \uCDA9\uB3CC\uD558\uBA70
      \uC790\uCC45 \uC5D0\uB108\uC9C0\uB97C \uACF5\uACA9\uC131\uC73C\uB85C \uBD84\uCD9C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Fighter_201
    ko: "\uC9C0\uAE08 \uC81C\uAC00 \uAC8C\uC73C\uB984 \uD53C\uC6B0\uB294 \uAC78\uB85C
      \uBCF4\uC774\uC2ED\uB2C8\uAE4C? \uC8FD\uC744 \uD798\uC744 \uB2E4\uD574 \uACF5\uC2DD\uC744
      \uC9C0\uD0A4\uB824\uB294\uB370 \uC5B5\uC6B8\uD574\uC11C \uBABB \uD558\uACA0\uB124\uC694!"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Fighter_2
    ko: "\uD22C\uC7C1 \uAC00\uCE58\uB97C \uBD80\uC815\uB2F9\uD574 \uC5B5\uC6B8\uD568\uACFC
      \uBD84\uB178\uC5D0 \uD729\uC2F8\uC5EC \uC815\uC0C1\uC801\uC778 \uD6C8\uB828\uC774
      \uBD88\uAC00\uB2A5\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Ch_Instinct_003
    ko: "\uC120\uC218\uC758 \uB9E4\uB274\uC5BC\uC744 \uB36E\uC5B4\uBC84\uB9AC\uACE0
      \uACF5\uC744 \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Bluffer_301
    ko: "\uAC10\uB3C5\uB2D8\uB3C4 \uC81C \uC2E4\uB825\uC744 \uBE68\uB9AC \uBCF4\uACE0
      \uC2F6\uC73C\uC2E0 \uBAA8\uC591\uC774\uB124\uC694. \uC774 \uC815\uB3C4 \uD15C\uD3EC\uB294
      \uC800 \uAC19\uC740 \uC2A4\uD0C0\uC5D0\uAC8C \uC2DD\uC740 \uC8FD \uBA39\uAE30\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Bluffer_3
    ko: "\uAC15\uC555\uC801 \uD589\uB3D9\uC744 \uC2A4\uD0C0\uC131 \uC778\uC815\uC73C\uB85C
      \uD574\uC11D\uD558\uBA70 \uC790\uCC45\uC744 \uBA48\uCD94\uACE0 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Wild_301
    ko: "\uC124\uBA85\uB3C4 \uC5C6\uC774 \uBB50 \uD558\uC2DC\uB294 \uAC81\uB2C8\uAE4C!
      \uC0AC\uB78C\uC744 \uC9D0\uC2B9 \uCDE8\uAE09\uD558\uB294 \uAC83\uB3C4 \uC544\uB2C8\uACE0,
      \uAE30\uBD84 \uC7A1\uCCD0\uC11C \uB354 \uBABB \uB6F0\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Wild_3
    ko: "\uAC70\uCE5C \uD589\uB3D9\uC5D0 \uBC18\uBC1C\uC2EC\uACFC \uB3D9\uBB3C\uC801\uC778
      \uBD88\uCF8C\uAC10\uC744 \uB290\uB07C\uACE0 \uD6C8\uB828\uC7A5\uC744 \uC774\uD0C8\uD558\uB824
      \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Egoist_301
    ko: "\uBC29\uD574\uB418\uB294 \uACF5\uC2DD \uB530\uC704 \uCE58\uC6CC\uC8FC\uC2DC\uB2C8
      \uC18D \uC2DC\uC6D0\uD558\uB124\uC694. \uC624\uC9C1 \uC81C \uC2E4\uB825\uC73C\uB85C\uB9CC\uC774
      \uD310\uC744 \uCC44\uC6B0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Egoist_3
    ko: "\uB9E4\uB274\uC5BC\uC774 \uC0AC\uB77C\uC9C0\uACE0 \uACF5\uC774 \uC8FC\uC5B4\uC9C0\uC790
      \uC790\uAE30\uC560\uB97C \uC99D\uBA85\uD558\uAE30 \uC704\uD574 \uC989\uAC01
      \uC2E4\uD589\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00012_Desc_Fighter_301
    ko: "\uADF8\uB798\uC694! \uB9D0\uC2F8\uC6C0\uD560 \uC2DC\uAC04\uC5D0 \uD55C \uBC88
      \uB354 \uBD80\uB52A\uCE58\uB294 \uAC8C \uB0AB\uC8E0! \uB2E4\uB4E4 \uB364\uBCBC!"
    en: 
    ja: 
  - stringKey: Event_00012_Rs_Fighter_3
    ko: "\uB09C\uAD00\uC744 \uC990\uACA8 \uAC70\uCE5C \uAC1C\uC785\uC774 \uD22C\uC7C1\uC2EC\uC744
      \uC790\uADF9\uD574 \uC790\uCC45 \uC5D0\uB108\uC9C0\uB97C \uB300\uACB0\uB85C
      \uC804\uD658\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Discipline_001
    ko: "\uC774\uC81C \uB9C9 \uC218\uBE44\uC758 \uAE30\uCD08\uB97C \uBC30\uC6B0\uAE30
      \uC2DC\uC791\uD55C \uC120\uC218\uB294 \uAC10\uB3C5\uB2D8\uC774 \uAC00\uB974\uCCD0\uC900
      \uC2A4\uD2F8\uC758 \uC815\uC11D \uC790\uC138\uB97C \uC720\uC9C0\uD558\uB290\uB77C
      \uC628\uBAB8\uC774 \uBEE3\uBEE3\uD558\uAC8C \uAD73\uC5B4 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Discipline_002
    ko: "\uBB34\uB98E\uC740 \uC815\uD655\uD788 120\uB3C4\uB97C \uC720\uC9C0\uD574\uC57C
      \uD558\uACE0, \uC2DC\uC120\uC740 \uACF5\uC774 \uC544\uB2CC \uC0C1\uB300\uC758
      \uBC30\uAF3D\uC744 \uD5A5\uD574\uC57C \uD55C\uB2E4\uB294 \uB9E4\uB274\uC5BC\uC744
      \uBA38\uB9BF\uC18D\uC73C\uB85C \uB04A\uC784\uC5C6\uC774 \uB418\uB1CC\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Discipline_003
    ko: "\uD558\uC9C0\uB9CC \uC815\uC791 \uB208\uC55E\uC758 \uC0C1\uB300\uAC00 \uAC00\uBCBC\uC6B4
      \uD398\uC774\uD06C\uB97C \uC4F0\uC790, \uC120\uC218\uB294 \uB9E4\uB274\uC5BC\uC5D0
      \uC5C6\uB294 \uB3D9\uC791\uC785\uB2C8\uB2E4!\uB77C\uBA70 \uB2F9\uD669\uD55C
      \uB098\uBA38\uC9C0 \uBC1C\uC774 \uAF2C\uC5EC \uCF54\uD2B8\uC5D0 \uB118\uC5B4\uC9C0\uACE0
      \uB9D9\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Discipline_004
    ko: "\uC6D0\uCE59\uC744 \uC9C0\uD0A4\uB824\uB2E4 \uC624\uD788\uB824 \uAC00\uC7A5
      \uAE30\uBCF8\uC801\uC778 \uC218\uBE44 \uD750\uB984\uC870\uCC28 \uB193\uCE58\uACE0
      \uC788\uB294 \uCD08\uBCF4 \uC120\uC218\uC758 \uBAA8\uC2B5\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Discipline_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00013_Ch_Discipline_001
    ko: "\uB9E4\uB274\uC5BC\uC740 \uBF08\uB300\uC77C \uBFD0, \uC0C1\uB300\uC640 \uD638\uD761\uD558\uB294
      \uAC10\uAC01\uC5D0 \uC9D1\uC911\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Principled_101
    ko: "\uB9E4\uB274\uC5BC\uC774 \uBF08\uB300\uB77C\uBA74, \uADF8 \uC704\uC758 \uC0B4\uC740
      \uD604\uC7A5\uC758 \uAC10\uAC01\uC774\uAD70\uC694. \uC0C8\uB85C\uC6B4 \uC6D0\uCE59\uC73C\uB85C
      \uC0BC\uACE0 \uB2E4\uC2DC \uBD80\uB52A\uCCD0 \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Principled_1
    ko: "\uAC10\uAC01 \uC775\uD788\uAE30\uB97C \uC0C8 \uC6D0\uCE59\uC73C\uB85C \uC815\uC758\uD574\uC8FC\uC790
      \uC548\uC2EC\uD558\uACE0 \uBEE3\uBEE3\uD568\uC744 \uD480\uC5B4\uB0B4\uBA70
      \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Guardian_101
    ko: "\uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C \uD574\uBCF4\uACA0\uC9C0\uB9CC...
      \uC815\uC11D\uC744 \uC5B4\uACA8\uC11C \uC218\uBE44 \uAD6C\uBA4D\uC774 \uC0DD\uAE30\uBA74
      \uD300\uC6D0\uB4E4\uC5D0\uAC8C \uBBF8\uC548\uD574\uC11C \uC5B4\uCA4C\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Guardian_1
    ko: "\uACA9\uB824\uC5D0\uB3C4 \uD300 \uC9C8\uC11C\uB97C \uD574\uCE60\uAE4C \uBD10
      \uBB34\uB98E \uAC01\uB3C4\uB97C \uC2E0\uACBD \uC4F0\uB290\uB77C \uC18C\uADF9\uC801\uC774\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Tactician_101
    ko: "\uAC10\uAC01\uC740 \uB108\uBB34 \uC8FC\uAD00\uC801\uC785\uB2C8\uB2E4. \uB9E4\uB274\uC5BC\uC758
      \uC218\uCE58\uB294 \uBB3C\uB9AC\uC801\uC73C\uB85C \uCD5C\uC801\uD654\uB41C
      \uB370\uC774\uD130\uC778\uB370, \uADF8\uAC78 \uD3EC\uAE30\uD558\uB77C\uB294
      \uAC74 \uBE44\uB17C\uB9AC\uC801\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Tactician_1
    ko: "\uC774\uB860\uC801 \uC644\uACB0\uC131\uC744 \uCD94\uAD6C\uD574 \uAC10\uAC01
      \uC704\uC8FC\uC758 \uACA9\uB824\uB97C \uBE44\uACFC\uD559\uC801\uC774\uB77C
      \uB290\uB07C\uACE0 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Exemplary_101
    ko: "\uB124! \uC720\uC5F0\uD558\uAC8C \uB300\uCC98\uD558\uBA70 \uBC30\uC6B0\uB294
      \uAC8C \uC9C4\uC9DC \uBAA8\uBC94\uC801\uC778 \uD0DC\uB3C4\uAD70\uC694! \uB2E4\uC2DC
      \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Exemplary_1
    ko: "\uACA9\uB824\uB97C \uBAA8\uBC94\uC801\uC778 \uD0DC\uB3C4\uB85C \uC218\uC6A9\uD574
      \uB118\uC5B4\uC9C4 \uC790\uB9AC\uB97C \uD138\uACE0 \uAC00\uC7A5 \uC5F4\uC815\uC801\uC73C\uB85C
      \uC784\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Ch_Discipline_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Principled_201
    ko: "\uC815\uC11D\uC744 \uC9C0\uCF30\uB294\uB370 \uC65C \uC9C8\uCC45\uBC1B\uC544\uC57C
      \uD569\uB2C8\uAE4C? \uB9E4\uB274\uC5BC\uC758 \uC2E0\uB8B0\uB3C4\uAC00 \uB5A8\uC5B4\uC9D1\uB2C8\uB2E4.
      \uC774\uB860\uBD80\uD130 \uB2E4\uC2DC \uAC80\uD1A0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Principled_2
    ko: "\uBC30\uC6B4 \uB300\uB85C \uD588\uC74C\uC5D0\uB3C4 \uBE44\uB09C\uBC1B\uC790
      \uADDC\uCE59 \uC790\uCCB4\uC5D0 \uC758\uAD6C\uC2EC\uC744 \uD488\uACE0 \uD750\uB984\uC744
      \uB193\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Guardian_201
    ko: "\uAC00\uB974\uCCD0\uC8FC\uC2E0 \uB300\uB85C \uD558\uB824\uB2E4 \uB118\uC5B4\uC9C4
      \uAC74\uB370... \uC81C \uBD80\uC871\uD568\uC774 \uD300 \uC804\uCCB4\uB97C \uB9DD\uCE58\uACE0
      \uC788\uAD70\uC694. \uC815\uB9D0 \uC8C4\uC1A1\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Guardian_2
    ko: "\uC790\uCC45\uAC10\uC774 \uADF9\uB300\uD654\uB418\uC5B4 \uAC10\uB3C5\uC758
      \uC2E4\uB9DD\uC774 \uC790\uC2E0 \uB54C\uBB38\uC774\uB780 \uC0DD\uAC01\uC5D0
      \uBA58\uD0C8\uC774 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Tactician_201
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uC218\uBE44\uC758 \uBAA9\uC801\uC740 \uC0C1\uB300\uB97C
      \uB9C9\uB294 \uAC83\uC774\uC9C0 \uAC01\uB3C4\uB97C \uC9C0\uD0A4\uB294 \uAC83\uC774
      \uC544\uB2C8\uC5C8\uB124\uC694. \uBAA9\uC801 \uB2EC\uC131\uC744 \uC704\uD574
      \uC218\uB2E8\uC744 \uBC14\uAFC9\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uD1B5\uD574 \uC804\uC220\uC758 \uBCF8\uC9C8\uC744 \uAE68\uB2EB\uACE0
      \uC720\uC5F0\uD558\uAC8C \uC790\uC138\uB97C \uC218\uC815\uD558\uC5EC \uD6C8\uB828\uC5D0
      \uC784\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Exemplary_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uC81C\uAC00 \uB108\uBB34 \uC735\uD1B5\uC131
      \uC5C6\uC774 \uD589\uB3D9\uD588\uB098 \uBD05\uB2C8\uB2E4. \uC880 \uB354 \uC0C1\uD669\uC744
      \uC0B4\uD53C\uBA70 \uB208\uCE58\uAECF \uD589\uB3D9\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Exemplary_2
    ko: "\uB208\uCE58\uB97C \uBCF4\uB290\uB77C \uD50C\uB808\uC774\uC5D0 \uD655\uC2E0\uC744
      \uAC16\uC9C0 \uBABB\uD558\uACE0 \uC0C1\uB300 \uD398\uC774\uD06C\uC5D0 \uACC4\uC18D
      \uB2F9\uD669\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Ch_Discipline_003
    ko: "\uBC14\uB2E5\uC758 \uB9E4\uB274\uC5BC\uC744 \uCE58\uC6CC\uBC84\uB9AC\uACE0
      \uACF5\uC744 \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Principled_301
    ko: "\uAE30\uC900\uC774 \uC0AC\uB77C\uC9C0\uBA74 \uC800\uB294 \uC5B4\uB5BB\uAC8C
      \uC6C0\uC9C1\uC5EC\uC57C \uD569\uB2C8\uAE4C? \uAE30\uCD08\uB3C4 \uC5C6\uB294
      \uC800\uC5D0\uAC8C \uB108\uBB34 \uAC00\uD639\uD55C \uCC98\uC0AC\uC785\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Principled_3
    ko: "\uC758\uC9C0\uD560 \uB9E4\uB274\uC5BC\uC744 \uBE8F\uAE30\uC790 \uACF5\uD3EC\uB97C
      \uB290\uB07C\uBA70 \uC2DC\uC2A4\uD15C\uC774 \uBD95\uAD34\uB41C \uCF54\uD2B8
      \uC704\uC5D0\uC11C \uB9C8\uBE44\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Guardian_301
    ko: "\uC0DD\uAC01\uD560 \uD2C8 \uC5C6\uC774 \uC6C0\uC9C1\uC774\uB294 \uAC8C \uB3D9\uB8CC\uB97C
      \uC9C0\uD0A4\uB294 \uBC95\uC774\uAD70\uC694. \uBAB8\uC73C\uB85C \uBC30\uC6B0\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Guardian_3
    ko: "\uC804\uC220\uD310\uC774 \uC0AC\uB77C\uC9C0\uC790 \uD604\uC7A5\uC758 \uB3D9\uB8CC\uB97C
      \uC218\uD638\uD574\uC57C \uD55C\uB2E4\uB294 \uC758\uBB34\uAC10\uC774 \uAE68\uC5B4
      \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Tactician_301
    ko: "\uC774\uB860 \uC5C6\uC774 \uBAB8\uC73C\uB85C \uBC18\uC751\uD560 \uB54C\uC758
      \uC131\uACF5 \uD655\uB960\uC744 \uD14C\uC2A4\uD2B8\uD574\uBCF4\uC8E0. \uC77C\uB2E8
      \uD15C\uD3EC\uC5D0 \uB9DE\uCDB0\uC11C \uB370\uC774\uD130\uB97C \uC313\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Tactician_3
    ko: "\uD589\uB3D9 \uAC1C\uC785\uC744 \uC0C8 \uC2E4\uD5D8 \uC870\uAC74\uC73C\uB85C
      \uC778\uC2DD\uD574 \uC6C0\uC9C1\uC774\uB098 \uBA38\uB9BF\uC18D \uC5F0\uC0B0
      \uD0D3\uC5D0 \uBC18\uC751\uC774 \uB290\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Exemplary_301
    ko: "\uB9E4\uB274\uC5BC\uC744 \uCE58\uC6B0\uC2DC\uB2E4\uB2C8... \uC81C\uAC00
      \uAE30\uBCF8\uB3C4 \uBABB \uC9C0\uD0A4\uB294 \uD55C\uC2EC\uD55C \uD559\uC0DD\uC774\uB77C
      \uD3EC\uAE30\uD558\uC2E0 \uAC70\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Exemplary_3
    ko: "\uB2E8\uD638\uD55C \uD589\uB3D9\uC744 \uC790\uC2E0\uC5D0 \uB300\uD55C \uB099\uC81C
      \uC120\uC5B8\uC73C\uB85C \uC624\uD574\uD574 \uC2AC\uD514\uC5D0 \uBE60\uC9C0\uACE0
      \uC911\uB2E8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Bond_001
    ko: "\uC774\uC81C \uB9C9 \uC218\uBE44\uC758 \uAE30\uCD08\uB97C \uBC30\uC6B0\uAE30
      \uC2DC\uC791\uD55C \uC120\uC218\uB294 \uAC10\uB3C5\uB2D8\uC774 \uAC00\uB974\uCCD0\uC900
      \uC2A4\uD2F8\uC758 \uC815\uC11D \uC790\uC138\uB97C \uC720\uC9C0\uD558\uB290\uB77C
      \uC628\uBAB8\uC774 \uBEE3\uBEE3\uD558\uAC8C \uAD73\uC5B4 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Bond_002
    ko: "\uBB34\uB98E\uC740 \uC815\uD655\uD788 120\uB3C4\uB97C \uC720\uC9C0\uD574\uC57C
      \uD558\uACE0, \uC2DC\uC120\uC740 \uACF5\uC774 \uC544\uB2CC \uC0C1\uB300\uC758
      \uBC30\uAF3D\uC744 \uD5A5\uD574\uC57C \uD55C\uB2E4\uB294 \uB9E4\uB274\uC5BC\uC744
      \uBA38\uB9BF\uC18D\uC73C\uB85C \uB04A\uC784\uC5C6\uC774 \uB418\uB1CC\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Bond_003
    ko: "\uD558\uC9C0\uB9CC \uC815\uC791 \uB208\uC55E\uC758 \uC0C1\uB300\uAC00 \uAC00\uBCBC\uC6B4
      \uD398\uC774\uD06C\uB97C \uC4F0\uC790, \uC120\uC218\uB294 \uB9E4\uB274\uC5BC\uC5D0
      \uC5C6\uB294 \uB3D9\uC791\uC785\uB2C8\uB2E4!\uB77C\uBA70 \uB2F9\uD669\uD55C
      \uB098\uBA38\uC9C0 \uBC1C\uC774 \uAF2C\uC5EC \uCF54\uD2B8\uC5D0 \uB118\uC5B4\uC9C0\uACE0
      \uB9D9\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Bond_004
    ko: "\uC6D0\uCE59\uC744 \uC9C0\uD0A4\uB824\uB2E4 \uC624\uD788\uB824 \uAC00\uC7A5
      \uAE30\uBCF8\uC801\uC778 \uC218\uBE44 \uD750\uB984\uC870\uCC28 \uB193\uCE58\uACE0
      \uC788\uB294 \uCD08\uBCF4 \uC120\uC218\uC758 \uBAA8\uC2B5\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Bond_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00013_Ch_Bond_001
    ko: "\uB9E4\uB274\uC5BC\uC740 \uBF08\uB300\uC77C \uBFD0, \uC0C1\uB300\uC640 \uD638\uD761\uD558\uB294
      \uAC10\uAC01\uC5D0 \uC9D1\uC911\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Kind_101
    ko: "\uB118\uC5B4\uC838\uB3C4 \uAD1C\uCC2E\uB2E4\uACE0 \uB9D0\uC500\uD574\uC8FC\uC2DC\uB2C8
      \uC815\uB9D0 \uB2E4\uD589\uC774\uC5D0\uC694. \uAC01\uB3C4\uC5D0 \uB9E4\uB2EC\uB9AC\uAE30\uBCF4\uB2E4
      \uC0C1\uB300\uB97C \uB354 \uB530\uB73B\uD558\uAC8C... \uC544\uB2C8, \uC138\uC2EC\uD558\uAC8C
      \uC0B4\uD53C\uBA70 \uC218\uBE44\uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Kind_1
    ko: "\uD3EC\uC6A9\uC801 \uACA9\uB824\uAC00 \uACF5\uD3EC\uC2EC\uC744 \uB179\uC5EC\uC8FC\uBA70
      \uC815\uC11C\uC801 \uC548\uC815\uC744 \uBC14\uD0D5\uC73C\uB85C \uC720\uC5F0\uD568\uC744
      \uB418\uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC8FC\uC2E0 \uBF08\uB300\uB97C \uC798 \uC138\uC6CC\uBCF4\uACA0\uC2B5\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC81C\uAC00 \uB9C8\uC74C\uB300\uB85C \uC6C0\uC9C1\uC774\uB2E4\uAC00
      \uAC10\uB3C5\uB2D8\uC758 \uCCA0\uD559\uC744 \uB9DD\uCE60\uAE4C \uBD10 \uAC71\uC815\uB3FC\uC694."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Loyal_1
    ko: "\uC808\uB300\uC801\uC73C\uB85C \uC2E0\uB8B0\uD574 \uC9C0\uC2DC\uB97C \uB530\uB974\uB824
      \uD558\uB098 \uC815\uC11D\uC744 \uC5B4\uAE30\uB294 \uB0B4\uC801 \uAC08\uB4F1\uC774
      \uC5EC\uC804\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Sincere_101
    ko: "\uBF08\uB300\uB9CC\uC73C\uB85C\uB294 \uBD80\uC871\uD569\uB2C8\uB2E4. 120\uB3C4\uB97C
      \uC9C0\uD0A4\uC9C0 \uC54A\uC73C\uBA74 \uC218\uBE44\uC758 \uAE30\uCD08\uAC00
      \uBB34\uB108\uC9C0\uB294 \uAC83 \uC544\uB2CC\uAC00\uC694? \uB108\uBB34 \uBD88\uC548\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Sincere_1
    ko: "\uB8E8\uD2F4\uACFC \uC218\uCE58 \uBC18\uBCF5\uC744 \uC911\uC2DC\uD574 \uC720\uC5F0\uC131\uC744
      \uAC15\uC870\uD558\uB294 \uC9C0\uC2DC\uB97C \uBD88\uC131\uC2E4\uD568\uC73C\uB85C
      \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Moodmaker_101
    ko: "\uC544\uD558, \uB108\uBB34 \uBE61\uBE61\uD558\uAC8C \uAD74\uC9C0 \uB9D0\uB77C\uB294
      \uAC70\uC8E0? \uC54C\uACA0\uC2B5\uB2C8\uB2E4! \uC790, \uB2E4\uB4E4 \uB2E4\uC2DC
      \uC990\uAC81\uAC8C \uAC00\uBCF4\uC790\uACE0\uC694!"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Moodmaker_1
    ko: "\uAE0D\uC815 \uC5D0\uB108\uC9C0\uB97C \uC218\uC6A9\uD574 \uCF54\uD2B8\uC758
      \uBB34\uAC70\uC6B4 \uBD84\uC704\uAE30\uB97C \uD138\uACE0 \uD2B9\uC720\uC758
      \uD0C4\uB825\uC73C\uB85C \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Ch_Bond_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Kind_201
    ko: "\uD300\uC5D0 \uB3C4\uC6C0\uC774 \uB418\uACE0 \uC2F6\uC5B4\uC11C \uC5F4\uC2EC\uD788
      \uC678\uC6B4 \uAC74\uB370... \uC81C\uAC00 \uC624\uD788\uB824 \uD300\uC744 \uB9DD\uCE58\uACE0
      \uC788\uAD70\uC694. \uC815\uB9D0 \uC8C4\uC1A1\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Kind_2
    ko: "\uC790\uC2E0\uC758 \uC120\uC758\uAC00 \uD300\uC5D0 \uD53C\uD574\uB97C \uC92C\uB2E4\uB294
      \uC9C0\uC801\uC5D0 \uC0C1\uCC98 \uC785\uACE0 \uBBF8\uC548\uD568\uC5D0 \uAD73\uC5B4\uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Loyal_201
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uAC00\uB974\uCE68\uC744 \uC81C\uB300\uB85C \uC18C\uD654\uD558\uC9C0
      \uBABB\uD55C \uC81C \uBD88\uCC30\uC785\uB2C8\uB2E4. \uC800\uB294 \uD300\uC758
      \uC218\uCE58\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC744 \uC874\uC7AC \uAC00\uCE58\uC758 \uBD80\uC815\uC73C\uB85C
      \uC5EC\uACA8 \uBA58\uD0C8\uC774 \uC644\uC804\uD788 \uBD95\uAD34\uB418\uC5B4
      \uC7AC\uAE30\uAC00 \uBD88\uAC00\uB2A5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Sincere_201
    ko: "\uC81C \uC5F0\uC2B5 \uBC29\uC2DD\uC774 \uC798\uBABB\uB418\uC5C8\uAD70\uC694.
      \uAC01\uB3C4\uAC00 \uC544\uB2C8\uB77C \uB300\uC751\uC744 \uC5F0\uC2B5\uC758
      \uC0C8\uB85C\uC6B4 \uBAA9\uD45C\uB85C \uC7A1\uACA0\uC2B5\uB2C8\uB2E4. \uB2F9\uC7A5
      \uB2E4\uC2DC \uD558\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Sincere_2
    ko: "\uBE44\uD6A8\uC728\uC801\uC774\uB77C\uB294 \uBE44\uD310\uC744 \uC989\uAC01
      \uAC1C\uC815\uB41C \uD6C8\uB828 \uBAA9\uD45C\uB85C \uC0BC\uC544 \uB3C5\uD558\uAC8C
      \uB9E4\uC9C4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Moodmaker_201
    ko: "\uBD84\uC704\uAE30 \uC88B\uAC8C \uAC00\uACE0 \uC2F6\uC5C8\uB294\uB370...
      \uC81C\uAC00 \uB108\uBB34 \uACE0\uC9D1\uC744 \uD53C\uC6E0\uB098 \uBCF4\uB124\uC694.
      \uC870\uAE08 \uBBFC\uB9DD\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Moodmaker_2
    ko: "\uBD84\uC704\uAE30\uAC00 \uC2F8\uB298\uD574\uC9C0\uC790 \uB208\uCE58 \uBCF4\uB290\uB77C
      \uC704\uCD95\uB418\uC5B4 \uCD08\uBCF4\uC790 \uD2B9\uC720\uC758 \uC0DD\uB3D9\uAC10\uC744
      \uC783\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Ch_Bond_003
    ko: "\uBC14\uB2E5\uC758 \uB9E4\uB274\uC5BC\uC744 \uCE58\uC6CC\uBC84\uB9AC\uACE0
      \uACF5\uC744 \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uC0AC\uACFC\uB3C4 \uB4E3\uC9C0 \uC54A\uC73C\uC2DC\uACE0...
      \uC81C\uAC00 \uADF8\uB807\uAC8C \uD55C\uC2EC\uD574 \uBCF4\uC774\uC2DC\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Kind_3
    ko: "\uB2E8\uD638\uD55C \uB9E4\uB274\uC5BC \uC81C\uAC70\uC5D0 \uAC70\uC808\uAC10\uC744
      \uB290\uB07C\uACE0 \uC11C\uB7EC\uC6C0\uC5D0 \uBD81\uBC1B\uCCD0 \uD6C8\uB828\uC744
      \uC911\uB2E8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Loyal_301
    ko: "\uC0DD\uAC01\uC744 \uBC84\uB9AC\uACE0 \uBAB8\uC73C\uB85C \uC99D\uBA85\uD558\uB77C\uB294
      \uBA85\uB839\uC774\uC2DC\uAD70\uC694. \uB2E4\uC2DC \uAC00\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Loyal_3
    ko: "\uB2E8\uD638\uD55C \uD589\uB3D9\uC744 \uC790\uCC45 \uB300\uC2E0 \uC2E4\uD589\uD558\uB77C\uB294
      \uC9C0\uC2DC\uB85C \uC778\uC2DD\uD574 \uAD70\uB354\uB354\uAE30 \uC5C6\uC774
      \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Sincere_301
    ko: "\uC544\uC9C1 \uAE30\uCD08\uB97C \uB2E4 \uC775\uD788\uC9C0 \uBABB\uD588\uB294\uB370...
      \uC77C\uB2E8 \uBAB8\uBD80\uD130 \uB358\uC838\uBCF4\uACA0\uC9C0\uB9CC \uBA38\uB9BF\uC18D\uC774
      \uC815\uB9AC\uAC00 \uC548 \uB418\uC5B4 \uB2F5\uB2F5\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Sincere_3
    ko: "\uB2E8\uACC4\uB97C \uAC74\uB108\uB6F0\uB294 \uAC15\uC81C \uC9D1\uD589\uC5D0
      \uB2F9\uD639\uAC10\uC744 \uB290\uB07C\uACE0 \uC6D0\uB9AC\uB97C \uBAB0\uB77C
      \uACC4\uC18D \uBC1C\uC774 \uAF2C\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Moodmaker_301
    ko: "\uAC11\uC790\uAE30 \uD718\uC2AC\uC744 \uBD88\uBA70 \uACF5\uC744 \uB358\uC9C0\uC2DC\uBA74
      \uC5B4\uB5A1\uD574\uC694! \uB180\uB790\uC796\uC544\uC694. \uD6C8\uB828 \uBD84\uC704\uAE30\uAC00
      \uB108\uBB34 \uBB34\uC11C\uC6CC\uC84C\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Moodmaker_3
    ko: "\uCF54\uD2B8 \uACF5\uAE30\uAC00 \uAC15\uC555\uC801\uC73C\uB85C \uBCC0\uD558\uC790
      \uAC70\uBD80\uAC10\uC744 \uB290\uB07C\uACE0 \uC990\uAC70\uC6C0\uC744 \uC783\uC5B4
      \uB9C8\uC74C\uC774 \uB5B4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Cold_001
    ko: "\uC774\uC81C \uB9C9 \uC218\uBE44\uC758 \uAE30\uCD08\uB97C \uBC30\uC6B0\uAE30
      \uC2DC\uC791\uD55C \uC120\uC218\uB294 \uAC10\uB3C5\uB2D8\uC774 \uAC00\uB974\uCCD0\uC900
      \uC2A4\uD2F8\uC758 \uC815\uC11D \uC790\uC138\uB97C \uC720\uC9C0\uD558\uB290\uB77C
      \uC628\uBAB8\uC774 \uBEE3\uBEE3\uD558\uAC8C \uAD73\uC5B4 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Cold_002
    ko: "\uBB34\uB98E\uC740 \uC815\uD655\uD788 120\uB3C4\uB97C \uC720\uC9C0\uD574\uC57C
      \uD558\uACE0, \uC2DC\uC120\uC740 \uACF5\uC774 \uC544\uB2CC \uC0C1\uB300\uC758
      \uBC30\uAF3D\uC744 \uD5A5\uD574\uC57C \uD55C\uB2E4\uB294 \uB9E4\uB274\uC5BC\uC744
      \uBA38\uB9BF\uC18D\uC73C\uB85C \uB04A\uC784\uC5C6\uC774 \uB418\uB1CC\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Cold_003
    ko: "\uD558\uC9C0\uB9CC \uC815\uC791 \uB208\uC55E\uC758 \uC0C1\uB300\uAC00 \uAC00\uBCBC\uC6B4
      \uD398\uC774\uD06C\uB97C \uC4F0\uC790, \uC120\uC218\uB294 \uB9E4\uB274\uC5BC\uC5D0
      \uC5C6\uB294 \uB3D9\uC791\uC785\uB2C8\uB2E4!\uB77C\uBA70 \uB2F9\uD669\uD55C
      \uB098\uBA38\uC9C0 \uBC1C\uC774 \uAF2C\uC5EC \uCF54\uD2B8\uC5D0 \uB118\uC5B4\uC9C0\uACE0
      \uB9D9\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Cold_004
    ko: "\uC6D0\uCE59\uC744 \uC9C0\uD0A4\uB824\uB2E4 \uC624\uD788\uB824 \uAC00\uC7A5
      \uAE30\uBCF8\uC801\uC778 \uC218\uBE44 \uD750\uB984\uC870\uCC28 \uB193\uCE58\uACE0
      \uC788\uB294 \uCD08\uBCF4 \uC120\uC218\uC758 \uBAA8\uC2B5\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Cold_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00013_Ch_Cold_001
    ko: "\uB9E4\uB274\uC5BC\uC740 \uBF08\uB300\uC77C \uBFD0, \uC0C1\uB300\uC640 \uD638\uD761\uD558\uB294
      \uAC10\uAC01\uC5D0 \uC9D1\uC911\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Planner_101
    ko: "\uBF08\uB300\uAC00 \uBD88\uC644\uC804\uD55C\uB370 \uAC10\uAC01\uC5D0 \uC758\uC874\uD558\uB77C\uB294
      \uAC74 \uBE44\uACFC\uD559\uC801\uC785\uB2C8\uB2E4. \uD398\uC774\uD06C\uC5D0
      \uB300\uC751\uD558\uB294 \uCD94\uAC00 \uC124\uACC4\uB3C4\uB97C \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Planner_1
    ko: "\uAD6C\uC870\uD654\uD558\uB824\uB294 \uC131\uD5A5\uC0C1 \uBAA8\uD638\uD55C
      \uAC10\uAC01 \uC911\uC2EC \uACA9\uB824\uB294 \uB17C\uB9AC\uC801 \uACF5\uD669\uB9CC
      \uAC00\uC911\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Opportunist_101
    ko: "\uAC10\uAC01\uC744 \uC775\uD788\uB294 \uAC8C \uC2E4\uC804\uC5D0\uC11C \uB354
      \uC720\uB9AC\uD558\uB2E4\uBA74 \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4. \uD558\uC9C0\uB9CC
      \uB118\uC5B4\uC9C0\uB294 \uAC74 \uD6A8\uC728\uC774 \uB108\uBB34 \uB5A8\uC5B4\uC9C0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Opportunist_1
    ko: "\uC9C0\uC2DC\uB97C \uC218\uC6A9\uD558\uB824 \uD558\uB098 \uCD08\uBCF4\uC790\uB85C\uC11C
      \uACAA\uB294 \uC2E4\uD328\uAC00 \uC774\uB4DD\uC774 \uB418\uB294\uC9C0 \uC758\uAD6C\uC2EC\uC744
      \uAC00\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Cunning_101
    ko: "\uAC10\uB3C5\uB2D8 \uB9D0\uC500\uC774 \uB9DE\uC544\uC694. \uC815\uC11D\uC744
      \uC9C0\uD0A4\uB294 \uCC99\uD558\uBA74\uC11C \uC2AC\uCA4D \uC0C1\uB300\uC758
      \uD0C0\uC774\uBC0D\uC744 \uBE8F\uB294 \uAC8C \uC9C4\uC9DC \uC218\uBE44\uAD70\uC694.
      \uC774\uC81C \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Cunning_1
    ko: "\uB9E4\uB274\uC5BC\uC744 \uC5ED\uC774\uC6A9\uD55C \uC2EC\uB9AC\uC804\uC744
      \uAE68\uB2EB\uACE0 \uC21C\uC751\uD558\uB294 \uCC99 \uC601\uC545\uD558\uAC8C
      \uD5C8\uC810\uC744 \uB178\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Believer_101
    ko: "\uC81C \uC2E0\uB150\uC740 \uC644\uBCBD\uD55C \uC815\uC11D\uC744 \uAD6C\uD604\uD558\uB294
      \uAC83\uC785\uB2C8\uB2E4. \uAC10\uAC01\uC5D0 \uC758\uC874\uD574 \uB300\uCDA9
      \uC218\uBE44\uD558\uB294 \uAC74 \uC81C \uC0AC\uC804\uC5D0 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Believer_1
    ko: "\uB17C\uB9AC\uC801 \uC2E0\uB150\uC774 \uC6CC\uB099 \uD655\uACE0\uD574 \uC720\uC5F0\uC131\uC744
      \uAC15\uC870\uD558\uB294 \uACA9\uB824\uB97C \uD0C0\uD611\uC73C\uB85C \uB290\uB07C\uACE0
      \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Ch_Cold_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Planner_201
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uAC01\uB3C4 \uC720\uC9C0\uB77C\uB294 \uD558\uC704
      \uC124\uACC4\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uC218\uBE44 \uC131\uACF5\uC774\uB77C\uB294
      \uC0C1\uC704 \uC124\uACC4\uB97C \uB9DD\uCCE4\uAD70\uC694. \uAD6C\uC870\uB97C
      \uB2E4\uC2DC \uC9DC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Planner_2
    ko: "\uBE44\uD6A8\uC728\uC131\uC744 \uAE68\uB2EB\uACE0 \uBAA9\uC801\uC5D0 \uB9DE\uB294
      \uC720\uC5F0\uD55C \uC124\uACC4\uB97C \uC704\uD574 \uC989\uC2DC \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Opportunist_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD2C0\uB838\uB2E4\uACE0\uC694? \uC815\uC11D\uB300\uB85C
      \uD574\uC11C \uC774\uB4DD\uC744 \uBCF4\uB824 \uD588\uB358 \uAC74\uB370... \uC9C8\uCC45\uB9CC
      \uBC1B\uB294\uB2E4\uBA74 \uC774 \uD300\uC758 \uC2DC\uC2A4\uD15C\uC740 \uBB34\uC758\uBBF8\uD558\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Opportunist_2
    ko: "\uC2E4\uC775 \uC5C6\uC774 \uBE44\uD310\uB9CC \uBC1B\uC790 \uD300 \uC2DC\uC2A4\uD15C\uC5D0
      \uB300\uD55C \uC2E0\uB8B0\uB97C \uC783\uACE0 \uBC18\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Cunning_201
    ko: "\uC81C\uAC00 \uB108\uBB34 \uB178\uACE8\uC801\uC73C\uB85C \uC815\uC11D\uB9CC
      \uB530\uB790\uB098 \uBCF4\uB124\uC694. \uC9C0\uC801\uD558\uC2E0 \uB300\uB85C
      \uC880 \uB354 \uC740\uBC00\uD558\uACE0 \uC720\uC5F0\uD558\uAC8C \uC6C0\uC9C1\uC5EC\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Cunning_2
    ko: "\uC804\uB7B5\uC774 \uAC04\uD30C\uB2F9\uD588\uB2E4\uB294 \uB290\uB08C\uC5D0
      \uC704\uCD95\uB418\uC5B4 \uB208\uCE58\uB97C \uBCF4\uB290\uB77C \uACBD\uC9C1\uB418\uACE0
      \uC18C\uADF9\uC801\uC73C\uB85C \uBCC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Believer_201
    ko: "\uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uB294 \uAC74 \uC81C \uC2E0\uB150\uC5D0\uB3C4
      \uC5B4\uAE0B\uB098\uB294 \uC77C\uC785\uB2C8\uB2E4. \uC2B9\uB9AC\uB77C\uB294
      \uB300\uC758\uB97C \uC704\uD574 \uC81C \uACE0\uC9D1\uC744 \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Believer_2
    ko: "\uC2E0\uB150\uC774 \uD300\uC758 \uC774\uC775\uACFC \uCDA9\uB3CC\uD568\uC744
      \uAE68\uB2EB\uACE0 \uC2A4\uC2A4\uB85C \uB17C\uB9AC\uB97C \uC218\uC815\uD574
      \uAC15\uB825\uD788 \uB3D9\uAE30\uBD80\uC5EC\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Ch_Cold_003
    ko: "\uBC14\uB2E5\uC758 \uB9E4\uB274\uC5BC\uC744 \uCE58\uC6CC\uBC84\uB9AC\uACE0
      \uACF5\uC744 \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Planner_301
    ko: "\uC774\uB860 \uAD50\uC721\uC744 \uC911\uB2E8\uD558\uACE0 \uD604\uC7A5 \uB370\uC774\uD130
      \uC218\uC9D1\uC73C\uB85C \uC804\uD658\uD558\uC2DC\uACA0\uB2E4\uB294 \uB73B\uC774\uAD70\uC694.
      \uC6C0\uC9C1\uC774\uBA70 \uD30C\uC545\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Planner_3
    ko: "\uAC00\uC774\uB4DC\uB77C\uC778 \uC0C1\uC2E4\uC5D0 \uB2F9\uD669\uD558\uB098
      \uC2E4\uC804 \uB370\uC774\uD130 \uC218\uC9D1 \uB2E8\uACC4\uB85C \uC7AC\uC815\uC758\uD574
      \uD6C8\uB828\uC744 \uC9C0\uC18D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Opportunist_301
    ko: "\uC0DD\uAC01\uD560 \uD2C8 \uC5C6\uC774 \uAE30\uD68C\uAC00 \uC624\uB124\uC694.
      \uC9C0\uAE08\uC740 \uAC01\uB3C4 \uACC4\uC0B0\uBCF4\uB2E4 \uC774 \uACF5\uC744
      \uBE8F\uB294 \uAC8C \uAC00\uC7A5 \uD070 \uC2E4\uB9AC\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Opportunist_3
    ko: "\uD15C\uD3EC \uC0C1\uC2B9\uC774 \uBBFC\uCCA9\uD55C \uD3EC\uCC29 \uC0C1\uD0DC\uB85C
      \uC804\uD658\uC2DC\uCF1C \uBCF5\uC7A1\uD55C \uC774\uB860 \uB300\uC2E0 \uC131\uACFC\uC5D0
      \uC9D1\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Cunning_301
    ko: "\uC774\uB7F0 \uC2DD\uC73C\uB85C \uC555\uBC15\uD558\uC2DC\uBA74 \uC81C \uC2A4\uD0C0\uC77C\uC744
      \uCC3E\uC744 \uC218\uAC00 \uC5C6\uC5B4\uC694. \uC81C \uC57D\uC810\uB9CC \uB4DC\uB7EC\uB098\uB294
      \uBB34\uC9C8\uC11C\uD55C \uD6C8\uB828\uC740 \uC0AC\uC591\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Cunning_3
    ko: "\uAE09\uBC15\uD55C \uC0C1\uD669\uC5D0 \uB178\uCD9C\uB418\uC790 \uC2EC\uB9AC\uC801
      \uC6B0\uC704\uB97C \uC783\uACE0 \uCD08\uBCF4\uC758 \uBD88\uC548\uAC10\uC774
      \uCEE4\uC838 \uD3EC\uAE30\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Believer_301
    ko: "\uD310\uC774 \uC5C6\uC5B4\uB3C4 \uC81C \uBA38\uB9BF\uC18D \uB17C\uB9AC\uB294
      \uC720\uD6A8\uD569\uB2C8\uB2E4. \uC774 \uBB34\uC9C8\uC11C\uD55C \uD750\uB984
      \uC18D\uC5D0\uC11C\uB3C4 \uC81C \uC218\uBE44\uAC00 \uC633\uC74C\uC744 \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Believer_3
    ko: "\uD658\uACBD \uBCC0\uD654\uC5D0 \uAD74\uD558\uC9C0 \uC54A\uACE0 \uD398\uC774\uC2A4\uB97C
      \uC720\uC9C0\uD558\uB098 \uD611\uB3D9\uBCF4\uB2E8 \uC790\uAE30 \uC99D\uBA85\uC5D0
      \uCE58\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Instinct_001
    ko: "\uC774\uC81C \uB9C9 \uC218\uBE44\uC758 \uAE30\uCD08\uB97C \uBC30\uC6B0\uAE30
      \uC2DC\uC791\uD55C \uC120\uC218\uB294 \uAC10\uB3C5\uB2D8\uC774 \uAC00\uB974\uCCD0\uC900
      \uC2A4\uD2F8\uC758 \uC815\uC11D \uC790\uC138\uB97C \uC720\uC9C0\uD558\uB290\uB77C
      \uC628\uBAB8\uC774 \uBEE3\uBEE3\uD558\uAC8C \uAD73\uC5B4 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Instinct_002
    ko: "\uBB34\uB98E\uC740 \uC815\uD655\uD788 120\uB3C4\uB97C \uC720\uC9C0\uD574\uC57C
      \uD558\uACE0, \uC2DC\uC120\uC740 \uACF5\uC774 \uC544\uB2CC \uC0C1\uB300\uC758
      \uBC30\uAF3D\uC744 \uD5A5\uD574\uC57C \uD55C\uB2E4\uB294 \uB9E4\uB274\uC5BC\uC744
      \uBA38\uB9BF\uC18D\uC73C\uB85C \uB04A\uC784\uC5C6\uC774 \uB418\uB1CC\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Instinct_003
    ko: "\uD558\uC9C0\uB9CC \uC815\uC791 \uB208\uC55E\uC758 \uC0C1\uB300\uAC00 \uAC00\uBCBC\uC6B4
      \uD398\uC774\uD06C\uB97C \uC4F0\uC790, \uC120\uC218\uB294 \uB9E4\uB274\uC5BC\uC5D0
      \uC5C6\uB294 \uB3D9\uC791\uC785\uB2C8\uB2E4!\uB77C\uBA70 \uB2F9\uD669\uD55C
      \uB098\uBA38\uC9C0 \uBC1C\uC774 \uAF2C\uC5EC \uCF54\uD2B8\uC5D0 \uB118\uC5B4\uC9C0\uACE0
      \uB9D9\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Instinct_004
    ko: "\uC6D0\uCE59\uC744 \uC9C0\uD0A4\uB824\uB2E4 \uC624\uD788\uB824 \uAC00\uC7A5
      \uAE30\uBCF8\uC801\uC778 \uC218\uBE44 \uD750\uB984\uC870\uCC28 \uB193\uCE58\uACE0
      \uC788\uB294 \uCD08\uBCF4 \uC120\uC218\uC758 \uBAA8\uC2B5\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Instinct_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00013_Ch_Instinct_001
    ko: "\uB9E4\uB274\uC5BC\uC740 \uBF08\uB300\uC77C \uBFD0, \uC0C1\uB300\uC640 \uD638\uD761\uD558\uB294
      \uAC10\uAC01\uC5D0 \uC9D1\uC911\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Bluffer_101
    ko: "\uC81C \uAC10\uAC01\uC774\uC57C \uB298 \uCD5C\uACE0\uC8E0! \uD558\uC9C0\uB9CC
      \uAC10\uB3C5\uB2D8\uC774 \uC815\uC11D\uC744 \uC9C0\uD0A4\uB77C\uACE0 \uD558\uC154\uC11C
      \uC81C \uC2E4\uB825\uC744 \uC5B5\uC81C\uD558\uACE0 \uC788\uC5C8\uB358 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Bluffer_1
    ko: "\uACA9\uB824\uB97C \uBA74\uC8C4\uBD80\uB85C\uB9CC \uC0AC\uC6A9\uD558\uBA70
      \uC218\uBE44 \uC2E4\uD328\uC758 \uC6D0\uC778\uC778 \uAE30\uBCF8\uAE30 \uBD80\uC871\uC740
      \uC678\uBA74\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Wild_101
    ko: "\uB9DE\uC544\uC694! \uC774 \uB2F5\uB2F5\uD55C \uAC01\uB3C4 \uACC4\uC0B0
      \uB54C\uBB38\uC5D0 \uBAB8\uC774 \uC548 \uC6C0\uC9C1\uC600\uB358 \uAC70\uC608\uC694.
      \uC774\uC81C \uC81C \uBC29\uC2DD\uB300\uB85C \uB364\uBCBC\uBCF4\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Wild_1
    ko: "\uC9C1\uAD00\uC744 \uC911\uC2DC\uD574 \uC871\uC1C4\uAC00 \uD480\uB9AC\uC790\uB9C8\uC790
      \uC0DD\uB3D9\uAC10\uC744 \uB418\uCC3E\uACE0 \uC989\uC2DC \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Egoist_101
    ko: "\uC81C \uAC10\uAC01\uC744 \uBBFF\uB294 \uAC74 \uB2F9\uC5F0\uD558\uC8E0.
      \uADF8\uB7F0\uB370 \uC800 \uBC14\uBCF4 \uAC19\uC740 \uB140\uC11D\uC774 \uB9E4\uB274\uC5BC\uC5D0
      \uC5C6\uB294 \uD398\uC774\uD06C\uB97C \uC368\uC11C \uC81C \uBB34\uB98E \uAC01\uB3C4\uB97C
      \uB9DD\uCCD0\uB1A8\uB2E4\uACE0\uC694."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Egoist_1
    ko: "\uC790\uAE30\uC911\uC2EC\uC801\uC774\uB77C \uB3D9\uB8CC \uBD88\uB9CC\uC744
      \uD574\uC18C\uD558\uC9C0 \uBABB\uD574 \uD6C8\uB828 \uD750\uB984\uC774 \uACC4\uC18D
      \uB04A\uACBC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Fighter_101
    ko: "\uD638\uD761\uC774\uACE0 \uAC10\uAC01\uC774\uACE0... \uC544\uAE4C \uC800
      \uB140\uC11D\uD55C\uD14C \uB118\uC5B4\uC9C4 \uAC8C \uB108\uBB34 \uC9DC\uC99D
      \uB098\uB124\uC694. \uC5B4\uB5BB\uAC8C\uB4E0 \uB2E4\uC2DC \uBE8F\uC5B4\uC57C\uACA0\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Fighter_1
    ko: "\uACBD\uC7C1\uC2EC\uC740 \uC788\uC73C\uB098 \uACA9\uB824\uB9CC\uC73C\uB860
      \uBD84\uB178\uAC00 \uD574\uACB0\uB418\uC9C0 \uC54A\uC544 \uAC10\uC815\uC801\uC73C\uB85C
      \uC8FC\uC800\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Ch_Instinct_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Bluffer_201
    ko: "\uC81C \uC2DC\uC57C\uAC00 \uC881\uB2E4\uACE0\uC694? \uC81C \uBAB8\uB180\uB9BC\uC774
      \uC5BC\uB9C8\uB098 \uD654\uB824\uD55C\uC9C0 \uACE7 \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0.
      \uC815\uC11D \uB530\uC704 \uC5C6\uC5B4\uB3C4 \uC2A4\uD2F8\uC740 \uC790\uC2E0
      \uC788\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Bluffer_2
    ko: "\uACFC\uC2DC \uC695\uAD6C\uAC00 \uC9C8\uCC45\uC744 \uACC4\uAE30\uB85C \uD3ED\uBC1C\uD574
      \uC99D\uBA85\uD558\uAE30 \uC704\uD574 \uB354 \uBBFC\uCCA9\uD558\uAC8C \uC6C0\uC9C1\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Wild_201
    ko: "\uBC29\uC2DD\uC774\uACE0 \uBB50\uACE0, \uBAB8\uC774 \uC548 \uB530\uB77C\uC8FC\uB294\uB370
      \uC5B4\uCA4C\uB780 \uAC81\uB2C8\uAE4C? \uC77C\uB2E8 \uB6F0\uAE34 \uD558\uACA0\uC9C0\uB9CC
      \uC601 \uD765\uC774 \uC548 \uB098\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Wild_2
    ko: "\uB17C\uB9AC\uC801 \uC9C8\uCC45\uC774 \uC57C\uC131\uC744 \uC77C\uAE68\uC6B0\uC9C0
      \uBABB\uD574 \uC5B5\uC9C0\uB85C \uC6C0\uC9C1\uC774\uB098 \uB3D9\uC791\uC774
      \uB454\uD0C1\uD558\uACE0 \uC218\uB3D9\uC801\uC774\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Egoist_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD300\uC744 \uB9DD\uCE5C\uB2E4\uACE0\uC694? \uC81C
      \uC2E4\uB825\uC774 \uACE7 \uD300\uC758 \uC218\uC900\uC778\uB370 \uC5B4\uB5BB\uAC8C
      \uADF8\uB7F0 \uB9D0\uC500\uC744 \uD558\uC2ED\uB2C8\uAE4C!"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Egoist_2
    ko: "\uC790\uAE30\uC560\uC5D0 \uC0C1\uCC98\uB97C \uC785\uC790 \uBD84\uB178\uD574
      \uAC10\uB3C5\uACFC \uC815\uBA74 \uCDA9\uB3CC\uD558\uBA70 \uD6C8\uB828\uC744
      \uB9DD\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Fighter_201
    ko: "\uC9C0\uAE08 \uC81C\uAC00 \uC124\uB801\uC124\uB801\uD558\uB294 \uAC78\uB85C
      \uBCF4\uC774\uC2ED\uB2C8\uAE4C? \uB9E4\uB274\uC5BC\uB300\uB85C \uC2F8\uC6B0\uB824\uB2E4
      \uB118\uC5B4\uC9C4 \uAC74\uB370 \uC5B5\uC6B8\uD574\uC11C \uBABB \uD558\uACA0\uB124\uC694!"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Fighter_2
    ko: "\uD22C\uC7C1 \uAC00\uCE58\uB97C \uBD80\uC815\uB2F9\uD574 \uC5B5\uC6B8\uD568\uACFC
      \uBD84\uB178\uB85C \uC815\uC0C1\uC801\uC778 \uD6C8\uB828 \uC218\uD589\uC774
      \uBD88\uAC00\uB2A5\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Ch_Instinct_003
    ko: "\uBC14\uB2E5\uC758 \uB9E4\uB274\uC5BC\uC744 \uCE58\uC6CC\uBC84\uB9AC\uACE0
      \uACF5\uC744 \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Bluffer_301
    ko: "\uC624, \uAC10\uB3C5\uB2D8\uB3C4 \uC81C \uBCF8\uBAA8\uC2B5\uC744 \uBCF4\uACE0
      \uC2F6\uC73C\uC2E0 \uBAA8\uC591\uC774\uB124\uC694. \uC815\uC11D\uC740 \uC9C0\uB8E8\uD588\uB294\uB370
      \uCC28\uB77C\uB9AC \uC774\uAC8C \uB0AB\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Bluffer_3
    ko: "\uAC15\uC555\uC801 \uD589\uB3D9\uC744 \uC2A4\uD0C0\uC131 \uC778\uC815\uC73C\uB85C
      \uD574\uC11D\uD558\uBA70 \uC5EC\uC720\uB85C\uC6B4 \uCC99 \uD6C8\uB828\uC5D0
      \uAC00\uB2F4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Wild_301
    ko: "\uC124\uBA85\uB3C4 \uC5C6\uC774 \uBB50 \uD558\uC2DC\uB294 \uAC81\uB2C8\uAE4C!
      \uC0AC\uB78C\uC744 \uC9D0\uC2B9 \uCDE8\uAE09\uD558\uB294 \uAC83\uB3C4 \uC544\uB2C8\uACE0,
      \uAE30\uBD84 \uC7A1\uCCD0\uC11C \uBABB \uB6F0\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Wild_3
    ko: "\uAC70\uCE5C \uD589\uB3D9\uC5D0 \uBC18\uBC1C\uC2EC\uC774 \uD06C\uAC8C \uC791\uC6A9\uD574
      \uB3D9\uBB3C\uC801 \uAC70\uBD80\uAC10\uC744 \uB290\uB07C\uACE0 \uC774\uD0C8\uD558\uB824
      \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Egoist_301
    ko: "\uBC29\uD574\uB418\uB294 \uADDC\uCE59\uC740 \uCE58\uC6B0\uB294 \uAC8C \uB9DE\uC8E0.
      \uC624\uC9C1 \uC81C \uC2E4\uB825\uC73C\uB85C\uB9CC\uC774 \uD310\uC744 \uCC44\uC6CC\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Egoist_3
    ko: "\uB9E4\uB274\uC5BC\uC774 \uC0AC\uB77C\uC9C0\uACE0 \uACF5\uC774 \uC8FC\uC5B4\uC9C0\uC790
      \uC790\uAE30\uC560 \uC99D\uBA85\uC744 \uC704\uD574 \uC989\uAC01 \uC2E4\uD589\uC5D0
      \uB3CC\uC785\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00013_Desc_Fighter_301
    ko: "\uADF8\uB798\uC694! \uB9D0\uC2F8\uC6C0\uD560 \uC2DC\uAC04\uC5D0 \uD55C \uBC88
      \uB354 \uBD80\uB52A\uCE58\uB294 \uAC8C \uB0AB\uC8E0! \uB2E4\uB4E4 \uB364\uBCBC!"
    en: 
    ja: 
  - stringKey: Event_00013_Rs_Fighter_3
    ko: "\uB09C\uAD00\uC744 \uC990\uACA8 \uAC70\uCE5C \uAC1C\uC785\uC774 \uD22C\uC7C1\uC2EC\uC744
      \uC790\uADF9\uD574 \uD300 \uC804\uCCB4 \uC5D0\uB108\uC9C0\uB97C \uD3ED\uBC1C\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Discipline_001
    ko: "\uC120\uC218\uB294 \uC624\uB298 \uC218\uBE44 \uC804\uC220 \uD6C8\uB828 \uC911,
      \uC0C1\uB300\uC758 \uD328\uC2A4 \uADA4\uC801\uC744 \uC815\uD655\uD788 \uC77D\uC5B4\uB0C8\uC74C\uC5D0\uB3C4
      \uBD88\uAD6C\uD558\uACE0 \uC2A4\uD2F8\uC5D0 \uC2E4\uD328\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Discipline_002
    ko: "\uADF8\uB294 \uC0C1\uB300\uC758 \uB4DC\uB9AC\uBE14\uC774 \uBA48\uCD98 \uD6C4
      0.5\uCD08 \uC774\uB0B4\uC5D0 \uC190\uC744 \uBED7\uC5B4\uC57C \uD55C\uB2E4\uB294
      \uADDC\uC728\uC744 \uC644\uBCBD\uD788 \uC9C0\uD0A4\uB824 \uD588\uC73C\uB098,
      \uC624\uD788\uB824 \uADF8 \uC218\uCE58\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uBAB8\uC774
      \uAD73\uC5B4\uBC84\uB9B0 \uAC83\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Discipline_003
    ko: "\uC120\uC218\uB294 \uCF54\uD2B8 \uAD6C\uC11D\uC5D0\uC11C \uC790\uC2E0\uC758
      \uBC18\uC751 \uC18D\uB3C4\uB97C \uC790\uCC45\uD558\uBA70, \uAC10\uB3C5\uB2D8\uC774
      \uB098\uB204\uC5B4\uC900 \uC218\uBE44 \uC9C0\uCE68\uC11C\uB97C \uD3B4\uB193\uACE0
      \uC190\uAC00\uB77D \uB05D\uC758 \uAC01\uB3C4\uAE4C\uC9C0 \uD558\uB098\uD558\uB098
      \uC810\uAC80\uD558\uBA70 \uC790\uAD34\uAC10\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00014_Ch_Discipline_001
    ko: "\uB9E4\uB274\uC5BC\uC740 \uBF08\uB300\uC77C \uBFD0, \uC0C1\uB300\uC640 \uD638\uD761\uD558\uB294
      \uAC10\uAC01\uC5D0 \uC9D1\uC911\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Principled_101
    ko: "\uC9C0\uCE68\uC11C\uC758 \uC218\uCE58\uBCF4\uB2E4 \uD604\uC7A5\uC758 \uAC10\uAC01\uC774
      \uB354 \uC0C1\uC704 \uC6D0\uCE59\uC774\uB77C\uB294 \uB9D0\uC500\uC774\uC2DC\uAD70\uC694.
      0.5\uCD08\uB77C\uB294 \uAC15\uBC15\uC744 \uBC84\uB9AC\uACE0 \uC0C1\uB300\uC758
      \uB9AC\uB4EC\uC744 \uC77D\uB294 \uB370 \uC9D1\uC911\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Principled_1
    ko: "\uAC10\uAC01 \uC775\uD788\uAE30\uB97C \uC0C8 \uC6D0\uCE59\uC73C\uB85C \uC815\uC758\uD574\uC8FC\uC790
      \uC548\uC2EC\uD558\uACE0 \uC9C0\uCE68\uC11C\uB97C \uB36E\uACE0 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Guardian_101
    ko: "\uAC10\uAC01\uC744 \uBBFF\uC5B4\uBCF4\uACA0\uC9C0\uB9CC, \uC81C\uAC00 \uC218\uCE58\uB97C
      \uC5B4\uACBC\uB2E4\uAC00 \uC218\uBE44 \uB77C\uC778\uC774 \uB6AB\uB824 \uB3D9\uB8CC\uB4E4\uC774
      \uACE0\uC0DD\uD558\uBA74 \uC5B4\uCA4C\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Guardian_1
    ko: "\uD300 \uC9C8\uC11C\uB97C \uB9DD\uCE60\uAE4C \uBD10 \uC190\uAC00\uB77D \uAC01\uB3C4\uB97C
      \uC2E0\uACBD \uC4F0\uB290\uB77C \uB3D9\uC791\uC774 \uC5B4\uC815\uCA61\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Tactician_101
    ko: "0.5\uCD08\uB294 \uBB3C\uB9AC\uC801\uC73C\uB85C \uCD5C\uC801\uD654\uB41C
      \uB370\uC774\uD130\uC785\uB2C8\uB2E4. \uADF8\uAC78 \uBB34\uC2DC\uD558\uACE0
      \uAC10\uAC01\uC5D0 \uC758\uC874\uD558\uB77C\uB294 \uAC74 \uC804\uC220\uC801\uC73C\uB85C
      \uBE44\uB17C\uB9AC\uC801\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Tactician_1
    ko: "\uC774\uB860\uC801 \uC644\uACB0\uC131\uC744 \uCD94\uAD6C\uD574 \uAC10\uAC01
      \uC704\uC8FC \uACA9\uB824\uB97C \uBE44\uACFC\uD559\uC801\uC774\uB77C \uB290\uB07C\uACE0
      \uC5F0\uC0B0\uC744 \uACE0\uC9D1\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Exemplary_101
    ko: "\uB124! \uC720\uC5F0\uD558\uAC8C \uB300\uCC98\uD558\uBA70 \uBC30\uC6B0\uB294
      \uAC8C \uC9C4\uC9DC \uBAA8\uBC94\uC801\uC778 \uD0DC\uB3C4\uAD70\uC694! \uB2E4\uC2DC
      \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Exemplary_1
    ko: "\uACA9\uB824\uB97C \uC0C8\uB85C\uC6B4 \uD0DC\uB3C4\uB85C \uC218\uC6A9\uD574
      \uC790\uAD34\uAC10\uC744 \uD138\uC5B4\uB0B4\uACE0 \uAC00\uC7A5 \uC5F4\uC815\uC801\uC73C\uB85C
      \uC784\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Ch_Discipline_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Principled_201
    ko: "\uC218\uCE58\uB97C \uC9C0\uD0A4\uB294 \uAC8C \uC798\uBABB\uB41C \uAC83\uC785\uB2C8\uAE4C?
      \uB9E4\uB274\uC5BC\uC774 \uD2C0\uB9B0 \uAC74\uC9C0 \uC81C \uBC18\uC751 \uC18D\uB3C4\uAC00
      \uBB38\uC81C\uC778\uC9C0 \uB2E4\uC2DC \uACC4\uC0B0\uD574\uBD10\uC57C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Principled_2
    ko: "\uC9C8\uCC45\uC5D0 \uC6D0\uCE59\uC758 \uC815\uB2F9\uC131\uC744 \uC758\uC2EC\uD558\uBA70
      \uC774\uB860 \uAC80\uD1A0\uC5D0 \uBE60\uC838 \uD6C8\uB828\uC744 \uC7AC\uAC1C\uD558\uC9C0
      \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Guardian_201
    ko: "\uC9C0\uCE68\uC11C\uB97C \uC9C0\uD0A4\uB824\uB2E4 \uC2E4\uD328\uD55C \uAC74\uB370...
      \uC81C \uBD80\uC871\uD568\uC774 \uD300 \uC804\uCCB4\uC758 \uC218\uBE44\uB97C
      \uB9DD\uCE58\uACE0 \uC788\uAD70\uC694. \uC815\uB9D0 \uC8C4\uC1A1\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Guardian_2
    ko: "\uADDC\uCE59 \uC900\uC218 \uB178\uB825\uC774 \uBD80\uC815\uB2F9\uD558\uC790
      \uC790\uAD34\uAC10\uC5D0 \uBA58\uD0C8\uC774 \uBB34\uB108\uC838 \uC218\uBE44
      \uC704\uCE58\uC870\uCC28 \uBABB \uC7A1\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Tactician_201
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. 0.5\uCD08\uB77C\uB294 \uC218\uCE58\uC5D0 \uB9E4\uBAB0\uB418\uC5B4
      \uC2A4\uD2F8 \uC131\uACF5\uC774\uB77C\uB294 \uC804\uC220\uC801 \uBAA9\uC801\uC744
      \uC78A\uC5C8\uC2B5\uB2C8\uB2E4. \uBAA9\uC801 \uC704\uC8FC\uB85C \uC804\uC220\uC744
      \uC7AC\uC218\uC815\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC73C\uB85C \uC804\uC220\uC758 \uBCF8\uC9C8\uC744 \uAE68\uB2EB\uACE0
      \uC720\uC5F0\uD558\uAC8C \uC218\uB2E8\uC744 \uC218\uC815\uD558\uC5EC \uD6C8\uB828\uC5D0
      \uC784\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Exemplary_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uC81C\uAC00 \uB108\uBB34 \uC735\uD1B5\uC131
      \uC5C6\uC774 \uD589\uB3D9\uD588\uB098 \uBD05\uB2C8\uB2E4. \uC880 \uB354 \uC720\uC5F0\uD558\uAC8C
      \uC6C0\uC9C1\uC774\uB294 \uBAA8\uBC94\uC744 \uBCF4\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Exemplary_2
    ko: "\uC9C0\uC2DC\uC5D0 \uC21C\uC751\uD558\uB098 \uD310\uB2E8\uC5D0 \uD655\uC2E0\uC774
      \uC0AC\uB77C\uC838 \uB208\uCE58 \uBCF4\uB290\uB77C \uD0C0\uC774\uBC0D\uC744
      \uACC4\uC18D \uB193\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Ch_Discipline_003
    ko: "\uC120\uC218\uC758 \uC218\uBE44 \uC9C0\uCE68\uC11C\uB97C \uB36E\uACE0 \uACF5\uC744
      \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Principled_301
    ko: "\uC9C0\uCE68\uC11C\uB3C4 \uC5C6\uC774 \uC5B4\uB5BB\uAC8C \uC218\uBE44\uB97C
      \uD569\uB2C8\uAE4C? \uAE30\uC900\uC774 \uC0AC\uB77C\uC9C0\uBA74 \uC800\uB294
      \uC544\uBB34\uAC83\uB3C4 \uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Principled_3
    ko: "\uC720\uC77C\uD55C \uC9C0\uCE68\uC11C\uB97C \uBE8F\uAE30\uC790 \uACF5\uD3EC\uB97C
      \uB290\uB07C\uACE0 \uC9C8\uC11C\uAC00 \uBD95\uAD34\uB41C \uCF54\uD2B8\uC5D0\uC11C
      \uB9C8\uBE44\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Guardian_301
    ko: "\uC0DD\uAC01\uD560 \uD2C8 \uC5C6\uC774 \uC6C0\uC9C1\uC774\uB294 \uAC8C \uB3D9\uB8CC\uB97C
      \uC9C0\uD0A4\uB294 \uBC95\uC774\uAD70\uC694. \uBAB8\uC73C\uB85C \uBC30\uC6B0\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Guardian_3
    ko: "\uC9C0\uCE68\uC11C \uC0C1\uC2E4\uC5D0 \uD604\uC7A5 \uB3D9\uB8CC \uC218\uD638
      \uBCF8\uB2A5\uC774 \uAE68\uC5B4\uB098 \uBCF5\uC7A1\uD55C \uACC4\uC0B0 \uC5C6\uC774
      \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Tactician_301
    ko: "\uC774\uB860 \uC5C6\uC774 \uBAB8\uC73C\uB85C \uBC18\uC751\uD588\uC744 \uB54C\uC758
      \uC131\uACF5 \uD655\uB960\uC744 \uD14C\uC2A4\uD2B8\uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4.
      \uC77C\uB2E8 \uBD80\uB52A\uCCD0 \uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Tactician_3
    ko: "\uD589\uB3D9 \uAC1C\uC785\uC744 \uC0C8 \uC2E4\uD5D8 \uC870\uAC74\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC774\uB098 \uBA38\uB9BF\uC18D \uD655\uB960 \uC5F0\uC0B0
      \uD0D3\uC5D0 \uB2A6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Exemplary_301
    ko: "\uC9C0\uCE68\uC11C\uB97C \uCE58\uC6B0\uC2DC\uB2E4\uB2C8... \uC81C\uAC00
      \uAE30\uBCF8\uB3C4 \uBABB \uC9C0\uD0A4\uB294 \uD55C\uC2EC\uD55C \uC120\uC218\uB77C
      \uD3EC\uAE30\uD558\uC2E0 \uAC70\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Exemplary_3
    ko: "\uB2E8\uD638\uD55C \uD589\uB3D9\uC744 \uC790\uC2E0\uC5D0 \uB300\uD55C \uB099\uC81C\uB85C
      \uC624\uD574\uD574 \uAE4A\uC740 \uC6B0\uC6B8\uAC10\uC5D0 \uBE60\uC9C0\uACE0
      \uD6C8\uB828\uC744 \uD3EC\uAE30\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Bond_001
    ko: "\uC120\uC218\uB294 \uC624\uB298 \uC218\uBE44 \uC804\uC220 \uD6C8\uB828 \uC911,
      \uC0C1\uB300\uC758 \uD328\uC2A4 \uADA4\uC801\uC744 \uC815\uD655\uD788 \uC77D\uC5B4\uB0C8\uC74C\uC5D0\uB3C4
      \uBD88\uAD6C\uD558\uACE0 \uC2A4\uD2F8\uC5D0 \uC2E4\uD328\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Bond_002
    ko: "\uADF8\uB294 \uC0C1\uB300\uC758 \uB4DC\uB9AC\uBE14\uC774 \uBA48\uCD98 \uD6C4
      0.5\uCD08 \uC774\uB0B4\uC5D0 \uC190\uC744 \uBED7\uC5B4\uC57C \uD55C\uB2E4\uB294
      \uADDC\uC728\uC744 \uC644\uBCBD\uD788 \uC9C0\uD0A4\uB824 \uD588\uC73C\uB098,
      \uC624\uD788\uB824 \uADF8 \uC218\uCE58\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uBAB8\uC774
      \uAD73\uC5B4\uBC84\uB9B0 \uAC83\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Bond_003
    ko: "\uC120\uC218\uB294 \uCF54\uD2B8 \uAD6C\uC11D\uC5D0\uC11C \uC790\uC2E0\uC758
      \uBC18\uC751 \uC18D\uB3C4\uB97C \uC790\uCC45\uD558\uBA70, \uAC10\uB3C5\uB2D8\uC774
      \uB098\uB204\uC5B4\uC900 \uC218\uBE44 \uC9C0\uCE68\uC11C\uB97C \uD3B4\uB193\uACE0
      \uC190\uAC00\uB77D \uB05D\uC758 \uAC01\uB3C4\uAE4C\uC9C0 \uD558\uB098\uD558\uB098
      \uC810\uAC80\uD558\uBA70 \uC790\uAD34\uAC10\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Bond_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00014_Ch_Bond_001
    ko: "\uB9E4\uB274\uC5BC\uC740 \uBF08\uB300\uC77C \uBFD0, \uC0C1\uB300\uC640 \uD638\uD761\uD558\uB294
      \uAC10\uAC01\uC5D0 \uC9D1\uC911\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Kind_101
    ko: "\uC218\uCE58\uBCF4\uB2E4 \uB3D9\uB8CC\uC640\uC758 \uD638\uD761\uC774 \uBA3C\uC800\uB77C\uACE0
      \uB9D0\uC500\uD574 \uC8FC\uC154\uC11C \uB9C8\uC74C\uC774 \uB193\uC5EC\uC694.
      \uC774\uC81C \uC190\uAC00\uB77D \uAC01\uB3C4\uBCF4\uB2E4 \uC6B0\uB9AC \uD300\uC6D0\uB4E4\uC758
      \uC704\uCE58\uB97C \uB354 \uC0B4\uD53C\uBA70 \uC6C0\uC9C1\uC77C\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Kind_1
    ko: "\uB530\uB73B\uD55C \uC9C0\uC9C0\uB85C \uC790\uCC45\uAC10\uC744 \uB179\uC774\uACE0
      \uC815\uC11C\uC801 \uC548\uC815\uC744 \uBC14\uD0D5\uC73C\uB85C \uC720\uC5F0\uD568\uC744
      \uB418\uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC8FC\uC2E0 \uBF08\uB300\uB97C \uBBFF\uACE0 \uAC00\uBCF4\uACA0\uC2B5\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC81C\uAC00 \uC784\uC758\uB85C \uAC10\uAC01\uC744 \uC4F0\uB2E4\uAC00
      \uC9C0\uCE68\uC744 \uC5B4\uAE30\uAC8C \uB420\uAE4C \uBD10 \uBD88\uC548\uD574\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Loyal_1
    ko: "\uC808\uB300\uC801\uC73C\uB85C \uC2E0\uB8B0\uD574 \uB530\uB974\uB824 \uB178\uB825\uD558\uB098
      \uACF5\uC2DD \uC9C0\uCE68\uC744 \uC5B4\uAE30\uB294 \uB0B4\uC801 \uAC08\uB4F1\uC774
      \uC5EC\uC804\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Sincere_101
    ko: "\uBF08\uB300\uB9CC\uC73C\uB85C\uB294 \uC218\uBE44\uB97C \uC644\uC131\uD560
      \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. 0.5\uCD08\uB97C \uC815\uD655\uD788 \uC9C0\uD0A4\uC9C0
      \uC54A\uC73C\uBA74 \uC5F0\uC2B5\uC758 \uC758\uBBF8\uAC00 \uD1F4\uC0C9\uB418\uB294
      \uAC83 \uAC19\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Sincere_1
    ko: "\uC218\uCE58 \uC219\uB2EC\uC744 \uC911\uC2DC\uD574 \uC720\uC5F0\uC131 \uC9C0\uC2DC\uB97C
      \uC624\uD788\uB824 \uBD88\uC131\uC2E4\uD55C \uD0C0\uD611\uC73C\uB85C \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Moodmaker_101
    ko: "\uC544\uD558, \uB108\uBB34 \uBE61\uBE61\uD558\uAC8C \uAD74\uC9C0 \uB9D0\uB77C\uB294
      \uAC70\uC8E0? \uC54C\uACA0\uC2B5\uB2C8\uB2E4! \uC790, \uB2E4\uB4E4 \uB2E4\uC2DC
      \uC990\uAC81\uAC8C \uAC00\uBCF4\uC790\uACE0\uC694!"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Moodmaker_1
    ko: "\uAE0D\uC815 \uC5D0\uB108\uC9C0\uB97C \uC218\uC6A9\uD574 \uCF54\uD2B8\uC758
      \uBB34\uAC70\uC6B4 \uACF5\uAE30\uB97C \uD138\uACE0 \uD2B9\uC720\uC758 \uD0C4\uB825\uC73C\uB85C
      \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Ch_Bond_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Kind_201
    ko: "\uC81C\uAC00 \uC218\uCE58\uC5D0\uB9CC \uB9E4\uB2EC\uB9AC\uB290\uB77C \uD300\uC744
      \uB9DD\uCE58\uACE0 \uC788\uC5C8\uAD70\uC694. \uB3D9\uB8CC\uB4E4\uC5D0\uAC8C
      \uB108\uBB34 \uBBF8\uC548\uD574\uC11C \uC5BC\uAD74\uC744 \uBCFC \uC218\uAC00
      \uC5C6\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Kind_2
    ko: "\uB178\uB825\uC774 \uD300\uC5D0 \uD53C\uD574\uB97C \uC92C\uB2E8 \uC9C0\uC801\uC5D0
      \uAE4A\uC740 \uC0C1\uCC98\uB97C \uC785\uACE0 \uD6C8\uB828 \uC758\uC9C0\uB97C
      \uC0C1\uC2E4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Loyal_201
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uC644\uBCBD\uD55C \uC9C0\uCE68\uC744 \uC81C\uAC00
      \uC81C\uB300\uB85C \uC18C\uD654\uD558\uC9C0 \uBABB\uD55C \uC81C \uBD88\uCC30\uC785\uB2C8\uB2E4.
      \uB354 \uC774\uC0C1 \uAC10\uB3C5\uB2D8\uC758 \uC81C\uC790\uB85C \uB0A8\uC744
      \uC790\uACA9\uC774 \uC5C6\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC744 \uC874\uC7AC \uAC00\uCE58\uC758 \uBD80\uC815\uC73C\uB85C
      \uC5EC\uACA8 \uBA58\uD0C8\uC774 \uC644\uC804\uD788 \uBD95\uAD34\uB418\uC5B4
      \uD6C8\uB828 \uBD88\uAC00 \uC0C1\uD0DC\uAC00 \uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Sincere_201
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uC81C \uC131\uC2E4\uD568\uC774 \uC218\uCE58\uB77C\uB294
      \uC881\uC740 \uC2DC\uC57C\uC5D0 \uAC07\uD600 \uC788\uC5C8\uB124\uC694. \uB300\uC751\uC774\uB77C\uB294
      \uC0C8\uB85C\uC6B4 \uBAA9\uD45C\uB97C \uC138\uC6B0\uACE0 \uB2E4\uC2DC \uC2DC\uC791\uD558\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Sincere_2
    ko: "\uBE44\uD6A8\uC728\uC131\uC744 \uBE44\uD310\uBC1B\uC73C\uBA74 \uAC1C\uC120\uD560
      \uACFC\uC81C\uB85C \uC0BC\uC544 \uB354\uC6B1 \uB3C5\uD558\uAC8C \uD6C8\uB828\uC5D0
      \uB9E4\uC9C4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Moodmaker_201
    ko: "\uBD84\uC704\uAE30 \uC88B\uAC8C \uAC00\uACE0 \uC2F6\uC5C8\uB294\uB370...
      \uC81C\uAC00 \uB108\uBB34 \uACE0\uC9D1\uC744 \uD53C\uC6E0\uB098 \uBCF4\uB124\uC694.
      \uC870\uAE08 \uBBFC\uB9DD\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Moodmaker_2
    ko: "\uBD84\uC704\uAE30\uAC00 \uC2F8\uB298\uD574\uC9C0\uC790 \uB208\uCE58 \uBCF4\uB290\uB77C
      \uC704\uCD95\uB418\uC5B4 \uD2B9\uC720\uC758 \uC0DD\uB3D9\uAC10 \uB118\uCE58\uB294
      \uC218\uBE44\uB97C \uBABB \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Ch_Bond_003
    ko: "\uC120\uC218\uC758 \uC218\uBE44 \uC9C0\uCE68\uC11C\uB97C \uB36E\uACE0 \uACF5\uC744
      \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uACE0\uBBFC\uC744 \uB4E3\uC9C0\uB3C4 \uC54A\uC73C\uC2DC\uACE0...
      \uC81C\uAC00 \uADF8\uB807\uAC8C \uD55C\uC2EC\uD574 \uBCF4\uC774\uC2DC\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Kind_3
    ko: "\uB2E8\uD638\uD55C \uC9C0\uCE68\uC11C \uC81C\uAC70\uC5D0 \uAC70\uC808\uAC10\uACFC
      \uC18C\uC678\uAC10\uC744 \uC774\uAE30\uC9C0 \uBABB\uD558\uACE0 \uCF54\uD2B8\uB97C
      \uB5A0\uB0AC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Loyal_301
    ko: "\uC0DD\uAC01\uD560 \uC2DC\uAC04\uC5D0 \uBAB8\uC73C\uB85C \uC99D\uBA85\uD558\uB77C\uB294
      \uBA85\uB839\uC774\uC2DC\uAD70\uC694. \uB2E4\uC2DC \uAC00\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Loyal_3
    ko: "\uB2E8\uD638\uD55C \uD589\uB3D9\uC744 \uC2E4\uD589\uC5D0 \uC9D1\uC911\uD558\uB780
      \uC2E0\uD638\uB85C \uC778\uC2DD\uD574 \uC989\uC2DC \uD544\uB4DC\uB85C \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Sincere_301
    ko: "\uC544\uC9C1 \uC190\uAC00\uB77D \uAC01\uB3C4 \uAD50\uC815\uC774 \uC548 \uB05D\uB0AC\uB294\uB370...
      \uC77C\uB2E8 \uBAB8\uBD80\uD130 \uB358\uC838\uBCF4\uACA0\uC9C0\uB9CC \uBA38\uB9BF\uC18D\uC774
      \uC815\uB9AC\uAC00 \uC548 \uB418\uC5B4 \uB2F5\uB2F5\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Sincere_3
    ko: "\uB2E8\uACC4\uB97C \uAC74\uB108\uB6F0\uB294 \uAC15\uC81C \uC9D1\uD589\uC5D0
      \uB2F9\uD639\uAC10\uC744 \uB290\uB07C\uACE0 \uC6D0\uB9AC\uB97C \uBAB0\uB77C
      \uC5C7\uBC15\uC790\uAC00 \uB0AC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Moodmaker_301
    ko: "\uAC11\uC790\uAE30 \uC9C0\uCE68\uC11C\uB97C \uCE58\uC6B0\uC2DC\uBA74 \uC5B4\uB5A1\uD574\uC694!
      \uB180\uB790\uC796\uC544\uC694. \uD6C8\uB828 \uBD84\uC704\uAE30\uAC00 \uB108\uBB34
      \uBB34\uC11C\uC6CC\uC84C\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Moodmaker_3
    ko: "\uCF54\uD2B8 \uACF5\uAE30\uAC00 \uAC15\uC555\uC801\uC73C\uB85C \uBCC0\uD558\uC790
      \uAC70\uBD80\uAC10\uC744 \uB290\uB07C\uACE0 \uC990\uAC70\uC6C0\uC744 \uC783\uC5B4
      \uC758\uC695\uC774 \uAEBE\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Cold_001
    ko: "\uC120\uC218\uB294 \uC624\uB298 \uC218\uBE44 \uC804\uC220 \uD6C8\uB828 \uC911,
      \uC0C1\uB300\uC758 \uD328\uC2A4 \uADA4\uC801\uC744 \uC815\uD655\uD788 \uC77D\uC5B4\uB0C8\uC74C\uC5D0\uB3C4
      \uBD88\uAD6C\uD558\uACE0 \uC2A4\uD2F8\uC5D0 \uC2E4\uD328\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Cold_002
    ko: "\uADF8\uB294 \uC0C1\uB300\uC758 \uB4DC\uB9AC\uBE14\uC774 \uBA48\uCD98 \uD6C4
      0.5\uCD08 \uC774\uB0B4\uC5D0 \uC190\uC744 \uBED7\uC5B4\uC57C \uD55C\uB2E4\uB294
      \uADDC\uC728\uC744 \uC644\uBCBD\uD788 \uC9C0\uD0A4\uB824 \uD588\uC73C\uB098,
      \uC624\uD788\uB824 \uADF8 \uC218\uCE58\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uBAB8\uC774
      \uAD73\uC5B4\uBC84\uB9B0 \uAC83\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Cold_003
    ko: "\uC120\uC218\uB294 \uCF54\uD2B8 \uAD6C\uC11D\uC5D0\uC11C \uC790\uC2E0\uC758
      \uBC18\uC751 \uC18D\uB3C4\uB97C \uC790\uCC45\uD558\uBA70, \uAC10\uB3C5\uB2D8\uC774
      \uB098\uB204\uC5B4\uC900 \uC218\uBE44 \uC9C0\uCE68\uC11C\uB97C \uD3B4\uB193\uACE0
      \uC190\uAC00\uB77D \uB05D\uC758 \uAC01\uB3C4\uAE4C\uC9C0 \uD558\uB098\uD558\uB098
      \uC810\uAC80\uD558\uBA70 \uC790\uAD34\uAC10\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Cold_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00014_Ch_Cold_001
    ko: "\uB9E4\uB274\uC5BC\uC740 \uBF08\uB300\uC77C \uBFD0, \uC0C1\uB300\uC640 \uD638\uD761\uD558\uB294
      \uAC10\uAC01\uC5D0 \uC9D1\uC911\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Planner_101
    ko: "\uBF08\uB300\uAC00 \uBD88\uC644\uC804\uD55C\uB370 \uAC10\uAC01\uC5D0 \uC758\uC874\uD558\uB77C\uB294
      \uAC74 \uBE44\uACFC\uD559\uC801\uC785\uB2C8\uB2E4. 0.5\uCD08 \uC218\uCE58 \uC790\uCCB4\uAC00
      \uC624\uB958\uC778\uC9C0\uBD80\uD130 \uAC80\uC99D\uD574\uC57C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Planner_1
    ko: "\uAD6C\uC870\uD654 \uC131\uD5A5\uC0C1 \uBAA8\uD638\uD55C \uACA9\uB824\uB294
      \uB17C\uB9AC\uC801 \uD574\uB2F5\uC744 \uC8FC\uC9C0 \uBABB\uD574 \uBD84\uC11D\uC5D0
      \uB354 \uC9D1\uCC29\uD558\uAC8C \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Opportunist_101
    ko: "\uAC10\uAC01\uC744 \uC775\uD788\uB294 \uAC8C \uC2E4\uC804\uC5D0\uC11C \uB354
      \uC720\uB9AC\uD558\uB2E4\uBA74 \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4. \uD558\uC9C0\uB9CC
      \uB370\uC774\uD130 \uC5C6\uC774 \uC6C0\uC9C1\uC774\uB294 \uAC74 \uD6A8\uC728\uC774
      \uB0AE\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Opportunist_1
    ko: "\uC2E4\uB9AC\uC801 \uAD00\uC810\uC5D0\uC11C \uC218\uC6A9\uD558\uB824 \uD558\uB098
      \uD655\uC2E4\uD55C \uADFC\uAC70 \uC5C6\uB294 \uD6C8\uB828\uC774 \uC774\uB4DD\uC77C\uC9C0
      \uC758\uC2EC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Cunning_101
    ko: "\uAC10\uB3C5\uB2D8 \uB9D0\uC500\uC774 \uB9DE\uC544\uC694. 0.5\uCD08\uC5D0
      \uAC07\uD788\uB294 \uCC99\uD558\uBA74\uC11C \uC0C1\uB300\uC758 \uD0C0\uC774\uBC0D\uC744
      \uBE8F\uB294 \uAC8C \uC9C4\uC9DC \uC218\uBE44\uAD70\uC694. \uC774\uC81C \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Cunning_1
    ko: "\uACA9\uB824\uB97C \uD1B5\uD574 \uC2EC\uB9AC\uC804\uC744 \uAE68\uB2EB\uACE0
      \uC21C\uC751\uD558\uB294 \uCC99 \uC601\uC545\uD558\uAC8C \uC0C1\uB300 \uD5C8\uC810\uC744
      \uB178\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Believer_101
    ko: "\uC81C \uC2E0\uB150\uC740 \uC644\uBCBD\uD55C \uC815\uC11D\uC744 \uAD6C\uD604\uD558\uB294
      \uAC83\uC785\uB2C8\uB2E4. \uAC10\uAC01\uC5D0 \uC758\uC874\uD574 \uB300\uCDA9
      \uC218\uBE44\uD558\uB294 \uAC74 \uC81C \uC0AC\uC804\uC5D0 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Believer_1
    ko: "\uB17C\uB9AC\uC801 \uC2E0\uB150\uC774 \uC6CC\uB099 \uD655\uACE0\uD574 \uC720\uC5F0\uC131\uC744
      \uD0C0\uD611\uC73C\uB85C \uB290\uB07C\uACE0 \uC644\uAC15\uD788 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Ch_Cold_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Planner_201
    ko: "0.5\uCD08\uB77C\uB294 \uD558\uC704 \uBCC0\uC218\uC5D0 \uB9E4\uBAB0\uB418\uC5B4
      \uC2A4\uD2F8\uC774\uB77C\uB294 \uC0C1\uC704 \uBAA9\uC801\uC744 \uB193\uCCE4\uAD70\uC694.
      \uC124\uACC4 \uC624\uB958\uB97C \uC778\uC815\uD558\uACE0 \uC989\uC2DC \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Planner_2
    ko: "\uBD84\uC11D\uC758 \uBE44\uD6A8\uC728\uC131\uC744 \uAE68\uB2EB\uACE0 \uBAA9\uC801\uC5D0
      \uB9DE\uB294 \uC720\uC5F0\uD55C \uC124\uACC4\uB97C \uC704\uD574 \uC989\uC2DC
      \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Opportunist_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD2C0\uB838\uB2E4\uACE0\uC694? \uC815\uC11D\uB300\uB85C
      \uD574\uC11C \uC774\uB4DD\uC744 \uBCF4\uB824 \uD588\uB358 \uAC74\uB370... \uC9C8\uCC45\uB9CC
      \uBC1B\uB294\uB2E4\uBA74 \uC774 \uC804\uC220\uC740 \uBB34\uC758\uBBF8\uD558\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Opportunist_2
    ko: "\uCD5C\uC120\uC744 \uB2E4\uD588\uC74C\uC5D0\uB3C4 \uBE44\uD310\uBC1B\uC790
      \uD300 \uC2DC\uC2A4\uD15C \uC2E0\uB8B0\uB97C \uC783\uACE0 \uC758\uC695\uC774
      \uAEBE\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Cunning_201
    ko: "\uC81C \uC218\uB2E8\uC774 \uB108\uBB34 \uB178\uACE8\uC801\uC774\uC5C8\uB098
      \uBCF4\uB124\uC694. \uC9C0\uC801\uD558\uC2E0 \uB300\uB85C \uC880 \uB354 \uC740\uBC00\uD558\uACE0
      \uC720\uC5F0\uD558\uAC8C \uC6C0\uC9C1\uC5EC\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Cunning_2
    ko: "\uC804\uB7B5\uC774 \uAC04\uD30C\uB2F9\uD55C \uB290\uB08C\uC5D0 \uC704\uCD95\uB418\uC5B4
      \uB208\uCE58 \uBCF4\uB290\uB77C \uACBD\uC9C1\uB418\uACE0 \uC18C\uADF9\uC801\uC73C\uB85C
      \uBCC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Believer_201
    ko: "\uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uB294 \uAC74 \uC81C \uC2E0\uB150\uC5D0\uB3C4
      \uC5B4\uAE0B\uB098\uB294 \uC77C\uC785\uB2C8\uB2E4. \uC2B9\uB9AC\uB77C\uB294
      \uB300\uC758\uB97C \uC704\uD574 \uC81C \uACE0\uC9D1\uC744 \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Believer_2
    ko: "\uC2E0\uB150\uC774 \uD300 \uC774\uC775\uACFC \uCDA9\uB3CC\uD568\uC744 \uAE68\uB2EB\uACE0
      \uC2A4\uC2A4\uB85C \uC218\uC815\uD574 \uAC15\uB825\uD788 \uB3D9\uAE30\uBD80\uC5EC\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Ch_Cold_003
    ko: "\uC120\uC218\uC758 \uC218\uBE44 \uC9C0\uCE68\uC11C\uB97C \uB36E\uACE0 \uACF5\uC744
      \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Planner_301
    ko: "\uC774\uB860 \uBD84\uC11D\uC744 \uC911\uB2E8\uD558\uACE0 \uD604\uC7A5 \uB370\uC774\uD130
      \uC218\uC9D1\uC73C\uB85C \uC804\uD658\uD558\uC2DC\uACA0\uB2E4\uB294 \uB73B\uC774\uAD70\uC694.
      \uC6C0\uC9C1\uC774\uBA70 \uD30C\uC545\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Planner_3
    ko: "\uAC00\uC774\uB4DC\uB77C\uC778 \uC0C1\uC2E4\uC5D0 \uB2F9\uD669\uD558\uB098
      \uC2E4\uC804 \uB370\uC774\uD130 \uC218\uC9D1 \uB2E8\uACC4\uB85C \uC7AC\uC815\uC758\uD574
      \uC9C0\uC18D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Opportunist_301
    ko: "\uC0DD\uAC01\uD560 \uD2C8 \uC5C6\uC774 \uAE30\uD68C\uAC00 \uC624\uB124\uC694.
      \uC9C0\uAE08\uC740 \uAC01\uB3C4 \uACC4\uC0B0\uBCF4\uB2E4 \uC774 \uACF5\uC744
      \uBE8F\uB294 \uAC8C \uAC00\uC7A5 \uD070 \uC2E4\uB9AC\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Opportunist_3
    ko: "\uD15C\uD3EC \uC0C1\uC2B9\uC774 \uBBFC\uCCA9\uD55C \uD3EC\uCC29 \uC0C1\uD0DC\uB85C
      \uC804\uD658\uC2DC\uCF1C \uBCF5\uC7A1\uD55C \uC774\uB860 \uB300\uC2E0 \uC131\uACFC\uC5D0
      \uC9D1\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Cunning_301
    ko: "\uC774\uB7F0 \uC2DD\uC73C\uB85C \uC555\uBC15\uD558\uC2DC\uBA74 \uC81C \uC2A4\uD0C0\uC77C\uC744
      \uCC3E\uC744 \uC218\uAC00 \uC5C6\uC5B4\uC694. \uC81C \uC57D\uC810\uB9CC \uB4DC\uB7EC\uB098\uB294
      \uBB34\uC9C8\uC11C\uD55C \uD6C8\uB828\uC740 \uC0AC\uC591\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Cunning_3
    ko: "\uAE09\uBC15\uD55C \uC0C1\uD669\uC5D0 \uB178\uCD9C\uB418\uC790 \uC2EC\uB9AC\uC801
      \uC6B0\uC704\uB97C \uC783\uACE0 \uC9D1\uC911\uB825\uC774 \uBB34\uB108\uC838
      \uD3EC\uAE30\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Believer_301
    ko: "\uC9C0\uCE68\uC11C\uAC00 \uC5C6\uC5B4\uB3C4 \uC81C \uBA38\uB9BF\uC18D \uB17C\uB9AC\uB294
      \uC720\uD6A8\uD569\uB2C8\uB2E4. \uC774 \uBB34\uC9C8\uC11C\uD55C \uD750\uB984
      \uC18D\uC5D0\uC11C\uB3C4 \uC81C \uC218\uBE44\uAC00 \uC633\uC74C\uC744 \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Believer_3
    ko: "\uD658\uACBD \uBCC0\uD654\uC5D0\uB3C4 \uD398\uC774\uC2A4\uB97C \uC720\uC9C0\uD558\uB824
      \uD558\uB098 \uB3D9\uB8CC\uC640\uC758 \uC870\uD654\uBCF4\uB2E8 \uC790\uAE30
      \uC99D\uBA85\uC5D0 \uCE58\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Instinct_001
    ko: "\uC120\uC218\uB294 \uC624\uB298 \uC218\uBE44 \uC804\uC220 \uD6C8\uB828 \uC911,
      \uC0C1\uB300\uC758 \uD328\uC2A4 \uADA4\uC801\uC744 \uC815\uD655\uD788 \uC77D\uC5B4\uB0C8\uC74C\uC5D0\uB3C4
      \uBD88\uAD6C\uD558\uACE0 \uC2A4\uD2F8\uC5D0 \uC2E4\uD328\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Instinct_002
    ko: "\uADF8\uB294 \uC0C1\uB300\uC758 \uB4DC\uB9AC\uBE14\uC774 \uBA48\uCD98 \uD6C4
      0.5\uCD08 \uC774\uB0B4\uC5D0 \uC190\uC744 \uBED7\uC5B4\uC57C \uD55C\uB2E4\uB294
      \uADDC\uC728\uC744 \uC644\uBCBD\uD788 \uC9C0\uD0A4\uB824 \uD588\uC73C\uB098,
      \uC624\uD788\uB824 \uADF8 \uC218\uCE58\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uBAB8\uC774
      \uAD73\uC5B4\uBC84\uB9B0 \uAC83\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Instinct_003
    ko: "\uC120\uC218\uB294 \uCF54\uD2B8 \uAD6C\uC11D\uC5D0\uC11C \uC790\uC2E0\uC758
      \uBC18\uC751 \uC18D\uB3C4\uB97C \uC790\uCC45\uD558\uBA70, \uAC10\uB3C5\uB2D8\uC774
      \uB098\uB204\uC5B4\uC900 \uC218\uBE44 \uC9C0\uCE68\uC11C\uB97C \uD3B4\uB193\uACE0
      \uC190\uAC00\uB77D \uB05D\uC758 \uAC01\uB3C4\uAE4C\uC9C0 \uD558\uB098\uD558\uB098
      \uC810\uAC80\uD558\uBA70 \uC790\uAD34\uAC10\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Instinct_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00014_Ch_Instinct_001
    ko: "\uB9E4\uB274\uC5BC\uC740 \uBF08\uB300\uC77C \uBFD0, \uC0C1\uB300\uC640 \uD638\uD761\uD558\uB294
      \uAC10\uAC01\uC5D0 \uC9D1\uC911\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Bluffer_101
    ko: "\uC81C \uAC10\uAC01\uC774\uC57C \uB298 \uCD5C\uACE0\uC8E0! \uD558\uC9C0\uB9CC
      \uAC10\uB3C5\uB2D8\uC774 \uC815\uC11D\uC744 \uC9C0\uD0A4\uB77C\uACE0 \uD558\uC154\uC11C
      \uC81C \uD654\uB824\uD55C \uC190\uAE30\uC220\uC744 \uC5B5\uC81C\uD558\uACE0
      \uC788\uC5C8\uB358 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Bluffer_1
    ko: "\uACA9\uB824\uB97C \uBA74\uC8C4\uBD80\uB85C \uC4F0\uBA70 \uC218\uBE44 \uC2E4\uD328\uC758
      \uC6D0\uC778\uC778 \uAE30\uBCF8\uAE30 \uBD80\uC871\uC740 \uC678\uBA74\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Wild_101
    ko: "\uB9DE\uC544\uC694! \uC774 \uB2F5\uB2F5\uD55C \uC22B\uC790 \uACC4\uC0B0
      \uB54C\uBB38\uC5D0 \uBAB8\uC774 \uC548 \uC6C0\uC9C1\uC600\uB358 \uAC70\uC608\uC694.
      \uC774\uC81C \uC81C \uAC10\uB300\uB85C \uB364\uBCBC\uBCF4\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Wild_1
    ko: "\uC9C1\uAD00\uC744 \uC911\uC2DC\uD574 \uC871\uC1C4\uAC00 \uD480\uB9AC\uC790\uB9C8\uC790
      \uC0DD\uB3D9\uAC10\uC744 \uB418\uCC3E\uACE0 \uC989\uC2DC \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Egoist_101
    ko: "\uC81C \uAC10\uAC01\uC744 \uBBFF\uB294 \uAC74 \uB2F9\uC5F0\uD558\uC8E0.
      \uADF8\uB7F0\uB370 \uC800 \uBA4D\uCCAD\uD55C \uC9C0\uCE68\uC11C\uAC00 \uC81C
      \uC6B0\uC6D4\uD55C \uC2E0\uCCB4 \uB2A5\uB825\uC744 \uBC29\uD574\uD558\uACE0
      \uC788\uC5C8\uB2E4\uACE0\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Egoist_1
    ko: "\uC790\uAE30\uC911\uC2EC\uC801\uC774\uB77C \uC678\uBD80 \uBD88\uB9CC\uC744
      \uD574\uC18C\uD558\uC9C0 \uBABB\uD574 \uC790\uCC45\uC758 \uAD74\uB808\uC5D0\uC11C
      \uBABB \uBC97\uC5B4\uB0AC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Fighter_101
    ko: "\uD638\uD761\uC774\uACE0 \uAC10\uAC01\uC774\uACE0... \uC544\uAE4C \uADF8
      \uD328\uC2A4\uB97C \uBABB \uBE8F\uC740 \uAC8C \uB108\uBB34 \uD654\uAC00 \uB098\uB124\uC694.
      \uC5B4\uB5BB\uAC8C\uB4E0 \uB2E4\uC2DC \uBE8F\uC5B4\uC57C\uACA0\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Fighter_1
    ko: "\uACBD\uC7C1\uC2EC\uC740 \uC788\uC73C\uB098 \uACA9\uB824\uB9CC\uC73C\uB860
      \uC2E4\uD328\uC758 \uBD84\uB178\uC640 \uC790\uAD34\uAC10\uC774 \uC548 \uD480\uB824
      \uAC10\uC815\uC801\uC73C\uB85C \uC8FC\uC800\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Ch_Instinct_002
    ko: "\uBC29\uC2DD\uC5D0 \uB9E4\uBAB0\uB3FC \uC2DC\uC57C\uAC00 \uC881\uC544\uC838
      \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uACE0 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Bluffer_201
    ko: "\uC81C \uC2DC\uC57C\uAC00 \uC881\uB2E4\uACE0\uC694? \uC81C \uC190\uC774
      \uC5BC\uB9C8\uB098 \uBE60\uB978\uC9C0 \uACE7 \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0.
      0.5\uCD08 \uB530\uC704 \uC5C6\uC5B4\uB3C4 \uC2A4\uD2F8\uC740 \uC790\uC2E0 \uC788\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Bluffer_2
    ko: "\uACFC\uC2DC \uC695\uAD6C\uAC00 \uC9C8\uCC45\uC744 \uACC4\uAE30\uB85C \uD3ED\uBC1C\uD574
      \uC99D\uBA85\uD558\uAE30 \uC704\uD574 \uB354 \uBBFC\uCCA9\uD558\uAC8C \uC6C0\uC9C1\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Wild_201
    ko: "\uBC29\uC2DD\uC774\uACE0 \uBB50\uACE0, \uBAB8\uC774 \uC548 \uB530\uB77C\uC8FC\uB294\uB370
      \uC5B4\uCA4C\uB780 \uAC81\uB2C8\uAE4C? \uC77C\uB2E8 \uB6F0\uAE34 \uD558\uACA0\uC9C0\uB9CC
      \uC601 \uD765\uC774 \uC548 \uB098\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Wild_2
    ko: "\uB17C\uB9AC\uC801 \uC9C8\uCC45\uC774 \uC57C\uC131\uC744 \uC77C\uAE68\uC6B0\uC9C0
      \uBABB\uD574 \uC5B5\uC9C0\uB85C \uC6C0\uC9C1\uC774\uB098 \uB454\uD0C1\uD558\uACE0
      \uC218\uB3D9\uC801\uC774\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Egoist_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD300\uC744 \uB9DD\uCE5C\uB2E4\uACE0\uC694? \uC81C
      \uC2E4\uB825\uC774 \uACE7 \uD300\uC758 \uC218\uC900\uC778\uB370 \uC5B4\uB5BB\uAC8C
      \uADF8\uB7F0 \uB9D0\uC500\uC744 \uD558\uC2ED\uB2C8\uAE4C!"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Egoist_2
    ko: "\uC790\uAE30\uC560\uC5D0 \uC0C1\uCC98\uB97C \uC785\uC790 \uBD84\uB178\uB97C
      \uCC38\uC9C0 \uBABB\uD558\uACE0 \uC815\uBA74 \uCDA9\uB3CC\uD558\uBA70 \uC644\uC804\uD788
      \uB9DD\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Fighter_201
    ko: "\uC9C0\uAE08 \uC81C\uAC00 \uC124\uB801\uC124\uB801\uD558\uB294 \uAC78\uB85C
      \uBCF4\uC774\uC2ED\uB2C8\uAE4C? \uC8FD\uC744 \uD798\uC744 \uB2E4\uD574 \uC218\uCE58\uB97C
      \uC9C0\uD0A4\uB824\uB2E4 \uC2E4\uD328\uD55C \uAC74\uB370 \uC5B5\uC6B8\uD574\uC11C
      \uBABB \uD558\uACA0\uB124\uC694!"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Fighter_2
    ko: "\uD22C\uC7C1 \uAC00\uCE58\uB97C \uBD80\uC815\uB2F9\uD574 \uC5B5\uC6B8\uD568\uACFC
      \uBD84\uB178\uB85C \uC815\uC0C1\uC801\uC778 \uD6C8\uB828 \uC218\uD589\uC774
      \uBD88\uAC00\uB2A5\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Ch_Instinct_003
    ko: "\uC120\uC218\uC758 \uC218\uBE44 \uC9C0\uCE68\uC11C\uB97C \uB36E\uACE0 \uACF5\uC744
      \uB358\uC838 \uD6C8\uB828\uC744 \uC18D\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Bluffer_301
    ko: "\uC624, \uAC10\uB3C5\uB2D8\uB3C4 \uC81C \uBCF8\uBAA8\uC2B5\uC744 \uBCF4\uACE0
      \uC2F6\uC73C\uC2E0 \uBAA8\uC591\uC774\uB124\uC694. \uC9C0\uCE68\uC11C\uB294
      \uC9C0\uB8E8\uD588\uB294\uB370 \uCC28\uB77C\uB9AC \uC774\uAC8C \uB0AB\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Bluffer_3
    ko: "\uAC15\uC555\uC801 \uD589\uB3D9\uC744 \uC2A4\uD0C0\uC131 \uC778\uC815\uC73C\uB85C
      \uD574\uC11D\uD558\uBA70 \uC5EC\uC720\uB85C\uC6B4 \uCC99 \uD6C8\uB828\uC5D0
      \uAC00\uB2F4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Wild_301
    ko: "\uC124\uBA85\uB3C4 \uC5C6\uC774 \uBB50 \uD558\uC2DC\uB294 \uAC81\uB2C8\uAE4C!
      \uC0AC\uB78C\uC744 \uC9D0\uC2B9 \uCDE8\uAE09\uD558\uB294 \uAC83\uB3C4 \uC544\uB2C8\uACE0,
      \uAE30\uBD84 \uC7A1\uCCD0\uC11C \uBABB \uB6F0\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Wild_3
    ko: "\uAC70\uCE5C \uD589\uB3D9\uC5D0 \uBC18\uBC1C\uC2EC\uC774 \uC791\uC6A9\uD574
      \uB3D9\uBB3C\uC801 \uAC70\uBD80\uAC10\uC744 \uB290\uB07C\uACE0 \uC774\uD0C8\uD558\uB824
      \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Egoist_301
    ko: "\uBC29\uD574\uB418\uB294 \uC885\uC774 \uCABC\uAC00\uB9AC\uB294 \uCE58\uC6B0\uB294
      \uAC8C \uB9DE\uC8E0. \uC624\uC9C1 \uC81C \uC2E4\uB825\uC73C\uB85C\uB9CC\uC774
      \uD310\uC744 \uCC44\uC6CC\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Egoist_3
    ko: "\uC9C0\uCE68\uC11C\uAC00 \uC0AC\uB77C\uC9C0\uACE0 \uACF5\uC774 \uC8FC\uC5B4\uC9C0\uC790
      \uC790\uAE30\uC560 \uC99D\uBA85\uC744 \uC704\uD574 \uC989\uAC01 \uC2E4\uD589\uC5D0
      \uB3CC\uC785\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00014_Desc_Fighter_301
    ko: "\uADF8\uB798\uC694! \uB9D0\uC2F8\uC6C0\uD560 \uC2DC\uAC04\uC5D0 \uD55C \uBC88
      \uB354 \uBD80\uB52A\uCE58\uB294 \uAC8C \uB0AB\uC8E0! \uB2E4\uB4E4 \uB364\uBCBC!"
    en: 
    ja: 
  - stringKey: Event_00014_Rs_Fighter_3
    ko: "\uB09C\uAD00\uC744 \uC990\uACA8 \uAC70\uCE5C \uAC1C\uC785\uC774 \uD22C\uC7C1\uC2EC\uC744
      \uC790\uADF9\uD574 \uC790\uCC45\uC744 \uACF5\uACA9\uC131\uC73C\uB85C \uC804\uD658\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Discipline_001
    ko: "\uC0C1\uB300\uC758 \uB9AC\uB4EC\uC744 \uC77D\uB294 \uB208\uC740 \uC0DD\uACBC\uC9C0\uB9CC,
      \uC911\uC2EC\uC744 \uC783\uC9C0 \uB9D0\uB77C\uB294 \uC218\uBE44 \uADDC\uC728
      \uB54C\uBB38\uC5D0 \uACB0\uC815\uC801 \uC2A4\uD2F8 \uAE30\uD68C\uB97C \uACC4\uC18D
      \uBC84\uB9AC\uB294 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Discipline_002
    ko: "\uADF8\uC5D0\uAC8C 100% \uD655\uC2E0 \uC5C6\uB294 \uC2DC\uB3C4\uB294 \uBB34\uCC45\uC784\uD55C
      \uB3C4\uBC15\uC77C \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Discipline_003
    ko: "\uC801\uADF9\uC131\uC744 \uC694\uAD6C\uD558\uB294 \uB3D9\uB8CC\uB4E4\uC5D0\uAC8C
      \uC804\uC220 \uC9C0\uCE68\uC11C\uB97C \uB4E4\uC774\uBC00\uBA70 \uC790\uC2E0\uC758
      \uBB34\uACB0\uD568\uC744 \uC8FC\uC7A5\uD558\uB294, \uC6D0\uCE59\uC5D0 \uAC07\uD78C
      \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00015_Ch_Discipline_001
    ko: "\uC911\uC2EC\uC744 \uC783\uB354\uB77C\uB3C4 \uAC10\uAC01\uC744 \uBBFF\uACE0
      \uB6F0\uB294 \uAC83\uC774 \uC9C4\uC815\uD55C \uC6D0\uCE59\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Principled_101
    ko: "\uB9E4\uB274\uC5BC\uC744 \uB118\uC5B4\uC120 \uD604\uC7A5 \uB300\uC751\uC744
      \uC0C8\uB85C\uC6B4 \uC9C0\uCE68\uC73C\uB85C \uC218\uC6A9\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uC2B9\uB9AC\uB97C \uC704\uD574 \uB9AC\uB4EC\uC774 \uC77D\uD788\uBA74 \uC989\uC2DC
      \uC190\uC744 \uBED7\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Principled_1
    ko: "\uC2B9\uB9AC\uB97C \uC0C1\uC704 \uC6D0\uCE59\uC73C\uB85C \uC2B9\uACA9\uC2DC\uCF1C
      \uAE30\uC874 \uADDC\uC728 \uC704\uBC18\uC5D0 \uB300\uD55C \uACF5\uD3EC\uB97C
      \uD480\uACE0 \uC720\uC5F0\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Guardian_101
    ko: "\uC81C \uAC10\uAC01\uC744 \uBBFF\uC5B4\uBCF4\uACA0\uC9C0\uB9CC, \uC81C\uAC00
      \uC911\uC2EC\uC744 \uC783\uC5B4 \uC218\uBE44 \uAD6C\uBA4D\uC774 \uC0DD\uAE30\uBA74
      \uB3D9\uB8CC\uB4E4\uC774 \uD798\uB4E4\uC5B4\uC9C0\uC9C0 \uC54A\uC744\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Guardian_1
    ko: "\uACA9\uB824\uC5D0\uB3C4 \uD300 \uC548\uC804\uC744 \uD574\uCE60\uAE4C \uBAB8\uC744
      \uC0AC\uB9AC\uBA70 \uC18C\uADF9\uC801\uC73C\uB85C \uB300\uCC98\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Tactician_101
    ko: "\uAC10\uAC01\uC740 \uC8FC\uAD00\uC801\uC785\uB2C8\uB2E4. 100% \uD655\uB960\uC774
      \uC544\uB2CC \uC2A4\uD2F8\uC740 \uC804\uC220\uC801 \uC190\uC2E4\uC744 \uCD08\uB798\uD560
      \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Tactician_1
    ko: "\uB370\uC774\uD130 \uC911\uC2EC\uC774\uB77C \uBAA8\uD638\uD55C \uACA9\uB824\uB97C
      \uAC70\uBD80\uD558\uACE0 \uC548\uC804\uD55C \uC218\uCE58\uB97C \uACE0\uC9D1\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Exemplary_101
    ko: "\uB124! \uC2E4\uD328\uB97C \uB450\uB824\uC6CC\uD558\uC9C0 \uC54A\uACE0 \uD750\uB984\uC744
      \uD0C0\uB294 \uC120\uC218\uAC00 \uC9C4\uC9DC \uBAA8\uBC94\uC774\uB77C\uB294
      \uAC70\uC8E0? \uB2E4\uC2DC \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Exemplary_1
    ko: "\uACA9\uB824\uB97C \uC0C8\uB85C\uC6B4 \uD0DC\uB3C4\uB85C \uC218\uC6A9\uD574
      \uC790\uAD34\uAC10\uC744 \uD138\uC5B4\uB0B4\uACE0 \uAC00\uC7A5 \uC5F4\uC815\uC801\uC73C\uB85C
      \uC784\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Ch_Discipline_002
    ko: "\uC9C0\uCE68\uC11C\uB97C \uBC29\uD328 \uC0BC\uC544 \uC2B9\uB9AC\uB97C \uB193\uCE58\uB294
      \uAC83\uC740 \uBB34\uCC45\uC784\uD55C \uBC18\uCE59\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Principled_201
    ko: "\uC548\uC804 \uC218\uCE59\uC744 \uC9C0\uCF30\uB294\uB370 \uC65C \uBC18\uCE59\uC774\uB77C\uACE0
      \uD558\uC2DC\uC8E0? \uC9C0\uCE68\uC11C\uC758 \uC6B0\uC120\uC21C\uC704\uAC00
      \uD63C\uB780\uC2A4\uB7FD\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Principled_2
    ko: "\uC9C8\uCC45\uC744 \uBC1B\uC73C\uBA74 \uC6D0\uCE59 \uC0AC\uC774\uC758 \uCDA9\uB3CC\uC744
      \uD574\uACB0\uD558\uB824 \uBD84\uC11D\uC5D0 \uBE60\uC838 \uBA48\uCDB0\uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Guardian_201
    ko: "\uC800\uB294 \uADF8\uC800 \uD300\uC758 \uC548\uC804\uC744 \uC218\uD638\uD558\uB824
      \uD588\uC744 \uBFD0\uC778\uB370... \uC81C \uBC29\uC2DD\uC774 \uD300\uC5D0 \uD574\uAC00
      \uB418\uC5C8\uB2E4\uB2C8 \uC815\uB9D0 \uAD34\uB86D\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Guardian_2
    ko: "\uB178\uB825\uC774 \uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCCE4\uB2E4\uB294
      \uC9C0\uC801\uC5D0 \uAE4A\uC740 \uC790\uAD34\uAC10\uC744 \uB290\uB07C\uACE0
      \uBA58\uD0C8\uC774 \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Tactician_201
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uC548\uC804\uC774\uB77C\uB294 \uC218\uB2E8\uC5D0
      \uAC07\uD600 \uBCFC \uD0C8\uD658\uC774\uB77C\uB294 \uC804\uCCB4 \uC804\uC220\uC744
      \uB9DD\uCCE4\uB124\uC694. \uC804\uC220 \uC6B0\uC120\uC21C\uC704\uB97C \uC7AC\uC124\uC815\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Tactician_2
    ko: "\uBC29\uC2DD\uC774 \uBE44\uD6A8\uC728\uC801\uC784\uC744 \uAE68\uB2EB\uACE0
      \uC2B9\uB9AC \uD655\uB960\uC744 \uB192\uC774\uAE30 \uC704\uD574 \uACFC\uAC10\uD55C
      \uB3C4\uC804\uC744 \uC120\uD0DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Exemplary_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uC81C\uAC00 \uB108\uBB34 \uAD50\uACFC\uC11C\uC801\uC73C\uB85C\uB9CC
      \uAD74\uC5C8\uB124\uC694. \uC880 \uB354 \uC735\uD1B5\uC131 \uC788\uB294 \uBAA8\uC2B5\uC744
      \uBCF4\uC774\uB3C4\uB85D \uB178\uB825\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Exemplary_2
    ko: "\uC9C0\uC2DC\uC5D0 \uB530\uB974\uB098 \uD310\uB2E8 \uD655\uC2E0\uC774 \uC0AC\uB77C\uC838
      \uC0C1\uB300 \uB208\uCE58 \uBCF4\uB290\uB77C \uD0C0\uC774\uBC0D\uC744 \uACC4\uC18D
      \uB193\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Ch_Discipline_003
    ko: "\uC9C0\uCE68\uC11C\uB97C \uBE8F\uC5B4 \uB358\uC9C0\uACE0 \uAC15\uC81C\uB85C
      1:1 \uC0C1\uD669\uC744 \uB9CC\uB4E4\uC5B4 \uD6C8\uB828\uD568."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Principled_301
    ko: "\uAE30\uC900\uB3C4 \uC5C6\uC774 \uB3C4\uBC15\uC744 \uD558\uB77C\uB294 \uB9D0\uC500\uC785\uB2C8\uAE4C?
      \uC774\uB7F0 \uBB34\uCC45\uC784\uD55C \uBC29\uC2DD\uC5D0\uB294 \uB3D9\uC758\uD560
      \uC218 \uC5C6\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Principled_3
    ko: "\uC720\uC77C\uD55C \uADFC\uAC70\uC778 \uC9C0\uCE68\uC11C\uB97C \uBE8F\uAE30\uC790
      \uBD88\uC548\uD574\uD558\uBA70 \uC9C0\uB3C4 \uBC29\uC2DD\uC744 \uBE44\uB17C\uB9AC\uC801\uC774\uB77C
      \uBE44\uB09C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Guardian_301
    ko: "\uC0DD\uAC01\uD560 \uD2C8 \uC5C6\uC774 \uBD80\uB52A\uD788\uB294 \uAC8C \uB3D9\uB8CC\uB97C
      \uC9C0\uD0A4\uB294 \uBC95\uC774\uAD70\uC694. \uBAB8\uC73C\uB85C \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Guardian_3
    ko: "\uC9C0\uCE68\uC11C \uC0C1\uC2E4\uC5D0 \uB3D9\uB8CC \uC218\uD638 \uCC45\uC784\uAC10\uC774
      \uBCF8\uB2A5\uC744 \uAE68\uC6CC \uC989\uC2DC \uAE30\uD68C\uB97C \uD3EC\uCC29\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Tactician_301
    ko: "\uC9C0\uCE68\uC11C \uC5C6\uB294 \uD658\uACBD\uC5D0\uC11C\uC758 \uC131\uACF5
      \uD655\uB960\uC744 \uACC4\uC0B0\uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4. \uC77C\uB2E8
      \uD15C\uD3EC\uC5D0 \uB9DE\uCDB0 \uB370\uC774\uD130\uB97C \uC313\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Tactician_3
    ko: "\uD589\uB3D9 \uAC1C\uC785\uC744 \uC0C8 \uBCC0\uC218\uB85C \uC778\uC2DD\uD574
      \uC6C0\uC9C1\uC774\uB098 \uBA38\uB9BF\uC18D \uC5F0\uC0B0 \uD0D3\uC5D0 \uBC18\uC751\uC774
      \uD55C \uBC15\uC790 \uB2A6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Exemplary_301
    ko: "\uC9C0\uCE68\uC11C\uB97C \uCE58\uC6B0\uC2DC\uB2E4\uB2C8... \uC81C\uAC00
      \uAE30\uBCF8\uB3C4 \uBABB \uD558\uB294 \uD55C\uC2EC\uD55C \uC120\uC218\uAC00
      \uB418\uC5B4\uBC84\uB9B0 \uAE30\uBD84\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Exemplary_3
    ko: "\uB2E8\uD638\uD55C \uD589\uB3D9\uC744 \uD3EC\uAE30\uB098 \uB099\uC81C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uC704\uCD95\uB418\uACE0 \uC758\uC695\uC744 \uC644\uC804\uD788
      \uC783\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Bond_001
    ko: "\uC0C1\uB300\uC758 \uB9AC\uB4EC\uC744 \uC77D\uB294 \uB208\uC740 \uC0DD\uACBC\uC9C0\uB9CC,
      \uC911\uC2EC\uC744 \uC783\uC9C0 \uB9D0\uB77C\uB294 \uC218\uBE44 \uADDC\uC728
      \uB54C\uBB38\uC5D0 \uACB0\uC815\uC801 \uC2A4\uD2F8 \uAE30\uD68C\uB97C \uACC4\uC18D
      \uBC84\uB9AC\uB294 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Bond_002
    ko: "\uADF8\uC5D0\uAC8C 100% \uD655\uC2E0 \uC5C6\uB294 \uC2DC\uB3C4\uB294 \uBB34\uCC45\uC784\uD55C
      \uB3C4\uBC15\uC77C \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Bond_003
    ko: "\uC801\uADF9\uC131\uC744 \uC694\uAD6C\uD558\uB294 \uB3D9\uB8CC\uB4E4\uC5D0\uAC8C
      \uC804\uC220 \uC9C0\uCE68\uC11C\uB97C \uB4E4\uC774\uBC00\uBA70 \uC790\uC2E0\uC758
      \uBB34\uACB0\uD568\uC744 \uC8FC\uC7A5\uD558\uB294, \uC6D0\uCE59\uC5D0 \uAC07\uD78C
      \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Bond_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00015_Ch_Bond_001
    ko: "\uADDC\uC728\uC744 \uC5B4\uAE30\uB354\uB77C\uB3C4 \uB3D9\uB8CC\uC758 \uBBFF\uC74C\uC5D0
      \uBCF4\uB2F5\uD558\uB294 \uC6A9\uAE30\uB97C \uBCF4\uC5EC\uB77C."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Kind_101
    ko: "\uC544... \uC81C\uAC00 \uB3D9\uB8CC\uB4E4\uC744 \uB354 \uD798\uB4E4\uAC8C
      \uD558\uACE0 \uC788\uC5C8\uAD70\uC694. \uBBFF\uC5B4\uC8FC\uC2E0\uB2E4\uBA74
      \uC6A9\uAE30\uB97C \uB0B4\uBCFC\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Kind_1
    ko: "\uC6D0\uCE59 \uACE0\uC218\uAC00 \uC0C1\uCC98\uB97C \uC92C\uB2E8 \uC815\uC11C\uC801
      \uC790\uAC01\uC5D0 \uBBF8\uC548\uD568\uC744 \uC6D0\uB3D9\uB825 \uC0BC\uC544
      \uADDC\uC728\uC744 \uAE7C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uC0C8\uB85C\uC6B4 \uC9C0\uD718\uB77C\uBA74 \uB530\uB974\uACA0\uC2B5\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC6D0\uCE59\uC774 \uBC14\uB00C\uB294 \uAC8C \uC870\uAE08
      \uD63C\uB780\uC2A4\uB7FD\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Loyal_1
    ko: "\uBA85\uB839 \uC218\uD589 \uC758\uC9C0\uB294 \uAC15\uD558\uB098 \uB17C\uB9AC\uC801
      \uCDA9\uB3CC\uC744 \uD574\uACB0\uD558\uB290\uB77C \uBC18\uC751\uC774 \uB2A6\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Sincere_101
    ko: "\uBF08\uB300\uB9CC\uC73C\uB85C\uB294 \uC218\uBE44\uB97C \uC644\uC131\uD560
      \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uADDC\uCE59\uC744 \uC815\uD655\uD788 \uC9C0\uD0A4\uC9C0
      \uC54A\uC73C\uBA74 \uC5F0\uC2B5\uC758 \uC758\uBBF8\uAC00 \uD1F4\uC0C9\uB418\uB294
      \uAC83 \uAC19\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Sincere_1
    ko: "\uC218\uCE58\uC640 \uB2E8\uACC4\uB97C \uC911\uC2DC\uD574 \uC720\uC5F0\uC131
      \uAC15\uC870 \uACA9\uB824\uB97C \uBD88\uC131\uC2E4\uD55C \uD0C0\uD611\uC73C\uB85C
      \uB290\uB07C\uACE0 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Moodmaker_101
    ko: "\uC624, \uC81C\uAC00 \uC8FC\uC778\uACF5\uC778\uAC00\uC694? \uC88B\uC8E0!
      \uC9DC\uB9BF\uD558\uAC8C \uD55C \uBC88 \uBE8F\uC5B4\uC11C \uD300 \uD150\uC158
      \uC880 \uC62C\uB824\uBCF4\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Moodmaker_1
    ko: "\uAE0D\uC815\uC801 \uC8FC\uBAA9\uACFC \uC5ED\uD560\uC744 \uBD80\uC5EC\uBC1B\uC790
      \uC989\uC2DC \uD150\uC158\uC774 \uC62C\uB77C \uACFC\uAC10\uD55C \uC218\uBE44\uC5D0
      \uC131\uACF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Ch_Bond_002
    ko: "\uC9C0\uCE68\uC11C \uB4A4\uC5D0 \uC228\uC5B4 \uBB34\uACB0\uD568\uC744 \uD551\uACC4\uB85C
      \uB3D9\uB8CC\uB97C \uACE0\uB9BD\uC2DC\uD0A4\uC9C0 \uB9C8\uB77C."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Kind_201
    ko: "\uBE44\uAC81\uD558\uB2E4\uB2C8\uC694... \uC800\uB294 \uADF8\uC800 \uD53C\uD574\uB97C
      \uC8FC\uAE30 \uC2EB\uC5C8\uC744 \uBFD0\uC778\uB370..."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Kind_2
    ko: "\uC120\uC758\uB97C \uBD80\uC815\uB2F9\uD588\uB2E4\uB294 \uC0DD\uAC01\uC5D0
      \uC0C1\uCC98 \uC785\uACE0 \uC2EC\uB9AC\uC801\uC73C\uB85C \uC704\uCD95\uB418\uC5B4
      \uACBD\uC9C1\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Loyal_201
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uC644\uBCBD\uD55C \uC9C0\uCE68\uC744 \uC81C\uAC00
      \uC81C\uB300\uB85C \uC18C\uD654\uD558\uC9C0 \uBABB\uD55C \uC81C \uBD88\uCC30\uC785\uB2C8\uB2E4.
      \uB354 \uC774\uC0C1 \uAC10\uB3C5\uB2D8\uC758 \uC81C\uC790\uB85C \uB0A8\uC744
      \uC790\uACA9\uC774 \uC5C6\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC744 \uC874\uC7AC \uAC00\uCE58 \uBD80\uC815\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uBA58\uD0C8\uC774 \uC644\uC804\uD788 \uBD95\uAD34\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Sincere_201
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uC81C \uC131\uC2E4\uD568\uC774 \uB098\uC758 \uBB34\uACB0\uD568\uC5D0\uB9CC
      \uC9D1\uC911\uB418\uC5B4 \uC788\uC5C8\uB124\uC694. \uD300 \uC804\uCCB4\uC758
      \uC131\uC2E4\uD568\uC744 \uC704\uD574 \uB2E4\uC2DC \uB6F0\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Sincere_2
    ko: "\uB178\uB825\uC774 \uBBFC\uD3D0\uC600\uB2E4\uB294 \uBE44\uD310\uC5D0 \uAC1C\uC120\uD560
      \uC0C8 \uACFC\uC81C\uB85C \uC0BC\uC544 \uB3C5\uD558\uAC8C \uB9E4\uC9C4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Moodmaker_201
    ko: "\uC544... \uBD84\uC704\uAE30 \uC88B\uC558\uB294\uB370 \uC65C \uAC11\uC790\uAE30
      \uD654\uB97C \uB0B4\uC138\uC694... \uC758\uC695 \uD655 \uB5A8\uC5B4\uC9C0\uB124."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Moodmaker_2
    ko: "\uCC2C\uBB3C \uB07C\uC5B9\uB294 \uC9C8\uCC45\uC5D0 \uAC10\uC815\uC774 \uC0C1\uD574
      \uB208\uCE58\uB97C \uBCF4\uB290\uB77C \uD0C0\uC774\uBC0D\uC744 \uB193\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Ch_Bond_003
    ko: "\uC9C0\uCE68\uC11C\uB97C \uBE8F\uC5B4 \uB358\uC9C0\uACE0 \uAC15\uC81C\uB85C
      1:1 \uC0C1\uD669\uC744 \uB9CC\uB4E4\uC5B4 \uD6C8\uB828\uD568."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Kind_301
    ko: "\uAC11\uC790\uAE30 \uC774\uB7EC\uC2DC\uBA74 \uBB34\uC11C\uC6CC\uC694. \uB3D9\uB8CC\uB4E4
      \uC55E\uC5D0\uC11C \uB9DD\uC2E0 \uC8FC\uC2DC\uB294 \uAC74\uAC00\uC694?"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Kind_3
    ko: "\uC815\uC11C\uC801 \uAD50\uAC10 \uC5C6\uB294 \uAC15\uC555\uC801\uC778 \uBCC0\uD654\uC5D0
      \uADF9\uC2EC\uD55C \uACF5\uD3EC\uC640 \uC18C\uC678\uAC10\uC744 \uB290\uB07C\uACE0
      \uD6C8\uB828\uC744 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Loyal_301
    ko: "\uC0DD\uAC01\uD560 \uC2DC\uAC04\uC5D0 \uBAB8\uC73C\uB85C \uC99D\uBA85\uD558\uB77C\uB294
      \uBA85\uB839\uC774\uC2DC\uAD70\uC694. \uB2E4\uC2DC \uAC00\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Loyal_3
    ko: "\uB2E8\uD638\uD55C \uBB3C\uB9AC\uC801 \uAC1C\uC785\uC744 \uAC15\uB825\uD55C
      \uD558\uC0AC \uBA85\uB839\uC73C\uB85C \uC778\uC2DD\uD574 \uC989\uC2DC \uAC01\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Sincere_301
    ko: "\uC544\uC9C1 \uADDC\uC728 \uC219\uC9C0\uAC00 \uC548 \uB05D\uB0AC\uB294\uB370...
      \uC77C\uB2E8 \uBAB8\uBD80\uD130 \uB358\uC838\uBCF4\uACA0\uC9C0\uB9CC \uBA38\uB9BF\uC18D\uC774
      \uC815\uB9AC\uAC00 \uC548 \uB418\uC5B4 \uB2F5\uB2F5\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Sincere_3
    ko: "\uC808\uCC28\uB97C \uAC74\uB108\uB6F0\uB294 \uAC15\uC81C \uC9D1\uD589\uC5D0
      \uB2F9\uD639\uAC10\uC744 \uB290\uB07C\uACE0 \uC5C7\uBC15\uC790\uAC00 \uBC1C\uC0DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Moodmaker_301
    ko: "\uC9C0\uCE68\uC11C \uB358\uC9C0\uACE0 \uC18C\uB9AC \uC9C0\uB974\uC2DC\uB2C8\uAE4C
      \uB108\uBB34 \uB2F9\uD669\uC2A4\uB7EC\uC6CC\uC694. \uD6C8\uB828 \uBD84\uC704\uAE30\uAC00
      \uB108\uBB34 \uC0B4\uBC8C\uD574\uC84C\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Moodmaker_3
    ko: "\uAC15\uC555\uC801\uC774\uACE0 \uBB34\uAC70\uC6B4 \uACF5\uAE30\uC5D0 \uAC70\uBD80\uAC10\uC744
      \uB290\uB07C\uACE0 \uC990\uAC70\uC6C0\uC744 \uC783\uC5B4 \uB2A5\uB825\uC774
      \uC800\uD558\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Cold_001
    ko: "\uC0C1\uB300\uC758 \uB9AC\uB4EC\uC744 \uC77D\uB294 \uB208\uC740 \uC0DD\uACBC\uC9C0\uB9CC,
      \uC911\uC2EC\uC744 \uC783\uC9C0 \uB9D0\uB77C\uB294 \uC218\uBE44 \uADDC\uC728
      \uB54C\uBB38\uC5D0 \uACB0\uC815\uC801 \uC2A4\uD2F8 \uAE30\uD68C\uB97C \uACC4\uC18D
      \uBC84\uB9AC\uB294 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Cold_002
    ko: "\uADF8\uC5D0\uAC8C 100% \uD655\uC2E0 \uC5C6\uB294 \uC2DC\uB3C4\uB294 \uBB34\uCC45\uC784\uD55C
      \uB3C4\uBC15\uC77C \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Cold_003
    ko: "\uC801\uADF9\uC131\uC744 \uC694\uAD6C\uD558\uB294 \uB3D9\uB8CC\uB4E4\uC5D0\uAC8C
      \uC804\uC220 \uC9C0\uCE68\uC11C\uB97C \uB4E4\uC774\uBC00\uBA70 \uC790\uC2E0\uC758
      \uBB34\uACB0\uD568\uC744 \uC8FC\uC7A5\uD558\uB294, \uC6D0\uCE59\uC5D0 \uAC07\uD78C
      \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Cold_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00015_Ch_Cold_001
    ko: "\uB9E4\uB274\uC5BC\uC740 \uAE30\uC900\uC77C \uBFD0\uC774\uB2C8 \uB124\uAC00
      \uC77D\uC740 \uB9AC\uB4EC\uC744 \uBBFF\uACE0 \uBCA0\uD305\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Planner_101
    ko: "80%\uB294 \uC644\uBCBD\uD55C \uC218\uCE58\uAC00 \uC544\uB2D9\uB2C8\uB2E4.
      \uB098\uBA38\uC9C0 20%\uC758 \uB9AC\uC2A4\uD06C\uB97C \uC0C1\uC1C4\uD560 \uBCF4\uC644\uCC45\uC774
      \uC5C6\uB2E4\uBA74, \uC6C0\uC9C1\uC774\uC9C0 \uC54A\uB294 \uAC83\uC774 \uAD6C\uC870\uC801\uC73C\uB85C
      \uC633\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Planner_1
    ko: "\uD655\uB960\uC801 \uACA9\uB824\uB3C4 \uBD88\uD655\uC2E4\uC131\uC73C\uB85C
      \uAC04\uC8FC\uD574 \uC644\uBCBD\uD55C \uB370\uC774\uD130\uB97C \uC694\uAD6C\uD558\uBA70
      \uBD84\uC11D\uC5D0 \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Opportunist_101
    ko: "\uBCA0\uD305\uD560 \uB9CC\uD55C \uAC00\uCE58\uAC00 \uC788\uB2E4\uBA74 \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC2E4\uD328 \uC2DC \uC81C \uAE30\uB85D\uC5D0 \uB0A8\uC744
      \uC624\uC810\uC740 \uAC10\uB3C5\uB2D8\uC774 \uCC45\uC784\uC838 \uC8FC\uC2DC\uB294
      \uAC81\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Opportunist_1
    ko: "\uC2E4\uB9AC\uC801\uC73C\uB85C \uC218\uC6A9\uD558\uB824 \uD558\uB098 \uBCF4\uC0C1
      \uC5C6\uC774 \uC790\uAE30 \uC190\uD574\uB97C \uBCF4\uC9C0 \uC54A\uC73C\uB824
      \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Cunning_101
    ko: "\uAC10\uB3C5\uB2D8 \uB9D0\uC500\uC774 \uB9DE\uC544\uC694. \uADDC\uC728\uC744
      \uC9C0\uD0A4\uB294 \uCC99\uD558\uBA74\uC11C \uC2AC\uCA4D \uC0C1\uB300\uC758
      \uD0C0\uC774\uBC0D\uC744 \uBE8F\uB294 \uAC8C \uC9C4\uC9DC \uC218\uBE44\uAD70\uC694.
      \uC774\uC81C \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Cunning_1
    ko: "\uC2EC\uB9AC\uC804\uC744 \uAE68\uB2EB\uACE0 \uC21C\uC751\uD558\uB294 \uCC99
      \uC601\uC545\uD558\uAC8C \uC0C1\uB300 \uD5C8\uC810\uC744 \uB178\uB9AC\uAE30
      \uC2DC\uC791\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Believer_101
    ko: "\uC81C \uC2E0\uB150\uC740 \uC644\uBCBD\uD55C \uC815\uC11D\uC744 \uAD6C\uD604\uD558\uB294
      \uAC83\uC785\uB2C8\uB2E4. \uAC10\uAC01\uC5D0 \uC758\uC874\uD574 \uB300\uCDA9
      \uC218\uBE44\uD558\uB294 \uAC74 \uC81C \uC0AC\uC804\uC5D0 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Believer_1
    ko: "\uB17C\uB9AC\uC801 \uC2E0\uB150\uC774 \uC6CC\uB099 \uD655\uACE0\uD574 \uC720\uC5F0\uC131
      \uAC15\uC870 \uACA9\uB824\uB97C \uD0C0\uD611\uC73C\uB85C \uB290\uB07C\uACE0
      \uC644\uAC15\uD788 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Ch_Cold_002
    ko: "\uC218\uB2E8\uC744 \uC9C0\uD0A4\uB290\uB77C \uC2E4\uC810\uC744 \uB9C9\uB294
      \uBCF8\uC9C8\uC744 \uBC84\uB9AC\uB294 \uAC74 \uBA4D\uCCAD\uD558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Planner_201
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uC911\uC2EC \uC720\uC9C0\uB77C\uB294 \uD558\uC704
      \uC124\uACC4\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uBCFC \uD0C8\uD658\uC774\uB77C\uB294
      \uC0C1\uC704 \uC124\uACC4\uB97C \uB9DD\uCCE4\uAD70\uC694. \uC804\uCCB4 \uC2DC\uC2A4\uD15C\uC758
      \uC6B0\uC120\uC21C\uC704\uB97C \uC7AC\uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Planner_2
    ko: "\uD655\uB960\uC801 \uACA9\uB824\uB3C4 \uBD88\uD655\uC2E4\uC131\uC73C\uB85C
      \uAC04\uC8FC\uD574 \uC644\uBCBD\uD55C \uB370\uC774\uD130\uB97C \uC694\uAD6C\uD558\uBA70
      \uBD84\uC11D \uB2AA\uC5D0 \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Opportunist_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD2C0\uB838\uB2E4\uACE0\uC694? \uC815\uC11D\uB300\uB85C
      \uD574\uC11C \uB9AC\uC2A4\uD06C\uB97C \uC904\uC774\uB824 \uD588\uB358 \uAC74\uB370...
      \uC9C8\uCC45\uB9CC \uBC1B\uB294\uB2E4\uBA74 \uC774 \uC2DC\uC2A4\uD15C\uC5D0
      \uB0A8\uC744 \uC774\uC720\uAC00 \uC5C6\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Opportunist_2
    ko: "\uC548\uC804\uC744 \uBCF4\uC7A5\uD558\uB358 \uADDC\uC728\uC774 \uBE44\uD310\uBC1B\uC790
      \uC2DC\uC2A4\uD15C \uC2E0\uB8B0\uB97C \uC783\uACE0 \uC758\uC695\uC774 \uAE09\uACA9\uD788
      \uAEBE\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Cunning_201
    ko: "\uC81C \uC218\uB2E8\uC774 \uB108\uBB34 \uB178\uACE8\uC801\uC774\uC5C8\uB098
      \uBCF4\uB124\uC694. \uC9C0\uC801\uD558\uC2E0 \uB300\uB85C \uC880 \uB354 \uC740\uBC00\uD558\uACE0
      \uC720\uC5F0\uD558\uAC8C \uC6C0\uC9C1\uC5EC\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Cunning_2
    ko: "\uC804\uB7B5\uC774 \uAC04\uD30C\uB2F9\uD55C \uB290\uB08C\uC5D0 \uC704\uCD95\uB418\uC5B4
      \uB2F9\uBD84\uAC04 \uB208\uCE58 \uBCF4\uB290\uB77C \uC18C\uADF9\uC801\uC73C\uB85C
      \uBCC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Believer_201
    ko: "\uD300\uC758 \uBAA9\uC801\uC744 \uB9DD\uCE58\uB294 \uAC74 \uC81C \uC2E0\uB150\uC5D0\uB3C4
      \uC5B4\uAE0B\uB098\uB294 \uC77C\uC785\uB2C8\uB2E4. \uC2B9\uB9AC\uB77C\uB294
      \uB300\uC758\uB97C \uC704\uD574 \uC81C \uACE0\uC9D1\uC744 \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Believer_2
    ko: "\uC2E0\uB150\uC774 \uD300 \uC774\uC775\uACFC \uCDA9\uB3CC\uD568\uC744 \uAE68\uB2EB\uACE0
      \uC2A4\uC2A4\uB85C \uC218\uC815\uD574 \uAC15\uB825\uD788 \uB3D9\uAE30\uBD80\uC5EC\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Ch_Cold_003
    ko: "\uC9C0\uCE68\uC11C\uB97C \uBE8F\uC5B4 \uB358\uC9C0\uACE0 \uAC15\uC81C\uB85C
      1:1 \uC0C1\uD669\uC744 \uB9CC\uB4E4\uC5B4 \uD6C8\uB828\uD568."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Planner_301
    ko: "\uC774\uB860 \uBD84\uC11D\uC744 \uC911\uB2E8\uD558\uACE0 \uD604\uC7A5 \uB370\uC774\uD130
      \uC218\uC9D1\uC73C\uB85C \uC804\uD658\uD558\uC2DC\uACA0\uB2E4\uB294 \uB73B\uC774\uAD70\uC694.
      \uC6C0\uC9C1\uC774\uBA70 \uD30C\uC545\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Planner_3
    ko: "\uAC00\uC774\uB4DC\uB77C\uC778 \uC0C1\uC2E4\uC744 \uC2E4\uD5D8 \uB2E8\uACC4\uB85C
      \uC7AC\uC815\uC758\uD558\uBA70 \uCD5C\uC801\uC758 \uC6C0\uC9C1\uC784\uC744
      \uCC3E\uAE30 \uC2DC\uC791\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Opportunist_301
    ko: "\uC0DD\uAC01\uD560 \uD2C8 \uC5C6\uC774 \uAE30\uD68C\uAC00 \uC624\uB124\uC694.
      \uC9C0\uAE08\uC740 \uAC01\uB3C4 \uACC4\uC0B0\uBCF4\uB2E4 \uC774 \uACF5\uC744
      \uBE8F\uB294 \uAC8C \uAC00\uC7A5 \uD070 \uC2E4\uB9AC\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Opportunist_3
    ko: "\uAC15\uC81C \uC2E4\uC804 \uD22C\uC785\uC774 \uBBFC\uCCA9\uD55C \uD3EC\uCC29
      \uC0C1\uD0DC\uB85C \uC804\uD658\uC2DC\uCF1C \uBCF5\uC7A1\uD55C \uC774\uB860
      \uB300\uC2E0 \uC131\uACFC\uC5D0 \uC9D1\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Cunning_301
    ko: "\uC774\uB7F0 \uC2DD\uC73C\uB85C \uC555\uBC15\uD558\uC2DC\uBA74 \uC81C \uC2A4\uD0C0\uC77C\uC744
      \uCC3E\uC744 \uC218\uAC00 \uC5C6\uC5B4\uC694. \uC81C \uC57D\uC810\uB9CC \uB4DC\uB7EC\uB098\uB294
      \uBB34\uC9C8\uC11C\uD55C \uD6C8\uB828\uC740 \uC0AC\uC591\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Cunning_3
    ko: "\uAE09\uBC15\uD55C \uC0C1\uD669\uC5D0 \uB178\uCD9C\uB418\uC790 \uC2EC\uB9AC\uC801
      \uC6B0\uC704\uB97C \uC783\uACE0 \uC9D1\uC911\uB825\uC774 \uBB34\uB108\uC838
      \uD6C8\uB828\uC744 \uD3EC\uAE30\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Believer_301
    ko: "\uC9C0\uCE68\uC11C\uAC00 \uC5C6\uC5B4\uB3C4 \uC81C \uBA38\uB9BF\uC18D \uB17C\uB9AC\uB294
      \uC720\uD6A8\uD569\uB2C8\uB2E4. \uC774 \uBB34\uC9C8\uC11C\uD55C \uD750\uB984
      \uC18D\uC5D0\uC11C\uB3C4 \uC81C \uC218\uBE44\uAC00 \uC633\uC74C\uC744 \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Believer_3
    ko: "\uD658\uACBD \uBCC0\uD654\uC5D0\uB3C4 \uD398\uC774\uC2A4\uB97C \uC720\uC9C0\uD558\uB098
      \uB3D9\uB8CC\uC640\uC758 \uC870\uD654\uBCF4\uB2E8 \uC790\uAE30 \uC99D\uBA85\uC5D0
      \uCE58\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Instinct_001
    ko: "\uC0C1\uB300\uC758 \uB9AC\uB4EC\uC744 \uC77D\uB294 \uB208\uC740 \uC0DD\uACBC\uC9C0\uB9CC,
      \uC911\uC2EC\uC744 \uC783\uC9C0 \uB9D0\uB77C\uB294 \uC218\uBE44 \uADDC\uC728
      \uB54C\uBB38\uC5D0 \uACB0\uC815\uC801 \uC2A4\uD2F8 \uAE30\uD68C\uB97C \uACC4\uC18D
      \uBC84\uB9AC\uB294 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Instinct_002
    ko: "\uADF8\uC5D0\uAC8C 100% \uD655\uC2E0 \uC5C6\uB294 \uC2DC\uB3C4\uB294 \uBB34\uCC45\uC784\uD55C
      \uB3C4\uBC15\uC77C \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Instinct_003
    ko: "\uC801\uADF9\uC131\uC744 \uC694\uAD6C\uD558\uB294 \uB3D9\uB8CC\uB4E4\uC5D0\uAC8C
      \uC804\uC220 \uC9C0\uCE68\uC11C\uB97C \uB4E4\uC774\uBC00\uBA70 \uC790\uC2E0\uC758
      \uBB34\uACB0\uD568\uC744 \uC8FC\uC7A5\uD558\uB294, \uC6D0\uCE59\uC5D0 \uAC07\uD78C
      \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Instinct_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00015_Ch_Instinct_001
    ko: "\uAC81\uC7C1\uC774\uCC98\uB7FC \uB9E4\uB274\uC5BC\uC5D0 \uC228\uC9C0 \uB9D0\uACE0
      \uC57C\uC131\uC744 \uBBFF\uACE0 \uACFC\uAC10\uD788 \uB364\uBCBC\uB77C."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uC81C \uC9C4\uAC00\uB97C \uC544\uC2DC\uB124\uC694.
      \uC800\uB7F0 \uC2DC\uC2DC\uD55C \uC9C0\uCE68\uC11C \uB530\uC704\uBCF4\uB2E4
      \uC81C \uD654\uB824\uD55C \uC2A4\uD2F8\uC774 \uD300\uC5D0 \uB354 \uD544\uC694\uD558\uC8E0.
      \uB611\uB611\uD788 \uBCF4\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Bluffer_1
    ko: "\uD2B9\uBCC4\uD568\uC744 \uC778\uC815\uBC1B\uACE0 \uAE30\uD68C\uB97C \uC5BB\uC790
      \uADDC\uC728\uC744 \uBC97\uC5B4\uB098 \uC555\uB3C4\uC801\uC778 \uD37C\uD3EC\uBA3C\uC2A4\uB97C
      \uC120\uBCF4\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Wild_101
    ko: "\uADF8 \uB9D0\uB9CC \uAE30\uB2E4\uB838\uC2B5\uB2C8\uB2E4! \uC5B5\uC9C0\uB85C
      \uCC38\uB290\uB77C \uBBF8\uCE60 \uC9C0\uACBD\uC774\uC5C8\uB294\uB370, \uB2E4
      \uBC15\uC0B4 \uB0B4\uBC84\uB9B4 \uD14C\uB2C8 \uB4B7\uAC10\uB2F9\uC740 \uAC10\uB3C5\uB2D8\uC774
      \uD558\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Wild_1
    ko: "\uACF5\uC2DD \uD5C8\uB77D\uC774 \uB5A8\uC5B4\uC9C0\uC790\uB9C8\uC790 \uB3D9\uBB3C\uC801\uC778
      \uAC10\uAC01\uC744 \uD3ED\uBC1C\uC2DC\uCF1C \uACB0\uC815\uC801\uC778 \uC2A4\uD2F8\uC5D0
      \uC131\uACF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Egoist_101
    ko: "\uC81C \uAC10\uAC01\uC774 \uC815\uB2F5\uC774\uB77C\uACE0\uC694? \uC88B\uAE34
      \uD55C\uB370, \uC2E4\uD328\uD574\uC11C \uC81C \uCEE4\uB9AC\uC5B4\uC5D0 \uC624\uC810\uC774
      \uB0A8\uC73C\uBA74 \uB204\uAC00 \uBCF4\uC0C1\uD558\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Egoist_1
    ko: "\uB9AC\uC2A4\uD06C\uB97C \uACC4\uC0B0\uD558\uB290\uB77C \uACB0\uC815\uC801\uC778
      \uD0C0\uC774\uBC0D\uC744 \uB193\uCE58\uACE0 \uD3C9\uBC94\uD55C \uC218\uBE44\uC5D0
      \uBA38\uBB3C\uB800\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Fighter_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uCC45\uC784\uC9C0\uC2DC\uB294 \uAC70\uC8E0? \uADF8\uB7FC
      \uC800 \uC9C4\uC9DC \uB9C9 \uB098\uAC11\uB2C8\uB2E4? \uC9C0\uBA74 \uAC10\uB3C5\uB2D8
      \uD0D3\uC774\uC5D0\uC694!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Fighter_1
    ko: "\uCC45\uC784 \uD68C\uD53C\uC131 \uD0DC\uB3C4\uB85C \uD50C\uB808\uC774\uC758
      \uC815\uBC00\uD568\uC774 \uB5A8\uC5B4\uC838 \uD3C9\uBC94\uD55C \uACB0\uACFC\uC5D0
      \uADF8\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Ch_Instinct_002
    ko: "\uBB34\uACB0\uD568\uC744 \uD551\uACC4\uB85C \uC6D0\uCE59 \uB4A4\uC5D0 \uC228\uB294
      \uAC83\uC740 \uC218\uBE44\uAC00 \uC544\uB2C8\uB77C \uB3C4\uB9DD\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Bluffer_201
    ko: "\uB3C4\uB9DD\uC774\uB77C\uB2C8\uC694? \uC81C\uAC00 \uC5BC\uB9C8\uB098 \uB300\uB2E8\uD55C\uC9C0
      \uBAA8\uB974\uC2DC\uB098 \uBCF8\uB370, \uC774\uB7F0 \uB300\uC6B0 \uBC1B\uC73C\uBA74\uC11C
      \uB6F8 \uC774\uC720 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Bluffer_2
    ko: "\uBE44\uB09C\uC5D0 \uC0C1\uCC98\uBC1B\uC544 \uC790\uC874\uC2EC\uC774 \uAEBE\uC774\uC790
      \uAE30\uC5EC\uD560 \uC758\uC9C0\uB97C \uC644\uC804\uD788 \uC0C1\uC2E4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Wild_201
    ko: "\uC57C\uC131\uC774 \uC8FD\uC5C8\uB2E4\uB2C8... \uB9D0\uC774 \uB108\uBB34
      \uC2EC\uD558\uC2DC\uB124. \uADF8\uB0E5 \uC9C0\uCE68\uB300\uB85C \uD558\uB77C\uBA74\uC11C
      \uC65C \uB09C\uB9AC\uC57C?"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Wild_2
    ko: "\uBE44\uB17C\uB9AC\uC801\uC778 \uBE44\uB09C\uC5D0 \uD63C\uB780\uC744 \uB290\uB07C\uBA70
      \uBC18\uBC1C\uC2EC\uC73C\uB85C \uD3C9\uC18C\uBCF4\uB2E4 \uB354 \uC18C\uADF9\uC801\uC73C\uB85C
      \uC77C\uAD00\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Egoist_201
    ko: "\uB098\uBCF4\uACE0 \uAC81\uC7C1\uC774\uB77C\uACE0? \uC774 \uD300\uC5D0\uC11C
      \uB098\uB9CC\uD07C \uC644\uBCBD\uD55C \uC120\uC218\uAC00 \uC5B4\uB528\uC5B4?
      \uB354\uB7EC\uC6CC\uC11C \uC548 \uD574."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Egoist_2
    ko: "\uD3C9\uAC00\uB97C \uD6FC\uC190\uD558\uB294 \uAC10\uB3C5\uC758 \uD0DC\uB3C4\uC5D0
      \uBD84\uB178\uD558\uC5EC \uB3C5\uB2E8\uC801\uC73C\uB85C \uCF54\uD2B8\uB97C
      \uC774\uD0C8\uD558\uAC70\uB098 \uBC29\uAD00\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Fighter_201
    ko: "\uAC81\uC7C1\uC774\uB77C\uACE0\uC694? \uC81C\uAC00 \uC5BC\uB9C8\uB098 \uC774\uAE30\uACE0
      \uC2F6\uC5B4 \uD558\uB294\uC9C0 \uC54C\uBA74\uC11C \uC5B4\uB5BB\uAC8C \uADF8\uB7F0
      \uB9D0\uC744! \uB2E4 \uBE8F\uC5B4\uBC84\uB9B4 \uD14C\uB2C8\uAE4C \uC798 \uBCF4\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Fighter_2
    ko: "\uB3C4\uBC1C\uC5D0 \uD22C\uC7C1\uC2EC\uC774 \uBD88\uD0C0\uC62C\uB77C \uACF5\uD3EC\uB97C
      \uC774\uACA8\uB0B4\uACE0 \uACF5\uACA9\uC801\uC778 \uC2A4\uD2F8\uC744 \uC131\uACF5\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Ch_Instinct_003
    ko: "\uC9C0\uCE68\uC11C\uB97C \uBE8F\uC5B4 \uB358\uC9C0\uACE0 \uAC15\uC81C\uB85C
      1:1 \uC0C1\uD669\uC744 \uB9CC\uB4E4\uC5B4 \uD6C8\uB828\uD568."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Bluffer_301
    ko: "\uC624, \uB2E4\uB4E4 \uBCF4\uACE0 \uC788\uB098? \uC774 \uD615\uB2D8\uC774
      \uC9C0\uCE68\uC11C \uC5C6\uC774\uB3C4 \uC5B4\uB5BB\uAC8C \uCF54\uD2B8\uB97C
      \uC539\uC5B4\uBA39\uB294\uC9C0 \uBCF4\uC5EC\uC8FC\uC9C0!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Bluffer_3
    ko: "\uBCF4\uC5EC\uC8FC\uAE30\uC2DD \uB3D9\uC791\uC5D0 \uCE58\uC911\uD558\uC5EC
      \uC2E4\uC9C8\uC801\uC778 \uC218\uBE44 \uD6A8\uC728\uC774 \uB5A8\uC5B4\uC9C0\uACE0
      \uD3C9\uBC94\uD55C \uACB0\uACFC\uB97C \uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Wild_301
    ko: "\uC9C0\uCE68\uC11C\uACE0 \uBB50\uACE0 \uBAA8\uB974\uACA0\uB2E4! \uADF8\uB0E5
      \uB364\uBCBC!"
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Wild_3
    ko: "\uAC15\uC81C\uB41C \uC0C1\uD669\uC5D0\uC11C \uAC10\uC815\uC744 \uC870\uC808\uD558\uC9C0
      \uBABB\uD574 \uBC18\uCE59\uC744 \uBC94\uD558\uAC70\uB098 \uD750\uB984\uC744
      \uB193\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Egoist_301
    ko: "\uB098 \uB54C\uBB38\uC5D0 \uB2E4\uB4E4 \uACE0\uC0DD\uD558\uAC8C \uD560 \uC21C
      \uC5C6\uC9C0. \uB0B4 \uC2E4\uB825\uC774 \uC5B4\uB5A4\uC9C0 \uB611\uB611\uD788
      \uBCF4\uC5EC\uC8FC\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Egoist_3
    ko: "\uBCBC\uB791 \uB05D \uC0C1\uD669\uC5D0 \uB193\uC774\uC790 \uCD08\uC9D1\uC911\uB825\uC744
      \uBC1C\uD718\uD574 \uC644\uBCBD\uD55C \uC218\uBE44\uB97C \uC131\uACF5\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Desc_Fighter_301
    ko: "\uC544\uC9C1 \uADDC\uC728 \uC219\uC9C0\uAC00 \uC548 \uB410\uB294\uB370...
      \uC77C\uB2E8 \uBAB8\uBD80\uD130 \uB358\uC838\uBCF4\uACA0\uC9C0\uB9CC \uBA38\uB9BF\uC18D\uC774
      \uC815\uB9AC\uAC00 \uC548 \uB418\uC5B4 \uB2F5\uB2F5\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00015_Rs_Fighter_3
    ko: "\uAC11\uC791\uC2A4\uB7EC\uC6B4 \uC0C1\uD669 \uBCC0\uD654\uC5D0 \uB300\uC751\uD558\uC9C0
      \uBABB\uD558\uACE0 \uC6B0\uC655\uC88C\uC655\uD558\uB2E4 \uB3CC\uD30C\uB97C
      \uD5C8\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Discipline_001
    ko: "\uC0C1\uB300\uC758 \uD328\uC2A4 \uAE38\uC744 \uC608\uCE21\uD558\uB294 \uB2E8\uACC4\uB97C
      \uB118\uC5B4 \uC124\uACC4\uD558\uB294 \uACBD\uC9C0\uC5D0 \uC774\uB978 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Discipline_002
    ko: "\uC624\uB298 \uB2E8 \uD55C \uBC88\uC758 \uC2A4\uD2F8 \uC2E4\uD328\uB97C
      \uBD84\uC11D\uD558\uB290\uB77C \uCF54\uD2B8\uB97C \uB5A0\uB098\uC9C0 \uBABB\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Discipline_003
    ko: "\uC218\uBE44 \uC704\uCE58\uC640 \uAC01\uB3C4\uB97C 0.01\uCD08 \uB2E8\uC704\uB85C
      \uBCF5\uAE30\uD558\uBA70, \uC2E4\uD328\uB97C \uC790\uC2E0\uC758 \uC2DC\uC2A4\uD15C\uC5D0
      \uBC1C\uC0DD\uD55C \uC624\uB958\uB85C \uADDC\uC815\uD558\uACE0 \uC2A4\uC2A4\uB85C\uB97C
      \uC790\uCC45\uD558\uBA70 \uC625\uC8C4\uACE0 \uC788\uB294 \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00016_Ch_Discipline_001
    ko: "0.01\uCD08 \uC624\uCC28\uB294 \uAE30\uACC4\uB3C4 \uB0B8\uB2E4. \uC624\uCC28\uAE4C\uC9C0
      \uACC4\uC0B0\uD558\uB294 \uAC8C \uC9C4\uC9DC \uC124\uACC4\uB2C8 \uB0B4\uC77C\uC758
      \uBCC0\uC218\uB97C \uC900\uBE44\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Principled_101
    ko: "\uBCC0\uC218\uAE4C\uC9C0 \uACC4\uC0B0\uC5D0 \uB123\uC5B4\uC57C \uD55C\uB2E4\uB2C8...
      \uC81C\uAC00 \uB193\uCE5C \uBD80\uBD84\uC774 \uC788\uC5C8\uAD70\uC694. \uB0B4\uC77C\uC740
      \uADF8 \uC624\uCC28\uAE4C\uC9C0 \uC644\uBCBD\uD788 \uD1B5\uC81C\uD574 \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Principled_1
    ko: "\uC704\uB85C\uB97C \uC0C8 \uAC00\uC774\uB4DC\uB77C\uC778\uC73C\uB85C \uC0BC\uC544
      \uC790\uCC45\uC744 \uBA48\uCD94\uACE0 \uC9D1\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Guardian_101
    ko: "\uC81C \uC124\uACC4\uAC00 \uB6AB\uB838\uB2E4\uB294 \uAC74 \uD300\uC758 \uCD5C\uD6C4\uBC29\uC774
      \uB6AB\uB838\uB2E4\uB294 \uB73B\uC785\uB2C8\uB2E4. \uB0B4\uC77C\uC758 \uBCC0\uC218\uB97C
      \uC900\uBE44\uD558\uAE30\uC5D4 \uC624\uB298 \uC81C \uCC45\uC784\uC774 \uB108\uBB34
      \uD07D\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Guardian_1
    ko: "\uCC45\uC784\uAC10\uC774 \uB192\uC544 \uAC1C\uC778\uC801 \uC704\uB85C\uBCF4\uB2E4
      \uD300 \uBD80\uCC44\uAC10\uC744 \uC6B0\uC120\uC2DC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Tactician_101
    ko: "\uC624\uCC28 \uBC94\uC704 \uC124\uC815\uC774\uB77C... \uD655\uC2E4\uD788
      \uCCB4\uACC4\uC801\uC778 \uC811\uADFC\uC774\uAD70\uC694. \uAC10\uC815\uC801\uC73C\uB85C
      \uC790\uCC45\uD558\uAE30\uBCF4\uB2E4 \uB370\uC774\uD130\uB97C \uC218\uC815\uD558\uB294
      \uAC8C \uD6A8\uC728\uC801\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Tactician_1
    ko: "\uCCB4\uACC4\uC801 \uB17C\uB9AC\uB97C \uBC1B\uC790 \uAC10\uC815 \uC18C\uBAA8\uB97C
      \uBA48\uCD94\uACE0 \uC720\uC5F0\uD568\uC744 \uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Exemplary_101
    ko: "\uAC15\uBC15\uC774 \uC624\uD788\uB824 \uC800\uB97C \uAC09\uC544\uBA39\uACE0
      \uC788\uC5C8\uB2E4\uB2C8... \uC81C\uAC00 \uAE30\uC900\uC810\uC774 \uB418\uB824\uB2E4
      \uC2A4\uC2A4\uB85C\uB97C \uB9DD\uCE58\uACE0 \uC788\uC5C8\uAD70\uC694. \uD55C
      \uC218 \uBC30\uC6E0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Exemplary_1
    ko: "\uC790\uC2E0\uC774 \uBE44\uD6A8\uC728\uC801\uC784\uC744 \uAE68\uB2EB\uACE0
      \uBAA8\uBC94\uC774 \uB418\uAE30 \uC704\uD574 \uD2C0\uC744 \uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Ch_Discipline_002
    ko: "\uC2DC\uC2A4\uD15C\uC774 \uB108\uBB34 \uACBD\uC9C1\uB410\uB2E4. \uC644\uBCBD\uD55C
      \uC9C8\uC11C\uB294 \uC5C6\uC73C\uB2C8 \uAC15\uBC15\uC774 \uBC18\uC751 \uC18D\uB3C4\uB97C
      \uAC09\uC544\uBA39\uC74C\uC744 \uAE68\uB2EC\uC544\uB77C."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Principled_201
    ko: "\uC644\uBCBD\uD55C \uC9C8\uC11C\uAC00 \uC5C6\uB2E4\uBA74 \uC81C\uAC00 \uC9C0\uCF1C\uC628
      \uC6D0\uCE59\uB4E4\uC740 \uB2E4 \uBB61\uB2C8\uAE4C? \uC800\uB294 \uAE30\uACC4\uC801\uC778
      \uBC18\uC751\uC774 \uC815\uB2F5\uC774\uB77C\uACE0 \uBBFF\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Principled_2
    ko: "\uC6D0\uCE59\uC744 \uBD80\uC815\uB2F9\uD558\uC790 \uAC15\uD55C \uAC70\uBD80\uAC10\uC5D0
      \uC2E0\uB8B0\uAC00 \uC644\uC804\uD788 \uAE68\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Guardian_201
    ko: "\uC81C \uAC15\uBC15\uC774 \uC218\uBE44 \uB77C\uC778\uC744 \uB9DD\uCE58\uACE0
      \uC788\uB2E4\uB294 \uB9D0\uC500\uC785\uB2C8\uAE4C? \uC800\uB294 \uADF8\uC800
      \uC644\uBCBD\uD558\uAC8C \uD300\uC744 \uC218\uD638\uD558\uACE0 \uC2F6\uC5C8\uC744
      \uBFD0\uC778\uB370..."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Guardian_2
    ko: "\uC218\uD638 \uC758\uC9C0\uAC00 \uBE44\uD310\uBC1B\uC790 \uC9C0\uD0AC \uAC00\uCE58\uB97C
      \uC783\uC5C8\uB2E4\uBA70 \uC790\uAD34\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Tactician_201
    ko: "\uC9C8\uC11C\uAC00 \uC5C6\uB2E4\uB294 \uAC74 \uB3D9\uC758\uD558\uAE30 \uC5B4\uB835\uC9C0\uB9CC,
      \uC81C \uBC18\uC751 \uC18D\uB3C4\uAC00 \uB5A8\uC5B4\uC9C0\uACE0 \uC788\uB2E4\uB294
      \uC9C0\uC801\uC740 \uCC38\uACE0\uD560 \uAC00\uCE58\uAC00 \uC788\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Tactician_2
    ko: "\uBB34\uACC4\uD68D\uC744 \uACBD\uACC4\uD574 \uAC10\uB3C5 \uBE44\uD310 \uC911
      \uD6A8\uC728\uC131 \uBD80\uBD84\uB9CC \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Exemplary_201
    ko: "\uAC10\uB3C5\uB2D8\uC740 \uAD00\uB300\uD558\uC2DC\uC9C0\uB9CC \uC800\uB294
      \uC800\uB97C \uC6A9\uC11C\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uC81C\uAC00
      \uBB34\uB108\uC9C0\uBA74 \uD300\uC758 \uAE30\uAC15\uC740 \uB204\uAC00 \uC7A1\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Exemplary_2
    ko: "\uBD80\uCC44\uAC10\uC774 \uAC15\uD574 \uD0C0\uC778 \uC704\uB85C\uB97C \uB098\uD0DC\uD568
      \uBCC0\uBA85\uC73C\uB85C \uCE58\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Ch_Discipline_003
    ko: "\uC190\uBAA9\uC744 \uC7A1\uC544 \uB04C\uC5B4 \uCF54\uD2B8 \uBC16\uC73C\uB85C
      \uBC00\uC5B4\uB0B4\uACE0 \uC804\uB4F1\uC744 \uAEBC \uC5B4\uB460 \uC18D\uC5D0
      \uAC00\uB454\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Principled_301
    ko: "\uBD88\uC744 \uAEBC\uB3C4 \uC18C\uC6A9\uC5C6\uC2B5\uB2C8\uB2E4. \uC5B4\uB460
      \uC18D\uC5D0\uC11C \uC81C\uAC00 \uBC29\uAE08 \uBC94\uD55C \uC624\uB958\uC758
      \uADA4\uC801\uC744 100\uBC88 \uB354 \uBCF5\uAE30\uD558\uACE0 \uD1F4\uADFC\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Principled_3
    ko: "\uC6D0\uCE59 \uACE0\uC9D1\uC774 \uAC15\uD574 \uBB3C\uB9AC\uC801 \uC81C\uC9C0\uB9CC\uC73C\uB860
      \uBD84\uC11D\uC744 \uC548 \uBA48\uCDC4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uC774\uB807\uAC8C\uAE4C\uC9C0 \uD558\uC2DC\uB294
      \uAC74... \uC81C\uAC00 \uC26C\uC5B4\uC57C \uB0B4\uC77C \uD300\uC5D0 \uD574\uAC00
      \uC548 \uB41C\uB2E4\uB294 \uB73B\uC774\uACA0\uC8E0. \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Guardian_3
    ko: "\uAC15\uD55C \uAC1C\uC785\uC5D0 \uC9D1\uB2E8 \uC9C8\uC11C\uB97C \uC704\uD574
      \uACE0\uC9D1\uC744 \uAEBE\uACE0 \uC21C\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Tactician_301
    ko: "\uC544\uC9C1 \uBD84\uC11D \uB370\uC774\uD130 \uC815\uB9AC\uAC00 \uC548 \uB05D\uB0AC\uC2B5\uB2C8\uB2E4!
      \uC9C0\uAE08 \uB04A\uAE30\uBA74 \uB0B4\uC77C \uACC4\uD68D\uC5D0 \uCC28\uC9C8\uC774
      \uC0DD\uAE41\uB2C8\uB2E4. \uC81C\uBC1C \uBC29\uD574\uD558\uC9C0 \uB9C8\uC2ED\uC2DC\uC624!"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Tactician_3
    ko: "\uB3CC\uBC1C\uC801\uC778 \uAC15\uC81C \uC911\uB2E8\uC5D0 \uADF9\uC2EC\uD55C
      \uBD88\uC548\uC744 \uB290\uB07C\uACE0 \uD328\uB2C9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Exemplary_301
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8 \uCCB4\uBA74\uC744 \uBD10\uC11C\uB77C\uB3C4
      \uCD94\uD55C \uBAA8\uC2B5\uC740 \uADF8\uB9CC \uBCF4\uC774\uACA0\uC2B5\uB2C8\uB2E4.
      \uB0B4\uC77C\uC740 \uC644\uBCBD\uD55C \uBAA8\uC2B5\uC73C\uB85C \uBCF5\uADC0\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Exemplary_3
    ko: "\uCCB4\uBA74\uC744 \uC9C0\uD0A4\uAE30 \uC704\uD574 \uAC89\uC73C\uB85C\uB9CC
      \uC21C\uC751\uD558\uB294 \uCC99 \uCF54\uD2B8\uB97C \uB5B4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Bond_001
    ko: "\uC0C1\uB300\uC758 \uD328\uC2A4 \uAE38\uC744 \uC608\uCE21\uD558\uB294 \uB2E8\uACC4\uB97C
      \uB118\uC5B4 \uC124\uACC4\uD558\uB294 \uACBD\uC9C0\uC5D0 \uC774\uB978 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Bond_002
    ko: "\uC624\uB298 \uB2E8 \uD55C \uBC88\uC758 \uC2A4\uD2F8 \uC2E4\uD328\uB97C
      \uBD84\uC11D\uD558\uB290\uB77C \uCF54\uD2B8\uB97C \uB5A0\uB098\uC9C0 \uBABB\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Bond_003
    ko: "\uC218\uBE44 \uC704\uCE58\uC640 \uAC01\uB3C4\uB97C 0.01\uCD08 \uB2E8\uC704\uB85C
      \uBCF5\uAE30\uD558\uBA70, \uC2E4\uD328\uB97C \uC790\uC2E0\uC758 \uC2DC\uC2A4\uD15C\uC5D0
      \uBC1C\uC0DD\uD55C \uC624\uB958\uB85C \uADDC\uC815\uD558\uACE0 \uC2A4\uC2A4\uB85C\uB97C
      \uC790\uCC45\uD558\uBA70 \uC625\uC8C4\uACE0 \uC788\uB294 \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Bond_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00016_Ch_Bond_001
    ko: "0.01\uCD08 \uC624\uB958\uBCF4\uB2E4 \uD300\uC6D0\uC744 \uBD88\uC548\uD558\uAC8C
      \uB9CC\uB4DC\uB294 \uAC8C \uB354 \uD070 \uBB38\uC81C\uB2E4. \uAE30\uACC4\uAC00
      \uC544\uB2CC \uD300\uC6CC\uD06C\uAC00 \uD544\uC694\uD558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Kind_101
    ko: "\uC81C\uAC00 \uD300\uC6D0\uB4E4\uC744 \uBD88\uC548\uD558\uAC8C \uD588\uB2E4\uB2C8...
      \uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC81C \uC2E4\uC218\uAC00
      \uD300\uC758 \uC218\uBE44\uB9DD\uC744 \uD5D0\uAC81\uAC8C \uB9CC\uB4E4\uC5C8\uB2E4\uB294
      \uC0AC\uC2E4\uC774 \uB108\uBB34 \uAD34\uB86D\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Kind_1
    ko: "\uC9C0\uC801\uC5D0 \uBC18\uC751\uD558\uB098 \uC2E4\uC218\uC5D0 \uB300\uD55C
      \uBBF8\uC548\uD568 \uD0D3\uC5D0 \uACC4\uC18D \uC790\uCC45\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Loyal_101
    ko: "\uC81C\uAC00 \uD300\uC758 \uC870\uD654\uB97C \uAE68\uB728\uB9AC\uACE0 \uC788\uC5C8\uAD70\uC694.
      \uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uB0B4\uC77C\uC740 \uAC1C\uC778\uC758 \uBCF5\uAE30\uBCF4\uB2E4
      \uD300\uC758 \uC218\uBE44 \uB77C\uC778\uC744 \uB9DE\uCD94\uB294 \uB370 \uB354
      \uD5CC\uC2E0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Loyal_1
    ko: "\uC870\uD654\uB97C \uC6B0\uC120\uC2DC\uD574 \uD300\uC5D0 \uD574\uAC00 \uB41C\uB2E8
      \uC9C0\uC2DC\uB97C \uC218\uC6A9\uD558\uACE0 \uACE0\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Sincere_101
    ko: "\uD300\uC6CC\uD06C\uAC00 \uC6B0\uC120\uC774\uB77C\uB294 \uB9D0\uC500, \uBA85\uC2EC\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uC624\uB298 \uBCF5\uAE30\uB294 \uC5EC\uAE30\uC11C \uBA48\uCD94\uACE0 \uB0B4\uC77C
      \uC544\uCE68 \uC77C\uCC0D \uD300\uC6D0\uB4E4\uACFC \uD638\uD761\uC744 \uB9DE\uCD94\uB294
      \uB370 \uC9D1\uC911\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Sincere_1
    ko: "\uBB35\uBB35\uD55C \uD3B8\uC774\uB77C \uACF5\uB3D9\uCCB4 \uAC00\uCE58 \uC55E\uC138\uC6B4
      \uB17C\uB9AC\uC801 \uC124\uB4DD\uC5D0 \uC548\uC815\uAC10 \uC5BB\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Moodmaker_101
    ko: "\uC624, \uAC10\uB3C5\uB2D8... \uBC29\uAE08 \uBA58\uD2B8 \uC880 \uAC10\uB3D9\uC778\uB370\uC694?
      \uC54C\uC558\uC5B4\uC694. \uC644\uBCBD\uD55C \uAE30\uACC4\uBCF4\uB2E4 \uAC10\uB3C5\uB2D8
      \uC606\uC5D0 \uC788\uB294 \uB4E0\uB4E0\uD55C \uC870\uB825\uC790\uAC00 \uB420\uAC8C\uC694.
      \uAE30\uC6B4 \uB098\uB124\uC694!"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Moodmaker_1
    ko: "\uC870\uD654 \uC911\uC2DC\uB77C \uAC10\uC131 \uACA9\uB824\uC640 \uC2E0\uB8B0
      \uACE0\uBC31\uC5D0 \uD06C\uAC8C \uACE0\uBB34\uB3FC \uAE30\uBD84 \uBC18\uC804\uC2DC\uCF30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Ch_Bond_002
    ko: "\uC2DC\uC2A4\uD15C\uC774 \uC644\uBCBD\uD574\uC11C\uAC00 \uC544\uB2C8\uB77C
      \uB124\uAC00 \uB0B4 \uC606\uC5D0 \uC788\uC744 \uAC70\uB780 \uBBFF\uC74C\uC73C\uB85C
      \uC4F0\uB294 \uAC70\uB2C8 \uC790\uCC45\uD558\uC9C0 \uB9C8\uB77C."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Kind_201
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uBBFF\uC74C\uC774 \uB108\uBB34 \uBB34\uAC81\uAC8C
      \uB290\uAEF4\uC838\uC694. \uC774\uB807\uAC8C \uBD80\uC871\uD55C \uC800\uB97C
      \uBBFF\uC5B4\uC8FC\uC2DC\uB294\uB370, \uACE0\uC791 0.01\uCD08 \uCC28\uC774\uB85C
      \uC2E4\uC218\uB97C \uD558\uB2E4\uB2C8 \uC81C \uC790\uC2E0\uC774 \uB108\uBB34
      \uC2EB\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Kind_2
    ko: "\uD3B8\uC548\uD568\uC744 \uCD94\uAD6C\uD574 \uC804\uD3ED\uC801 \uC2E0\uB8B0\uAC00
      \uBB34\uAC70\uC6B4 \uC555\uBC15\uC73C\uB85C \uBCC0\uC9C8\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Loyal_201
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uBBFF\uC74C\uC5D0 \uBCF4\uB2F5\uD558\uB294 \uC720\uC77C\uD55C
      \uAE38\uC740 \uC81C\uAC00 \uC644\uBCBD\uD574\uC9C0\uB294 \uAC83\uBFD0\uC785\uB2C8\uB2E4.
      \uC870\uAE08\uB9CC \uB354 \uC2DC\uAC04\uC744 \uC8FC\uC2ED\uC2DC\uC624. \uC644\uBCBD\uD55C
      \uBAA8\uC2B5\uC73C\uB85C \uC606\uC5D0 \uC11C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Loyal_2
    ko: "\uC2E0\uB8B0\uB294 \uAD73\uAC74\uD558\uB098 \uC790\uC2E0\uC758 \uC624\uB958\uB97C
      \uB454 \uCC44 \uC11C\uB294 \uAC78 \uC2A4\uC2A4\uB85C \uC6A9\uB0A9 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Sincere_201
    ko: "\uBBFF\uC74C\uB9CC\uC73C\uB85C\uB294 \uC624\uB958\uB97C \uC218\uC815\uD560
      \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uC800\uB294 \uAFB8\uC900\uD788 \uBD84\uC11D\uD574\uC11C
      \uADFC\uAC70\uB97C \uB9CC\uB4E4\uC5B4\uC57C \uC548\uC2EC\uC774 \uB429\uB2C8\uB2E4.
      \uC81C \uB178\uB825\uC744 \uBA48\uCD94\uC9C0 \uB9C8\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Sincere_2
    ko: "\uAFB8\uC900\uD568\uC73C\uB85C \uC99D\uBA85\uD558\uB824 \uC815\uC131\uC801
      \uC811\uADFC\uC744 \uC624\uD788\uB824 \uC131\uAC00\uC2E0 \uBC29\uD574\uB85C
      \uC5EC\uACBC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Moodmaker_201
    ko: "\uD300\uC6CC\uD06C\uB77C\uB2C8\uC694... \uC81C\uAC00 \uD300\uC744 \uB9DD\uCE58\uB824\uACE0
      \uC774\uB7EC\uB294 \uAC8C \uC544\uB2C8\uC796\uC544\uC694. \uADF8\uB807\uAC8C
      \uB9D0\uC500\uD558\uC2DC\uBA74 \uC81C \uC9C4\uC2EC\uC774 \uB108\uBB34 \uC65C\uACE1\uB418\uB294
      \uAC83 \uAC19\uC544 \uC11C\uC6B4\uD574\uC694."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Moodmaker_2
    ko: "\uB178\uB825\uC774 \uD300\uC5D0 \uD574\uB780 \uD3C9\uAC00\uC5D0 \uC815\uC11C\uC801
      \uD070 \uD0C0\uACA9 \uC785\uACE0 \uB9C8\uC74C\uC744 \uB2EB\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Ch_Bond_003
    ko: "\uBD84\uC11D \uB178\uD2B8\uB97C \uB36E\uC5B4\uBC84\uB9AC\uACE0 \uC5B4\uAE68\uC5D0
      \uD314\uC744 \uB458\uB7EC \uC5B5\uC9C0\uB85C \uC774\uB04C\uACE0 \uCF54\uD2B8
      \uBC16 \uB9E4\uC810\uC73C\uB85C \uD5A5\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uB3C4 \uBC30\uAC00 \uCD9C\uCD9C\uD558\uC168\uB098 \uBCF4\uB124\uC694.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4, \uC624\uB298\uC740 \uADF8\uB9CC\uD558\uACE0
      \uB9DB\uC788\uB294 \uAC70 \uBA39\uC73C\uB7EC \uAC00\uC694. \uAC19\uC774 \uAC00\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Kind_3
    ko: "\uBD80\uB4DC\uB7EC\uC6B4 \uAC1C\uC785\uC5D0 \uC720\uB300\uAC10 \uD655\uC778\uD558\uBA70
      \uAC15\uBC15\uC5D0\uC11C \uC544\uC8FC \uC790\uC5F0\uC2A4\uB808 \uBC97\uC5B4\uB0AC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Loyal_301
    ko: "\uC774\uB7EC\uC9C0 \uB9C8\uC2ED\uC2DC\uC624, \uAC10\uB3C5\uB2D8! \uC544\uC9C1
      \uC81C \uD560 \uC77C\uC744 \uB2E4 \uB9C8\uCE58\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4.
      \uAC10\uB3C5\uB2D8\uAED8 \uC644\uBCBD\uD55C \uB370\uC774\uD130\uB97C \uBC14\uCE58\uAE30
      \uC804\uAE4C\uC9C4 \uBABB \uB098\uAC11\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Loyal_3
    ko: "\uC644\uC218 \uC804 \uCF54\uD2B8 \uB5A0\uB098\uB294 \uAC78 \uBC30\uC2E0\uC73C\uB85C
      \uC5EC\uACA8 \uD6C8\uB828 \uC911\uB2E8\uC744 \uAC15\uD558\uAC8C \uC800\uD56D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Sincere_301
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8 \uCCB4\uBA74\uC744 \uC0DD\uAC01\uD574\uC11C
      \uC77C\uB2E8 \uB098\uAC00\uC8E0. \uD558\uC9C0\uB9CC \uB0B4\uC77C \uC0C8\uBCBD\uC5D0
      \uB204\uAD6C\uBCF4\uB2E4 \uBA3C\uC800 \uB098\uC640\uC11C \uB0A8\uC740 \uBD84\uC11D\uC744
      \uB05D\uB0BC \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Sincere_3
    ko: "\uC131\uC2E4\uD568\uC774 \uAC15\uBC15\uC73C\uB85C \uC791\uC6A9\uD574 \uB05D\uAE4C\uC9C0
      \uB9C8\uC74C\uC744 \uB193\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Moodmaker_301
    ko: "\uB9E4\uC810\uC774\uC694? \uAC70\uAE30 \uB5A1\uBCF6\uC774 \uB9DB\uC788\uB294\uB370!
      \uC88B\uC544\uC694, \uAC10\uB3C5\uB2D8\uC774 \uC3D8\uC2DC\uB294 \uAC70\uC8E0?
      \uBD84\uC704\uAE30 \uD655 \uAE68\uAC8C \uBD84\uC11D\uC740 \uBB34\uC2A8 \uBD84\uC11D\uC785\uB2C8\uAE4C!"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Moodmaker_3
    ko: "\uAC00\uBCBC\uC6B4 \uAC1C\uC785\uC740 \uB530\uB974\uB098 \uC6D0\uC778 \uD574\uACB0\uC774
      \uC5C6\uC5B4 \uBD88\uC548\uC744 \uB0A8\uACBC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Cold_001
    ko: "\uC0C1\uB300\uC758 \uD328\uC2A4 \uAE38\uC744 \uC608\uCE21\uD558\uB294 \uB2E8\uACC4\uB97C
      \uB118\uC5B4 \uC124\uACC4\uD558\uB294 \uACBD\uC9C0\uC5D0 \uC774\uB978 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Cold_002
    ko: "\uC624\uB298 \uB2E8 \uD55C \uBC88\uC758 \uC2A4\uD2F8 \uC2E4\uD328\uB97C
      \uBD84\uC11D\uD558\uB290\uB77C \uCF54\uD2B8\uB97C \uB5A0\uB098\uC9C0 \uBABB\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Cold_003
    ko: "\uC218\uBE44 \uC704\uCE58\uC640 \uAC01\uB3C4\uB97C 0.01\uCD08 \uB2E8\uC704\uB85C
      \uBCF5\uAE30\uD558\uBA70, \uC2E4\uD328\uB97C \uC790\uC2E0\uC758 \uC2DC\uC2A4\uD15C\uC5D0
      \uBC1C\uC0DD\uD55C \uC624\uB958\uB85C \uADDC\uC815\uD558\uACE0 \uC2A4\uC2A4\uB85C\uB97C
      \uC790\uCC45\uD558\uBA70 \uC625\uC8C4\uACE0 \uC788\uB294 \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Cold_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00016_Ch_Cold_001
    ko: "0.01\uCD08 \uC624\uCC28\uC5D0 \uB9E4\uBAB0\uB418\uB294 \uAC74 \uC790\uC6D0
      \uB0AD\uBE44\uB2C8, \uB2E4\uC74C \uACBD\uAE30 \uBCC0\uC218\uB97C \uC2DC\uBBAC\uB808\uC774\uC158\uD558\uB294
      \uAC8C \uD6A8\uC728\uC801\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Planner_101
    ko: "\uC790\uC6D0 \uB0AD\uBE44... \uD655\uC2E4\uD788 \uADF8\uB807\uAD70\uC694.
      \uACFC\uAC70\uC758 \uC624\uB958\uC5D0 \uB9E4\uBAB0\uB418\uAE30\uBCF4\uB2E4
      \uBBF8\uB798\uC758 \uACBD\uC6B0\uC758 \uC218\uB97C \uD655\uC7A5\uD558\uB294
      \uAC83\uC774 \uB354 \uD070 \uADF8\uB9BC\uC744 \uADF8\uB9AC\uB294 \uBC95\uC774\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Planner_1
    ko: "\uC548\uBAA9 \uAE38\uC5B4 \uAC10\uC815\uBCF4\uB2E4 \uD6A8\uC728 \uC608\uCE21
      \uB17C\uB9AC\uC5D0 \uC124\uB4DD\uB418\uC5B4 \uC790\uCC45 \uC989\uC2DC \uBA48\uCDC4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Opportunist_101
    ko: "\uD6A8\uC728\uC801\uC778 \uAC74 \uC54C\uACA0\uC9C0\uB9CC, \uC774 \uC624\uB958\uB97C
      \uD574\uACB0\uD558\uC9C0 \uBABB\uD558\uBA74 \uC81C \uAC00\uCE58\uAC00 \uB5A8\uC5B4\uC9D1\uB2C8\uB2E4.
      \uB2F9\uC7A5\uC758 \uC190\uC2E4\uC744 \uBA54\uC6CC\uC57C \uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Opportunist_1
    ko: "\uC624\uC810\uC774 \uB0B4 \uD3C9\uAC00\uC5D0 \uBBF8\uCE60 \uC545\uC601\uD5A5\uC744
      \uC6B0\uB824\uD574 \uD3EC\uAE30\uD558\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Cunning_101
    ko: "\uB17C\uB9AC\uB294 \uC88B\uC9C0\uB9CC \uADF8\uAC74 \uB204\uAD6C\uB098 \uD560
      \uC218 \uC788\uB294 \uB9D0\uC774\uC8E0. \uAC10\uB3C5\uB2D8\uC740 \uC81C\uAC00
      \uC774 \uC0C1\uD669\uC744 \uC774\uC6A9\uD574 \uBB34\uC5B8\uAC00\uB97C \uAFB8\uBBF8\uACE0
      \uC788\uB2E4\uACE0\uB294 \uC0DD\uAC01 \uC548 \uD558\uC2DC\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Cunning_1
    ko: "\uC2EC\uB9AC\uC804\uC744 \uC990\uACA8 \uB17C\uB9AC\uC801 \uC9C0\uC801\uC744
      \uC9C0\uB8E8\uD55C \uAC04\uC12D\uC73C\uB85C \uC5EC\uACBC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Believer_101
    ko: "\uD6A8\uC728\uC758 \uBB38\uC81C\uAC00 \uC544\uB2D9\uB2C8\uB2E4. \uC81C\uAC00
      \uD2C0\uB838\uB2E4\uB294 \uAC83, \uADF8 \uBCF8\uC9C8\uC801\uC778 \uC624\uB958\uB97C
      \uD574\uACB0\uD558\uC9C0 \uBABB\uD558\uBA74 \uC804 \uD55C \uBC1C\uC790\uAD6D\uB3C4
      \uB098\uAC08 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Believer_1
    ko: "\uB0B4 \uB17C\uB9AC\uAC00 \uD655\uACE0\uD574 \uC790\uC6D0 \uD6A8\uC728 \uC7A3\uB300\uC5D0\uB3C4
      \uC2E0\uB150\uC744 \uC548 \uAD7D\uD614\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Ch_Cold_002
    ko: "\uC644\uBCBD\uD55C \uC9C8\uC11C\uB780 \uCC29\uAC01\uC774\uB2E4. \uCF54\uD2B8\uB294
      \uC0DD\uBB3C\uC774\uB2C8 \uBB34\uB108\uC9C0\uAE30 \uC804\uC5D0 \uC0C8 \uD310\uC744
      \uC9DC\uB77C."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Planner_201
    ko: "\uC720\uB9AC\uC131\uC774\uB77C\uB2C8\uC694. \uC81C \uC2DC\uC2A4\uD15C\uC740
      \uAC00\uC7A5 \uACAC\uACE0\uD55C \uC124\uACC4\uC600\uC2B5\uB2C8\uB2E4. \uBC84\uB9AC\uB294
      \uAC83\uB9CC\uC774 \uB2A5\uC0AC\uB294 \uC544\uB2D9\uB2C8\uB2E4. \uBCF4\uC644\uC774
      \uD544\uC694\uD560 \uBFD0\uC774\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Planner_2
    ko: "\uAD6C\uC870 \uBD80\uC815\uC5D0 \uBC18\uAC10\uC740 \uC0DD\uAE30\uB098 \uB17C\uB9AC
      \uC9C0\uC801 \uC790\uCCB4\uB294 \uB0B4\uBD80\uC801\uC73C\uB85C \uAC80\uD1A0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Opportunist_201
    ko: "\uC720\uB9AC\uC131... \uB9DE\uC2B5\uB2C8\uB2E4. \uBB34\uB108\uC9C8 \uC2DC\uC2A4\uD15C\uC5D0
      \uC9D1\uCC29\uD558\uB294 \uAC83\uB9CC\uD07C \uC5B4\uB9AC\uC11D\uC740 \uAC74
      \uC5C6\uC8E0. \uAC00\uC7A5 \uC720\uB9AC\uD55C \uC0C8 \uC9C0\uC810\uC73C\uB85C
      \uC774\uB3D9\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Opportunist_2
    ko: "\uC774\uB4DD\uC774 \uB418\uB294 \uBC29\uD5A5\uC73C\uB85C \uAC08\uC544\uD0C0\uB77C\uB294
      \uC870\uC5B8\uC5D0 \uC989\uAC01 \uBC18\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Cunning_201
    ko: "\uC0C8 \uD310\uC744 \uC9DC\uB77C... \uC7AC\uBBF8\uC788\uB294 \uC81C\uC548\uC774\uB124\uC694.
      \uD558\uC9C0\uB9CC \uC774 \uBB34\uB108\uC9C4 \uC2DC\uC2A4\uD15C\uC870\uCC28
      \uC0C1\uB300\uB97C \uC18D\uC77C \uBBF8\uB07C\uAC00 \uB420 \uC218 \uC788\uB2E4\uB294
      \uAC78 \uC78A\uC9C0 \uB9C8\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Cunning_2
    ko: "\uC2E4\uD328\uB3C4 \uC2EC\uB9AC\uC804 \uB3C4\uAD6C\uB85C \uC4F0\uB824 \uD558\uBA70
      \uAC10\uB3C5 \uC9C0\uC2DC\uB97C \uC548 \uB530\uB790\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Believer_201
    ko: "\uBC84\uB9AC\uB77C\uACE0\uC694? \uC81C \uC2DC\uC2A4\uD15C\uC774 \uC720\uB9AC\uC131\uC778\uC9C0
      \uC544\uB2CC\uC9C0\uB294 \uC81C\uAC00 \uC99D\uBA85\uD569\uB2C8\uB2E4. \uD0C0\uC778\uC758
      \uD3C9\uAC00\uB85C \uC81C \uC2E0\uB150\uC744 \uD754\uB4E4 \uC21C \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Believer_2
    ko: "\uBFCC\uB9AC\uAC00 \uB2E8\uB2E8\uD574 \uBE44\uD310\uC5D0 \uCDA9\uB3CC\uD558\uBA70
      \uC790\uC2E0\uC758 \uBC29\uC2DD\uC744 \uACE0\uC218\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Ch_Cold_003
    ko: "\uD0DC\uBE14\uB9BF\uC774\uB098 \uB178\uD2B8\uB97C \uB09A\uC544\uCC44 \uB358\uC838
      \uBC15\uC0B4 \uB0B4\uACE0 \uCC28\uAC00\uC6B4 \uB208\uBE5B\uC73C\uB85C \uC751\uC2DC\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Planner_301
    ko: "\uC81C \uBAA8\uB4E0 \uB370\uC774\uD130\uAC00... \uC9C0\uAE08 \uBB34\uC2A8
      \uC9D3\uC744 \uD558\uC2E0 \uAC81\uB2C8\uAE4C? \uC774\uB807\uAC8C \uD310\uC744
      \uAE68\uBC84\uB9AC\uBA74 \uB2E4\uC74C \uC124\uACC4\uB294 \uBD88\uAC00\uB2A5\uD569\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Planner_3
    ko: "\uB17C\uB9AC \uD1A0\uB300\uB97C \uD30C\uAD34\uB2F9\uD558\uC790 \uD1B5\uC81C\uAD8C
      \uC0C1\uC2E4 \uACF5\uD3EC\uC640 \uBD84\uB178\uC5D0 \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Opportunist_301
    ko: "\uD310\uC744 \uC5CE\uB294\uB2E4\uACE0\uC694? \uC774\uAC74 \uC81C\uAC8C \uAC00\uC7A5
      \uBD88\uB9AC\uD55C \uC0C1\uD669\uC785\uB2C8\uB2E4. \uB300\uC548\uB3C4 \uC5C6\uC774
      \uACB0\uACFC\uBB3C\uC744 \uBD80\uC218\uBA74 \uC800\uBCF4\uACE0 \uC5B4\uCA4C\uB77C\uB294
      \uAC81\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Opportunist_3
    ko: "\uC720\uB9AC\uD55C \uD0C0\uC774\uBC0D\uC5D0 \uC815\uBCF4 \uACF5\uBC31\uC774
      \uAC15\uC81C\uB85C \uC0DD\uAE30\uC790 \uC644\uBCBD\uD788 \uB300\uC751 \uB2A5\uB825\uC744
      \uC783\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Cunning_301
    ko: "\uD654\uB048\uD558\uC2DC\uB124\uC694. \uC88B\uC2B5\uB2C8\uB2E4. \uB9D0\uB85C
      \uD558\uB294 \uD6C8\uACC4\uBCF4\uB2E4 \uC774\uB7F0 \uADF9\uB2E8\uC801\uC778
      \uC0C1\uD669\uC774 \uD6E8\uC52C \uC601\uAC10\uC744 \uC8FC\uAC70\uB4E0\uC694."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Cunning_3
    ko: "\uD30C\uACA9\uC801 \uD589\uB3D9\uC744 \uC5ED\uC774\uC6A9\uD574 \uC2EC\uB9AC\uC801
      \uC6B0\uC704\uC640 \uB3D9\uAE30\uBD80\uC5EC\uB97C \uC5BB\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Believer_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uACB0\uB860\uC774 \uADF8\uAC83\uC774\uB77C\uBA74
      \uB530\uB974\uACA0\uC2B5\uB2C8\uB2E4. \uD30C\uAD34\uB41C \uACF3\uC5D0\uC11C\uBD80\uD130
      \uB2E4\uC2DC \uC81C \uB17C\uB9AC\uB97C \uC138\uC6B0\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Believer_3
    ko: "\uB0C9\uC815\uD568 \uB355\uC5D0 \uADF9\uB2E8\uC801 \uAC1C\uC785\uB3C4 \uB17C\uB9AC\uC801
      \uACB0\uB860\uC73C\uB85C \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Instinct_001
    ko: "\uC0C1\uB300\uC758 \uD328\uC2A4 \uAE38\uC744 \uC608\uCE21\uD558\uB294 \uB2E8\uACC4\uB97C
      \uB118\uC5B4 \uC124\uACC4\uD558\uB294 \uACBD\uC9C0\uC5D0 \uC774\uB978 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Instinct_002
    ko: "\uC624\uB298 \uB2E8 \uD55C \uBC88\uC758 \uC2A4\uD2F8 \uC2E4\uD328\uB97C
      \uBD84\uC11D\uD558\uB290\uB77C \uCF54\uD2B8\uB97C \uB5A0\uB098\uC9C0 \uBABB\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Instinct_003
    ko: "\uC218\uBE44 \uC704\uCE58\uC640 \uAC01\uB3C4\uB97C 0.01\uCD08 \uB2E8\uC704\uB85C
      \uBCF5\uAE30\uD558\uBA70, \uC2E4\uD328\uB97C \uC790\uC2E0\uC758 \uC2DC\uC2A4\uD15C\uC5D0
      \uBC1C\uC0DD\uD55C \uC624\uB958\uB85C \uADDC\uC815\uD558\uACE0 \uC2A4\uC2A4\uB85C\uB97C
      \uC790\uCC45\uD558\uBA70 \uC625\uC8C4\uACE0 \uC788\uB294 \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Instinct_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00016_Ch_Instinct_001
    ko: "\uC124\uACC4\uB3C4 \uB300\uC2E0 \uCF54\uB05D\uC744 \uBBFF\uC5B4\uB77C. 0.01\uCD08
      \uC624\uCC28\uB294 \uC624\uB958\uAC00 \uC544\uB2C8\uB77C \uB124 \uC57C\uC131\uC758
      \uC694\uB3D9\uC77C \uBFD0\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Bluffer_101
    ko: "\uC81C \uC2EC\uC7A5 \uBC15\uB3D9\uC774 \uB354 \uBE60\uB974\uB2E4\uB294 \uB9D0,
      \uAF64 \uADFC\uC0AC\uD558\uB124\uC694. \uB9DE\uC544\uC694, \uC774\uB7F0 \uC2DC\uC2DC\uD55C
      \uC22B\uC790\uB4E4\uC740 \uC81C \uCC9C\uC7AC\uC801\uC778 \uAC10\uAC01\uC744
      \uB2F4\uC544\uB0B4\uAE30\uC5D4 \uB108\uBB34 \uC881\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Bluffer_1
    ko: "\uC2E4\uC218\uB97C \uC7AC\uB2A5 \uBD84\uCD9C\uB85C \uD3EC\uC7A5\uD574\uC8FC\uC790
      \uAE30\uC138 \uD68C\uBCF5\uD558\uBA70 \uD654\uB824\uD55C \uD50C\uB808\uC774\uB97C
      \uC900\uBE44\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Wild_101
    ko: "\uD53C\uAC00 \uB053\uB294 \uBC29\uD5A5... \uADF8\uB7EC\uAC8C\uC694. \uBA38\uB9AC\uB97C
      \uC4F8\uC218\uB85D \uBAB8\uC774 \uBB34\uAC70\uC6CC\uC9C0\uB294 \uAE30\uBD84\uC774\uC5C8\uB294\uB370,
      \uC774\uC81C\uC57C \uC228\uD1B5\uC774 \uC880 \uD2B8\uC774\uB294 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Wild_1
    ko: "\uC124\uACC4 \uC871\uC1C4 \uD480\uC5B4\uC8FC\uB294 \uC870\uC5B8\uC5D0 \uC0DD\uB3D9\uAC10
      \uB418\uCC3E\uC73C\uBA70 \uB3D9\uBB3C\uC801\uC778 \uC218\uBE44 \uAC10\uAC01
      \uD68C\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Egoist_101
    ko: "\uAC10\uAC01\uB3C4 \uC911\uC694\uD558\uC8E0. \uD558\uC9C0\uB9CC \uC644\uBCBD\uD55C
      \uC2DC\uC2A4\uD15C\uC774\uC57C\uB9D0\uB85C \uC800\uB97C \uAC00\uC7A5 \uB3CB\uBCF4\uC774\uAC8C
      \uB9CC\uB4ED\uB2C8\uB2E4. \uBD88\uD655\uC2E4\uC131\uC5D0 \uC800\uB97C \uB358\uC9C0\uACE0
      \uC2F6\uC9C4 \uC54A\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Egoist_1
    ko: "\uC644\uBCBD\uC744 \uCD94\uAD6C\uD574 \uBCF8\uB2A5\uC5D0 \uC758\uC874\uD558\uB780
      \uC870\uC5B8\uC744 \uBB34\uC2DC\uD558\uACE0 \uACE0\uC9D1\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Fighter_101
    ko: "\uD53C\uAC00 \uB053\uAE34 \uD558\uB294\uB370... \uC774 \uC624\uB958\uB97C
      \uC9D3\uBC1F\uC9C0 \uBABB\uD558\uBA74 \uBD84\uD574\uC11C \uC7A0\uC774 \uC548
      \uC62C \uAC83 \uAC19\uC544\uC694. \uC77C\uB2E8 \uC774 \uC22B\uC790\uB4E4\uBD80\uD130
      \uC774\uAE30\uACE0 \uC62C\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Fighter_1
    ko: "\uC2E4\uD328 \uB370\uC774\uD130\uB97C \uC815\uBCF5 \uB300\uC0C1\uC73C\uB85C
      \uC5EC\uACA8 \uBD80\uB4DC\uB7EC\uC6B4 \uD574\uBC29\uC73C\uB860 \uACE0\uC9D1
      \uC548 \uAEBE\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Ch_Instinct_002
    ko: "\uC218\uD559 \uBB38\uC81C \uD480 \uB4EF \uBA38\uB9AC \uAD74\uB9AC\uB2C8
      \uC0C1\uB300\uC5D0\uAC8C \uBA39\uD788\uB294 \uAC70\uB2E4. \uD55C \uBC88 \uB6AB\uB838\uB2E4\uACE0
      \uAC81\uBA39\uC744 \uAC70\uBA74 \uB2F9\uC7A5 \uB54C\uB824\uCCD0\uB77C."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Bluffer_201
    ko: "\uC218\uD559\uC790\uB77C\uB2C8\uC694, \uAC10\uB3C5\uB2D8. \uC81C\uAC00 \uC5BC\uB9C8\uB098
      \uACF5\uC744 \uB4E4\uC5EC \uD300\uC744 \uB9CC\uB4E4\uACE0 \uC788\uB294\uB370...
      \uADF8\uB7F0 \uC2DD\uC73C\uB85C \uD3C4\uD558\uD558\uC2DC\uBA74 \uB354 \uC774\uC0C1
      \uBCF4\uC5EC\uC904 \uAC8C \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Bluffer_2
    ko: "\uB178\uB825\uC744 \uB3C4\uB9DD\uC73C\uB85C \uCE58\uBD80\uD558\uC790 \uC790\uC874\uC2EC\uC744
      \uB2E4\uCE58\uACE0 \uB9C8\uC74C\uC744 \uB2EB\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Wild_201
    ko: "\uC228\uB294 \uAC8C \uC544\uB2C8\uC5D0\uC694. \uC798\uD558\uACE0 \uC2F6\uC5B4\uC11C
      \uADF8\uB7F0 \uAC74\uB370... \uC65C \uADF8\uB807\uAC8C \uBB34\uC12D\uAC8C \uB9D0\uC500\uD558\uC138\uC694?
      \uBD84\uC11D\uD558\uB294 \uAC8C \uC798\uBABB\uB41C \uAC74 \uC544\uB2C8\uC796\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Wild_2
    ko: "\uAC70\uCE5C \uB3C4\uBC1C\uC5D0 \uC57C\uC131 \uC548 \uAE68\uC5B4\uB098\uACE0
      \uC704\uCD95\uB418\uC5B4 \uC815\uC11C\uC801 \uD070 \uD63C\uB780\uB9CC \uACC4\uC18D
      \uACAA\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Egoist_201
    ko: "\uC81C \uD55C\uACC4\uB77C\uACE0\uC694? \uC81C \uAC00\uCE58\uB97C \uBAA8\uB974\uB294
      \uD300\uC5D0 \uB0A8\uC544\uC788\uC744 \uC774\uC720\uB294 \uC5C6\uC2B5\uB2C8\uB2E4.
      \uB354 \uC774\uC0C1 \uC800\uB97C \uBAA8\uC695\uD558\uC9C0 \uB9C8\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Egoist_2
    ko: "\uC758\uC2EC \uBC1C\uC5B8 \uADF9\uB3C4 \uC608\uBBFC \uBC18\uC751\uD574 \uC790\uC544
      \uBCF4\uD638\uB97C \uCD5C\uC6B0\uC120\uD558\uC5EC \uCF54\uD2B8 \uC774\uD0C8\uC744
      \uD0DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Fighter_201
    ko: "\uACF5\uD3EC? \uD55C\uACC4? \uC81C\uAC00 \uADF8\uB534 \uB2E8\uC5B4\uB791
      \uC5B4\uC6B8\uB9B0\uB2E4\uACE0 \uC0DD\uAC01\uD558\uC138\uC694? \uB2F9\uC7A5
      \uCF54\uD2B8 \uBE44\uC6B0\uC138\uC694. \uB204\uAC00 \uC9C4\uC9DC \uC8FC\uC778\uC778\uC9C0
      \uBAB8\uC73C\uB85C \uBCF4\uC5EC\uC904 \uD14C\uB2C8\uAE4C!"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Fighter_2
    ko: "\uD22C\uC9C0\uB97C \uC758\uC2EC\uD558\uB294 \uB3C4\uBC1C\uC5D0 \uBD88\uBD99\uC5B4
      \uD3ED\uBC1C\uC801\uC778 \uACF5\uACA9\uC131\uC744 \uD68C\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Ch_Instinct_003
    ko: "\uB178\uD2B8 \uC704\uC5D0 \uBC1C\uC744 \uC62C\uB9AC\uACE0 \uACF5\uC744 \uAC00\uB85C\uCC44\uB294
      \uC2A4\uD15D\uC744 \uC120\uBCF4\uC774\uBA70 \uBE44\uC6C3\uB4EF \uC190\uAC00\uB77D\uC744
      \uAE4C\uB531\uC778\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Bluffer_301
    ko: "\uC624, \uBC29\uAE08 \uADF8 \uB3D9\uC791 \uAF64 \uD799\uD55C\uB370\uC694?
      \uC800\uB3C4 \uB9C8\uC74C\uB9CC \uBA39\uC73C\uBA74 \uADF8 \uC815\uB3C4\uB294
      \uD558\uC8E0. \uADFC\uB370 \uC81C \uB178\uD2B8\uC5D0 \uBC1C\uC790\uAD6D \uB0A8\uC740
      \uAC74 \uC5B4\uB5BB\uAC8C \uCC45\uC784\uC9C0\uC2E4 \uAC74\uAC00\uC694?"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Bluffer_3
    ko: "\uD37C\uD3EC\uBA3C\uC2A4\uC5D0 \uAD00\uC2EC\uC740 \uBCF4\uC774\uB098 \uBCF8\uC9C8\uBCF4\uB2E8
      \uD488\uC704\uB098 \uC0C1\uD669\uC5D0 \uB354 \uC9D1\uCC29\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Wild_301
    ko: "\uBC29\uAE08 \uADF8 \uC6C0\uC9C1\uC784... \uB208\uC73C\uB85C\uB294 \uC548
      \uBCF4\uC774\uB294\uB370 \uBAB8\uC774 \uBA3C\uC800 \uC6C0\uCC14\uD588\uC5B4\uC694.
      \uC2E0\uAE30\uD558\uAE34 \uD55C\uB370, \uC544\uC9C1 \uC774 \uAC01\uB3C4 \uBB38\uC81C\uB294
      \uD574\uACB0\uC774 \uC548 \uB410\uAC70\uB4E0\uC694."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Wild_3
    ko: "\uC2E0\uCCB4\uC801 \uC790\uADF9\uC5D0 \uBC18\uC751\uC740 \uD588\uC73C\uB098
      \uBD84\uC11D\uC801 \uC0AC\uACE0 \uAD00\uC131\uC774 \uAC15\uD574 \uC804\uD658\uC774
      \uB2A6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Egoist_301
    ko: "\uC81C \uB17C\uB9AC\uB97C \uD798\uC73C\uB85C \uB204\uB974\uC2DC\uACA0\uB2E4?
      \uC7AC\uBBF8\uC788\uB124\uC694. \uAC10\uB3C5\uB2D8\uC758 \uADF8 \uBCC0\uCE59\uC801\uC778
      \uC2A4\uD15D, \uC81C \uC2DC\uC2A4\uD15C\uC5D0 \uAC15\uC81C\uB85C \uC785\uB825\uD574\uC11C
      \uC644\uBCBD\uD558\uAC8C \uBE8F\uC5B4\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Egoist_3
    ko: "\uC9C0\uC801 \uCE68\uBC94 \uBD88\uCF8C\uAC10\uC744 \uC18C\uC720\uC695\uC73C\uB85C
      \uC804\uD658\uD574 \uC774\uAE30\uAE30 \uC704\uD574 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00016_Desc_Fighter_301
    ko: "\uC9C0\uAE08 \uBB50 \uD558\uC2DC\uB294 \uAC81\uB2C8\uAE4C! \uC81C\uAC00
      \uC9C0\uAE08 \uC7A5\uB09C\uCE58\uB294 \uAC78\uB85C \uBCF4\uC5EC\uC694? \uBD84\uC11D
      \uBC29\uD574\uD558\uC9C0 \uB9D0\uACE0 \uBC1C \uCE58\uC6B0\uC138\uC694. \uC800
      \uC9C4\uC9DC \uC774\uAE30\uACE0 \uC2F6\uC5B4\uC11C \uC774\uB7EC\uB294 \uAC70\uB77C\uACE0\uC694!"
    en: 
    ja: 
  - stringKey: Event_00016_Rs_Fighter_3
    ko: "\uB178\uB825\uC744 \uAC00\uBCCD\uAC8C \uC5EC\uAE34 \uD0DC\uB3C4\uB97C \uBAA8\uC695\uC73C\uB85C
      \uADDC\uC815\uD558\uACE0 \uAC15\uD558\uAC8C \uB300\uB9BD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Discipline_001
    ko: "\uBE14\uB85D\uC758 \uAE30\uCD08\uB97C \uBC30\uC6B0\uB294 \uACFC\uC815\uC5D0\uC11C
      \uBE14\uB85D\uC758 \uC815\uC11D \uB9E4\uB274\uC5BC\uC5D0 \uACFC\uD558\uAC8C
      \uC9D1\uCC29\uD558\uB294 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Discipline_002
    ko: "\uD314\uC758 \uAC01\uB3C4\uC640 \uC218\uC9C1 \uC810\uD504 \uADDC\uCE59\uC744
      \uC9C0\uD0A4\uB824\uB2E4 \uC815\uC791 \uC2E4\uC804 \uD0C0\uC774\uBC0D\uC744
      \uB193\uCE58\uACE0 \uB9D0\uC558\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Discipline_003
    ko: "\uC6D0\uCE59\uC744 \uC900\uC218\uD588\uC74C\uC5D0\uB3C4 \uACB0\uACFC\uAC00
      \uB098\uC058\uC790, \uC790\uC2E0\uC758 \uC2DC\uC2A4\uD15C \uB0B4\uC5D0\uC11C
      \uBC1C\uC0DD\uD55C \uC624\uB958\uB97C \uC774\uD574\uD558\uC9C0 \uBABB\uD558\uACE0
      \uC5B5\uC6B8\uD568\uACFC \uC790\uCC45\uC5D0 \uBE60\uC838 \uC788\uB294 \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00017_Ch_Discipline_001
    ko: "\uB9E4\uB274\uC5BC \uC81C1\uC870\uB294 \uC2E4\uC810\uC744 \uB9C9\uB294 \uAC83\uC774\uB2E4.
      \uD558\uC704 \uADDC\uCE59\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uBCF8\uC9C8\uC744
      \uB193\uCE58\uC9C0 \uB9C8\uB77C."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Principled_101
    ko: "\uC81C1\uC870, \uC2E4\uC810\uC744 \uB9C9\uB294\uB2E4... \uC81C\uAC00 \uD558\uC704
      \uADDC\uCE59\uC744 \uC9C0\uD0A4\uB290\uB77C \uCD5C\uC0C1\uC704 \uC6D0\uCE59\uC744
      \uC78A\uACE0 \uC788\uC5C8\uAD70\uC694. \uC6B0\uC120\uC21C\uC704\uB97C \uB2E4\uC2DC
      \uC815\uB9AC\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Principled_1
    ko: "\uB354 \uB192\uC740 \uC6D0\uCE59\uC744 \uC81C\uC2DC\uD574\uC8FC\uC790 \uBAA8\uC21C\uC744
      \uD574\uACB0\uD558\uACE0 \uB0A9\uB4DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Guardian_101
    ko: "\uC2E4\uC810\uC744 \uB9C9\uB294 \uAC8C \uC81C1\uC870\uB77C\uB294 \uAC74
      \uC555\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC81C\uAC00 \uADDC\uCE59\uC744 \uC5B4\uAE30\uBA74\uC11C\uAE4C\uC9C0
      \uB9C9\uC73C\uB824\uB2E4 \uD30C\uC6B8\uC774\uB77C\uB3C4 \uBC94\uD558\uBA74
      \uD300\uC5D0 \uB354 \uD070 \uD574\uAC00 \uB418\uC9C0 \uC54A\uC744\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Guardian_1
    ko: "\uACF5\uB3D9\uCCB4 \uC218\uD638 \uC758\uC9C0\uAC00 \uAC15\uD574 \uADDC\uCE59
      \uC704\uBC18\uC774 \uB07C\uCE60 \uB9AC\uC2A4\uD06C\uB97C \uACFC\uD558\uAC8C
      \uAC71\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Tactician_101
    ko: "\uC0C1\uC704 \uD504\uB85C\uD1A0\uCF5C\uC744 \uC6B0\uC120\uC2DC\uD558\uB294
      \uAC74 \uD569\uB9AC\uC801\uC778 \uC804\uB7B5\uC785\uB2C8\uB2E4. \uC0C1\uD669\uC5D0
      \uB530\uB978 \uC720\uB3D9\uC801\uC778 \uADDC\uCE59 \uC801\uC6A9\uC744 \uC81C
      \uC804\uC220 \uBAA9\uB85D\uC5D0 \uCD94\uAC00\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Tactician_1
    ko: "\uCCB4\uACC4\uC801 \uC0AC\uACE0\uB97C \uC120\uD638\uD574 \uC0C1\uD669\uBCC4
      \uC6B0\uC120\uC21C\uC704\uB77C\uB294 \uB300\uC548\uC5D0 \uBE60\uB974\uAC8C
      \uC801\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Exemplary_101
    ko: "\uC81C\uAC00 \uB108\uBB34 \uAD50\uACFC\uC11C\uC801\uC778 \uBAA8\uC2B5\uC5D0\uB9CC
      \uC9D1\uCC29\uD588\uAD70\uC694. \uAE30\uC900\uC810\uC774 \uB418\uB824\uB2E4
      \uC624\uD788\uB824 \uC2E4\uC804\uC5D0\uC11C \uAD6C\uBA4D\uC774 \uB418\uB2E4\uB2C8...
      \uAC10\uB3C5\uB2D8 \uC9C0\uC801\uC774 \uB9DE\uC2B5\uB2C8\uB2E4. \uB0B4\uB824\uB193\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Exemplary_1
    ko: "\uBE44\uD6A8\uC728\uC801\uC778 \uBAA8\uBC94\uC774\uC5C8\uC74C\uC744 \uAE68\uB2EB\uACE0
      \uC989\uC2DC \uAE30\uC874 \uD2C0\uC744 \uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Ch_Discipline_002
    ko: "\uAE00\uC790\uAC00 \uB110 \uC9C0\uCF1C\uC8FC\uC9C0 \uC54A\uB294\uB2E4. \uBAB8\uC774
      \uBC18\uC751\uD558\uC9C0 \uBABB\uD560 \uB54C \uBCF4\uB294 \uCC38\uACE0\uC11C\uC77C
      \uBFD0\uC774\uB2C8 \uB2F9\uC7A5 \uC9C0\uC6CC\uBC84\uB824\uB77C."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Principled_201
    ko: "\uC9C0\uC6CC\uBC84\uB9AC\uB77C\uB2C8\uC694? \uC6D0\uCE59\uC774 \uC5C6\uB2E4\uBA74
      \uC81C\uAC00 \uC5F0\uC2B5\uD558\uB294 \uBAA8\uB4E0 \uB3D9\uC791\uC758 \uADFC\uAC70\uAC00
      \uC0AC\uB77C\uC9D1\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uC740 \uC774\uD574\uD558\uAE30
      \uC5B4\uB835\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Principled_2
    ko: "\uAC00\uC774\uB4DC\uB77C\uC778\uC744 \uBD80\uC815\uB2F9\uD558\uC790 \uADF9\uC2EC\uD55C
      \uBD88\uC548\uC744 \uB290\uB07C\uBA70 \uC2E0\uB8B0\uB97C \uC783\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Guardian_201
    ko: "\uB9E4\uB274\uC5BC\uC774 \uC800\uB97C \uC9C0\uCF1C\uC8FC\uB294 \uAC8C \uC544\uB2C8\uB77C,
      \uC81C\uAC00 \uB9E4\uB274\uC5BC\uC744 \uC9C0\uCF1C\uC57C \uC6B0\uB9AC \uD300\uC758
      \uC218\uBE44 \uCCB4\uACC4\uAC00 \uC720\uC9C0\uB418\uB294 \uAC83 \uC544\uB2D9\uB2C8\uAE4C?
      \uC2E4\uB9DD\uC2A4\uB7FD\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Guardian_2
    ko: "\uC218\uD638\uB97C \uC911\uC2DC\uD574 \uADDC\uCE59 \uBB34\uC2DC \uBC1C\uC5B8\uC744
      \uBB34\uCC45\uC784\uD55C \uC9C0\uC2DC\uB85C \uC5EC\uACBC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Tactician_201
    ko: "\uC9C0\uC6CC\uBC84\uB9AC\uB294 \uAC74 \uBE44\uD6A8\uC728\uC801\uC785\uB2C8\uB2E4.
      \uB9E4\uB274\uC5BC\uC758 \uAE30\uBCF8 \uB370\uC774\uD130\uC5D0 \uC2E4\uC804
      \uBCC0\uC218\uB97C \uACB0\uD569\uD558\uB294 \uBC29\uC2DD\uC73C\uB85C \uC5C5\uB370\uC774\uD2B8\uD558\uB294
      \uAC8C \uB0AB\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Tactician_2
    ko: "\uBB34\uACC4\uD68D\uC744 \uACBD\uACC4\uD574 \uC81C\uC548\uC744 \uADF9\uB2E8\uC801\uC73C\uB85C
      \uACE0\uCCD0 \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Exemplary_201
    ko: "\uC81C1\uC870\uB97C \uC9C0\uD0A4\uAE30 \uC704\uD574 \uD558\uC704 \uADDC\uCE59\uC744
      \uC5B4\uAE34\uB2E4\uBA74, \uC81C\uAC00 \uB2E4\uB978 \uC120\uC218\uB4E4\uC5D0\uAC8C
      \uADDC\uCE59\uC744 \uC9C0\uD0A4\uB77C\uACE0 \uC5B4\uB5BB\uAC8C \uB9D0\uD560
      \uC218 \uC788\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Exemplary_2
    ko: "\uC608\uC678\uB97C \uD5C8\uC6A9\uD558\uBA74 \uC874\uC7AC \uAC00\uCE58\uAC00
      \uBB34\uB108\uC9C4\uB2E4\uACE0 \uC5EC\uACBC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Ch_Discipline_003
    ko: "\uB9E4\uB274\uC5BC\uC744 \uBE8F\uC5B4 \uC8FC\uBA38\uB2C8\uC5D0 \uB123\uACE0,
      \uC62C\uBC14\uB978 \uBE14\uB85D \uC704\uCE58\uB97C \uC7A1\uC544\uC900 \uB4A4
      \uACF5\uC744 \uB358\uC838 \uC190\uB9DB\uC744 \uBCF4\uAC8C \uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Principled_301
    ko: "\uBAB8\uC73C\uB85C \uAC00\uB974\uCCD0\uC8FC\uC2DC\uB294 \uAC74 \uC88B\uC9C0\uB9CC,
      \uBC29\uAE08 \uC774 \uC704\uCE58\uAC00 \uB9E4\uB274\uC5BC \uBA87 \uD398\uC774\uC9C0\uC5D0
      \uB098\uC624\uB294 \uB0B4\uC6A9\uC778\uC9C0 \uD655\uC2E4\uD788 \uC54C\uACE0
      \uC2F6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Principled_3
    ko: "\uD589\uB3D9\uC740 \uB530\uB974\uC9C0\uB9CC \uC774\uB860\uC801\uC73C\uB85C
      \uAE30\uB85D\uD574\uC57C \uD55C\uB2E4\uB294 \uAC15\uBC15\uC774 \uB0A8\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Guardian_301
    ko: "\uC544... \uB9E4\uB274\uC5BC\uC5D0 \uC801\uD78C \uAE00\uC790\uBCF4\uB2E4
      \uAC10\uB3C5\uB2D8\uC758 \uC190\uAE38\uC774 \uB354 \uD655\uC2E4\uD558\uB124\uC694.
      \uC81C\uAC00 \uD300\uC744 \uC704\uD574 \uBB34\uC5C7\uC744 \uC9C0\uCF1C\uC57C
      \uD558\uB294\uC9C0 \uC774\uC81C\uC57C \uBAB8\uC774 \uC54C \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Guardian_3
    ko: "\uD655\uC2E4\uD55C \uD589\uB3D9 \uAE30\uC900\uC5D0 \uC548\uC815\uC744 \uB290\uB07C\uACE0
      \uC720\uC5F0\uD55C \uB300\uCC98\uB97C \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Tactician_301
    ko: "\uAC11\uC790\uAE30 \uC774\uB7EC\uC2DC\uBA74 \uACE4\uB780\uD569\uB2C8\uB2E4.
      \uC804 \uC544\uC9C1 \uC81C \uC624\uB958 \uC6D0\uC778\uC744 \uC774\uB860\uC801\uC73C\uB85C
      \uC644\uBCBD\uD788 \uD30C\uC545\uD558\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4.
      \uD750\uB984\uC744 \uB04A\uC9C0 \uB9C8\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Tactician_3
    ko: "\uBD84\uC11D\uC744 \uC0DD\uB7B5\uD55C \uB3CC\uBC1C \uAC1C\uC785\uC5D0 \uBD88\uCF8C\uAC10\uC744
      \uB290\uB07C\uACE0 \uC800\uD56D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Exemplary_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uAC00\uB974\uCCD0\uC8FC\uC2E0 \uC774
      \uC790\uC138\uAC00 \uC0C8\uB85C\uC6B4 \uC815\uC11D\uC774 \uB418\uB294 \uAC70\uAD70\uC694.
      \uC774 \uB3D9\uC791\uC744 \uC644\uBCBD\uD788 \uC775\uD600\uC11C \uD6C4\uBC30\uB4E4\uC5D0\uAC8C
      \uBCF4\uC5EC\uC8FC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Exemplary_3
    ko: "\uBCF8\uC9C8\uC801 \uC720\uC5F0\uD568 \uB300\uC2E0 \uADF8\uC800 \uC0C8\uB85C\uC6B4
      \uB9E4\uB274\uC5BC\uC744 \uCD94\uAC00\uD558\uBA70 \uB530\uB790\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Bond_001
    ko: "\uAC1C\uC778 \uC218\uBE44 \uD6C8\uB828 \uC911\uC778 \uC120\uC218\uC785\uB2C8\uB2E4.
      \uADF8\uB294 \uC790\uC2E0\uC774 \uBD80\uC871\uD558\uBA74 \uD300 \uC804\uCCB4\uC758
      \uD6C8\uB828 \uD750\uB984\uC774 \uAE68\uC9C8\uAE4C \uBD10 \uB450\uB824\uC6CC\uD558\uBA70,"
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Bond_002
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC900 \uB9E4\uB274\uC5BC\uC758 \uD314 \uAC01\uB3C4\uC640
      \uC810\uD504 \uC218\uCE59\uC744 \uD544\uC0AC\uC801\uC73C\uB85C \uC9C0\uD0A4\uB824
      \uD569\uB2C8\uB2E4.\uD558\uC9C0\uB9CC \uADDC\uCE59\uC744 \uBA38\uB9BF\uC18D\uC73C\uB85C
      \uC74A\uC870\uB9AC\uB290\uB77C \uC815\uC791 \uB0A0\uC544\uC624\uB294 \uACF5\uC5D0
      \uBC18\uC751\uD558\uC9C0 \uBABB\uD588\uACE0,"
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Bond_003
    ko: "\uD6C8\uB828\uC744 \uB9DD\uCE58\uC790 \uB0B4\uAC00 \uC131\uC2E4\uD558\uC9C0
      \uBABB\uD574\uC11C \uD300\uC758 \uAE30\uC900\uC744 \uB9DE\uCD94\uC9C0 \uBABB\uD588\uC5B4
      \uB77C\uBA70 \uC790\uCC45\uACFC \uBBF8\uC548\uD568\uC5D0 \uBE60\uC838 \uACE0\uAC1C\uB97C
      \uB4E4\uC9C0 \uBABB\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Bond_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00017_Ch_Bond_001
    ko: "\uB9E4\uB274\uC5BC\uBCF4\uB2E4 \uD300\uC744 \uC0DD\uAC01\uD558\uB294 \uB124
      \uC9C4\uC2EC\uC774 \uB354 \uC911\uC694\uD558\uB2E4. \uB178\uB825\uC740 \uB2E4
      \uC54C\uACE0 \uC788\uC73C\uB2C8 \uACE0\uAC1C \uC219\uC774\uC9C0 \uB9C8\uB77C."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uADF8\uB807\uAC8C \uB9D0\uC500\uD574 \uC8FC\uC2DC\uB2C8
      \uC815\uB9D0 \uD798\uC774 \uB098\uC694. \uC81C\uAC00 \uB354 \uBC1D\uC740 \uBAA8\uC2B5\uC73C\uB85C
      \uD300\uC5D0 \uB3C4\uC6C0\uC774 \uB420 \uC218 \uC788\uB3C4\uB85D \uB2E4\uC2DC
      \uB178\uB825\uD560\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Kind_1
    ko: "\uB530\uB73B\uD55C \uC9C0\uC9C0\uC5D0 \uC548\uC815\uC744 \uCC3E\uACE0 \uC790\uCC45\uC744
      \uD138\uC5B4\uB0B4\uBA70 \uB2E4\uC2DC \uD798\uC744 \uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Loyal_101
    ko: "\uACA9\uB824\uB294 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uC81C\uAC00 \uC2E4\uB825\uC744
      \uC99D\uBA85\uD558\uC9C0 \uBABB\uD55C\uB2E4\uBA74 \uADF8 \uACA9\uB824\uB97C
      \uBC1B\uC744 \uC790\uACA9\uC774 \uC5C6\uB2E4\uACE0 \uC0DD\uAC01\uD569\uB2C8\uB2E4.
      \uC644\uBCBD\uD574\uC9C4 \uB4A4\uC5D0 \uCE6D\uCC2C\uBC1B\uACE0 \uC2F6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Loyal_1
    ko: "\uC131\uACFC\uB85C \uC99D\uBA85\uD558\uAE38 \uC6D0\uD574 \uACA9\uB824\uB9CC\uC73C\uB860
      \uB9E4\uB274\uC5BC \uC9D1\uCC29\uC744 \uAEBE\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Sincere_101
    ko: "\uC704\uB85C\uD574 \uC8FC\uC2DC\uB294 \uAC74 \uC88B\uC9C0\uB9CC, \uACB0\uAD6D
      \uC81C\uAC00 \uC774 \uB3D9\uC791\uC744 \uB9C8\uC2A4\uD130\uD558\uC9C0 \uBABB\uD558\uBA74
      \uB0B4\uC77C \uD6C8\uB828\uC5D0\uC11C\uB3C4 \uB611\uAC19\uC740 \uC2E4\uC218\uB97C
      \uBC18\uBCF5\uD560 \uAC81\uB2C8\uB2E4. \uC804 \uB354 \uC5F0\uC2B5\uD574\uC57C
      \uD574\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Sincere_1
    ko: "\uAD6C\uCCB4\uC801 \uC219\uB2EC\uC744 \uC131\uC2E4\uD568\uC73C\uB85C \uBBFF\uC5B4
      \uACA9\uB824\uB9CC\uC73C\uB860 \uACE0\uC9D1\uC744 \uC548 \uAEBE\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Moodmaker_101
    ko: "\uAC10\uB3C5\uB2D8\uAE4C\uC9C0 \uADF8\uB807\uAC8C \uC9C4\uC9C0\uD558\uAC8C
      \uB9D0\uC500\uD558\uC2DC\uB2C8\uAE4C \uB354 \uBD80\uB2F4\uC2A4\uB7EC\uC6CC\uC694.
      \uADF8\uB0E5 \uC81C\uAC00 \uC54C\uC544\uC11C \uD138\uACE0 \uC77C\uC5B4\uB0A0
      \uD14C\uB2C8\uAE4C \uB108\uBB34 \uC2E0\uACBD \uC4F0\uC9C0 \uB9C8\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Moodmaker_1
    ko: "\uC9C4\uC9C0\uD55C \uC704\uB85C\uC5D0 \uC0C1\uD669\uC774 \uBB34\uAC70\uC6CC\uC84C\uB2E4\uACE0
      \uB290\uAEF4 \uBD80\uB2F4\uAC10\uC5D0 \uD68C\uD53C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Ch_Bond_002
    ko: "\uADDC\uCE59 \uD558\uB098\uC5D0 \uB9E4\uBAB0\uB3FC \uD6C8\uB828 \uD750\uB984\uC744
      \uB04A\uB294 \uAC74 \uD300\uC6CC\uD06C\uAC00 \uC544\uB2C8\uB2C8 \uD300 \uC804\uCCB4\uC758
      \uB9AC\uB4EC\uC744 \uBA3C\uC800 \uC0DD\uAC01\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Kind_201
    ko: "\uC81C\uAC00 \uD300\uC758 \uB9AC\uB4EC\uC744 \uB9DD\uCE58\uACE0 \uC788\uC5C8\uB2E4\uB2C8...
      \uC815\uB9D0 \uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uC81C\uAC00 \uC5C6\uC5B4\uC57C
      \uD300\uC774 \uB354 \uC798 \uB3CC\uC544\uAC08 \uAC83 \uAC19\uB2E4\uB294 \uC0DD\uAC01\uC774
      \uB4E4\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Kind_2
    ko: "\uD300\uC5D0 \uBBFC\uD3D0\uB780 \uC9C8\uCC45\uC5D0 \uC0C1\uCC98\uB97C \uC785\uACE0
      \uADF9\uC2EC\uD55C \uC790\uAE30 \uBE44\uD558\uC5D0 \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Loyal_201
    ko: "\uBA85\uC2EC\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uC81C \uACE0\uC9D1\uC774 \uD300\uC758
      \uC9C8\uC11C\uB97C \uC5B4\uC9C0\uB7FD\uD614\uAD70\uC694. \uAC1C\uC778\uC801\uC778
      \uAC15\uBC15\uC740 \uBC84\uB9AC\uACE0 \uD300\uC758 \uC2B9\uB9AC\uB77C\uB294
      \uB300\uC758\uB97C \uC704\uD574 \uC6C0\uC9C1\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Loyal_2
    ko: "\uC870\uC9C1 \uD6A8\uC728\uC744 \uAE6C\uB2E4\uB294 \uC9C8\uCC45\uC5D0 \uD300\uC744
      \uC704\uD574 \uC989\uC2DC \uD0DC\uB3C4\uB97C \uACE0\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Sincere_201
    ko: "\uD750\uB984\uC744 \uB04A\uC73C\uB824\uB358 \uAC8C \uC544\uB2C8\uB77C \uB354
      \uC644\uBCBD\uD558\uAC8C \uD558\uACE0 \uC2F6\uC5B4\uC11C \uADF8\uB7AC\uB358
      \uAC81\uB2C8\uB2E4. \uC81C \uC9C4\uC9C0\uD55C \uB178\uB825\uC744 \uADF8\uB807\uAC8C
      \uD3C9\uAC00\uD558\uC2DC\uB2E4\uB2C8 \uC5B5\uC6B8\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Sincere_2
    ko: "\uB178\uB825\uC744 \uBBFC\uD3D0\uB85C \uCE58\uBD80\uD558\uC790 \uAC15\uD55C
      \uAC70\uBD80\uAC10\uC744 \uB290\uB07C\uACE0 \uB9C8\uC74C\uC744 \uB2EB\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Moodmaker_201
    ko: "\uC5D0\uC774, \uC81C\uAC00 \uBB34\uC2A8 \uD750\uB984\uC744 \uB2E4 \uB04A\uC5C8\uB2E4\uACE0
      \uADF8\uB7EC\uC138\uC694. \uC54C\uC558\uC5B4\uC694, \uC54C\uC558\uC5B4! \uB2E4\uC2DC
      \uBC1D\uAC8C \uAC00\uBCF4\uC790\uACE0\uC694. \uC790, \uB2E4\uB4E4 \uD30C\uC774\uD305\uD569\uC2DC\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Moodmaker_2
    ko: "\uC6C3\uC5B4\uB118\uAE30\uB824 \uD588\uC9C0\uB9CC \uC11C\uC6B4\uD568\uC774
      \uB0A8\uC544 \uD6C8\uB828 \uC9D1\uC911\uB825\uC774 \uB5A8\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Ch_Bond_003
    ko: "\uC5B4\uAE68\uB97C \uCE58\uBA70 \uB9E4\uB274\uC5BC\uC744 \uB36E\uACE0 \uC9C1\uC811
      \uACE8\uBC11\uC5D0\uC11C \uBAB8\uC744 \uBD80\uB52A\uCE58\uBA70 \uB9AC\uBC14\uC6B4\uB4DC
      \uACBD\uD569 \uD6C8\uB828\uC744 \uD568\uAED8 \uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uB3C4\uC640\uC8FC\uC2DC\uB2C8 \uAC10\uC0AC\uD558\uAE34
      \uD55C\uB370, \uC81C\uAC00 \uB108\uBB34 \uBD80\uC871\uD574\uC11C \uAC10\uB3C5\uB2D8\uAE4C\uC9C0
      \uACE0\uC0DD\uC2DC\uD0A4\uB294 \uAC83 \uAC19\uC544 \uB9C8\uC74C\uC774 \uD3B8\uCE58
      \uC54A\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Kind_3
    ko: "\uC5D0\uB108\uC9C0\uB97C \uC4F0\uAC8C \uD55C \uC0C1\uD669\uC774 \uBBF8\uC548\uD574
      \uC628\uC804\uD788 \uC9D1\uC911\uD558\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8! \uD6C8\uB828\uC740 \uC5C4\uACA9\uD574\uC57C \uD569\uB2C8\uB2E4.
      \uC774\uB807\uAC8C \uAC10\uC815\uC801\uC73C\uB85C \uBAB8\uC744 \uC11E\uB294
      \uAC83\uBCF4\uB2E4 \uC81C\uAC00 \uC815\uD574\uC9C4 \uB8E8\uD2F4\uC744 \uB05D\uB9C8\uCE58\uB3C4\uB85D
      \uC5C4\uD558\uAC8C \uC9C0\uB3C4\uD574 \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Loyal_3
    ko: "\uC808\uCC28\uB97C \uC911\uC2DC\uD574 \uB3CC\uBC1C\uC801 \uC2E0\uCCB4 \uAC1C\uC785\uC744
      \uAE30\uAC15 \uD6FC\uC190\uC73C\uB85C \uAC04\uC8FC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Sincere_301
    ko: "\uC544... \uBAB8\uC73C\uB85C \uC9C1\uC811 \uBD80\uB52A\uCCD0\uBCF4\uB2C8
      \uB9E4\uB274\uC5BC\uC5D0 \uC5C6\uB358 \uBB34\uAC8C\uAC10\uC774 \uB290\uAEF4\uC9C0\uB124\uC694.
      \uAC10\uB3C5\uB2D8\uC774 \uAC00\uB974\uCCD0\uC8FC\uC2E0 \uC774 \uAC10\uAC01\uC744
      \uC81C \uBAB8\uC5D0 \uB2E4\uC2DC \uC0C8\uACA8\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Sincere_3
    ko: "\uB9D0\uBCF4\uB2E4 \uC2E4\uCC9C\uC5D0 \uBC18\uC751\uD574 \uD568\uAED8 \uB540
      \uD758\uB9AC\uBA70 \uC0C8 \uC9C0\uCE68\uC744 \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Moodmaker_301
    ko: "\uC640! \uAC10\uB3C5\uB2D8 \uBAB8\uC2F8\uC6C0 \uC9C4\uC9DC \uC7A5\uB09C
      \uC544\uB2C8\uC2E0\uB370\uC694? \uC800 \uB9AC\uC561\uC158 \uC81C\uB300\uB85C
      \uD560 \uBED4\uD588\uC796\uC544\uC694! \uC5ED\uC2DC \uD6C8\uB828\uC740 \uC774\uB807\uAC8C
      \uC990\uAC81\uAC8C \uBAB8\uC73C\uB85C \uD574\uC57C \uC81C\uB9DB\uC774\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Moodmaker_3
    ko: "\uB3D9\uC801 \uAD50\uB958\uB97C \uC120\uD638\uD574 \uD589\uB3D9 \uAC1C\uC785\uC5D0
      \uD65C\uBC1C\uD788 \uBC18\uC751\uD558\uBA70 \uADF9\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Cold_001
    ko: "\uD6C8\uB828\uC7A5 \uCF54\uB108\uC5D0\uC11C \uD314\uC758 \uAC01\uB3C4\uC640
      \uC810\uD504 \uB192\uC774\uB97C \uC13C\uD2F0\uBBF8\uD130 \uB2E8\uC704\uB85C
      \uCCB4\uD06C\uD558\uBA70 \uC5F0\uC2B5 \uC911\uC778 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Cold_002
    ko: "\uADF8\uB294 \uB9E4\uB274\uC5BC\uC758 \uB370\uC774\uD130\uAC00 \uACE7 \uC815\uB2F5\uC774\uB77C
      \uBBFF\uACE0 \uC774\uB97C \uC644\uBCBD\uD788 \uAD6C\uD604\uD558\uB294 \uAC83\uC5D0\uB9CC
      \uC9D1\uC911\uD569\uB2C8\uB2E4. \uADF8\uB7EC\uB098 \uBCC0\uCE59\uC801\uC778
      \uD6C8\uB828 \uC0C1\uD669\uC5D0\uC11C \uACE0\uC815\uB41C \uADDC\uCE59\uC744
      \uACE0\uC218\uD558\uB2E4 \uD0C0\uC774\uBC0D\uC744 \uB193\uCE58\uC790,"
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Cold_003
    ko: "\uB0B4 \uACC4\uC0B0\uC740 \uC644\uBCBD\uD588\uB294\uB370 \uC65C \uACB0\uACFC\uAC12\uC774
      \uD2C0\uB9B0 \uAC70\uC9C0? \uB77C\uBA70 \uB17C\uB9AC\uC801 \uBAA8\uC21C\uC5D0
      \uBD80\uB52A\uD600 \uD63C\uB780\uACFC \uBD84\uB178\uB97C \uC0AD\uC774\uACE0
      \uC788\uB294 \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Cold_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00017_Ch_Cold_001
    ko: "\uC815\uBC00\uD568\uC740 \uC790\uC0B0\uC774\uB098 \uBBF8\uCC98 \uC785\uB825
      \uC548 \uB41C \uBCC0\uC218\uB85C \uC778\uD55C \uC624\uCC28\uC77C \uBFD0, \uBCC0\uC218\uB97C
      \uACC4\uC0B0\uD558\uBA74 \uC644\uBCBD\uD574\uC9C8 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Planner_101
    ko: "\uC678\uBD80 \uBCC0\uC218... \uD655\uC2E4\uD788 \uC81C\uAC00 \uACE0\uC815\uB41C
      \uB370\uC774\uD130\uC5D0\uB9CC \uCE58\uC911\uD588\uAD70\uC694. \uADF8 \uBCC0\uB3D9
      \uC218\uCE58\uAE4C\uC9C0 \uC2DC\uBBAC\uB808\uC774\uC158\uC5D0 \uD3EC\uD568\uD574\uC11C
      \uB2E4\uC2DC \uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Planner_1
    ko: "\uB17C\uB9AC\uC801 \uD655\uC7A5 \uC81C\uC548\uC5D0 \uC2E0\uB8B0\uB97C \uB290\uB07C\uACE0
      \uC989\uAC01 \uC2DC\uC2A4\uD15C\uC744 \uC218\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Opportunist_101
    ko: "\uACA9\uB824\uB294 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uC81C\uAC00 \uC774 \uB9E4\uB274\uC5BC\uC744
      \uB9C8\uC2A4\uD130\uD558\uC9C0 \uBABB\uD558\uBA74 \uB098\uC911\uC5D0 \uC81C
      \uAC00\uCE58\uB97C \uC99D\uBA85\uD560 \uAE30\uD68C\uB97C \uC783\uAC8C \uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Opportunist_1
    ko: "\uB530\uB73B\uD55C \uB9D0\uBCF4\uB2E4 \uC2E4\uC9C8\uC801\uC778 \uC2E4\uB825
      \uD5A5\uC0C1\uC774 \uB0AB\uB2E4 \uD310\uB2E8\uD574 \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Cunning_101
    ko: "\uACA9\uB824\uB77C\uB2C8, \uAC11\uC790\uAE30 \uC65C \uC774\uB807\uAC8C \uCE5C\uC808\uD558\uC2DC\uC8E0?
      \uC2E4\uC218\uB97C \uB36E\uC5B4\uC8FC\uB294 \uCC99 \uB098\uC911\uC5D0 \uB354
      \uD070 \uCC45\uC784\uC744 \uBB3C\uC73C\uB824\uB294 \uAC74 \uC544\uB2C8\uACE0\uC694?"
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Cunning_1
    ko: "\uD638\uC758\uB97C \uBD88\uC2E0\uD558\uACE0 \uBC30\uD6C4\uC758 \uC758\uB3C4\uB97C
      \uC758\uC2EC\uD558\uC5EC \uBC29\uC5B4\uC801\uC73C\uB85C \uB300\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Believer_101
    ko: "\uBCC0\uC218 \uD0D3\uC774 \uC544\uB2D9\uB2C8\uB2E4. \uC81C \uC6D0\uCE59\uC774
      \uC544\uC9C1 \uC644\uBCBD\uD558\uAC8C \uAD6C\uD604\uB418\uC9C0 \uC54A\uC558\uC744
      \uBFD0\uC785\uB2C8\uB2E4. \uC81C \uC218\uCE58\uB300\uB85C \uACB0\uACFC\uB97C
      \uB0B4\uBCF4\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Believer_1
    ko: "\uB17C\uB9AC\uAC00 \uC808\uB300\uC801\uC774\uB77C \uC218\uC815 \uC81C\uC548\uC744
      \uC6D0\uCE59\uC5D0 \uB300\uD55C \uB3C4\uC804\uC73C\uB85C \uC5EC\uACBC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Ch_Cold_002
    ko: "\uC218\uCE58\uC5D0 \uB9E4\uBAB0\uB3FC \uC0C1\uD669\uB3C4 \uBABB \uC77D\uB294
      \uAC74 \uBB34\uB2A5\uD55C \uAE30\uACC4\uC77C \uBFD0\uC774\uB2C8 \uB2F9\uC7A5
      \uBA38\uB9AC \uBE44\uC6B0\uACE0 \uD604\uC7A5\uC5D0 \uC9D1\uC911\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Planner_201
    ko: "\uBB34\uB2A5\uD55C \uAE30\uACC4\uB77C\uB2C8\uC694. \uD655\uB960\uC801\uC73C\uB85C
      \uAC00\uC7A5 \uB192\uC740 \uC120\uD0DD\uC744 \uD588\uC744 \uBFD0\uC785\uB2C8\uB2E4.
      \uC81C \uC124\uACC4\uC758 \uC2E0\uB8B0\uB3C4\uB97C \uB192\uC77C \uC2DC\uAC04\uC744
      \uB354 \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Planner_2
    ko: "\uBE44\uB09C\uBCF4\uB2E4 \uACC4\uC0B0\uC774 \uD2C0\uB9AC\uC9C0 \uC54A\uC558\uC74C\uC744
      \uC99D\uBA85\uD558\uB824\uB294 \uACE0\uC9D1\uC774 \uC55E\uC130\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Opportunist_201
    ko: "\uC2B9\uB9AC\uB97C \uB193\uCE58\uB294 \uAC74 \uAC00\uCE58\uAC00 \uC5C6\uB2E4\uB294
      \uB9D0\uC500\uC774\uC2DC\uAD70\uC694. \uB9E4\uB274\uC5BC\uC774 \uC81C \uBAB8\uAC12\uC744
      \uAE4E\uB294\uB2E4\uBA74 \uBC84\uB9AC\uACE0 \uC774\uAE30\uB294 \uAE38\uC744
      \uCC3E\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Opportunist_2
    ko: "\uBB34\uB2A5\uD558\uB2E8 \uD3C9\uAC00\uB97C \uAC00\uCE58 \uD558\uB77D\uC73C\uB85C
      \uC5EC\uACA8 \uC2E4\uB9AC\uC801 \uD0DC\uB3C4\uB85C \uC804\uD658\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Cunning_201
    ko: "\uD6A8\uC728? \uC81C\uAC00 \uB9E4\uB274\uC5BC\uB300\uB85C \uD55C \uAC74
      \uB098\uC911\uC5D0 \uC81C \uD0D3\uC774 \uC544\uB2C8\uB77C\uB294 \uAC78 \uC99D\uBA85\uD558\uAE30
      \uC704\uD574\uC11C\uC600\uB294\uB370, \uADF8\uAC78 \uBB34\uB2A5\uC73C\uB85C
      \uBAB0\uC544\uC138\uC6B0\uC2DC\uBA74 \uACE4\uB780\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Cunning_2
    ko: "\uCC45\uC784 \uD68C\uD53C\uAC00 \uBB34\uB2A5\uC73C\uB85C \uBE44\uCE58\uC790
      \uC790\uC874\uC2EC \uC0C1\uD574 \uAE30 \uC2F8\uC6C0\uC744 \uBC8C\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Believer_201
    ko: "\uBE44\uB09C\uD558\uC154\uB3C4 \uC81C \uC2E0\uB150\uC740 \uBCC0\uD558\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4. \uB2E4\uB9CC, \uD6A8\uC728\uC774 \uB5A8\uC5B4\uC9C4\uB2E4\uB294
      \uC9C0\uC801\uC740 \uAC80\uD1A0\uD574 \uBCFC \uAC00\uCE58\uAC00 \uC788\uACA0\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Believer_2
    ko: "\uAD74\uBCF5\uD558\uC9C4 \uC54A\uC73C\uB098 \uD6A8\uC728\uC774\uB77C\uB294
      \uB17C\uB9AC\uC5D4 \uD55C \uBC1C \uBB3C\uB7EC\uB098 \uACE0\uBBFC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Ch_Cold_003
    ko: "\uB178\uD2B8\uB97C \uCC22\uACE0 \uC885\uC774 \uC870\uAC01\uC744 \uD769\uBFCC\uB9B0
      \uB4A4, \uC120\uC218\uB97C \uB6AB\uC5B4\uC9C8 \uB4EF \uC751\uC2DC\uD558\uBA70
      \uACF5\uC744 \uBC1C\uB85C \uCC28\uC11C \uBCF4\uB0B8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Planner_301
    ko: "\uC9C0\uAE08 \uBB34\uC2A8 \uC9D3\uC744... \uC81C \uBAA8\uB4E0 \uBD84\uC11D
      \uADFC\uAC70\uAC00 \uC0AC\uB77C\uC84C\uC2B5\uB2C8\uB2E4. \uAE30\uC900\uC810
      \uC5C6\uC774\uB294 \uB2E4\uC74C \uC124\uACC4\uB97C \uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Planner_3
    ko: "\uADFC\uAC70 \uD30C\uAD34\uC5D0 \uD6C8\uB828 \uB85C\uC9C1\uC774 \uBB34\uB108\uC838
      \uACF5\uD3EC\uC640 \uC0C1\uC2E4\uAC10\uC744 \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Opportunist_301
    ko: "\uB300\uC548\uB3C4 \uC5C6\uC774 \uC790\uB8CC\uB97C \uC5C6\uC560\uC2DC\uB2E4\uB2C8...
      \uD558\uC9C0\uB9CC \uAC10\uB3C5\uB2D8\uC758 \uBB34\uC5B8\uC758 \uC555\uBC15\uC774
      \uB354 \uD070 \uB9AC\uC2A4\uD06C\uB77C\uB294 \uAC74 \uC54C\uACA0\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Opportunist_3
    ko: "\uC790\uC0B0 \uC0C1\uC2E4\uC740 \uBD88\uB9CC\uC774\uB098 \uB300\uB9BD\uC774
      \uBD88\uB9AC\uD568\uC744 \uC54C\uACE0 \uC77C\uB2E8 \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Cunning_301
    ko: "\uB9D0\uBCF4\uB2E4 \uD655\uC2E4\uD558\uC2DC\uB124\uC694. \uADDC\uCE59\uC774\uB77C\uB294
      \uAECD\uB370\uAE30\uB294 \uD544\uC694 \uC5C6\uB2E4\uB294 \uB73B\uC774\uACA0\uC8E0.
      \uC7AC\uBBF8\uC788\uC5B4\uC9C0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Cunning_3
    ko: "\uAE08\uAE30 \uD30C\uAD34\uC5D0 \uB3D9\uC9C8\uAC10\uC744 \uB290\uAEF4 \uC218\uB2E8\uC744
      \uAC00\uB9AC\uC9C0 \uB9D0\uB77C \uC774\uD574\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Believer_301
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uC774\uC804\uC758 \uB17C\uB9AC\uB294 \uD3D0\uAE30\uD558\uACE0
      \uC0C8\uB85C\uC6B4 \uC815\uB2F5\uC744 \uCC3E\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Believer_3
    ko: "\uAC15\uB825\uD55C \uD589\uB3D9\uC744 \uACB0\uB860\uC73C\uB85C \uC5EC\uAE30\uACE0
      \uC989\uC2DC \uB2E4\uC74C \uB17C\uB9AC\uB97C \uAD6C\uCD95\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Instinct_001
    ko: "\uAC1C\uC778 \uC218\uBE44 \uD6C8\uB828 \uC911\uC778 \uC120\uC218\uC785\uB2C8\uB2E4.
      \uB9E4\uB274\uC5BC\uC5D0 \uC801\uD78C \uC218\uCE58\uB97C \uC9C0\uD0A4\uB824\uB2E4
      \uC815\uC791 \uB0A0\uC544\uC624\uB294 \uACF5\uC5D0 \uBC18\uC751\uD558\uC9C0
      \uBABB\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Instinct_002
    ko: "\uC790\uC2E0\uC758 \uB3D9\uBB3C\uC801\uC778 \uAC10\uAC01 \uB300\uC2E0 \uC885\uC774
      \uC704\uC758 \uAE00\uC790\uC5D0 \uC758\uC874\uD558\uB2E4 \uD6C8\uB828\uC744
      \uB9DD\uCE58\uC790, \uC790\uC2E0\uC758 \uBC18\uC751\uC774 \uAE30\uACC4\uC801\uC774\uC9C0
      \uBABB\uD588\uC74C\uC5D0 \uBD84\uB178\uD558\uBA70 \uAC70\uCE5C \uC228\uC744
      \uBAB0\uC544\uC26C\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Instinct_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00017_Ch_Instinct_001
    ko: "\uADDC\uCE59\uC5D0 \uAC00\uB450\uC9C0 \uB9C8\uB77C. \uD53C\uAC00 \uB053\uB294
      \uB300\uB85C, \uBAB8\uC774 \uD280\uC5B4\uB098\uAC00\uB294 \uB300\uB85C \uACF5\uC744
      \uC9D3\uB20C\uB7EC\uBC84\uB9B4 \uD798\uC774 \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Bluffer_101
    ko: "\uC81C \uBAB8\uC774 \uB9E4\uB274\uC5BC\uBCF4\uB2E4 \uBE60\uB974\uB2E4\uB294
      \uB9D0, \uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uC808 \uC544\uC2DC\uB124\uC694!
      \uC774\uB7F0 \uC2DC\uC2DC\uD55C \uADDC\uCE59\uB4E4\uC740 \uC81C \uD654\uB824\uD55C
      \uAC10\uAC01\uC744 \uB2F4\uAE30\uC5D4 \uB108\uBB34 \uC881\uC8E0. \uB2E4\uC2DC
      \uBCF4\uC2DC\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Bluffer_1
    ko: "\uC7AC\uB2A5 \uC778\uC815 \uACA9\uB824\uC5D0 \uC790\uC874\uAC10\uC774 \uD3ED\uBC1C\uD558\uBA70
      \uC989\uC2DC \uAE30\uC138\uB97C \uD68C\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Wild_101
    ko: "\uBAB8\uC774 \uB098\uAC00\uB294 \uB300\uB85C... \uD558\uC9C0\uB9CC \uAC10\uB3C5\uB2D8\uC774
      \uB9E4\uB274\uC5BC\uB300\uB85C \uD558\uB77C\uACE0 \uD558\uC168\uC796\uC544\uC694.
      \uAC11\uC790\uAE30 \uBC14\uAFB8\uB77C\uACE0 \uD558\uC2DC\uBA74 \uBA38\uB9BF\uC18D\uC774
      \uB354 \uBCF5\uC7A1\uD574\uC838\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Wild_1
    ko: "\uBCF8\uB2A5 \uC790\uADF9\uC5D0\uB3C4 \uAE30\uC874 \uADDC\uCE59\uACFC \uCDA9\uB3CC\uD574
      \uD63C\uB780\uC2A4\uB7EC\uC6CC \uBA38\uBB47\uAC70\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Egoist_101
    ko: "\uC81C \uD798\uC740 \uC81C\uAC00 \uC81C\uC77C \uC798 \uC555\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC644\uBCBD\uD55C \uC218\uC2DD\uC744 \uC775\uD600\uC57C
      \uC81C \uC2E4\uB825\uC774 \uC644\uC131\uB418\uC8E0. \uAC10\uAC01\uC5D0\uB9CC
      \uC758\uC874\uD558\uB294 \uAC74 \uD558\uC218\uB4E4\uC774\uB098 \uD558\uB294
      \uC9D3\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Egoist_1
    ko: "\uC644\uBCBD\uC8FC\uC758 \uD0D3\uC5D0 \uBCF8\uB2A5 \uAC15\uC870\uB97C \uC800\uAE09\uD55C
      \uC870\uC5B8\uC774\uB77C\uBA70 \uBB34\uC2DC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Fighter_101
    ko: "\uD53C\uAC00 \uB053\uAE34 \uD558\uB294\uB370... \uC804 \uC774 \uB9E4\uB274\uC5BC\uC774\uB77C\uB294
      \uB188\uC744 \uC815\uBCF5\uD558\uC9C0 \uBABB\uD558\uBA74 \uBD84\uD574\uC11C
      \uC7A0\uC774 \uC548 \uC62C \uAC83 \uAC19\uC544\uC694. \uC77C\uB2E8 \uC774 \uAE00\uC790\uB4E4\uBD80\uD130
      \uC774\uAE30\uACE0 \uC62C\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Fighter_1
    ko: "\uB300\uC0C1\uC744 \uC801\uC73C\uB85C \uC5EC\uACA8 \uC644\uC218\uD558\uAE30
      \uC804\uAE4C\uC9C4 \uB2E4\uB978 \uC81C\uC548\uC744 \uBB34\uC2DC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Ch_Instinct_002
    ko: "\uC2E4\uD328\uAC00 \uBB34\uC11C\uC6CC \uC228\uB294 \uAC8C \uB124 \uC57C\uC131\uC758
      \uD55C\uACC4\uB77C\uBA74 \uB2F9\uC7A5 \uD6C8\uB828\uC7A5 \uB098\uAC00\uB77C.
      \uAF34\uB3C4 \uBCF4\uAE30 \uC2EB\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Bluffer_201
    ko: "\uC228\uB2E4\uB2C8\uC694! \uC81C\uAC00 \uC5BC\uB9C8\uB098 \uC644\uBCBD\uD558\uAC8C
      \uD6C8\uB828\uD558\uB824\uACE0 \uB178\uB825 \uC911\uC778\uB370... \uADF8\uB7F0
      \uC2DD\uC73C\uB85C \uB9D0\uC500\uD558\uC2DC\uBA74 \uC800 \uC9C4\uC9DC \uC758\uC695
      \uC548 \uB0A9\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Bluffer_2
    ko: "\uB178\uB825\uC744 \uBE44\uAC81\uD568\uC73C\uB85C \uCE58\uBD80\uD558\uC790
      \uBAA8\uC695\uAC10\uC744 \uB290\uB07C\uBA70 \uB9C8\uC74C\uC744 \uB2EB\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Wild_201
    ko: "\uC228\uB294 \uAC8C \uC544\uB2C8\uC5D0\uC694. \uC798\uD558\uACE0 \uC2F6\uC5B4\uC11C
      \uADF8\uB7F0 \uAC74\uB370... \uC65C \uADF8\uB807\uAC8C \uBB34\uC12D\uAC8C \uB9D0\uC500\uD558\uC138\uC694?
      \uADF8\uB0E5 \uC5F0\uC2B5\uD558\uAC8C \uB0B4\uBC84\uB824 \uB450\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Wild_2
    ko: "\uB3C4\uBC1C\uC5D0 \uACF5\uD3EC\uB97C \uB290\uAEF4 \uBC29\uC5B4\uC801 \uD0DC\uB3C4\uB85C
      \uBCC0\uD574 \uD6A8\uC728\uC774 \uB5A8\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Egoist_201
    ko: "\uC81C \uD55C\uACC4\uB77C\uACE0\uC694? \uC81C \uC7A0\uC7AC\uB825\uC744 \uACE0\uC791
      \uC774 \uC815\uB3C4\uB85C \uBCF4\uC2DC\uB2E4\uB2C8. \uC88B\uC2B5\uB2C8\uB2E4,
      \uADF8 \uB9D0\uC774 \uD2C0\uB838\uB2E4\uB294 \uAC78 \uC81C \uBAB8\uC73C\uB85C
      \uC9C1\uC811 \uC99D\uBA85\uD574 \uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Egoist_2
    ko: "\uBE44\uD558\uC5D0 \uC2B9\uBD80\uC695\uC774 \uBC1C\uB3D9\uD574 \uC99D\uBA85\uD558\uB824
      \uD3ED\uBC1C\uC801 \uC5D0\uB108\uC9C0\uB97C \uC3DF\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Fighter_201
    ko: "\uD55C\uACC4? \uC81C\uAC00 \uC9C0\uAE08 \uBB34\uC11C\uC6CC \uBCF4\uC785\uB2C8\uAE4C?
      \uB2F9\uC7A5 \uACF5 \uB358\uC9C0\uC138\uC694. \uB204\uAC00 \uC774 \uCF54\uD2B8\uC758
      \uC8FC\uC778\uC778\uC9C0 \uBCF4\uC5EC\uB4DC\uB9B4 \uD14C\uB2C8\uAE4C! \uADFC\uB370
      \uC774 \uB9D0\uC740 \uCDE8\uC18C\uD558\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Fighter_2
    ko: "\uD22C\uC9C0\uB294 \uBD88\uD0C0\uB098 \uBE44\uD558 \uBD88\uB9CC \uB54C\uBB38\uC5D0
      \uC628\uC804\uD788 \uC9D1\uC911\uD558\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Ch_Instinct_003
    ko: "\uB178\uD2B8\uB97C \uCC22\uC5B4 \uC870\uAC01\uB09C \uC885\uC774\uB97C \uD769\uBFCC\uB9B0
      \uB4A4, \uC120\uC218\uB97C \uC3D8\uC544\uBCF4\uBA70 \uACF5\uC744 \uAC15\uD558\uAC8C
      \uBC14\uB2E5\uC5D0 \uD295\uACA8 \uBCF4\uB0B8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Bluffer_301
    ko: "\uC624, \uBC29\uAE08 \uCC22\uB294 \uD3EC\uC2A4 \uC7A5\uB09C \uC544\uB2CC\uB370\uC694?
      \uC800\uB3C4 \uB098\uC911\uC5D0 \uC800\uB807\uAC8C \uD574\uBD10\uC57C\uC9C0.
      \uADFC\uB370 \uC81C \uB178\uD2B8\uC5D0 \uD759 \uBB3B\uC740 \uAC74 \uC5B4\uB5BB\uAC8C
      \uD558\uC2E4 \uAC70\uC608\uC694?"
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Bluffer_3
    ko: "\uD30C\uACA9 \uD37C\uD3EC\uBA3C\uC2A4\uC5D0 \uAC10\uD0C4\uD558\uB098 \uBCF8\uC9C8\uBCF4\uB2E4
      \uAC89\uBAA8\uC2B5\uC5D0 \uB354 \uCE58\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Wild_301
    ko: "\uC2DC\uC6D0\uD558\uB124\uC694. \uC800\uB3C4 \uC774 \uC885\uC774 \uCABC\uAC00\uB9AC\uB4E4\uC774
      \uAC70\uC2AC\uB838\uAC70\uB4E0\uC694. \uD655 \uB09A\uC544\uCC44 \uBC84\uB9B4\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Wild_3
    ko: "\uD30C\uAD34 \uD589\uC704\uAC00 \uC57C\uC131\uC744 \uAE68\uC6CC \uC989\uAC01\uC801\uC778
      \uC2E0\uCCB4 \uBC18\uC751\uC73C\uB85C \uC804\uD658\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Egoist_301
    ko: "\uBB34\uB840\uD558\uC2DC\uB124\uC694. \uC81C \uBD84\uC11D \uC790\uB8CC\uB97C
      \uC774\uB807\uAC8C \uD30C\uAD34\uD558\uC2DC\uB294 \uAC74 \uC808 \uBB34\uC2DC\uD558\uB294
      \uCC98\uC0AC\uC785\uB2C8\uB2E4. \uC774\uB7F0 \uC2DD\uC774\uBA74 \uB354 \uC774\uC0C1
      \uAC10\uB3C5\uB2D8 \uC9C0\uB3C4\uB97C \uBC1B\uC744 \uC774\uC720\uAC00 \uC5C6\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Egoist_3
    ko: "\uB178\uB825\uC744 \uD568\uBD80\uB85C \uB2E4\uB8E8\uC790 \uCE68\uD574\uB85C
      \uC5EC\uACA8 \uAC15\uD55C \uC801\uAC1C\uC2EC\uC744 \uBCF4\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00017_Desc_Fighter_301
    ko: "...\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uB9D0\uBCF4\uB2E4 \uC774\uAC8C \uD6E8\uC52C
      \uBE60\uB974\uACA0\uB124\uC694. \uB2E4\uC2DC \uB358\uC9C0\uC138\uC694. \uBC15\uC0B4
      \uB0B4\uBC84\uB9B4 \uD14C\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00017_Rs_Fighter_3
    ko: "\uD30C\uAD34 \uD589\uC704\uAC00 \uD22C\uC7C1\uC2EC\uC744 \uAE68\uC6CC \uC7A1\uB150
      \uC5C6\uC774 \uC555\uB3C4\uC801\uC778 \uD798\uC744 \uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Discipline_001
    ko: "\uD6C8\uB828\uC7A5\uC5D0\uC11C \uAC00\uC774\uB4DC\uB77C\uC778\uACFC \uBC1C
      \uC704\uCE58\uB97C \uB300\uC870\uD558\uBA70 \uC218\uC9C1 \uC810\uD504\uB9CC
      \uBB34\uD55C \uBC18\uBCF5 \uC911\uC778 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Discipline_002
    ko: "\uD30C\uC6B8\uC744 \uBC94\uD588\uB2E4\uB294 \uC0AC\uC2E4\uC744 \uC6D0\uCE59\uC744
      \uC5B4\uAE34 \uC2E4\uD328\uB85C \uC815\uC758\uD558\uACE0, \uC644\uBCBD\uD55C
      90\uB3C4 \uB3C4\uC57D\uC5D0 \uC9D1\uCC29\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Discipline_003
    ko: "1cm\uC758 \uC624\uCC28\uB3C4 \uD5C8\uC6A9\uD558\uC9C0 \uC54A\uC73C\uB824\uB2E4
      \uBCF4\uB2C8 \uC815\uC791 \uD6C8\uB828\uC6A9 \uD53C\uB529 \uACF5\uC5D0\uB294
      \uBC18\uC751\uC870\uCC28 \uBABB \uD55C \uCC44,"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Discipline_004
    ko: "\uC790\uC2E0\uC758 \uB8E8\uD2F4\uC774 \uAE68\uC9C0\uBA74 \uCC98\uC74C\uBD80\uD130
      \uB2E4\uC2DC \uC790\uB9AC\uB97C \uC7A1\uB294 \uACBD\uC9C1\uB41C \uD0DC\uB3C4\uB97C
      \uBCF4\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Discipline_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00018_Ch_Discipline_001
    ko: 
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Principled_101
    ko: "\uC0C1\uB300\uC758 \uBCC0\uCE59 \uB300\uC751\uAE4C\uC9C0 \uC6D0\uCE59\uC5D0
      \uD3EC\uD568\uC2DC\uD0A8\uB2E4... \uC0C8\uB85C\uC6B4 \uC218\uC2DD\uC744 \uC5BB\uC740
      \uAE30\uBD84\uC774\uAD70\uC694. \uC989\uC2DC \uC81C \uC218\uBE44 \uB8E8\uD2F4\uC5D0
      \uC5C5\uB370\uC774\uD2B8\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Principled_1
    ko: "\uACB0\uACFC: GREAT (Resultdata \uCC38\uC870)"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Guardian_101
    ko: "\uBCC0\uCE59 \uB300\uC751\uB3C4 \uC88B\uC9C0\uB9CC, \uAE30\uBCF8\uC778 \uC2E4\uB9B0\uB354
      \uC6D0\uCE59\uC774 \uD754\uB4E4\uB9AC\uBA74 \uD300\uC758 \uC218\uBE44 \uAE30\uAC15
      \uC790\uCCB4\uAC00 \uBB34\uB108\uC9D1\uB2C8\uB2E4. \uC804 \uB05D\uAE4C\uC9C0
      90\uB3C4\uB97C \uC218\uD638\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Guardian_1
    ko: "\uACB0\uACFC: FAIL (Resultdata \uCC38\uC870)"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Tactician_101
    ko: "\uB17C\uB9AC\uC801\uC778 \uC81C\uC548\uC774\uAE34 \uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC
      \uB370\uC774\uD130\uAC00 \uC313\uC774\uAE30 \uC804\uAE4C\uC9C4 \uC81C \uC218\uC9C1
      \uC810\uD504 \uC218\uCE58\uB97C \uBBFF\uC744 \uC218\uBC16\uC5D0 \uC5C6\uB124\uC694.
      \uC2DC\uAC04\uC744 \uB354 \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Tactician_1
    ko: "\uACB0\uACFC: None (Resultdata \uCC38\uC870)"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Exemplary_101
    ko: "\uC798\uD558\uACE0 \uC788\uB2E4\uB294 \uACA9\uB824\uB294 \uD798\uC774 \uB418\uC9C0\uB9CC,
      \uD30C\uC6B8\uC744 \uBC94\uD55C \uC81C\uAC00 \uBAA8\uBC94\uC774 \uB420 \uC21C
      \uC5C6\uC2B5\uB2C8\uB2E4. \uC644\uBCBD\uD55C 90\uB3C4\uB97C \uC644\uC131\uD574
      \uBCF8\uBCF4\uAE30\uAC00 \uB418\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Exemplary_1
    ko: "\uACB0\uACFC: None (Resultdata \uCC38\uC870)"
    en: 
    ja: 
  - stringKey: Event_00018_Ch_Discipline_002
    ko: 
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Principled_201
    ko: "\uB9D0\uB69D\uC774\uB77C\uB1E8. \uC6D0\uCE59\uC774 \uBB34\uB108\uC9C0\uBA74
      \uC218\uBE44 \uC804\uCCB4\uAC00 \uBB34\uB108\uC9D1\uB2C8\uB2E4. \uC804 \uC81C
      \uC218\uC9C1\uC131\uC774 \uC644\uBCBD\uD574\uC9C8 \uB54C\uAE4C\uC9C0 \uC774
      \uD6C8\uB828\uC744 \uBA48\uCD9C \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Principled_2
    ko: "\uACB0\uACFC: None (Resultdata \uCC38\uC870)"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Guardian_201
    ko: "\uD6C8\uB828 \uD750\uB984\uBCF4\uB2E4 \uC911\uC694\uD55C \uAC74 \uC644\uBCBD\uD55C
      \uADDC\uC728\uC758 \uC774\uD589\uC785\uB2C8\uB2E4. \uC81C\uAC00 \uAD6C\uBA4D\uC774
      \uB418\uC9C0 \uC54A\uC73C\uB824\uBA74 \uC774 \uC6D0\uCE59\uC744 \uC0AC\uC218\uD574\uC57C\uB9CC
      \uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Guardian_2
    ko: "\uACB0\uACFC: None (Resultdata \uCC38\uC870)"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Tactician_201
    ko: "\uC81C \uAC15\uBC15\uC774 \uC804\uC220\uC801 \uD6A8\uC728\uC744 \uB5A8\uC5B4\uB728\uB9AC\uACE0
      \uC788\uC5C8\uAD70\uC694. \uB9D0\uB69D \uC218\uBE44\uB294 \uC804\uC220\uC801
      \uAC00\uCE58\uAC00 \uC5C6\uB2E4\uB294 \uC9C0\uC801, \uC218\uC6A9\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uC720\uC5F0\uD558\uAC8C \uC6C0\uC9C1\uC774\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Tactician_2
    ko: "\uACB0\uACFC: GREAT (Resultdata \uCC38\uC870)"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Exemplary_201
    ko: "\uB3D9\uB8CC\uB4E4 \uC55E\uC5D0\uC11C \uC808 \uADF8\uB807\uAC8C \uB9DD\uC2E0
      \uC8FC\uC154\uC57C \uD588\uC2B5\uB2C8\uAE4C? \uC804 \uADF8\uC800 \uADDC\uCE59\uC744
      \uAC00\uC7A5 \uC798 \uC9C0\uD0A4\uB294 \uC120\uC218\uAC00 \uB418\uACE0 \uC2F6\uC5C8\uC744
      \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Exemplary_2
    ko: "\uACB0\uACFC: FAIL (Resultdata \uCC38\uC870)"
    en: 
    ja: 
  - stringKey: Event_00018_Ch_Discipline_003
    ko: 
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8! \uC9C0\uAE08 \uC81C \uD6C8\uB828\uC758 \uAE30\uC900\uC810\uC744
      \uD30C\uAD34\uD558\uC2E0 \uAC81\uB2C8\uAE4C? \uADFC\uAC70\uAC00 \uC0AC\uB77C\uC9C4
      \uC0C1\uD0DC\uC5D0\uC11C \uC5B4\uB5BB\uAC8C \uC62C\uBC14\uB978 \uC790\uC138\uB97C
      \uC720\uC9C0\uD558\uB77C\uB294 \uAC70\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Principled_3
    ko: "\uACB0\uACFC: FAIL (Resultdata \uCC38\uC870)"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Guardian_301
    ko: "...\uADDC\uC728\uC758 \uD615\uD0DC\uAC00 \uC544\uB2CC, \uACB0\uACFC\uB85C
      \uC99D\uBA85\uD558\uB77C\uB294 \uB73B\uC785\uB2C8\uAE4C. \uC774\uC81C \uBAB8\uC73C\uB85C
      \uACE8\uBC11\uC744 \uC218\uD638\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Guardian_3
    ko: "\uACB0\uACFC: GREAT (Resultdata \uCC38\uC870)"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Tactician_301
    ko: "\uC804\uC220\uC801\uC778 \uB300\uC548\uB3C4 \uC5C6\uC774 \uAC00\uC774\uB4DC\uB77C\uC778\uBD80\uD130
      \uC5C6\uC560\uC2DC\uBA74 \uC5B4\uB5A1\uD569\uB2C8\uAE4C? \uC774\uAC74 \uD6A8\uC728\uC801\uC778
      \uD6C8\uB828 \uBC29\uC2DD\uC774 \uC544\uB2D9\uB2C8\uB2E4. \uBE44\uD569\uB9AC\uC801\uC774\uC5D0\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Tactician_3
    ko: "\uACB0\uACFC: FAIL (Resultdata \uCC38\uC870)"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Exemplary_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uBAB8\uC73C\uB85C \uAC00\uB974\uCCD0\uC8FC\uC2E0
      \uC774 \uAC10\uAC01\uC774 \uC0C8\uB85C\uC6B4 \uAE30\uC900\uC774\uAD70\uC694.
      \uC815\uC11D\uC758 \uD2C0\uC744 \uAE68\uACE0 \uB2E4\uC2DC \uC2DC\uC791\uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Exemplary_3
    ko: "\uD589\uB3D9\uC744 \uC0C8 \uBAA8\uBC94\uC73C\uB85C \uC815\uC758\uD558\uACE0
      \uC2E0\uCCB4\uC801 \uAE30\uC900\uC5D0 \uC989\uAC01 \uB3D9\uD654\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Bond_001
    ko: "\uD6C8\uB828\uC7A5\uC5D0\uC11C \uAC00\uC774\uB4DC\uB77C\uC778\uACFC \uBC1C
      \uC704\uCE58\uB97C \uB300\uC870\uD558\uBA70 \uC218\uC9C1 \uC810\uD504\uB9CC
      \uBB34\uD55C \uBC18\uBCF5 \uC911\uC778 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Bond_002
    ko: "\uADF8\uB294 \uC790\uC2E0\uC758 \uD30C\uC6B8\uC774 \uD300\uC758 \uC218\uBE44
      \uB77C\uC778\uC744 \uBB34\uB108\uB728\uB838\uB2E4\uB294 \uC8C4\uCC45\uAC10\uC5D0
      \uC2DC\uB2EC\uB9AC\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Bond_003
    ko: "\uC2E4\uB9B0\uB354 \uC6D0\uCE59\uC774\uB77C\uB294 \uADDC\uC728\uC744 \uC644\uBCBD\uD788
      \uC9C0\uD0A4\uB294 \uAC83\uB9CC\uC774 \uB3D9\uB8CC\uB4E4\uC5D0\uAC8C \uC0AC\uC8C4\uD558\uB294
      \uAE38\uC774\uB77C \uBBFF\uAE30\uC5D0 90\uB3C4 \uAC01\uB3C4\uC5D0 \uC9D1\uCC29\uD558\uC9C0\uB9CC,"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Bond_004
    ko: " \uADF8 \uACBD\uC9C1\uB41C \uD0DC\uB3C4\uAC00 \uC624\uD788\uB824 \uD6C8\uB828
      \uD750\uB984\uC744 \uBC29\uD574\uD558\uC790 \uB354 \uD070 \uBBF8\uC548\uD568\uACFC
      \uC790\uCC45\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Bond_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00018_Ch_Bond_001
    ko: "90\uB3C4 \uAC01\uB3C4\uBCF4\uB2E4 \uD300\uC744 \uC0DD\uAC01\uD558\uB294
      \uB124 \uC9C4\uC2EC\uC774 \uB354 \uC911\uC694\uD558\uB2E4. \uC2E4\uC218\uD574\uB3C4
      \uAD1C\uCC2E\uC73C\uB2C8 \uACE0\uAC1C \uC219\uC774\uC9C0 \uB9C8\uB77C."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uADF8\uB807\uAC8C \uB9D0\uC500\uD574 \uC8FC\uC2DC\uB2C8
      \uC815\uB9D0 \uD798\uC774 \uB098\uC694. \uC81C\uAC00 \uB354 \uBC1D\uC740 \uBAA8\uC2B5\uC73C\uB85C
      \uD300\uC5D0 \uB3C4\uC6C0\uC774 \uB420 \uC218 \uC788\uB3C4\uB85D \uB2E4\uC2DC
      \uB178\uB825\uD560\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Kind_1
    ko: "\uC790\uCC45\uAC10\uC744 \uD138\uC5B4\uB0B4\uACE0 \uB2E4\uC2DC \uC2DC\uC791\uD560
      \uB3D9\uB825\uC744 \uC5BB\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Loyal_101
    ko: "\uACA9\uB824\uB294 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uC81C\uAC00 \uC2E4\uB825\uC744
      \uC99D\uBA85\uD558\uC9C0 \uBABB\uD55C\uB2E4\uBA74 \uADF8 \uACA9\uB824\uB97C
      \uBC1B\uC744 \uC790\uACA9\uC774 \uC5C6\uB2E4\uACE0 \uC0DD\uAC01\uD569\uB2C8\uB2E4.
      \uC644\uBCBD\uD574\uC9C4 \uB4A4\uC5D0 \uCE6D\uCC2C\uBC1B\uACE0 \uC2F6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Loyal_1
    ko: "\uB9E4\uB274\uC5BC \uC9D1\uCC29\uC744 \uBC84\uB9AC\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Sincere_101
    ko: "\uC704\uB85C\uD574 \uC8FC\uC2DC\uB294 \uAC74 \uC88B\uC9C0\uB9CC, \uACB0\uAD6D
      \uC81C\uAC00 \uC774 \uB3D9\uC791\uC744 \uB9C8\uC2A4\uD130\uD558\uC9C0 \uBABB\uD558\uBA74
      \uB0B4\uC77C \uD6C8\uB828\uC5D0\uC11C\uB3C4 \uB611\uAC19\uC740 \uC2E4\uC218\uB97C
      \uBC18\uBCF5\uD560 \uAC81\uB2C8\uB2E4. \uC804 \uB354 \uC5F0\uC2B5\uD574\uC57C
      \uD574\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Sincere_1
    ko: "\uD6C8\uB828 \uACE0\uC9D1\uC744 \uAEBE\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Moodmaker_101
    ko: "\uAC10\uB3C5\uB2D8\uAE4C\uC9C0 \uADF8\uB807\uAC8C \uC9C4\uC9C0\uD558\uAC8C
      \uB9D0\uC500\uD558\uC2DC\uB2C8\uAE4C \uB354 \uBD80\uB2F4\uC2A4\uB7EC\uC6CC\uC694.
      \uADF8\uB0E5 \uC81C\uAC00 \uC54C\uC544\uC11C \uD138\uACE0 \uC77C\uC5B4\uB0A0
      \uD14C\uB2C8\uAE4C \uB108\uBB34 \uC2E0\uACBD \uC4F0\uC9C0 \uB9C8\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Moodmaker_1
    ko: "\uC0C1\uD669\uC744 \uD68C\uD53C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Ch_Bond_002
    ko: "\uAC01\uB3C4 \uC9C0\uD0A4\uB290\uB77C \uD6C8\uB828 \uD750\uB984\uC744 \uB04A\uB294
      \uAC74 \uD300\uC6CC\uD06C\uAC00 \uC544\uB2C8\uB2C8 \uAC1C\uC778 \uB9CC\uC871\uBCF4\uB2E4
      \uD300 \uB9AC\uB4EC\uC744 \uBA3C\uC800 \uC0DD\uAC01\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Kind_201
    ko: "\uC81C\uAC00 \uD300\uC758 \uB9AC\uB4EC\uC744 \uB9DD\uCE58\uACE0 \uC788\uC5C8\uB2E4\uB2C8...
      \uC815\uB9D0 \uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uC81C\uAC00 \uC5C6\uC5B4\uC57C
      \uD300\uC774 \uB354 \uC798 \uB3CC\uC544\uAC08 \uAC83 \uAC19\uB2E4\uB294 \uC0DD\uAC01\uC774
      \uB4E4\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Kind_2
    ko: "\uADF9\uC2EC\uD55C \uC790\uAE30 \uBE44\uD558\uC5D0 \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Loyal_201
    ko: "\uBA85\uC2EC\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uC81C \uACE0\uC9D1\uC774 \uD300\uC758
      \uC9C8\uC11C\uB97C \uC5B4\uC9C0\uB7FD\uD614\uAD70\uC694. \uAC1C\uC778\uC801\uC778
      \uAC15\uBC15\uC740 \uBC84\uB9AC\uACE0 \uD300\uC758 \uC2B9\uB9AC\uB77C\uB294
      \uB300\uC758\uB97C \uC704\uD574 \uC6C0\uC9C1\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Loyal_2
    ko: "\uC989\uC2DC \uAC1C\uC778\uC758 \uD0DC\uB3C4\uB97C \uC218\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Sincere_201
    ko: "\uD750\uB984\uC744 \uB04A\uC73C\uB824\uB358 \uAC8C \uC544\uB2C8\uB77C \uB354
      \uC644\uBCBD\uD558\uAC8C \uD558\uACE0 \uC2F6\uC5B4\uC11C \uADF8\uB7AC\uB358
      \uAC81\uB2C8\uB2E4. \uC81C \uC9C4\uC9C0\uD55C \uB178\uB825\uC744 \uADF8\uB807\uAC8C
      \uD3C9\uAC00\uD558\uC2DC\uB2E4\uB2C8 \uC5B5\uC6B8\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Sincere_2
    ko: "\uB9C8\uC74C\uC758 \uBB38\uC744 \uB2EB\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Moodmaker_201
    ko: "\uC5D0\uC774, \uC81C\uAC00 \uBB34\uC2A8 \uD750\uB984\uC744 \uB2E4 \uB04A\uC5C8\uB2E4\uACE0
      \uADF8\uB7EC\uC138\uC694. \uC54C\uC558\uC5B4\uC694, \uC54C\uC558\uC5B4! \uB2E4\uC2DC
      \uBC1D\uAC8C \uAC00\uBCF4\uC790\uACE0\uC694. \uC790, \uB2E4\uB4E4 \uD30C\uC774\uD305\uD569\uC2DC\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Moodmaker_2
    ko: "\uC9D1\uC911\uB825\uC774 \uB5A8\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Ch_Bond_003
    ko: "\uAC00\uC774\uB4DC\uB77C\uC778 \uD14C\uC774\uD504\uB97C \uB72F\uC5B4\uB0B4\uACE0,
      \uB2F9\uD669\uD55C \uC120\uC218\uC758 \uC5B4\uAE68\uB97C \uD22D \uCE58\uBA70
      \uD568\uAED8 \uBE14\uB85D \uACBD\uD569 \uD6C8\uB828\uC744 \uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uB3C4\uC640\uC8FC\uC2DC\uB2C8 \uAC10\uC0AC\uD558\uAE34
      \uD55C\uB370, \uC800 \uB54C\uBB38\uC5D0 \uAC10\uB3C5\uB2D8\uAE4C\uC9C0 \uACE0\uC0DD\uD558\uC2DC\uB294
      \uAC83 \uAC19\uC544 \uB9C8\uC74C\uC774 \uD3B8\uCE58 \uC54A\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Kind_3
    ko: "\uC628\uC804\uD788 \uC9D1\uC911\uD558\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8! \uD6C8\uB828\uC740 \uC5C4\uACA9\uD574\uC57C \uD569\uB2C8\uB2E4.
      \uC774\uB807\uAC8C \uAC10\uC815\uC801\uC73C\uB85C \uBAB8\uC744 \uC11E\uB294
      \uAC83\uBCF4\uB2E4 \uC81C\uAC00 \uC815\uD574\uC9C4 \uB8E8\uD2F4\uC744 \uB05D\uB9C8\uCE58\uB3C4\uB85D
      \uC5C4\uD558\uAC8C \uC9C0\uB3C4\uD574 \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Loyal_3
    ko: "\uD6C8\uB828 \uAE30\uAC15\uC744 \uD574\uCE58\uB294 \uD589\uC704\uB85C \uAC04\uC8FC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Sincere_301
    ko: "\uC544... \uBAB8\uC73C\uB85C \uC9C1\uC811 \uBD80\uB52A\uCCD0\uBCF4\uB2C8
      90\uB3C4 \uC218\uCE58\uC5D0 \uC5C6\uB358 \uBB34\uAC8C\uAC10\uC774 \uB290\uAEF4\uC9C0\uB124\uC694.
      \uAC10\uB3C5\uB2D8\uC774 \uAC00\uB974\uCCD0\uC8FC\uC2E0 \uC774 \uAC10\uAC01\uC744
      \uC81C \uBAB8\uC5D0 \uB2E4\uC2DC \uC0C8\uACA8\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Sincere_3
    ko: "\uC0C8\uB85C\uC6B4 \uD6C8\uB828 \uC9C0\uCE68\uC744 \uC131\uC2E4\uD788 \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Moodmaker_301
    ko: "\uC640! \uAC10\uB3C5\uB2D8 \uBAB8\uC2F8\uC6C0 \uC9C4\uC9DC \uC7A5\uB09C
      \uC544\uB2C8\uC2E0\uB370\uC694? \uC800 \uB9AC\uC561\uC158 \uC81C\uB300\uB85C
      \uD560 \uBED4\uD588\uC796\uC544\uC694! \uC5ED\uC2DC \uD6C8\uB828\uC740 \uC774\uB807\uAC8C
      \uC990\uAC81\uAC8C \uBAB8\uC73C\uB85C \uD574\uC57C \uC81C\uB9DB\uC774\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Moodmaker_3
    ko: "\uAC00\uC7A5 \uD65C\uBC1C\uD558\uAC8C \uBC18\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Cold_001
    ko: "\uD6C8\uB828\uC7A5\uC5D0\uC11C \uAC00\uC774\uB4DC\uB77C\uC778\uACFC \uBC1C
      \uC704\uCE58\uB97C \uB300\uC870\uD558\uBA70 \uC218\uC9C1 \uC810\uD504\uB9CC
      \uBB34\uD55C \uBC18\uBCF5 \uC911\uC778 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Cold_002
    ko: "\uADF8\uB294 \uD30C\uC6B8\uC744 \uB17C\uB9AC\uC801 \uC124\uACC4\uC758 \uC2E4\uD328\uB85C
      \uC815\uC758\uD558\uACE0, \uC644\uBCBD\uD55C 90\uB3C4 \uC218\uC9C1\uC131\uC744
      \uAD6C\uD604\uD558\uB294 \uAC83\uC5D0\uB9CC \uB9E4\uBAB0\uB418\uC5B4 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Cold_003
    ko: "1cm\uC758 \uC624\uCC28\uB3C4 \uD5C8\uC6A9\uD558\uC9C0 \uC54A\uC73C\uB824\uB2E4
      \uBCF4\uB2C8 \uC815\uC791 \uD53C\uB529\uB418\uB294 \uACF5\uC5D0\uB294 \uBC18\uC751\uD558\uC9C0
      \uBABB\uD558\uBA70, "
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Cold_004
    ko: "\uB8E8\uD2F4\uC774 \uC870\uAE08\uC774\uB77C\uB3C4 \uC5B4\uAE0B\uB098\uBA74
      \uCC98\uC74C\uBD80\uD130 \uB2E4\uC2DC \uC790\uB9AC\uB97C \uC7A1\uB294 \uADF9\uB3C4\uB85C
      \uACBD\uC9C1\uB41C \uD0DC\uB3C4\uB97C \uBCF4\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Cold_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00018_Ch_Cold_001
    ko: "\uC624\uCC28\uB294 \uC0C1\uB300\uC758 \uC6C0\uC9C1\uC784\uC774\uB780 \uBCC0\uC218\uB97C
      \uBE7C\uBA39\uC5C8\uAE30 \uB54C\uBB38\uC774\uB2C8 \uBCC0\uB3D9\uAC12\uAE4C\uC9C0
      \uACC4\uC0B0\uC5D0 \uB123\uC73C\uBA74 \uC644\uBCBD\uD574\uC9C8 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Planner_101
    ko: "\uC0C1\uB300\uC758 \uC6C0\uC9C1\uC784\uC744 \uBCC0\uB3D9 \uC218\uCE58\uB85C
      \uB300\uC785\uD55C\uB2E4... \uD655\uC2E4\uD788 \uC81C\uAC00 \uACE0\uC815 \uB370\uC774\uD130\uC5D0\uB9CC
      \uCE58\uC911\uD588\uAD70\uC694. \uADF8 \uBCC0\uC218\uAE4C\uC9C0 \uD3EC\uD568\uD574\uC11C
      \uC218\uBE44 \uB85C\uC9C1\uC744 \uB2E4\uC2DC \uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Planner_1
    ko: "\uC989\uAC01 \uB0A9\uB4DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Opportunist_101
    ko: "\uACA9\uB824\uB294 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uC81C\uAC00 \uC774 \uC218\uC9C1\uC131\uC744
      \uB9C8\uC2A4\uD130\uD558\uC9C0 \uBABB\uD558\uBA74 \uB2E4\uC74C \uACBD\uAE30\uC5D0\uC11C
      \uC81C \uAC00\uCE58\uB97C \uC99D\uBA85\uD560 \uAE30\uD68C\uB97C \uC783\uAC8C
      \uB429\uB2C8\uB2E4. \uC644\uBCBD\uD574\uC838\uC57C \uD574\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Opportunist_1
    ko: "\uC790\uC2E0\uC5D0\uAC8C \uB354 \uC774\uB4DD\uC774\uB77C\uACE0 \uD310\uB2E8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Cunning_101
    ko: "\uACA9\uB824\uB77C\uB2C8, \uAC11\uC790\uAE30 \uC65C \uC774\uB807\uAC8C \uCE5C\uC808\uD558\uC2DC\uC8E0?
      \uC81C \uC2E4\uC218\uB97C \uB36E\uC5B4\uC8FC\uB294 \uCC99 \uB098\uC911\uC5D0
      \uB354 \uD070 \uCC45\uC784\uC744 \uBB3C\uC73C\uC2DC\uB824\uB294 \uAC74 \uC544\uB2C8\uACE0\uC694?"
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Cunning_1
    ko: "\uBC29\uC5B4\uC801\uC73C\uB85C \uBC18\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Believer_101
    ko: "\uBCC0\uC218 \uD0D3\uC774 \uC544\uB2D9\uB2C8\uB2E4. \uC81C \uC218\uC9C1
      \uC6D0\uCE59\uC774 \uC544\uC9C1 \uC644\uBCBD\uD558\uAC8C \uAD6C\uD604\uB418\uC9C0
      \uC54A\uC558\uC744 \uBFD0\uC785\uB2C8\uB2E4. \uC800\uB294 \uC81C \uBC29\uC2DD\uB300\uB85C
      \uACB0\uACFC\uB97C \uB0B4\uBCF4\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Believer_1
    ko: "\uC6D0\uCE59\uC5D0 \uB300\uD55C \uB3C4\uC804\uC73C\uB85C \uBC1B\uC544\uB4E4\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Ch_Cold_002
    ko: "\uC218\uCE58\uC5D0 \uB9E4\uBAB0\uB3FC \uC0C1\uD669\uB3C4 \uBABB \uC77D\uB294
      \uAC74 \uBB34\uB2A5\uD55C \uAE30\uACC4\uC77C \uBFD0\uC774\uB2C8 \uB2F9\uC7A5
      \uADF8 \uBA4D\uCCAD\uD55C \uB8E8\uD2F4 \uCE58\uC6CC\uB77C."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Planner_201
    ko: "\uBB34\uB2A5\uD55C \uAE30\uACC4\uB77C\uB2C8\uC694. \uD655\uB960\uC801\uC73C\uB85C
      \uAC00\uC7A5 \uC548\uC804\uD55C \uC218\uC9C1\uC131\uC744 \uD655\uBCF4\uD558\uB824\uB294
      \uAC81\uB2C8\uB2E4. \uC81C \uC124\uACC4\uC758 \uC2E0\uB8B0\uB3C4\uB97C \uB192\uC77C
      \uC2DC\uAC04\uC744 \uB354 \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Planner_2
    ko: "\uB17C\uB9AC\uC801 \uACE0\uC9D1\uC774 \uC55E\uC130\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Opportunist_201
    ko: "\uC2B9\uB9AC\uB97C \uB193\uCE58\uB294 \uC804\uB7B5\uAC00\uB294 \uAC00\uCE58\uAC00
      \uC5C6\uB2E4\uB294 \uB9D0\uC500\uC774\uC2DC\uAD70\uC694. \uC774 90\uB3C4 \uAC01\uB3C4\uAC00
      \uC81C \uBAB8\uAC12\uC744 \uAE4E\uC544\uBA39\uB294\uB2E4\uBA74 \uBBF8\uB828
      \uC5C6\uC774 \uBC84\uB9AC\uACE0 \uC774\uAE30\uB294 \uC218\uBE44\uB97C \uCC3E\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Opportunist_2
    ko: "\uC2E4\uB9AC\uC801\uC778 \uD0DC\uB3C4\uB85C \uC804\uD658\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Cunning_201
    ko: "\uD6A8\uC728? \uC81C\uAC00 \uC815\uC11D\uB300\uB85C \uD55C \uAC74 \uB098\uC911\uC5D0
      \uD30C\uC6B8\uC774 \uB098\uC640\uB3C4 \uB09C \uAC00\uB974\uCE5C \uB300\uB85C
      \uD588\uB2E4\uACE0 \uBC1C\uBE8C\uD558\uAE30 \uC704\uD574\uC11C\uC600\uB294\uB370,
      \uADF8\uAC78 \uBB34\uB2A5\uC73C\uB85C \uBAB0\uC544\uC138\uC6B0\uC2DC\uBA74
      \uACE4\uB780\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Cunning_2
    ko: "\uAC10\uB3C5\uACFC \uAE30 \uC2F8\uC6C0\uC744 \uBC8C\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Believer_201
    ko: "\uBB34\uB2A5\uD55C \uAE30\uACC4\uB77C \uBE44\uB09C\uD558\uC154\uB3C4 \uC81C
      \uC2E0\uB150\uC740 \uBCC0\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4. \uB2E4\uB9CC,
      \uD6A8\uC728\uC774 \uB5A8\uC5B4\uC9C4\uB2E4\uB294 \uC9C0\uC801\uC740 \uAC80\uD1A0\uD574
      \uBCFC \uAC00\uCE58\uAC00 \uC788\uACA0\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Believer_2
    ko: "\uD55C \uBC1C \uBB3C\uB7EC\uB098 \uACE0\uBBFC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Ch_Cold_003
    ko: "\uAC00\uC774\uB4DC\uB77C\uC778 \uD14C\uC774\uD504\uB97C \uB72F\uC5B4\uB0B4\uACE0
      \uBC14\uB2E5\uC5D0 \uD769\uBFCC\uB9B0 \uB4A4, \uB6AB\uC5B4\uC9C8 \uB4EF \uC751\uC2DC\uD558\uBA70
      \uACF5\uC744 \uBC1C\uB85C \uCC28\uC11C \uBCF4\uB0B8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Planner_301
    ko: "\uC9C0\uAE08 \uBB34\uC2A8 \uC9D3\uC744... \uC81C \uBAA8\uB4E0 \uBD84\uC11D
      \uAE30\uC900\uC810\uC774 \uC0AC\uB77C\uC84C\uC2B5\uB2C8\uB2E4. \uC88C\uD45C
      \uC5C6\uC774 \uC5B4\uB5BB\uAC8C \uC218\uC9C1 \uB3C4\uC57D\uC744 \uC124\uACC4\uD558\uB77C\uB294
      \uB9D0\uC500\uC785\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Planner_3
    ko: "\uACF5\uD3EC\uC640 \uC0C1\uC2E4\uAC10\uC744 \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Opportunist_301
    ko: "\uB300\uC548\uB3C4 \uC5C6\uC774 \uC790\uB8CC\uB97C \uC5C6\uC560\uC2DC\uB2E4\uB2C8...
      \uD558\uC9C0\uB9CC \uAC10\uB3C5\uB2D8\uC758 \uBB34\uC5B8\uC758 \uC555\uBC15\uC774
      \uB354 \uD070 \uB9AC\uC2A4\uD06C\uB77C\uB294 \uAC74 \uC54C\uACA0\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Opportunist_3
    ko: "\uC77C\uB2E8 \uC9C0\uC2DC\uC5D0 \uB530\uB790\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Cunning_301
    ko: "\uB9D0\uBCF4\uB2E4 \uD655\uC2E4\uD558\uC2DC\uB124\uC694. \uAE30\uC900\uC120
      \uB530\uC704\uB294 \uD544\uC694 \uC5C6\uB2E4\uB294 \uB73B\uC774\uACA0\uC8E0.
      \uC7AC\uBBF8\uC788\uC5B4\uC9C0\uB124\uC694. \uD310\uC744 \uD754\uB4E4\uC5B4\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Cunning_3
    ko: "\uC218\uB2E8\uC744 \uAC00\uB9AC\uC9C0 \uB9D0\uB77C\uB294 \uC2E0\uD638\uB85C
      \uC774\uD574\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Believer_301
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uC774\uC804\uC758 \uC88C\uD45C\uB294 \uD3D0\uAE30\uD558\uACE0
      \uC0C8\uB85C\uC6B4 \uC815\uB2F5\uC744 \uCC3E\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Believer_3
    ko: "\uC989\uC2DC \uB2E4\uC74C \uB17C\uB9AC\uB97C \uAD6C\uCD95\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Instinct_001
    ko: "\uD6C8\uB828\uC7A5\uC5D0\uC11C 90\uB3C4 \uC218\uC9C1 \uC810\uD504\uC5D0\uB9CC
      \uB9E4\uBAB0\uB41C \uC120\uC218\uC785\uB2C8\uB2E4. \uADF8\uB294 \uD30C\uC6B8\uC774\uB77C\uB294
      \uC624\uB2F5\uC744 \uB0C8\uB2E4\uB294 \uC0AC\uC2E4\uC5D0 \uBCF8\uB2A5\uC801\uC778
      \uAC70\uBD80\uAC10\uC744 \uB290\uB07C\uBA70,"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Instinct_002
    ko: "\uC644\uBCBD\uD55C \uC218\uCE58\uB97C \uAD6C\uD604\uD558\uB294 \uAC83\uC73C\uB85C
      \uC790\uC2E0\uC758 \uC2E4\uC218\uB97C \uB36E\uC73C\uB824 \uD569\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uADF8 \uAC15\uBC15 \uB54C\uBB38\uC5D0 \uBAB8\uC758 \uBC18\uC751
      \uC18D\uB3C4\uAC00 \uD604\uC800\uD788 \uB5A8\uC5B4\uC84C\uC73C\uBA70,"
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Instinct_003
    ko: "\uB8E8\uD2F4\uC5D0 \uC9D1\uCC29\uD558\uB290\uB77C \uC815\uC791 \uB208\uC55E\uC758
      \uACF5\uC744 \uB193\uCE58\uB294 \uC8FC\uAC1D\uC804\uB3C4\uB41C \uC0C1\uD669\uC5D0
      \uB193\uC5EC \uAC70\uCE5C \uC228\uB9CC \uBAB0\uC544\uC26C\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Instinct_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00018_Ch_Instinct_001
    ko: "90\uB3C4 \uC218\uCE58 \uB530\uC704\uAC00 \uB124 \uBAB8\uBCF4\uB2E4 \uBE60\uB97C
      \uB9AC \uC5C6\uC73C\uB2C8 \uB124 \uD53C\uAC00 \uB053\uB294 \uB300\uB85C \uACF5\uC744
      \uC9D3\uB20C\uB7EC\uBC84\uB824\uB77C."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Bluffer_101
    ko: "\uC81C \uBAB8\uC774 \uB9E4\uB274\uC5BC\uBCF4\uB2E4 \uBE60\uB974\uB2E4\uB294
      \uB9D0, \uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uC808 \uC544\uC2DC\uB124\uC694!
      \uC774\uB7F0 \uC2DC\uC2DC\uD55C \uADDC\uCE59\uB4E4\uC740 \uC81C \uD654\uB824\uD55C
      \uAC10\uAC01\uC744 \uB2F4\uAE30\uC5D4 \uB108\uBB34 \uC881\uC8E0. \uB2E4\uC2DC
      \uBCF4\uC2DC\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Bluffer_1
    ko: "\uC989\uC2DC \uAE30\uC138\uB97C \uD68C\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Wild_101
    ko: "\uBAB8\uC774 \uB098\uAC00\uB294 \uB300\uB85C... \uD558\uC9C0\uB9CC \uAC10\uB3C5\uB2D8\uC774
      \uC6D0\uCE59\uB300\uB85C \uD558\uB77C\uACE0 \uD558\uC168\uC796\uC544\uC694.
      \uAC11\uC790\uAE30 \uBC14\uAFB8\uB77C\uACE0 \uD558\uC2DC\uBA74 \uBA38\uB9BF\uC18D\uC774
      \uB354 \uBCF5\uC7A1\uD574\uC838\uC11C \uBABB \uD558\uACA0\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Wild_1
    ko: "\uD63C\uB780\uC2A4\uB7EC\uC6CC\uD558\uBA70 \uBA38\uBB47\uAC70\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Egoist_101
    ko: "\uC81C \uD798\uC740 \uC81C\uAC00 \uC81C\uC77C \uC798 \uC555\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC644\uBCBD\uD55C \uC218\uC9C1\uC131\uC744 \uC775\uD600\uC57C
      \uC81C \uC2E4\uB825\uC774 \uC644\uC131\uB418\uC8E0. \uAC10\uAC01\uC5D0\uB9CC
      \uC758\uC874\uD558\uB294 \uAC74 \uD558\uC218\uB4E4\uC774\uB098 \uD558\uB294
      \uC9D3\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Egoist_1
    ko: "\uC800\uAE09\uD55C \uC870\uC5B8\uC73C\uB85C \uCE58\uBD80\uD558\uACE0 \uBB34\uC2DC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Fighter_101
    ko: "\uD53C\uAC00 \uB053\uAE34 \uD558\uB294\uB370... \uC804 \uC774 90\uB3C4\uB77C\uB294
      \uB188\uC744 \uC815\uBCF5\uD558\uC9C0 \uBABB\uD558\uBA74 \uBD84\uD574\uC11C
      \uC7A0\uC774 \uC548 \uC62C \uAC83 \uAC19\uC544\uC694. \uC77C\uB2E8 \uC774 \uC218\uCE58\uBD80\uD130
      \uC774\uAE30\uACE0 \uC62C\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Fighter_1
    ko: "\uB2E4\uB978 \uC81C\uC548\uC774 \uB4E4\uB9AC\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Ch_Instinct_002
    ko: "\uC218\uD559 \uBB38\uC81C \uD480 \uAC70\uBA74 \uB2F9\uC7A5 \uB098\uAC00\uB77C.
      \uC2E4\uD328\uAC00 \uBB34\uC11C\uC6CC \uC228\uB294 \uAC70\uBA74 \uD3C9\uC0DD
      \uB9D0\uB69D\uC774\uB098 \uD574\uB77C. \uAF34\uB3C4 \uBCF4\uAE30 \uC2EB\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Bluffer_201
    ko: "\uC228\uB2E4\uB2C8\uC694! \uC81C\uAC00 \uC5BC\uB9C8\uB098 \uC644\uBCBD\uD558\uAC8C
      \uD6C8\uB828\uD558\uB824\uACE0 \uB178\uB825 \uC911\uC778\uB370... \uADF8\uB7F0
      \uC2DD\uC73C\uB85C \uB9D0\uC500\uD558\uC2DC\uBA74 \uC800 \uC9C4\uC9DC \uC758\uC695
      \uC548 \uB0A9\uB2C8\uB2E4. \uC0AC\uB78C \uBB34\uC2DC\uD558\uC2DC\uB294 \uAC70\uC608\uC694?"
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Bluffer_2
    ko: "\uBAA8\uC695\uAC10\uC744 \uB290\uB07C\uBA70 \uBC18\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Wild_201
    ko: "\uC228\uB294 \uAC8C \uC544\uB2C8\uC5D0\uC694. \uC798\uD558\uACE0 \uC2F6\uC5B4\uC11C
      \uADF8\uB7F0 \uAC74\uB370... \uC65C \uADF8\uB807\uAC8C \uBB34\uC12D\uAC8C \uB9D0\uC500\uD558\uC138\uC694?
      \uADF8\uB0E5 \uC5F0\uC2B5\uD558\uAC8C \uB0B4\uBC84\uB824 \uB450\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Wild_2
    ko: "\uBC29\uC5B4\uC801\uC778 \uD0DC\uB3C4\uB85C \uBCC0\uD574 \uD6C8\uB828 \uD6A8\uC728\uC774
      \uAE09\uAC10\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Egoist_201
    ko: "\uC81C \uD55C\uACC4\uB77C\uACE0\uC694? \uC81C \uC7A0\uC7AC\uB825\uC744 \uACE0\uC791
      \uC774 \uC815\uB3C4\uB85C \uBCF4\uC2DC\uB2E4\uB2C8. \uC88B\uC2B5\uB2C8\uB2E4,
      \uADF8 \uB9D0\uC774 \uD2C0\uB838\uB2E4\uB294 \uAC78 \uC81C \uBAB8\uC73C\uB85C
      \uC9C1\uC811 \uC99D\uBA85\uD574 \uB4DC\uB9AC\uC8E0. \uB611\uBC14\uB85C \uBCF4\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Egoist_2
    ko: "\uD3ED\uBC1C\uC801\uC778 \uC5D0\uB108\uC9C0\uB97C \uC3DF\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Fighter_201
    ko: "\uD55C\uACC4? \uC81C\uAC00 \uC9C0\uAE08 \uBB34\uC11C\uC6CC \uBCF4\uC785\uB2C8\uAE4C?
      \uB2F9\uC7A5 \uACF5 \uB358\uC9C0\uC138\uC694. \uB204\uAC00 \uC774 \uCF54\uD2B8\uC758
      \uC8FC\uC778\uC778\uC9C0 \uBCF4\uC5EC\uB4DC\uB9B4 \uD14C\uB2C8\uAE4C! \uADFC\uB370
      \uADF8 \uB9D0\uB69D\uC774\uB77C\uB294 \uD45C\uD604\uC740 \uCDE8\uC18C\uD558\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Fighter_2
    ko: "\uC628\uC804\uD788 \uD6C8\uB828\uC5D0\uB9CC \uC9D1\uC911\uD558\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Ch_Instinct_003
    ko: "\uD14C\uC774\uD504\uB97C \uAC70\uCE60\uAC8C \uB72F\uC5B4 \uBC1F\uC544\uBC84\uB9AC\uACE0,
      \uC3D8\uC544\uBCF4\uBA70 \uACF5\uC744 \uAC15\uD558\uAC8C \uBC14\uB2E5\uC5D0
      \uD295\uACA8 \uBCF4\uB0B8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Bluffer_301
    ko: "\uC624, \uBC29\uAE08 \uD14C\uC774\uD504 \uB72F\uB294 \uD3EC\uC2A4 \uC7A5\uB09C
      \uC544\uB2CC\uB370\uC694? \uC800\uB3C4 \uB098\uC911\uC5D0 \uC800\uB807\uAC8C
      \uD574\uBD10\uC57C\uC9C0. \uADFC\uB370 \uC81C \uC2E0\uBC1C\uC5D0 \uD14C\uC774\uD504
      \uB048\uB048\uC774 \uBB3B\uC740 \uAC74 \uC5B4\uB5BB\uAC8C \uD558\uC2E4 \uAC70\uC608\uC694?"
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Bluffer_3
    ko: "\uC5EC\uC804\uD788 \uAC89\uBAA8\uC2B5\uC5D0 \uCE58\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Wild_301
    ko: "\uC2DC\uC6D0\uD558\uB124\uC694. \uC800\uB3C4 \uC774 \uC120\uB4E4\uC774 \uAC70\uC2AC\uB838\uAC70\uB4E0\uC694.
      \uC774\uC81C \uADF8\uB0E5 \uC81C \uAC10\uB300\uB85C \uD655 \uB09A\uC544\uCC44
      \uBC84\uB9B4\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Wild_3
    ko: "\uC989\uAC01\uC801\uC778 \uC2E0\uCCB4 \uBC18\uC751\uC73C\uB85C \uC804\uD658\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Egoist_301
    ko: "\uBB34\uB840\uD558\uC2DC\uB124\uC694. \uC81C \uAE30\uC900\uC810\uC744 \uC774\uB807\uAC8C
      \uD30C\uAD34\uD558\uC2DC\uB294 \uAC74 \uC808 \uBB34\uC2DC\uD558\uB294 \uCC98\uC0AC\uC785\uB2C8\uB2E4.
      \uC774\uB7F0 \uC2DD\uC774\uBA74 \uB354 \uC774\uC0C1 \uAC10\uB3C5\uB2D8 \uC9C0\uB3C4\uB97C
      \uBC1B\uC744 \uC774\uC720\uAC00 \uC5C6\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Egoist_3
    ko: "\uAC15\uD55C \uC801\uAC1C\uC2EC\uC744 \uBCF4\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00018_Desc_Fighter_301
    ko: "...\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uB9D0\uBCF4\uB2E4 \uC774\uAC8C \uD6E8\uC52C
      \uBE60\uB974\uACA0\uB124\uC694. \uB2E4\uC2DC \uB358\uC9C0\uC138\uC694. \uBC15\uC0B4
      \uB0B4\uBC84\uB9B4 \uD14C\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00018_Rs_Fighter_3
    ko: "\uC555\uB3C4\uC801\uC778 \uD798\uC744 \uBC1C\uD718\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Discipline_001
    ko: "\uC5F0\uC2B5 \uACBD\uAE30 \uC911 \uC2E4\uC810 \uC9C1\uD6C4, \uC790\uCC45
      \uB300\uC2E0 \uC804\uC220 \uB178\uD2B8\uB97C \uD3BC\uCCD0 \uB4E0 \uC120\uC218\uC785\uB2C8\uB2E4.
      \uADF8\uB294 \uC790\uC2E0\uC758 \uC2E4\uCC45\uC744 \uC6D0\uCE59\uC758 \uD55C\uACC4\uB85C
      \uADDC\uC815\uD558\uBA70,"
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Discipline_002
    ko: "\uADDC\uC728\uC744 \uC644\uBCBD\uD788 \uC900\uC218\uD588\uC74C\uC5D0\uB3C4
      \uC2E4\uC810\uD55C \uC0C1\uD669\uC5D0 \uB300\uD574 \uB17C\uB9AC\uC801 \uD574\uBA85\uC744
      \uC694\uAD6C\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Discipline_003
    ko: "\uADDC\uCE59\uC774 \uBCF4\uD638\uD574\uC8FC\uC9C0 \uBABB\uD55C \uACB0\uACFC\uAC12\uC5D0
      \uB300\uD574 \uC5B5\uC6B8\uD568\uC744 \uD638\uC18C\uD558\uBA70, \uB2E4\uC74C
      \uD589\uB3D9 \uC9C0\uCE68\uC774 \uB0B4\uB824\uC9C0\uAE30 \uC804\uAE4C\uC9C0\uB294
      \uCF54\uD2B8\uB85C \uB3CC\uC544\uAC08 \uC758\uC9C0\uAC00 \uBCF4\uC774\uC9C0
      \uC54A\uB294 \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00019_Ch_Discipline_001
    ko: "\uCC45\uC784\uAC10\uC740 \uB192\uAC8C \uC0AC\uB098, \uAE30\uBCF8 \uC704\uC5D0
      \uBCC0\uCE59 \uB300\uC751 \uC870\uD56D\uC744 \uCD94\uAC00\uD574 \uC608\uC678\uAE4C\uC9C0
      \uD1B5\uC81C\uD560 \uB2A5\uB825\uC744 \uD0A4\uC6CC\uB77C."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Principled_101
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uC6D0\uCE59\uC774 \uD2C0\uB9B0 \uAC8C \uC544\uB2C8\uB77C
      \uC81C\uAC00 \uC0C1\uC704 \uB2E8\uACC4\uB97C \uC801\uC6A9\uD558\uC9C0 \uBABB\uD588\uAD70\uC694.
      \uC989\uC2DC \uBCC0\uCE59 \uD0C0\uC774\uBC0D\uC5D0 \uB300\uD55C \uB300\uC751
      \uB85C\uC9C1\uC744 \uC218\uB9BD\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Principled_1
    ko: "\uC815\uC11C\uC801 \uC548\uC815\uC744 \uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Guardian_101
    ko: "\uAE30\uBCF8 \uC870\uD56D\uC870\uCC28 \uC644\uBCBD\uD788 \uC9C0\uD0A4\uC9C0
      \uBABB\uD588\uB294\uB370 \uC2EC\uD654 \uB2E8\uACC4\uB97C \uB17C\uD560 \uC21C
      \uC5C6\uC2B5\uB2C8\uB2E4. \uC804 \uC5B4\uB5A4 \uC0C1\uD669\uC5D0\uC11C\uB3C4
      \uAD6C\uD604\uD574\uB0BC \uC218 \uC788\uC744 \uB54C\uAE4C\uC9C0 \uBC18\uBCF5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Guardian_1
    ko: "\uC6D0\uCE59\uC758 \uC624\uC5FC\uC73C\uB85C \uAC04\uC8FC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Tactician_101
    ko: "\uC774\uB860\uC801\uC73C\uB85C\uB294 \uD569\uB9AC\uC801\uC785\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uBCC0\uCE59 \uB300\uC751 \uC870\uD56D\uC774 \uB370\uC774\uD130\uB85C
      \uAC80\uC99D\uB418\uAE30 \uC804\uAE4C\uC9C4  \uACE0\uC218\uD558\uB294 \uAC8C
      \uC804\uC220\uC801 \uB9AC\uC2A4\uD06C\uAC00 \uC801\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Tactician_1
    ko: "\uAE30\uC874\uC758 \uC548\uC815\uC801\uC778 \uCCB4\uACC4\uB97C \uC720\uC9C0\uD558\uB824
      \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Exemplary_101
    ko: "\uACA9\uB824\uB294 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uC6D0\uCE59\uC744 \uC9C0\uD0A4\uACE0\uB3C4
      \uC2E4\uC810\uD55C \uC81C\uAC00 \uB2E4\uB978 \uC120\uC218\uB4E4\uC5D0\uAC8C
      \uC5B4\uB5A4 \uBAA8\uBC94\uC774 \uB418\uACA0\uC2B5\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Exemplary_1
    ko: "\uC720\uC5F0\uD55C \uBCC0\uD654\uB97C \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Ch_Discipline_002
    ko: "\uAE00\uC790 \uC9C0\uD0A4\uB290\uB77C \uC2E4\uC810\uD558\uB294 \uAC74 \uADDC\uC728\uC774
      \uC544\uB2C8\uB2E4. \uCD5C\uC6B0\uC120 \uADDC\uCE59\uC740 \uC2E4\uC810\uD558\uC9C0
      \uC54A\uB294 \uAC83\uC774\uB2C8 \uB2F9\uC7A5 \uB6F0\uC5B4\uB77C."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Principled_201
    ko: "\uC2E4\uC810\uC744 \uC815\uB2F9\uD654\uD558\uB294 \uAC8C \uC544\uB2D9\uB2C8\uB2E4.
      \uC6D0\uCE59\uC774 \uD754\uB4E4\uB9AC\uBA74 \uD300\uC758 \uC218\uBE44 \uCCB4\uACC4
      \uC790\uCCB4\uAC00 \uBB34\uB108\uC9D1\uB2C8\uB2E4. \uC608\uC678 \uC0C1\uD669\uC744
      \uBA85\uD655\uD788 \uC815\uC758\uD574 \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Principled_2
    ko: "\uB354 \uC138\uBC00\uD55C \uADDC\uCE59 \uC218\uB9BD\uC744 \uC694\uAD6C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Guardian_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC81C\uAC00 \uADDC\uC728\uC744
      \uC5B4\uAE30\uBA74 \uD300\uC758 \uC9C8\uC11C\uAC00 \uBB34\uB108\uC9C8\uAE4C
      \uBD10 \uB450\uB824\uC6E0\uC2B5\uB2C8\uB2E4. \uC2E4\uC810\uBCF4\uB2E4 \uBB34\uC11C\uC6B4
      \uAC74 \uADDC\uCE59 \uC5C6\uB294 \uC218\uBE44\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Guardian_2
    ko: "\uC2E0\uB150\uC744 \uC27D\uAC8C \uAEBE\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Tactician_201
    ko: "\uC804\uC220\uC758 \uCD5C\uC885 \uBAA9\uC801\uC744 \uB9DD\uAC01\uD588\uAD70\uC694.
      \uC2E4\uC810 \uBC29\uC9C0\uB77C\uB294 \uB300\uC804\uC81C \uC544\uB798 \uC720\uC5F0\uD558\uAC8C
      \uB300\uC751\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uC9C0\uC801\uC774 \uC815\uD655\uD558\uC168\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Tactician_2
    ko: "\uC989\uC2DC \uACE0\uC9D1\uC744 \uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Exemplary_201
    ko: "\uD300\uC6D0\uB4E4 \uC55E\uC5D0\uC11C \uC81C \uB178\uB825\uC744 \uBB34\uB2A5\uD568\uC73C\uB85C
      \uCE58\uBD80\uD558\uC2DC\uB2C8 \uBE44\uCC38\uD569\uB2C8\uB2E4. \uC804 \uADF8\uC800
      \uAC10\uB3C5\uB2D8\uC774 \uC138\uC6B0\uC2E0 \uADDC\uC728\uC744 \uAC00\uC7A5
      \uC815\uC9C1\uD558\uAC8C \uC774\uD589\uD588\uC744 \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Exemplary_2
    ko: "\uC758\uC695\uC774 \uAEBE\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Ch_Discipline_003
    ko: "\uC804\uC220 \uB178\uD2B8\uB97C \uBE8F\uC5B4 \uCC22\uACE0, \uC885\uC774
      \uBB49\uCE58\uB97C \uAC00\uC2B4\uD30D\uC5D0 \uB358\uC9C4 \uB4A4 \uCF54\uD2B8\uB97C
      \uAC00\uB9AC\uD0A4\uBA70 \uBCF5\uADC0\uB97C \uBA85\uB839\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8! \uD300\uC758 \uADFC\uAC04\uC778 \uC804\uC220 \uB178\uD2B8\uB97C
      \uC774\uB807\uAC8C \uD6FC\uC190\uD558\uC2DC\uBA74 \uC5B4\uB5A1\uD569\uB2C8\uAE4C?
      \uAE30\uC900\uC774 \uC0AC\uB77C\uC9C4 \uCF54\uD2B8\uC5D0\uC11C \uC800\uB294
      \uBB34\uC5C7\uC744 \uBBFF\uACE0 \uC218\uBE44\uD574\uC57C \uD558\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Principled_3
    ko: "\uADF9\uC2EC\uD55C \uBD88\uC548\uACFC \uD63C\uB780\uC744 \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Guardian_301
    ko: "...\uBB38\uAD6C\uC5D0 \uAC07\uD788\uC9C0 \uB9D0\uACE0 \uACB0\uACFC\uB85C
      \uD300\uC744 \uC9C0\uD0A4\uB77C\uB294 \uB73B\uC774\uAD70\uC694. \uC9C0\uC2DC\uD558\uC2E0
      \uB300\uB85C \uBAB8\uC73C\uB85C \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Guardian_3
    ko: "\uAC10\uB3C5\uC758 \uACB0\uB2E8\uC744 \uC0C1\uC704 \uCCB4\uACC4\uB85C \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Tactician_301
    ko: "\uC804\uC220\uC801 \uAC00\uC774\uB4DC\uB77C\uC778\uC744 \uC5C6\uC560\uBC84\uB9AC\uB294
      \uAC74 \uC9C0\uADF9\uD788 \uBE44\uD569\uB9AC\uC801\uC778 \uCC98\uC0AC\uC785\uB2C8\uB2E4.
      \uADFC\uAC70 \uC5C6\uB294 \uC218\uBE44\uB294 \uC804\uC220\uC774 \uC544\uB2C8\uB77C
      \uB3C4\uBC15\uC77C \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Tactician_3
    ko: "\uC9C0\uB3C4 \uBC29\uC2DD\uC774 \uBE44\uACFC\uD559\uC801\uC774\uB77C \uD310\uB2E8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Exemplary_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uD589\uB3D9\uC5D0\uC11C \uC81C\uAC00 \uB098\uC544\uAC08
      \uBC29\uD5A5\uC744 \uBCF4\uC558\uC2B5\uB2C8\uB2E4. \uC8FD\uC740 \uBB38\uAD6C\uAC00
      \uC544\uB2CC \uC0B4\uC544\uC788\uB294 \uC218\uBE44\uB97C \uBCF4\uC5EC\uC8FC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Exemplary_3
    ko: "\uCE74\uB9AC\uC2A4\uB9C8\uC5D0 \uC989\uAC01\uC801\uC73C\uB85C \uB3D9\uD654\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Bond_001
    ko: "\uC5F0\uC2B5 \uACBD\uAE30 \uC911 \uC2E4\uC810 \uD6C4 \uCF54\uD2B8 \uAD6C\uC11D\uC5D0\uC11C
      \uC804\uC220 \uB178\uD2B8\uB97C \uBD99\uC7A1\uACE0 \uC788\uB294 \uC120\uC218\uC785\uB2C8\uB2E4.
      \uADF8\uB294 \uC790\uC2E0\uC758 \uC2E4\uC218\uB97C \uC6D0\uCE59\uC758 \uD55C\uACC4
      \uD0D3\uC73C\uB85C \uB3CC\uB9AC\uACE0 \uC788\uC9C0\uB9CC,"
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Bond_002
    ko: "\uC0AC\uC2E4 \uADF8 \uC774\uBA74\uC5D0\uB294 \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C
      \uD588\uB294\uB370 \uC2E4\uD328\uD574\uC11C \uB108\uBB34 \uC18D\uC0C1\uD558\uACE0
      \uBBF8\uC548\uD558\uB2E4\uB294 \uC815\uC11C\uC801 \uBD88\uC548\uC774 \uAE54\uB824
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Bond_003
    ko: "\uB17C\uB9AC\uC801 \uD574\uBA85\uC744 \uC694\uAD6C\uD558\uB294 \uB4EF \uBCF4\uC774\uB098
      \uC2E4\uC81C\uB85C\uB294 \uC790\uC2E0\uC758 \uB178\uB825\uC774 \uD5DB\uB418\uC9C0
      \uC54A\uC558\uC74C\uC744 \uAC10\uB3C5\uB2D8\uAED8 \uD655\uC778\uBC1B\uACE0
      \uC2F6\uC5B4 \uD558\uB294 \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Bond_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00019_Ch_Bond_001
    ko: "\uADDC\uCE59\uC744 \uC9C0\uD0A4\uB824 \uC560\uC4F4 \uB9CC\uD07C \uC6D0\uCE59\uC774
      \uB2E8\uB2E8\uD574\uC84C\uC73C\uB2C8 \uC774\uC81C \uB2E4\uC2DC \uAC00\uC11C
      \uB124 \uC9C4\uC2EC\uC744 \uBCF4\uC5EC\uC918\uB77C."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uC81C \uB9C8\uC74C\uC744 \uC54C\uC544\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD574\uC694. \uADDC\uCE59\uC774 \uC804\uBD80\uAC00 \uC544\uB2C8\uB77C\uB294
      \uAC78 \uC54C\uC558\uC73C\uB2C8, \uC774\uC81C \uB354 \uC6A9\uAE30 \uB0B4\uC11C
      \uB6F0\uC5B4\uBCFC\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Kind_1
    ko: "\uC815\uC11C\uC801 \uC5D0\uB108\uC9C0\uB97C \uD68C\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Loyal_101
    ko: "\uC704\uB85C\uB294 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uAC10\uB3C5\uB2D8\uC774
      \uC8FC\uC2E0 \uADDC\uC728\uC774 \uC2E4\uD328\uD588\uB2E4\uB294 \uC0AC\uC2E4\uC774
      \uB354 \uAC00\uC2B4 \uC544\uD515\uB2C8\uB2E4. \uC644\uBCBD\uD55C \uC9C0\uCE68\uC774
      \uC788\uC5B4\uC57C\uB9CC \uAC10\uB3C5\uB2D8\uAED8 \uC2B9\uB9AC\uB97C \uBC14\uCE60
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Loyal_1
    ko: "\uD589\uB3D9\uC758 \uBCC0\uD654\uAC00 \uC77C\uC5B4\uB098\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Sincere_101
    ko: "\uC81C \uC9C4\uC2EC\uC774 \uC911\uC694\uD55C \uAC8C \uC544\uB2C8\uB77C,
      \uC774 \uC624\uCC28 10cm\uB97C \uC5B4\uB5BB\uAC8C \uBA54\uC6B0\uB290\uB0D0\uAC00
      \uBB38\uC81C\uC785\uB2C8\uB2E4. \uC219\uB2EC\uB418\uC9C0 \uC54A\uC740 \uC0C1\uD0DC\uB85C
      \uB098\uAC00\uB294 \uAC74 \uBB34\uCC45\uC784\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Sincere_1
    ko: "\uACA9\uB824\uB9CC\uC73C\uB85C\uB294 \uC6C0\uC9C1\uC774\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Moodmaker_101
    ko: "\uAC10\uB3C5\uB2D8\uAE4C\uC9C0 \uB108\uBB34 \uC9C4\uC9C0\uD574\uC9C0\uC2DC\uB2C8\uAE4C
      \uBBFC\uB9DD\uD558\uB124\uC694. \uADF8\uB0E5 \uC81C\uAC00 \uC880 \uC5B5\uC6B8\uD574\uC11C
      \uADF8\uB798\uC694. \uB108\uBB34 \uC2E0\uACBD \uC4F0\uC9C0 \uB9C8\uC138\uC694,
      \uC608?"
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Moodmaker_1
    ko: "\uAC00\uBCBC\uC6B4 \uB18D\uB2F4\uC73C\uB85C \uD68C\uD53C\uD558\uB824 \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Ch_Bond_002
    ko: "\uADDC\uCE59 \uB4A4\uC5D0 \uC228\uC5B4 \uC2E4\uC810\uC744 \uC815\uB2F9\uD654\uD558\uB294
      \uAC74 \uD300\uC6CC\uD06C\uAC00 \uC544\uB2C8\uB2E4. \uC5B5\uC6B8\uD574\uD560
      \uC2DC\uAC04\uC5D0 \uB2F9\uC7A5 \uBCF5\uADC0\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Kind_201
    ko: "\uC81C\uAC00 \uC774\uAE30\uC801\uC774\uC5C8\uB098\uC694... \uD300\uC744
      \uC704\uD574\uC11C \uC6D0\uCE59\uC744 \uC9C0\uD0A8 \uAC74\uB370, \uADF8\uAC8C
      \uBBFC\uD3D0\uC600\uB2E4\uB2C8 \uC815\uB9D0 \uC8C4\uC1A1\uD569\uB2C8\uB2E4.
      \uC804 \uC815\uB9D0 \uD300\uC5D0 \uB3C4\uC6C0\uC774 \uC548 \uB418\uB098 \uBD10\uC694."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Kind_2
    ko: "\uADF9\uC2EC\uD55C \uC790\uAE30 \uBE44\uD558\uC640 \uC704\uCD95 \uC0C1\uD0DC\uC5D0
      \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Loyal_201
    ko: "\uBA85\uC2EC\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uADDC\uC728\uBCF4\uB2E4 \uC911\uC694\uD55C
      \uAC74 \uAC10\uB3C5\uB2D8\uC758 \uC2B9\uB9AC\uB77C\uB294 \uAC78 \uC78A\uC5C8\uAD70\uC694.
      \uC81C \uC5B5\uC6B8\uD568\uC740 \uC811\uC5B4\uB450\uACE0 \uD300\uC758 \uB9AC\uB4EC\uC744
      \uC704\uD574 \uC989\uC2DC \uBCF5\uADC0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Loyal_2
    ko: "\uC989\uC2DC \uAC1C\uC778\uC758 \uACE0\uC9D1\uC744 \uAEBE\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Sincere_201
    ko: "\uC815\uB2F9\uD654\uD558\uB824\uB358 \uAC8C \uC544\uB2C8\uB77C \uB354 \uC644\uBCBD\uD558\uAC8C
      \uC218\uD589\uD558\uACE0 \uC2F6\uC5C8\uC744 \uBFD0\uC785\uB2C8\uB2E4. \uC81C
      \uC9C4\uC9C0\uD55C \uB178\uB825\uC744 \uAC1C\uC778\uC801\uC778 \uB9CC\uC871\uC73C\uB85C
      \uCE58\uBD80\uD558\uC2DC\uB2C8 \uC5B5\uC6B8\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Sincere_2
    ko: "\uB9C8\uC74C\uC758 \uBB38\uC744 \uB2EB\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Moodmaker_201
    ko: "\uC544\uC774\uACE0, \uBB34\uC11C\uC6CC\uB77C! \uC54C\uC558\uC5B4\uC694,
      \uAC10\uB3C5\uB2D8.  \uC2DC\uC6D0\uD558\uAC8C \uD55C\uBC88 \uB0A0\uC544\uBCF4\uACA0\uC2B5\uB2C8\uB2E4.
      \uC790, \uB2E4\uB4E4 \uD798\uB0B4\uC790\uACE0!"
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Moodmaker_2
    ko: "\uC9D1\uC911\uB825\uC774 \uB0AE\uC544\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Ch_Bond_003
    ko: "\uC804\uC220 \uB178\uD2B8\uB97C \uB36E\uC5B4 \uC190\uC5D0 \uC950\uC5EC\uC8FC\uACE0,
      \uC5B4\uAE68\uB97C \uAF49 \uC954 \uB4A4 \uCF54\uD2B8 \uCABD\uC73C\uB85C \uBC00\uBA70
      \uACE0\uAC1C\uB97C \uB044\uB355\uC778\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uBBFF\uC5B4\uC8FC\uC2DC\uB294 \uAC74 \uC54C\uACA0\uC9C0\uB9CC,
      \uC774 \uBAA8\uC21C\uC774 \uD574\uACB0\uB418\uC9C0 \uC54A\uC73C\uBA74 \uB610
      \uC2E4\uC218\uD560\uAE4C \uBD10 \uBB34\uC11C\uC6CC\uC694. \uC870\uAE08\uB9CC
      \uB354 \uC124\uBA85\uD574 \uC8FC\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Kind_3
    ko: "\uBCF5\uADC0\uB97C \uC8FC\uC800\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8, \uC774 \uBB38\uC81C\uB294 \uC774\uB807\uAC8C \uB118\uC5B4\uAC00\uC120
      \uC548 \uB429\uB2C8\uB2E4. \uD6C8\uB828 \uAE30\uAC15\uC744 \uC704\uD574\uC11C\uB77C\uB3C4
      \uADDC\uCE59\uC758 \uC624\uB958\uB97C \uBC14\uB85C\uC7A1\uACE0 \uB2E4\uC2DC
      \uB6F0\uB294 \uAC8C \uB9DE\uB2E4\uACE0 \uBD05\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Loyal_3
    ko: "\uAC70\uBD80\uAC10\uC744 \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Sincere_301
    ko: "...\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uD39C\uC774 \uC544\uB2C8\uB77C \uBAB8\uC73C\uB85C
      \uB2E4\uC2DC \uC368\uB0B4\uB824\uAC00\uB77C\uB294 \uB9D0\uC500\uC774\uC2DC\uC8E0.
      \uD604\uC7A5\uC5D0\uC11C \uB2F5\uC744 \uCC3E\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Sincere_3
    ko: "\uBB34\uC5B8\uC758 \uC9C0\uC2DC\uB97C \uC131\uC2E4\uD788 \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Moodmaker_301
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uCFE8\uD558\uC2DC\uB124\uC694! \uB9DE\uC544\uC694,
      \uC885\uC774 \uCABC\uAC00\uB9AC \uBCF8\uB2E4\uACE0 \uC810\uC218 \uB098\uB098\uC694?
      \uC81C\uAC00 \uAC00\uC11C \uCF54\uD2B8 \uBD84\uC704\uAE30 \uC2F9 \uBC14\uAFD4\uB193\uACE0
      \uC624\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Moodmaker_3
    ko: "\uC2AC\uB7FC\uD504\uB97C \uD65C\uAE30\uCC28\uAC8C \uADF9\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Cold_001
    ko: "\uC5F0\uC2B5 \uACBD\uAE30 \uC911 \uC2E4\uC810 \uC9C1\uD6C4, \uC13C\uD130\uC778
      \uC774 \uC120\uC218\uB294 \uBCF5\uADC0\uD558\uB294 \uB300\uC2E0 \uB2F9\uC2E0\uC5D0\uAC8C
      \uB2E4\uAC00\uC640 \uC804\uC220 \uB178\uD2B8\uB97C \uD3BC\uCCD0 \uBCF4\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Cold_002
    ko: "\uADF8\uB294 \uC790\uC2E0\uC758 \uC2E4\uCC45\uC744 \uC778\uC815\uD558\uB294
      \uB300\uC2E0 \uC2DC\uC2A4\uD15C\uC758 \uB17C\uB9AC\uC801 \uBAA8\uC21C\uC744
      \uD30C\uACE0\uB4E4\uC5B4 \uCC45\uC784\uC744 \uD68C\uD53C\uD558\uB824 \uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Cold_003
    ko: "\uC9C0\uC2DC\uB41C \uC218\uBE44 \uC6D0\uCE59\uACFC \uC2E4\uC804 \uC0C1\uD669
      \uC0AC\uC774\uC758 \uAD34\uB9AC\uB97C \uADFC\uAC70\uB85C \uB4E4\uBA70,"
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Cold_004
    ko: "\uAC10\uB3C5\uC774 \uC774 \uBAA8\uC21C\uC744 \uD574\uACB0\uD574 \uC8FC\uAE30
      \uC804\uAE4C\uC9C0\uB294 \uCF54\uD2B8\uC5D0 \uBCF5\uADC0\uD558\uB294 \uAC83\uC774
      \uC790\uC6D0 \uB0AD\uBE44\uC774\uC790 \uBE44\uD6A8\uC728\uC774\uB77C\uACE0
      \uC8FC\uC7A5\uD558\uBA70 \uB0C9\uC18C\uC801\uC778 \uD0DC\uB3C4\uB85C \uC77C\uAD00\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Cold_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00019_Ch_Cold_001
    ko: "\uD1B5\uCC30\uC740 \uC633\uC73C\uB098 \uD604\uC7A5 \uBCC0\uC218\uAC00 \uB204\uB77D\uB410\uB2E4.
      \uBCC0\uC218\uAE4C\uC9C0 \uC218\uBE44 \uB85C\uC9C1\uC5D0 \uB300\uC785\uD558\uBA74
      \uC644\uBCBD\uD55C \uC815\uB2F5\uC774 \uB420 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Planner_101
    ko: "\uD604\uC7A5 \uBCC0\uC218 \uB300\uC785... \uC81C \uB85C\uC9C1\uC758 \uAD6C\uBA4D\uC744
      \uC815\uD655\uD788 \uC9DA\uC73C\uC168\uAD70\uC694. \uC989\uC2DC \uBCF4\uC644\uD574\uC11C
      \uBB34\uACB0\uC810 \uC218\uBE44\uC548\uC744 \uB2E4\uC2DC \uC9DC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Planner_1
    ko: "\uC989\uAC01 \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Opportunist_101
    ko: "\uACA9\uB824\uB294 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uC2DC\uC2A4\uD15C \uBAA8\uC21C\uC774
      \uD574\uACB0 \uC548 \uB418\uBA74 \uC81C \uD3C9\uC810\uB9CC \uAE4E\uC785\uB2C8\uB2E4.
      \uC81C \uAC00\uCE58\uB97C \uBCF4\uD638\uD560 \uD655\uC2E4\uD55C \uB9E4\uB274\uC5BC\uC744
      \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Opportunist_1
    ko: "\uBCC0\uD654\uB97C \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Cunning_101
    ko: "\uC81C \uD1B5\uCC30\uC744 \uC778\uC815\uD558\uC2DC\uB2E4\uB2C8 \uC758\uC678\uB124\uC694.
      \uD639\uC2DC \uB098\uC911\uC5D0 \uB610 \uC2E4\uC810\uD558\uBA74 \uB124 \uC124\uACC4\uB300\uB85C
      \uD588\uC73C\uB2C8 \uB124 \uCC45\uC784\uC774\uB2E4\uB77C\uACE0 \uAF2C\uB9AC
      \uC790\uB974\uB824\uB294 \uC804\uB7B5\uC778\uAC00\uC694?"
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Cunning_1
    ko: "\uBC29\uC5B4\uB9C9\uC744 \uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Believer_101
    ko: "\uBCC0\uC218 \uD0D3\uC774 \uC544\uB2D9\uB2C8\uB2E4. \uC81C \uC6D0\uCE59\uC774
      \uC544\uC9C1 \uC644\uBCBD\uD558\uAC8C \uAD6C\uD604\uB418\uC9C0 \uC54A\uC558\uC744
      \uBFD0\uC785\uB2C8\uB2E4. \uC800\uB294 \uC81C \uBC29\uC2DD\uB300\uB85C \uC99D\uBA85\uD574
      \uBCF4\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Believer_1
    ko: "\uB354 \uAC15\uD558\uAC8C \uBC84\uD17C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Ch_Cold_002
    ko: "\uB17C\uB9AC \uC9C0\uD0A4\uB290\uB77C \uC2E4\uC810\uD558\uB294 \uAC74 \uD6A8\uC728\uC774
      \uC544\uB2C8\uB2E4. \uC2DC\uC2A4\uD15C \uB4A4\uC5D0 \uC228\uC5B4 \uCC45\uC784\uC744
      \uD53C\uD558\uC9C0 \uB9D0\uACE0 \uBCF5\uADC0\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Planner_201
    ko: "\uACE0\uC7A5 \uB09C \uACC4\uC0B0\uAE30\uAC00 \uC544\uB2D9\uB2C8\uB2E4. \uD655\uB960\uC801\uC73C\uB85C
      \uAC00\uC7A5 \uC548\uC804\uD55C \uC120\uD0DD\uC744 \uD588\uC744 \uBFD0\uC785\uB2C8\uB2E4.
      \uC81C \uC124\uACC4\uC758 \uC2E0\uB8B0\uB3C4\uB97C \uB192\uC77C \uC2DC\uAC04\uC744
      \uB354 \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Planner_2
    ko: "\uB85C\uC9C1\uC744 \uC7AC\uAC80\uD1A0\uD560 \uC2DC\uAC04\uC744 \uBC8C\uB824
      \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Opportunist_201
    ko: "\uBB34\uB2A5\uD55C \uBD84\uC11D\uAC00\uB77C\uB2C8... \uC81C \uAC00\uCE58\uAC00
      \uB5A8\uC5B4\uC9C0\uB294 \uAC74 \uCC38\uC744 \uC218 \uC5C6\uAD70\uC694. \uC2DC\uC2A4\uD15C\uC774
      \uB9DD\uAC00\uC84C\uB2E4\uBA74 \uC81C \uAC1C\uC778 \uAE30\uB7C9\uC73C\uB85C\uB77C\uB3C4
      \uB9C9\uC544\uC11C \uC81C \uAC00\uCE58\uB97C \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Opportunist_2
    ko: "\uC0DD\uC874 \uBCF8\uB2A5\uC774 \uBC1C\uB3D9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Cunning_201
    ko: "\uD6A8\uC728? \uC81C\uAC00 \uC774 \uB178\uD2B8\uB97C \uB4E4\uC774\uBBF8\uB294
      \uAC74 \uCC45\uC784\uC744 \uAC10\uB3C5\uB2D8\uAED8 \uB118\uAE30\uAE30 \uC704\uD574\uC11C\uC778\uB370,
      \uADF8\uAC78 \uBB34\uB2A5\uC73C\uB85C \uBAB0\uC544\uC138\uC6B0\uC2DC\uBA74
      \uC81C \uC124\uACC4\uAC00 \uAF2C\uC774\uC9C0 \uC54A\uC2B5\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Cunning_2
    ko: "\uBCF8\uC2EC\uC744 \uB4DC\uB7EC\uB0B4\uACE0 \uACF5\uACA9\uC801\uC73C\uB85C
      \uBCC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Believer_201
    ko: "\uBE44\uB09C\uD558\uC154\uB3C4 \uC81C \uB0C9\uCCA0\uD55C \uC2E0\uB150\uC740
      \uBCC0\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4. \uB2E4\uB9CC, \uD6A8\uC728\uC5D0
      \uB300\uD574\uC11C\uB294 \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uC744 \uB2E4\uC2DC
      \uAC80\uD1A0\uD574 \uBCFC \uC758\uD5A5\uC740 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Believer_2
    ko: "\uB0B4\uC801\uC73C\uB85C \uAE4A\uAC8C \uACE0\uBBFC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Ch_Cold_003
    ko: "\uB178\uD2B8\uB97C \uCC22\uC5B4 \uAC00\uC2B4\uC5D0 \uB358\uC9C4 \uB4A4,
      \uCC28\uAC00\uC6B4 \uB208\uBE5B\uC73C\uB85C \uCF54\uD2B8\uB97C \uAC00\uB9AC\uD0A4\uBA70
      \uD131 \uB05D\uC744 \uAE4C\uB531\uC778\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Planner_301
    ko: "\uAC10\uB3C5\uB2D8! \uC81C \uBD84\uC11D \uADFC\uAC70\uB97C \uC774\uB807\uAC8C
      \uD30C\uAD34\uD558\uC2DC\uBA74 \uC5B4\uB5A1\uD569\uB2C8\uAE4C? \uAE30\uC900\uC810
      \uC5C6\uC774\uB294 \uB2E8 1cm\uC758 \uC2A4\uD15D\uB3C4 \uC124\uACC4\uD560 \uC218
      \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Planner_3
    ko: "\uADF9\uC2EC\uD55C \uACF5\uD669 \uC0C1\uD0DC\uC5D0 \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Opportunist_301
    ko: "\uC81C \uC790\uC0B0\uC744 \uC774\uB807\uAC8C \uB2E4\uB8E8\uC2DC\uB2E4\uB2C8...
      \uD558\uC9C0\uB9CC \uAC10\uB3C5\uB2D8\uACFC \uB300\uB9BD\uD558\uB294 \uAC8C
      \uB354 \uD070 \uC190\uD574\uB77C\uB294 \uAC74 \uC54C\uACA0\uB124\uC694. \uB6F0\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Opportunist_3
    ko: "\uC2E4\uB9AC\uC801\uC73C\uB85C \uC989\uAC01 \uAD74\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Cunning_301
    ko: "\uB9D0\uBCF4\uB2E4 \uD655\uC2E4\uD558\uC2DC\uB124\uC694. \uC804\uC220 \uB178\uD2B8\uB77C\uB294
      \uD551\uACC4 \uB4A4\uC5D0 \uC228\uC9C0 \uB9D0\uB77C\uB294 \uB73B\uC774\uACA0\uC8E0.
      \uC7AC\uBBF8\uC788\uC5B4\uC9C0\uB124\uC694. \uC81C\uB300\uB85C \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Cunning_3
    ko: "\uAC10\uB3C5\uC758 \uCE74\uB9AC\uC2A4\uB9C8\uC5D0 \uB9E4\uB8CC\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Believer_301
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uB0A1\uC740 \uB17C\uB9AC\uB294 \uC5EC\uAE30\uC11C
      \uD3D0\uAE30\uD558\uC8E0. \uC774\uC81C \uCF54\uD2B8 \uC704\uC5D0\uC11C \uC0C8\uB85C\uC6B4
      \uC815\uB2F5\uC744 \uCC3E\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Believer_3
    ko: "\uBA85\uCF8C\uD55C \uACB0\uB2E8\uC5D0 \uC21C\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Instinct_001
    ko: "\uC5F0\uC2B5 \uD6C8\uB828 \uC911 \uC2E4\uC810\uC774 \uBC18\uBCF5\uB418\uC790,
      \uC13C\uD130\uC778 \uC774 \uC120\uC218\uB294 \uD6C8\uB828\uC744 \uBA48\uCD94\uACE0
      \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC640 \uC804\uC220 \uB178\uD2B8\uB97C
      \uB4E4\uC774\uBC09\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Instinct_002
    ko: "\uC790\uC2E0\uC758 \uC2E4\uCC45\uC744 \uC778\uC815\uD558\uAE30\uBCF4\uB2E4
      \uC804\uC220\uC801 \uBAA8\uC21C\uC744 \uD30C\uACE0\uB4E4\uBA70 \uCC45\uC784\uC744
      \uD53C\uD558\uB824 \uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Instinct_003
    ko: "\uC9C0\uC2DC\uB41C \uC6D0\uCE59\uC774 \uD604\uC7A5\uACFC \uB9DE\uC9C0 \uC54A\uC73C\uB2C8,
      \uC774 \uBB38\uC81C\uAC00 \uD574\uACB0\uB418\uAE30 \uC804\uAE4C\uC9C0 \uD6C8\uB828\uC744
      \uC7AC\uAC1C\uD558\uB294 \uAC83\uC740 \uC5D0\uB108\uC9C0 \uB0AD\uBE44\uB77C\uBA70
      \uB0C9\uC18C\uC801\uC778 \uD0DC\uB3C4\uB85C \uBC84\uD2F0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Instinct_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00019_Ch_Instinct_001
    ko: "\uC804\uC220\uC740 \uB3C4\uAD6C\uC77C \uBFD0 \uADDC\uCE59\uC5D0 \uB110 \uAC00\uB450\uC9C0
      \uB9C8\uB77C. \uC9C1\uAD00\uC774 \uC774\uB044\uB294 \uB300\uB85C \uBAB8\uC744
      \uB358\uC9C0\uB294 \uAC8C \uC9C4\uC9DC \uC774\uC720\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uC808 \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694.
      \uC774\uB530\uC704 \uB178\uD2B8\uAC00 \uB2F4\uAE30\uC5D4 \uC81C \uC874\uC7AC\uAC10\uC774
      \uB108\uBB34 \uD06C\uAE34 \uD558\uC8E0. \uC9C4\uC9DC \uC8FC\uC5F0\uC758 \uC2E4\uB825\uC744
      \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Bluffer_1
    ko: "\uD6C8\uB828 \uC5D0\uB108\uC9C0\uB85C \uC644\uC804\uD788 \uC804\uD658\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Wild_101
    ko: "\uC9C1\uAD00? \uADF8\uB7F0 \uB9D0\uC7A5\uB09C \uB9D0\uACE0 \uC804\uC220
      \uC624\uB958\uB098 \uACE0\uCCD0\uC8FC\uC1FC. \uBAB8\uC774 \uC548 \uC6C0\uC9C1\uC5EC\uC9C0\uB294\uB370
      \uB9D0\uB85C \uB54C\uC6B0\uB824 \uD558\uC9C0 \uB9C8\uC2DC\uACE0."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Wild_1
    ko: "\uD655\uC2E4\uD55C \uD574\uACB0\uCC45 \uC5C6\uC778 \uC548 \uC6C0\uC9C1\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Egoist_101
    ko: "\uC81C\uAC00 \uC644\uBCBD\uD574\uC9C0\uB294 \uAC74 \uC800\uB97C \uC704\uD574\uC11C\uC9C0
      \uAC10\uB3C5\uB2D8 \uC804\uC220\uC744 \uC704\uD574\uC11C\uAC00 \uC544\uB2C8\uC5D0\uC694.
      \uBB50, \uC81C \uBCF8\uB2A5\uC744 \uBC29\uD574 \uC548 \uD558\uACA0\uB2E4\uBA74
      \uC0DD\uAC01\uC740 \uD574\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Egoist_1
    ko: "\uC790\uB9CC\uD558\uBA70 \uC624\uB9CC\uD55C \uD0DC\uB3C4\uB97C \uC720\uC9C0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Fighter_101
    ko: "\uACA9\uB824 \uAC19\uC740 \uAC74 \uC57D\uD574 \uBE60\uC9C4 \uB188\uB4E4\uD55C\uD14C\uB098
      \uD558\uC138\uC694. \uC804 \uC774 \uB17C\uB9AC\uC801 \uBAA8\uC21C\uC744 \uC774\uACA8\uB0B4\uC9C0
      \uBABB\uD558\uBA74 \uD6C8\uB828\uD560 \uB9DB \uC548 \uB0A9\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Fighter_1
    ko: "\uBD80\uB4DC\uB7EC\uC6B4 \uACA9\uB824\uC5D0 \uC5D0\uB108\uC9C0\uB97C \uBABB
      \uC5BB\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Ch_Instinct_002
    ko: "\uC804\uC220 \uB178\uD2B8 \uB4A4\uC5D0 \uC228\uB294 \uAC8C \uBCF8\uC2B5\uC774\uB0D0.
      \uC57C\uC131\uC774 \uC8FD\uC740 \uAC8C \uD55C\uC2EC\uD558\uB2C8 \uD551\uACC4
      \uB308 \uAE30\uC6B4 \uC788\uC73C\uBA74 \uC99D\uBA85\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Bluffer_201
    ko: "\uB204\uAC00 \uC228\uC5C8\uB2E4\uACE0 \uADF8\uB798\uC694? \uC804 \uADF8\uB0E5
      \uAC10\uB3C5\uB2D8 \uC804\uC220\uC774 \uC81C \uD654\uB824\uD55C \uD50C\uB808\uC774\uB97C
      \uBC29\uD574\uD558\uB2C8\uAE4C \uC870\uC5B8 \uC880 \uD574\uB4DC\uB9B0 \uAC70\uB77C\uACE0\uC694!"
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Bluffer_2
    ko: "\uC740\uADFC\uC2AC\uCA4D \uACE8\uB300 \uCABD\uC73C\uB85C \uBC1C\uC744 \uC62E\uACBC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Wild_201
    ko: "\uB0B4 \uC57C\uC131? \uAC71\uC815 \uB9C8\uC1FC. \uADF8\uCABD \uC804\uC220\uC774
      \uD558\uB3C4 \uB2F5\uB2F5\uD574\uC11C \uC7A0\uC2DC \uC7A0\uB4E4\uC5C8\uB358
      \uAC83\uBFD0\uC774\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Wild_2
    ko: "\uBCF8\uB2A5\uC801\uC73C\uB85C \uC790\uAE30 \uC810\uAC80\uC744 \uC2DC\uC791\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Egoist_201
    ko: "\uC81C\uAC00 \uAC00\uCE58\uAC00 \uC5C6\uB2E4\uACE0\uC694? \uAC10\uB3C5\uB2D8
      \uC804\uC220\uC774 \uC81C \uAC00\uCE58\uB97C \uAE4E\uC544\uBA39\uACE0 \uC788\uB294
      \uAC74 \uC0DD\uAC01 \uC548 \uD558\uB098 \uBCF4\uB124. \uB354 \uBD88\uCF8C\uD574\uC9C0\uAE30
      \uC804\uC5D0 \uAD00\uB450\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Egoist_2
    ko: "\uAE30\uBD84\uACFC \uC874\uC5C4\uC744 \uC9C0\uD0A4\uB824 \uC0C1\uD669\uC744
      \uD68C\uD53C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Fighter_201
    ko: "\uC57C\uC131\uC774 \uC8FD\uC5C8\uB2E4\uACE0? \uADF8 \uB9D0 \uCC45\uC784\uC9C8
      \uC218 \uC788\uACA0\uC5B4? \uB2F9\uC7A5 \uACE8\uBC11\uC73C\uB85C \uAC00. \uB0B4
      \uC57C\uC131\uC774 \uB2F9\uC2E0 \uC804\uC220\uBCF4\uB2E4 \uD6E8\uC52C \uC138\uB2E4\uB294
      \uAC78 \uBCF4\uC5EC\uC904 \uD14C\uB2C8\uAE4C!"
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Fighter_2
    ko: "\uAC00\uC7A5 \uACA9\uB82C\uD558\uAC8C \uD6C8\uB828\uC5D0 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Ch_Instinct_003
    ko: "\uC120\uC218\uC758 \uBA71\uC0B4\uC744 \uAC00\uBCCD\uAC8C \uC7A1\uC544 \uB2F9\uACA8
      \uB208\uC744 \uB9DE\uCD98 \uB4A4, \uC555\uBC15\uAC10\uC744 \uC8FC\uACE0 \uACE8\uB300
      \uCABD\uC73C\uB85C \uBC00\uC5B4\uB0B8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Bluffer_301
    ko: "\uC9C0\uAE08 \uC0AC\uB78C\uB4E4 \uB2E4 \uBCF4\uB294\uB370 \uBB50 \uD558\uC2DC\uB294
      \uAC70\uC608\uC694? \uC800 \uC774\uB7F0 \uB300\uC811 \uBC1B\uC73C\uBA74\uC11C
      \uD6C8\uB828 \uBABB \uD569\uB2C8\uB2E4. \uC0AC\uACFC\uD558\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Bluffer_3
    ko: "\uADF9\uC2EC\uD55C \uC218\uCE58\uC2EC\uC744 \uB290\uB07C\uACE0 \uC774\uD0C8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Wild_301
    ko: "\uB9D0\uBCF4\uB2E4 \uC774\uAC8C \uD6E8\uC52C \uC774\uD574\uAC00 \uBE60\uB974\uB124.
      \uC88B\uC544, \uADF8 \uAE30\uC138 \uADF8\uB300\uB85C \uBC1B\uC544\uC8FC\uC9C0.
      \uBE44\uCF1C!"
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Wild_3
    ko: "\uC989\uC2DC \uB3D9\uBB3C\uC801\uC778 \uC0AC\uB0E5\uC5D0 \uB3CC\uC785\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Egoist_301
    ko: "\uC7AC\uBBF8\uC788\uB124. \uB0A0 \uC774\uB807\uAC8C \uB2E4\uB8EC \uC0AC\uB78C\uC740
      \uCC98\uC74C\uC774\uAC70\uB4E0\uC694. \uAC10\uB3C5\uB2D8\uC774 \uC6D0\uD558\uB294
      \uAC8C \uBB54\uC9C0 \uBAB8\uC73C\uB85C \uD655\uC778\uC2DC\uCF1C \uB4DC\uB9B4\uAC8C."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Egoist_3
    ko: "\uB9CC\uC871\uAC10\uC744 \uB290\uB07C\uBA70 \uD6C8\uB828\uC5D0 \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00019_Desc_Fighter_301
    ko: "\uC190\uBC84\uB987 \uB098\uC058\uC2DC\uB124. \uD558\uC9C0\uB9CC \uADF8 \uB208\uBE5B\uC740
      \uB9C8\uC74C\uC5D0 \uB4E4\uC5B4. \uB204\uAC00 \uC633\uC740\uC9C0 \uCF54\uD2B8
      \uC704\uC5D0\uC11C \uB05D\uC7A5\uC744 \uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00019_Rs_Fighter_3
    ko: "\uADF8 \uAE34\uC7A5\uAC10\uC744 \uD6C8\uB828\uC758 \uB3D9\uB825\uC73C\uB85C
      \uC0BC\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Discipline_001
    ko: "\uC5F0\uC2B5 \uACBD\uAE30 \uC885\uB8CC \uD6C4, \uC13C\uD130\uC778 \uC774
      \uC120\uC218\uB294 \uC0E4\uC6CC\uC2E4\uB85C \uD5A5\uD558\uB294 \uB300\uC2E0
      \uCF54\uD2B8 \uD55C\uBCF5\uD310\uC5D0 \uC11C\uC11C \uC804\uC220 \uB178\uD2B8\uB97C
      \uB4E4\uC774\uBC00\uBA70 \uB2F9\uC2E0\uC744 \uBD99\uC7A1\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Discipline_002
    ko: "\uC624\uB298 \uBC1C\uC0DD\uD55C \uB2E8 \uD55C \uBC88\uC758 \uD30C\uC6B8\uC774
      \uC2DC\uC2A4\uD15C\uC801\uC73C\uB85C \uC65C \uC77C\uC5B4\uB0AC\uB294\uC9C0,
      \uADF8\uB9AC\uACE0 \uC65C \uADF8\uAC83\uC774 \uAC10\uB3C5\uC758 \uC804\uC220\uC801
      \uACB0\uD568\uC778\uC9C0\uB97C \uC9D1\uC694\uD558\uAC8C \uD30C\uACE0\uB4ED\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Discipline_003
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00020_Ch_Discipline_001
    ko: "\uD1B5\uCC30\uC740 \uC633\uC73C\uB098 \uD604\uC7A5 \uBCC0\uC218\uAC00 \uB204\uB77D\uB410\uB2E4.
      \uBCC0\uC218\uAE4C\uC9C0 \uC218\uBE44 \uB85C\uC9C1\uC5D0 \uB300\uC785\uD558\uBA74
      \uC644\uBCBD\uD55C \uC815\uB2F5\uC774 \uB420 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Principled_101
    ko: "\uD604\uC7A5 \uBCC0\uC218 \uB300\uC785... \uC81C\uAC00 \uACE0\uC815\uB41C
      \uC218\uCE58\uC5D0\uB9CC \uB9E4\uBAB0\uB418\uC5B4 \uD750\uB984\uC774\uB77C\uB294
      \uC0C1\uC704 \uC6D0\uCE59\uC744 \uB193\uCCE4\uAD70\uC694. \uC989\uC2DC \uB85C\uC9C1\uC744
      \uBCF4\uC644\uD558\uC5EC \uC644\uBCBD\uD55C \uC218\uBE44\uB97C \uC7AC\uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Principled_1
    ko: "\uC0C8\uB85C\uC6B4 \uBCC0\uC218\uB97C \uC6D0\uCE59\uC758 \uC644\uC131\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Guardian_101
    ko: "\uACA9\uB824\uB294 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uC2DC\uC2A4\uD15C\uC774
      \uD300\uC6D0\uB4E4\uC744 \uBCF4\uD638\uD558\uC9C0 \uBABB\uD558\uACE0 \uD30C\uC6B8\uC774\uB77C\uB294
      \uC624\uC810\uC744 \uB0A8\uACBC\uC2B5\uB2C8\uB2E4. \uC774 \uBD88\uC644\uC804\uD568\uC744
      \uBB35\uC778\uD558\uACE0 \uB6F8 \uC218\uB294 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Guardian_1
    ko: "\uBD88\uC548\uAC10 \uD0D3\uC5D0 \uACA9\uB824\uAC00 \uC804\uD600 \uD1B5\uD558\uC9C0
      \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Tactician_101
    ko: "\uD1B5\uCC30\uB825\uC744 \uC778\uC815\uD574\uC8FC\uC2DC\uB294 \uAC74 \uC88B\uC2B5\uB2C8\uB2E4\uB9CC,
      \uBCC0\uC218\uB97C \uC81C\uC5B4\uD558\uC9C0 \uBABB\uD558\uB294 \uC2DC\uC2A4\uD15C\uC740
      \uC804\uC220\uB85C\uC11C \uAC00\uCE58\uAC00 \uB0AE\uC2B5\uB2C8\uB2E4. \uBCF4\uC644\uCC45\uC774
      \uB354 \uD544\uC694\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Tactician_1
    ko: "\uACC4\uC0B0\uAE30\uB97C \uB450\uB4DC\uB9AC\uB290\uB77C \uBCF5\uADC0\uAC00
      \uB2A6\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Exemplary_101
    ko: "\uC644\uBCBD\uD55C \uC815\uB2F5\uC774\uB77C\uB2C8\uC694... \uC774\uBBF8
      \uD30C\uC6B8\uC774\uB77C\uB294 \uC624\uC810\uC744 \uB0A8\uAE34 \uC2DC\uC810\uC5D0\uC11C
      \uC800\uB294 \uAE30\uC900\uC810\uC774 \uB420 \uC790\uACA9\uC744 \uC783\uC5C8\uC2B5\uB2C8\uB2E4.
      \uC2DC\uAC04\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Exemplary_1
    ko: "\uAC10\uB3C5\uC758 \uB108\uADF8\uB7EC\uC6C0\uC744 \uBD80\uB044\uB7EC\uC6CC\uD558\uBA70
      \uC790\uCC45\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Ch_Discipline_002
    ko: "\uD56D\uC0C1 \uBCC0\uC218\uAC00 \uC77C\uC5B4\uB098\uAE30 \uB9C8\uB828\uC774\uB2E4.
      \uADF8\uAC83\uC744 \uC54C\uC9C0 \uBABB\uD558\uBA74 \uACE0\uC7A5 \uB09C \uACC4\uC0B0\uAE30\uC77C
      \uBFD0\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Principled_201
    ko: "\uACE0\uC7A5 \uB09C \uACC4\uC0B0\uAE30\uAC00 \uC544\uB2D9\uB2C8\uB2E4. \uC6D0\uCE59\uC774
      \uBB34\uB108\uC9C0\uBA74 \uC2B9\uB9AC\uB3C4 \uC6B0\uC5F0\uC77C \uBFD0\uC785\uB2C8\uB2E4.
      \uC81C \uC6D0\uCE59\uC758 \uC815\uB2F9\uC131\uC744 \uC99D\uBA85\uD560 \uC2DC\uAC04\uC744
      \uB354 \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Principled_2
    ko: "\uBE44\uD310\uC744 \uC2DC\uD5D8\uC73C\uB85C \uC5EC\uAE30\uACE0 \uACE0\uC9D1\uC744
      \uD53C\uC6E0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Guardian_201
    ko: "\uCC45\uC784\uC744 \uD53C\uD558\uB824\uB294 \uAC8C \uC544\uB2D9\uB2C8\uB2E4.
      \uB3D9\uB8CC\uB4E4\uC5D0\uAC8C \uD30C\uC6B8\uC774\uB77C\uB294 \uC9D0\uC744
      \uC9C0\uC6B0\uC9C0 \uC54A\uAE30 \uC704\uD55C \uBD84\uC11D\uC77C \uBFD0\uC785\uB2C8\uB2E4.
      \uB2E4\uC2DC \uC0DD\uAC01\uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Guardian_2
    ko: "\uC5EC\uC804\uD788 \uC790\uC2E0\uC758 \uC624\uB958\uB97C \uC6A9\uC11C\uD558\uC9C0
      \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Tactician_201
    ko: "\uACC4\uC0B0\uAE30\uC77C \uBFD0\uC774\uB77C... \uC81C \uC804\uC220\uC801
      \uC624\uB9CC\uC774 \uACB0\uACFC\uC801\uC73C\uB85C \uD300\uC758 \uC790\uC6D0\uC744
      \uB0AD\uBE44\uD588\uAD70\uC694. \uB2F9\uC7A5 \uCF54\uD2B8 \uC704\uC5D0\uC11C
      \uC2E4\uC804 \uB370\uC774\uD130\uB85C \uC81C \uD6A8\uC728\uC131\uC744 \uC785\uC99D\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Tactician_2
    ko: "\uC2B9\uB9AC\uC5D0 \uAE30\uC5EC\uD568\uC744 \uC99D\uBA85\uD558\uB824 \uC989\uAC01
      \uC6C0\uC9C1\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Exemplary_201
    ko: "\uC81C\uAC00 \uC2DC\uC2A4\uD15C \uB4A4\uC5D0 \uC228\uC5B4 \uBE44\uAC81\uD558\uAC8C
      \uAD74\uC5C8\uAD70\uC694. \uB098\uBD80\uD130 \uC798\uD574\uC57C \uD55C\uB2E4\uB294
      \uC6D0\uCE59\uC744 \uC78A\uC5C8\uC2B5\uB2C8\uB2E4. \uB2E4\uC2DC \uBC11\uBC14\uB2E5\uBD80\uD130
      \uC81C \uBAA8\uBC94\uC744 \uC138\uC6B0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Exemplary_2
    ko: "\uB3C4\uB355\uC801 \uB3D9\uAE30\uBD80\uC5EC\uAC00 \uAC15\uD558\uAC8C \uC791\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Ch_Discipline_003
    ko: "\uB178\uD2B8\uB97C \uCC22\uC5B4 \uAC00\uC2B4\uC5D0 \uB358\uC9C4 \uB4A4,
      \uCC28\uAC00\uC6B4 \uB208\uBE5B\uC73C\uB85C \uCF54\uD2B8\uB97C \uAC00\uB9AC\uD0A4\uBA70
      \uD131 \uB05D\uC744 \uAE4C\uB531\uC778\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uAE30\uC900\uC810\uC744 \uC774\uB807\uAC8C \uD30C\uAD34\uD558\uC2DC\uBA74
      \uC5B4\uB5A1\uD569\uB2C8\uAE4C? \uC9C8\uC11C\uAC00 \uC0AC\uB77C\uC9C4 \uCF54\uD2B8
      \uC704\uC5D0\uC11C \uC804 \uBB34\uC5C7\uC744 \uADFC\uAC70\uB85C \uC6C0\uC9C1\uC5EC\uC57C
      \uD569\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Principled_3
    ko: "\uAE30\uC900\uC774 \uC0AC\uB77C\uC838 \uD589\uB3D9 \uC790\uCCB4\uAC00 \uBD88\uAC00\uB2A5\uD574\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Guardian_301
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uAE30\uB85D\uB41C \uBB38\uC7A5\uBCF4\uB2E4
      \uAC10\uB3C5\uB2D8\uC758 \uC758\uC9C0\uB97C \uC9C0\uD0A4\uB294 \uAC83\uC774
      \uC9C0\uAE08 \uC81C\uAC00 \uD574\uC57C \uD560 \uC218\uD638\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Guardian_3
    ko: "\uB2E8\uD638\uD55C \uACB0\uB2E8\uB825\uC5D0 \uC555\uB3C4\uB418\uC5B4 \uC21C\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Tactician_301
    ko: "\uC804\uC220\uC801 \uADFC\uAC70\uB97C \uCC22\uC73C\uC2DC\uB2E4\uB2C8\uC694.
      \uC774\uAC74 \uB208\uC744 \uAC10\uACE0 \uC804\uC7C1\uD130\uB85C \uB098\uAC00\uB77C\uB294
      \uC18C\uB9AC\uC640 \uAC19\uC2B5\uB2C8\uB2E4. \uBD84\uC11D \uC5C6\uB294 \uBCF5\uADC0\uB294
      \uBB34\uC758\uBBF8\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Tactician_3
    ko: "\uC804\uC758\uB97C \uC783\uACE0 \uC644\uC804\uD788 \uC0C1\uC2E4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Exemplary_301
    ko: "\uB9D0\uC500\uD558\uC9C0 \uC54A\uC73C\uC154\uB3C4 \uC54C\uACA0\uC2B5\uB2C8\uB2E4.
      \uADDC\uC728\uBCF4\uB2E4 \uC55E\uC11C\uC57C \uD558\uB294 \uAC74 \uC194\uC120\uC218\uBC94\uD558\uB294
      \uC790\uC138\uACA0\uC8E0. \uAC00\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Exemplary_3
    ko: "\uBAA8\uBC94\uC801 \uC790\uAC01\uC744 \uD558\uAC8C \uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Bond_001
    ko: "\uC5F0\uC2B5 \uACBD\uAE30 \uC885\uB8CC \uD6C4, \uC13C\uD130\uC778 \uC774
      \uC120\uC218\uB294 \uD300\uC6D0\uB4E4\uACFC \uC5B4\uC6B8\uB9AC\uC9C0 \uBABB\uD55C
      \uCC44 \uCF54\uD2B8 \uD55C\uBCF5\uD310\uC5D0\uC11C \uC804\uC220 \uB178\uD2B8\uB97C
      \uB4E4\uC774\uBC00\uBA70 \uB2F9\uC2E0\uC744 \uBD99\uC7A1\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Bond_002
    ko: "\uC624\uB298 \uBC1C\uC0DD\uD55C \uB2E8 \uD55C \uBC88\uC758 \uD30C\uC6B8\uC774
      \uD300\uC758 \uC644\uBCBD\uD55C \uD750\uB984\uC744 \uB04A\uC5C8\uB2E4\uB294
      \uC790\uCC45\uAC10\uC744 \uC804\uC220\uC801 \uACB0\uD568\uC5D0 \uB300\uD55C
      \uC9C0\uC801\uC73C\uB85C \uC2B9\uD654\uC2DC\uCF1C \uC3DF\uC544\uB0C5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Bond_003
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC774 \uBAA8\uC21C\uC744 \uD574\uACB0\uD574 \uC8FC\uC9C0
      \uC54A\uC73C\uBA74 \uC790\uC2E0\uC774 \uD300\uC5D0 \uD574\uAC00 \uB418\uB294
      \uC874\uC7AC\uAC00 \uB420\uAE4C \uBD10 \uB450\uB824\uC6CC\uD558\uBA70 \uB9DD\uC124\uC774\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Bond_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00020_Ch_Bond_001
    ko: "\uD30C\uC6B8 \uD558\uB098\uB85C \uAC00\uCE58\uB294 \uBCC0\uD558\uC9C0 \uC54A\uB294\uB2E4.
      \uB10C \uD300\uC758 \uC911\uC2EC\uC774\uB2C8 \uD1B5\uCC30\uB825\uC73C\uB85C
      \uD300\uC6D0\uB4E4\uC758 \uBE48\uD2C8\uC744 \uCC44\uC6CC\uB77C."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uC81C \uC2E4\uC218\uAC00 \uD300 \uC804\uCCB4\uC758
      \uC798\uBABB\uC774 \uC544\uB2C8\uB77C\uACE0 \uB9D0\uC500\uD574 \uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD574\uC694. \uB2E4\uC2DC \uD300\uC6D0\uB4E4\uC5D0\uAC8C \uC6C3\uC73C\uBA70
      \uB2E4\uAC00\uAC08 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Kind_1
    ko: "\uC2EC\uB9AC\uC801 \uBD88\uC548\uC744 \uD574\uC18C\uD558\uACE0 \uB2E4\uC2DC
      \uD5CC\uC2E0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Loyal_101
    ko: "\uBBFF\uC5B4\uC8FC\uC2DC\uB294 \uAC74 \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC
      \uAC10\uB3C5\uB2D8\uC758 \uC644\uBCBD\uD55C \uC804\uC220\uC5D0 \uC81C\uAC00
      \uC624\uC810\uC744 \uB0A8\uACBC\uB2E4\uB294 \uC0AC\uC2E4\uC774 \uB108\uBB34
      \uAD34\uB86D\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Loyal_1
    ko: "\uACA9\uB824\uB9CC\uC73C\uB860 \uC790\uC2E0\uC758 \uACFC\uC624\uB97C \uC53B\uC5B4\uB0B4\uC9C0
      \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Sincere_101
    ko: "\uC81C \uBD84\uC11D\uC774 \uD300\uC6D0\uB4E4\uC758 \uBE48\uD2C8\uC744 \uCC44\uC6B8
      \uC218 \uC788\uB2E4\uBA74... \uB2E4\uC2DC \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4.
      \uAFB8\uC900\uD568\uC774 \uC81C \uC7A5\uC810\uC774\uB2C8\uAE4C\uC694. \uC2E4\uB9DD\uC2DC\uD0A4\uC9C0
      \uC54A\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Sincere_1
    ko: "\uC2E0\uB8B0\uB97C \uC5BB\uC5C8\uB2E4\uB294 \uC0DD\uAC01\uC5D0 \uBB35\uBB35\uD788
      \uC790\uB9AC\uB97C \uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Moodmaker_101
    ko: "\uC5D0\uC774, \uAC10\uB3C5\uB2D8. \uADF8\uB7F0 \uC9C4\uC9C0\uD55C \uC704\uB85C\uB294
      \uC800\uB791 \uC548 \uC5B4\uC6B8\uB824\uC694. \uC804 \uC9C0\uAE08 \uC774 \uC804\uC220\uC801
      \uACB0\uD568\uC774 \uB108\uBB34 \uC9DC\uC99D \uB098\uC11C \uBABB \uCC38\uACA0\uB2E4\uACE0\uC694!"
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Moodmaker_1
    ko: "\uC804\uC220 \uC9C0\uC801\uC73C\uB85C \uAC10\uCD94\uB824\uB2E4 \uACA9\uB824\uAC00
      \uAC89\uB3CC\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Ch_Bond_002
    ko: "\uD30C\uC6B8 \uBD84\uC11D\uD558\uB290\uB77C \uB3D9\uB8CC\uB4E4\uC744 \uD63C\uC790
      \uB450\uB294 \uAC8C \uC720\uB300\uB0D0. \uD551\uACC4 \uB300\uC9C0 \uB9D0\uACE0
      \uB2F9\uC7A5 \uD569\uC744 \uB9DE\uCDB0\uB77C."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Kind_201
    ko: "\uC800\uB294 \uB2E8\uC9C0 \uD300\uC744 \uC704\uD574\uC11C... \uAC10\uB3C5\uB2D8\uAED8
      \uC2E4\uB9DD\uC744 \uB4DC\uB838\uAD70\uC694. \uC8C4\uC1A1\uD569\uB2C8\uB2E4.
      \uC81C\uAC00 \uD300\uC5D0 \uC788\uC744 \uC790\uACA9\uC774 \uC788\uB294\uC9C0
      \uBAA8\uB974\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Kind_2
    ko: "\uAE4A\uC740 \uC6B0\uC6B8\uAC10\uC5D0 \uBE60\uC838 \uD300\uC5D0\uC11C \uBA40\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Loyal_201
    ko: "\uC81C\uAC00 \uAC10\uB3C5\uB2D8\uAED8 \uD551\uACC4\uB97C \uB300\uACE0 \uC788\uB2E4\uB2C8...
      \uBC30\uC2E0\uAC10\uB9C8\uC800 \uB4DC\uB124\uC694. \uC804 \uC815\uB9D0 \uD300\uC744
      \uC644\uBCBD\uD558\uAC8C \uB9CC\uB4E4\uACE0 \uC2F6\uC5C8\uC744 \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Loyal_2
    ko: "\uC2E0\uB8B0 \uAD00\uACC4\uC5D0 \uADE0\uC5F4\uC774 \uC0DD\uACA8 \uC758\uC695\uC744
      \uC0C1\uC2E4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Sincere_201
    ko: "\uB3D9\uB8CC\uB4E4\uC744 \uD63C\uC790 \uB454 \uAC8C \uC798\uBABB\uC774\uB77C\uB294
      \uB9D0\uC500, \uC774\uD574\uD569\uB2C8\uB2E4. \uBD84\uC11D\uB3C4 \uC911\uC694\uD558\uC9C0\uB9CC
      \uC81C \uC790\uB9AC\uB97C \uC9C0\uD0A4\uB294 \uAC8C \uC6B0\uC120\uC774\uC5C8\uAD70\uC694.
      \uBCF5\uADC0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Sincere_2
    ko: "\uC5ED\uD560\uC744 \uAE68\uB2EB\uACE0 \uAC15\uD55C \uC758\uBB34\uAC10\uC5D0
      \uBCF5\uADC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Moodmaker_201
    ko: "\uC544, \uB531 \uAC78\uB838\uB124. \uB3D9\uB8CC\uB4E4\uC774 \uAE30\uB2E4\uB9B0\uB2E4\uB294
      \uB9D0\uC5D0 \uC57D\uD55C \uAC70 \uC544\uC2DC\uBA74\uC11C! \uC54C\uC558\uC5B4\uC694,
      \uAC00\uC11C \uBD84\uC704\uAE30 \uC880 \uB744\uC6CC\uBCF4\uACE0 \uC62C\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Moodmaker_2
    ko: "\uD300 \uBD84\uC704\uAE30\uAC00 \uC6B0\uC120\uC774\uB77C\uBA70 \uAE08\uBC29
      \uD65C\uAE30\uB97C \uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Ch_Bond_003
    ko: "\uC5B4\uAE68\uB97C \uAF49 \uC950\uACE0 \uB2E8\uD638\uD55C \uC2E0\uB8B0\uB97C
      \uBCF4\uB0B8 \uB4A4, \uB178\uD2B8 \uC870\uAC01\uC744 \uC8FC\uBA38\uB2C8\uC5D0
      \uB123\uACE0 \uD300\uC6D0\uB4E4 \uCABD\uC73C\uB85C \uC774\uB048\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Kind_301
    ko: "\uC5B4\uAE68\uB97C \uC7A1\uC544\uC8FC\uC154\uC11C \uC870\uAE08 \uC548\uC2EC\uC774
      \uB3FC\uC694. \uD558\uC9C0\uB9CC \uC81C\uAC00 \uC800\uC9C0\uB978 \uC2E4\uC218\uB97C
      \uD300\uC6D0\uB4E4\uC774 \uC6A9\uC11C\uD574 \uC904\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Kind_3
    ko: "\uD0C0\uC778 \uC2DC\uC120\uC744 \uC758\uC2DD\uD574 \uC644\uC804\uD788 \uB9C8\uC74C\uC744
      \uBABB \uC5F4\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uB208\uBE5B\uC5D0\uC11C \uB2F5\uC744 \uC5BB\uC5C8\uC2B5\uB2C8\uB2E4.
      \uC774 \uB178\uD2B8\uBCF4\uB2E4 \uAC10\uB3C5\uB2D8\uC758 \uC9C0\uC2DC\uB97C
      \uB05D\uAE4C\uC9C0 \uB530\uB974\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Loyal_3
    ko: "\uB9D0\uBCF4\uB2E4 \uD655\uC2E4\uD55C \uCDA9\uC131\uC758 \uC9C0\uD45C\uB85C
      \uBC1B\uC544\uB4E4\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Sincere_301
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uACE0\uBBFC\uC740 \uAC00\uBCBC\uC6B4 \uAC8C
      \uC544\uB2D9\uB2C8\uB2E4. \uB178\uD2B8\uB97C \uC774\uB807\uAC8C \uCE58\uC6CC\uBC84\uB9AC\uC2DC\uBA74
      \uC81C \uB178\uB825\uC774 \uBD80\uC815\uB2F9\uD558\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Sincere_3
    ko: "\uB370\uC774\uD130\uB97C \uBB34\uC2DC\uD558\uB294 \uD589\uB3D9\uC5D0 \uD070
      \uC0C1\uC2E4\uAC10\uC744 \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Moodmaker_301
    ko: "\uC624, \uAC10\uB3C5\uB2D8 \uBC15\uB825! \uADFC\uB370 \uC81C \uB178\uD2B8
      \uC870\uAC01 \uC8FC\uBA38\uB2C8\uC5D0 \uB123\uC73C\uC2E0 \uAC74 \uC880 \uADC0\uC5EC\uC6B0\uC2E0\uB370\uC694?
      \uD06C\uD06C, \uC77C\uB2E8 \uAC00\uBCFC\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Moodmaker_3
    ko: "\uC2E4\uCC45\uC5D0 \uB300\uD55C \uADFC\uBCF8\uC801\uC778 \uBD88\uC548\uC740
      \uACC4\uC18D \uB0A8\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Cold_001
    ko: "\uD6C8\uB828\uC774 \uBAA8\uB450 \uB05D\uB0AC\uC74C\uC5D0\uB3C4 \uC774 \uC120\uC218\uB294
      \uCF54\uD2B8\uB97C \uB5A0\uB098\uC9C0 \uC54A\uACE0 \uB2F9\uC2E0\uC744 \uB9C9\uC544\uC12D\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Cold_002
    ko: "\uC624\uB298 \uAE30\uB85D\uB41C \uD30C\uC6B8 1\uAC1C\uB97C \uBD84\uC11D\uD558\uB290\uB77C
      \uBA38\uB9BF\uC18D\uC774 \uBCF5\uC7A1\uD574\uC9C4 \uADF8\uB294, \uC790\uAE30
      \uC798\uBABB\uC774 \uC544\uB2C8\uB77C \uC804\uC220\uC774 \uC774\uC0C1\uD574\uC11C
      \uC0DD\uAE34 \uC624\uB958\uB77C\uACE0 \uC8FC\uC7A5\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Cold_003
    ko: "\uC18D\uC73C\uB85C\uB294 \uC2E4\uC218\uD55C \uC790\uC2E0\uC774 \uD300\uC5D0
      \uBC29\uD574\uAC00 \uB420\uAE4C \uBD10 \uAC81\uB098\uBA74\uC11C, \uAC89\uC73C\uB85C\uB294
      \uAC10\uB3C5\uB2D8\uC758 \uC804\uC220\uC801 \uACB0\uD568\uC744 \uC9C0\uC801\uD558\uBA70
      \uCC1D\uCC1D\uD568\uC744 \uD574\uC18C\uD574\uC8FC\uAE30 \uC804\uAE4C\uC9C0\uB294
      \uBABB \uAC00\uACA0\uB2E4\uACE0 \uBC84\uD2F0\uB294 \uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Cold_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00020_Ch_Cold_001
    ko: "\uBD84\uC11D\uC740 \uB0A0\uCE74\uB85C\uC6B0\uB098 \uC2E4\uC804 \uBCC0\uC218\uAC00
      \uBE60\uC84C\uB2E4. \uB0B4\uC77C \uC544\uCE68\uAE4C\uC9C0 \uBCC0\uC218\uB97C
      \uBCF4\uC644\uD55C \uC0C8 \uC218\uBE44\uC548\uC744 \uC9DC\uC640\uB77C."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Planner_101
    ko: "\uBCC0\uC218 \uB300\uC785... \uC81C \uB85C\uC9C1\uC758 \uAD6C\uBA4D\uC744
      \uC815\uD655\uD788 \uC9DA\uC73C\uC168\uAD70\uC694. \uC989\uC2DC \uBCF4\uC644\uD574\uC11C
      \uBB34\uACB0\uC810 \uC218\uBE44\uC548\uC744 \uC9DC\uC624\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Planner_1
    ko: "\uC9C0\uC801 \uC720\uD76C\uB97C \uB290\uB07C\uBA70 \uC0C8\uB85C\uC6B4 \uBCC0\uC218\uB97C
      \uC989\uAC01 \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Opportunist_101
    ko: "\uACA9\uB824\uB294 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uC2DC\uC2A4\uD15C \uBAA8\uC21C\uC774
      \uD574\uACB0 \uC548 \uB418\uBA74 \uC81C \uD3C9\uC810\uB9CC \uAE4E\uC785\uB2C8\uB2E4.
      \uC800\uB97C \uBCF4\uD638\uD560 \uD655\uC2E4\uD55C \uB9E4\uB274\uC5BC\uC744
      \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Opportunist_1
    ko: "\uC8FC\uC804 \uC790\uB9AC\uB97C \uC9C0\uD0AC \uC2E4\uC9C8\uC801\uC778 \uC774\uB4DD\uC744
      \uC6B0\uC120\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Cunning_101
    ko: "\uC81C \uBD84\uC11D\uC744 \uC778\uC815\uD558\uC2DC\uB2E4\uB2C8 \uC758\uC678\uB124\uC694.
      \uB098\uC911\uC5D0 \uBB38\uC81C \uC0DD\uAE30\uBA74 \uB124 \uC124\uACC4\uB300\uB85C
      \uD588\uC73C\uB2C8 \uB124 \uCC45\uC784\uC774\uB2E4\uB77C\uACE0 \uD558\uC2DC\uB824\uB294
      \uAC74 \uC544\uB2C8\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Cunning_1
    ko: "\uCC45\uC784 \uC804\uAC00\uB97C \uC704\uD55C \uBC11\uC791\uC5C5\uC73C\uB85C
      \uAC15\uD558\uAC8C \uC758\uC2EC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Believer_101
    ko: "\uBCC0\uC218 \uD0D3\uC774 \uC544\uB2D9\uB2C8\uB2E4. \uC81C \uC6D0\uCE59\uC774
      \uC544\uC9C1 \uC644\uBCBD\uD558\uAC8C \uAD6C\uD604\uB418\uC9C0 \uC54A\uC558\uC744
      \uBFD0\uC785\uB2C8\uB2E4. \uC800\uB294 \uC81C \uBC29\uC2DD\uB300\uB85C \uB05D\uC744
      \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Believer_1
    ko: "\uC720\uC5F0\uC131\uC744 \uAD8C\uD558\uB294 \uACA9\uB824\uB97C \uC6D0\uCE59
      \uD6FC\uC190\uC73C\uB85C \uAC04\uC8FC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Ch_Cold_002
    ko: "\uC774\uB860 \uB530\uC9C0\uB290\uB77C \uB2A6\uCD94\uB294 \uAC8C \uD6A8\uC728\uC774\uB0D0.
      \uBD84\uC11D\uC740 \uC9D1\uC5D0\uC11C \uD558\uACE0 \uB0B4\uC77C \uC2E4\uB825\uC73C\uB85C
      \uC99D\uBA85 \uBABB \uD558\uBA74 \uC785\uB9CC \uC0B0 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Planner_201
    ko: "\uC785\uB9CC \uC0B0 \uAC8C \uC544\uB2D9\uB2C8\uB2E4. \uD655\uB960\uC801\uC73C\uB85C
      \uAC00\uC7A5 \uC548\uC804\uD55C \uC120\uD0DD\uC744 \uD588\uC744 \uBFD0\uC785\uB2C8\uB2E4.
      \uC81C \uACC4\uC0B0\uC744 \uC99D\uBA85\uD560 \uC2DC\uAC04\uC744 \uB354 \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Planner_2
    ko: "\uACC4\uC0B0\uC774 \uB9DE\uC74C\uC744 \uC99D\uBA85\uD558\uB290\uB77C \uB300\uD654\uAC00
      \uAE38\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Opportunist_201
    ko: "\uC785\uB9CC \uC0B0 \uB188\uC774\uB77C\uB2C8... \uC81C \uAC00\uCE58\uAC00
      \uB5A8\uC5B4\uC9C0\uB294 \uAC74 \uCC38\uC744 \uC218 \uC5C6\uAD70\uC694. \uB0B4\uC77C
      \uCF54\uD2B8\uC5D0\uC11C \uC81C \uD6A8\uC6A9\uC131\uC744 \uD655\uC2E4\uD788
      \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Opportunist_2
    ko: "\uC785\uC9C0\uAC00 \uC881\uC544\uC9C8\uAE4C \uACF5\uD3EC\uB97C \uB290\uAEF4
      \uC0DD\uC874 \uBCF8\uB2A5\uC774 \uCF1C\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Cunning_201
    ko: "\uC785\uB9CC \uC0B4\uC558\uB2E4\uB2C8\uC694. \uC81C\uAC00 \uC774 \uB178\uD2B8\uB97C
      \uB4E4\uC774\uBBF8\uB294 \uAC74 \uAC10\uB3C5\uB2D8 \uC804\uC220 \uC2E4\uD328\uB97C
      \uBBF8\uB9AC \uCEE4\uBC84\uD574\uB4DC\uB9AC\uB824\uB294 \uAC74\uB370, \uC12D\uC12D\uD558\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Cunning_2
    ko: "\uB0A0\uCE74\uB85C\uC6B4 \uB3C5\uC124\uB85C \uB300\uC751\uD558\uBA70 \uBCF8\uC2EC\uC744
      \uB4DC\uB7EC\uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Believer_201
    ko: "\uBE44\uB09C\uD558\uC154\uB3C4 \uC81C \uC2E0\uB150\uC740 \uBCC0\uD558\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4. \uB2E4\uB9CC \uC2B9\uB9AC\uB97C \uC704\uD574 \uC81C
      \uC6D0\uCE59\uC744 \uC5B4\uB5BB\uAC8C \uC801\uC6A9\uD560\uC9C0\uB294 \uB2E4\uC2DC
      \uACE0\uBBFC\uD574\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Believer_2
    ko: "\uB85C\uC9C1\uC744 \uC7AC\uAC80\uD1A0\uD560 \uCD5C\uC18C\uD55C\uC758 \uC758\uC0AC\uB294
      \uBCF4\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Ch_Cold_003
    ko: "\uB178\uD2B8\uB97C \uB36E\uC5B4 \uCC45\uAC00\uBC29\uC5D0 \uB123\uACE0 \uAC00\uBC29\uC744
      \uACE0\uCCD0 \uB9E4\uAC8C \uD55C \uB4A4 \uCCB4\uC721\uAD00 \uBB38\uCABD\uC73C\uB85C
      \uB4F1\uC744 \uBC00\uC5B4\uB0B4\uACE0 \uB4A4\uB3CC\uC544\uC120\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Planner_301
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uADFC\uAC70\uB97C \uC774\uB807\uAC8C \uCE58\uC6B0\uC2DC\uBA74
      \uC5B4\uB5A1\uD569\uB2C8\uAE4C? \uC124\uACC4\uB3C4 \uC5C6\uC774 \uB0B4\uC77C
      \uC5B4\uB5BB\uAC8C \uB701\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Planner_3
    ko: "\uB17C\uB9AC\uC801 \uC5F0\uC18D\uC131\uC774 \uB04A\uACA8 \uADF9\uC2EC\uD55C
      \uACF5\uD669\uC5D0 \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Opportunist_301
    ko: "\uB2E8\uD638\uD558\uC2DC\uB124\uC694. \uAC10\uB3C5\uB2D8\uACFC \uCC99\uC838\uBD10\uC57C
      \uC190\uD574\uB77C\uB294 \uAC74 \uC544\uB2C8\uAE4C \uC77C\uB2E8 \uAC00\uC8E0.
      \uB0B4\uC77C \uBD59\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Opportunist_3
    ko: "\uBD88\uC774\uC775\uC744 \uBE60\uB974\uAC8C \uACC4\uC0B0\uD558\uACE0 \uC2E4\uB9AC\uC801\uC73C\uB85C
      \uAD74\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Cunning_301
    ko: "\uB9D0\uBCF4\uB2E4 \uD655\uC2E4\uD558\uC2DC\uB124\uC694. \uB17C\uB9AC \uB530\uC704
      \uC9D1\uC5B4\uCE58\uC6B0\uACE0 \uC2E4\uC804\uC73C\uB85C\uB9CC \uBCF4\uC790\uB294
      \uB73B\uC774\uC8E0? \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Cunning_3
    ko: "\uD30C\uACA9\uC801\uC778 \uD589\uB3D9\uC5D0\uC11C \uCE74\uB9AC\uC2A4\uB9C8\uB97C
      \uB290\uB07C\uACE0 \uB9E4\uB8CC\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Believer_301
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uB0A1\uC740 \uBB38\uC790\uB294 \uBC84\uB9AC\uC8E0.
      \uB0B4\uC77C \uCF54\uD2B8 \uC704\uC5D0\uC11C \uC81C \uBAB8\uC73C\uB85C \uC0C8\uB85C\uC6B4
      \uC9C8\uC11C\uB97C \uC138\uC6B0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Believer_3
    ko: "\uC0C8\uB85C\uC6B4 \uC9C8\uC11C\uC758 \uC120\uD3EC\uB85C \uB290\uB07C\uACE0
      \uB2E8\uD638\uD788 \uC21C\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Instinct_001
    ko: "\uD6C8\uB828\uC774 \uBAA8\uB450 \uB05D\uB0AC\uC74C\uC5D0\uB3C4 \uC774 \uC120\uC218\uB294
      \uCF54\uD2B8\uB97C \uB5A0\uB098\uC9C0 \uC54A\uACE0 \uB2F9\uC2E0\uC744 \uB9C9\uC544\uC12D\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Instinct_002
    ko: "\uC624\uB298 \uAE30\uB85D\uB41C \uD30C\uC6B8 1\uAC1C\uB97C \uBD84\uC11D\uD558\uB290\uB77C
      \uBA38\uB9BF\uC18D\uC774 \uBCF5\uC7A1\uD574\uC9C4 \uADF8\uB294, \uC790\uAE30
      \uC798\uBABB\uC774 \uC544\uB2C8\uB77C \uC804\uC220\uC774 \uC774\uC0C1\uD574\uC11C
      \uC0DD\uAE34 \uC624\uB958\uB77C\uACE0 \uC8FC\uC7A5\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Instinct_003
    ko: "\uC18D\uC73C\uB85C\uB294 \uC2E4\uC218\uD55C \uC790\uC2E0\uC774 \uD300\uC5D0
      \uBC29\uD574\uAC00 \uB420\uAE4C \uBD10 \uAC81\uB098\uBA74\uC11C, \uAC89\uC73C\uB85C\uB294
      \uAC10\uB3C5\uB2D8\uC758 \uC804\uC220\uC801 \uACB0\uD568\uC744 \uC9C0\uC801\uD558\uBA70
      \uCC1D\uCC1D\uD568\uC744 \uD574\uC18C\uD574\uC8FC\uAE30 \uC804\uAE4C\uC9C0\uB294
      \uBABB \uAC00\uACA0\uB2E4\uACE0 \uBC84\uD2F0\uB294 \uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Instinct_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00020_Ch_Instinct_001
    ko: "\uD798\uC774 \uB118\uCCD0 \uB098\uC628 \uD30C\uC6B8\uC774\uB2C8 \uC704\uCD95\uB418\uC9C0
      \uB9D0\uACE0 \uC0C1\uB300\uB97C \uC9D3\uBC1F\uB294 \uB370\uB9CC \uC368\uB77C.
      \uB10C \uD300\uC758 \uCD5C\uC885 \uBCD1\uAE30\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uC81C \uD30C\uC6CC\uB97C \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694?
      \uD558\uAE34, \uC81C \uD798\uC774 \uC880 \uACFC\uD588\uC8E0. \uB0B4\uC77C \uACE8\uB300
      \uBC15\uC0B4 \uB0B4\uB3C4 \uBAA8\uB985\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Bluffer_1
    ko: "\uADFC\uAC70 \uC5C6\uB294 \uC790\uC2E0\uAC10\uC744 \uB3D9\uB825 \uC0BC\uC544
      \uC0AC\uAE30\uB97C \uD68C\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Wild_101
    ko: "\uD798\uC774 \uB118\uCE5C\uB2E4\uB2C8\uC694. \uAC10\uB3C5\uB2D8 \uB208\uC5D4
      \uC81C\uAC00 \uC9C0\uAE08 \uD798 \uC8FC\uCCB4 \uBABB \uD574\uC11C \uC0AC\uACE0
      \uCE5C \uAC70\uB85C \uBCF4\uC774\uC2ED\uB2C8\uAE4C? \uB410\uC2B5\uB2C8\uB2E4.
      \uADF8\uB0E5 \uAC08\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Wild_1
    ko: "\uB2E8\uC21C\uD55C \uD798 \uC790\uB791\uC73C\uB85C \uCE58\uBD80\uD558\uBA70
      \uB9C8\uC74C\uC744 \uAD73\uAC8C \uB2EB\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Egoist_101
    ko: "\uC81C \uD798\uC774 \uB118\uCE5C \uAC74 \uC54C\uC9C0\uB9CC, \uC624\uB298
      \uD30C\uC6B8\uC740 \uC81C \uC644\uBCBD\uD55C \uAE30\uB85D\uC5D0 \uC624\uC810\uC785\uB2C8\uB2E4.
      \uC81C\uAC00 \uC800 \uC790\uC2E0\uC5D0\uAC8C \uC9DC\uC99D \uB09C \uAC74\uB370
      \uC65C \uC704\uB85C\uD558\uC2DC\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Egoist_1
    ko: "\uC704\uB85C\uAC00 \uC2E4\uC218\uB97C \uC9C0\uC6CC\uC8FC\uC9C0 \uBABB\uD574
      \uC624\uD788\uB824 \uBD88\uCF8C\uD574\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Fighter_101
    ko: "\uD798\uC774 \uB118\uCCD0\uC11C \uADF8\uB7AC\uB2E4\uACE0\uC694? \uC9C0\uAE08
      \uC800 \uB2EC\uB798\uC2DC\uB294 \uAC81\uB2C8\uAE4C? \uADF8\uB7F0 \uC2F8\uAD6C\uB824
      \uC704\uB85C\uB294 \uC9D1\uC5B4\uCE58\uC6B0\uACE0 \uC81C\uB300\uB85C \uB41C
      \uD53C\uB4DC\uBC31\uC744 \uC8FC\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Fighter_1
    ko: "\uC2E4\uC218\uB97C \uD68C\uD53C\uD558\uB294 \uAC10\uB3C5\uC758 \uD0DC\uB3C4\uC5D0
      \uD06C\uAC8C \uC2E4\uB9DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Ch_Instinct_002
    ko: "\uD30C\uC6B8\uC5D0 \uCAC4\uC544 \uB178\uD2B8 \uB4A4\uC5D0 \uC228\uC9C0 \uB9C8\uB77C.
      \uAC81\uC7C1\uC774\uCC98\uB7FC \uAD74 \uAC70\uBA74 \uB0B4\uC77C \uCF54\uD2B8\uC5D0
      \uC11C\uC9C0 \uB9C8\uB77C."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Bluffer_201
    ko: "\uB204\uAC00 \uCAC4\uC558\uB2E4\uACE0 \uADF8\uB798\uC694? \uC804 \uADF8\uB0E5
      \uC804\uC220\uC744 \uB17C\uC758\uD55C \uAC81\uB2C8\uB2E4! \uB0B4\uC77C \uC81C
      \uD654\uB824\uD55C \uD50C\uB808\uC774 \uBCF4\uC2DC\uBA74 \uB180\uB77C\uC2E4\uAC78\uC694?"
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Bluffer_2
    ko: "\uB9DD\uC2E0\uB2F9\uD558\uC9C0 \uC54A\uC73C\uB824\uACE0 \uC624\uAE30\uB85C
      \uB0B4\uC77C \uD6C8\uB828\uC744 \uC900\uBE44\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Wild_201
    ko: "\uCAC4\uC558\uB0D0\uB2C8... \uC9C0\uAE08 \uC808 \uAC81\uC7C1\uC774 \uCDE8\uAE09\uD558\uC2DC\uB294
      \uAC81\uB2C8\uAE4C? \uADF8\uB7F0 \uC2DD\uC73C\uB85C \uB9D0\uC500\uD558\uC2DC\uBA74
      \uC800\uB3C4 \uC548 \uCC38\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Wild_2
    ko: "\uC801\uB300\uC801 \uD589\uC704\uB85C \uAC04\uC8FC\uD574 \uAC10\uB3C5\uACFC
      \uC815\uBA74\uCDA9\uB3CC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Egoist_201
    ko: "\uC81C\uAC00 \uBB34\uC11C\uC6B4 \uAC74 \uAC10\uB3C5\uB2D8 \uC9C8\uCC45\uC774
      \uC544\uB2C8\uB77C, \uC81C \uC2E4\uB825\uC774 \uC815\uCCB4\uB418\uB294 \uAC81\uB2C8\uB2E4.
      \uB0B4\uC77C \uC81C \uAC00\uCE58\uAC00 \uC5BC\uB9C8\uB098 \uB192\uC740\uC9C0
      \uB2E4\uC2DC \uD655\uC778\uC2DC\uCF1C \uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Egoist_2
    ko: "\uC9C8\uCC45\uC744 \uC99D\uBA85\uD560 \uB3C4\uC804\uC73C\uB85C \uC5EC\uAE30\uACE0
      \uC989\uAC01 \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Fighter_201
    ko: "\uCF54\uD2B8\uC5D0 \uC11C\uC9C0 \uB9D0\uB77C\uACE0\uC694? \uC6C3\uAE30\uC9C0
      \uB9C8\uC138\uC694. \uB0B4\uC77C \uC81C\uAC00 \uADF8\uB188\uB4E4 \uC601\uD63C\uAE4C\uC9C0
      \uD138\uC5B4\uBC84\uB9AC\uB294 \uAC70 \uC81C\uC77C \uC55E\uC904\uC5D0\uC11C
      \uAD6C\uACBD\uC774\uB098 \uD558\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Fighter_2
    ko: "\uBCF8\uB54C\uB97C \uBCF4\uC5EC\uC8FC\uACA0\uB2E4\uB294 \uC77C\uB150\uC73C\uB85C
      \uAC15\uD558\uAC8C \uC804\uC758\uB97C \uB2E4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Ch_Instinct_003
    ko: "\uB178\uD2B8\uB97C \uB358\uC838\uBC84\uB9AC\uACE0, \uBAA9\uB35C\uBBF8\uB97C
      \uAC00\uBCCD\uAC8C \uC950\uC5B4 \uB208\uC744 \uB9DE\uCD98 \uB4A4 \uACE8\uB300\uB97C
      \uAC00\uB9AC\uD0A4\uBA70 \uB4F1\uC744 \uAC15\uD558\uAC8C \uCE5C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Bluffer_301
    ko: "\uC544\uB2C8, \uAC10\uB3C5\uB2D8! \uC81C \uAE08\uCABD\uAC19\uC740 \uB178\uD2B8\uB97C...
      \uD3FC \uC548 \uB098\uAC8C \uC774\uAC8C \uBB61\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Bluffer_3
    ko: "\uB300\uC0AC \uC5C6\uC774 \uC81C\uC555\uB2F9\uD558\uC790 \uAC00\uC624\uAC00
      \uBB34\uB108\uC838 \uC2EC\uD1B5\uC774 \uB0AC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Wild_301
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uBA38\uB9AC\uB294 \uC880 \uC544\uD320\uB294\uB370,
      \uC774\uC81C \uC880 \uC0B4 \uAC83 \uAC19\uB124\uC694. \uB0B4\uC77C \uBD59\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Wild_3
    ko: "\uAC70\uCE5C \uC790\uADF9\uC5D0 \uC5B5\uB20C\uB9B0 \uC57C\uC131\uC774 \uAE68\uC5B4
      \uBAB8\uC758 \uAC10\uAC01\uC774 \uB3CC\uC544\uC654\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Egoist_301
    ko: "\uAC70\uCE60\uAC8C \uB2E4\uB8E8\uC2DC\uB124\uC694. \uBB50, \uC88B\uC2B5\uB2C8\uB2E4.
      \uC804\uC220 \uB530\uC704\uBCF4\uB2E4 \uC81C\uAC00 \uCF54\uD2B8\uC5D0\uC11C
      \uBE5B\uB098\uB294 \uAC8C \uB354 \uC911\uC694\uD558\uB2C8\uAE4C\uC694."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Egoist_3
    ko: "\uAC15\uC555\uC801 \uD0DC\uB3C4\uB3C4 \uC790\uAE30\uC560\uB85C \uD3EC\uC7A5\uD558\uBA70
      \uCFE8\uD558\uAC8C \uB118\uACBC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Desc_Fighter_301
    ko: "\uB178\uD2B8 \uB530\uC704 \uBC84\uB9AC\uC8E0. \uB0B4\uC77C \uC81C\uAC00
      \uB2E4 \uCC0D\uC5B4\uBC84\uB9AC\uBA74 \uAC10\uB3C5\uB2D8 \uC804\uC220\uC774
      \uB9DE\uB4E0 \uD2C0\uB9AC\uB4E0 \uC81C\uAC00 \uC774\uAE34 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00020_Rs_Fighter_3
    ko: "\uC2B9\uBD80\uC0AC \uBCF8\uB2A5\uC5D0 \uBD88\uC774 \uBD99\uC5B4 \uAE30\uC138\uB4F1\uB4F1\uD558\uAC8C
      \uD1F4\uADFC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Discipline_001
    ko: "\uC774 \uC120\uC218\uB294 \uAC10\uB3C5\uB2D8\uC774 \uAC15\uC870\uD55C \uBC15\uC2A4\uC544\uC6C3\uC758
      \uC815\uC11D \uC790\uC138\uC5D0\uB9CC \uC9D1\uCC29\uD558\uB290\uB77C \uC81C
      \uBA38\uB9AC \uB4A4\uB85C \uB118\uC5B4\uAC00\uB294 \uACF5\uC744 \uB2E8 \uD558\uB098\uB3C4
      \uD655\uBCF4\uD558\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Discipline_002
    ko: "\uD6C8\uB828\uC774 \uB05D\uB098\uACE0 \uAC10\uB3C5\uB2D8\uC774 \uC544\uBB34
      \uB9D0 \uC5C6\uC774 \uCF54\uD2B8\uB97C \uB5A0\uB098\uB824 \uD558\uC790, \uC120\uC218\uB294
      \uD669\uAE09\uD788 \uB2EC\uB824\uC640 \uB2F9\uC2E0\uC758 \uC55E\uAE38\uC744
      \uB9C9\uC544\uC12D\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Discipline_003
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uAC00\uB974\uCE5C \uADDC\uC728\uC744 100% \uC774\uD589\uD588\uC73C\uB2C8
      \uC790\uC2E0\uC740 \uD2C0\uB9AC\uC9C0 \uC54A\uC558\uB2E4\uB294 \uD655\uB2F5\uC744
      \uB4E3\uACE0 \uC2F6\uC5B4 \uBEE3\uBEE3\uD558\uAC8C \uBC84\uD2F0\uB294 \uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00021_Ch_Discipline_001
    ko: "\uC790\uC138\uB294 \uB9CC\uC810\uC774\uB098 \uB0B4\uC77C\uBD80\uD130\uB294
      \uADF8 \uC815\uC11D\uC5D0 \uACF5 \uD655\uBCF4\uB77C\uB294 \uB9C8\uC9C0\uB9C9
      \uB2E8\uACC4\uB97C \uCD94\uAC00\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Principled_101
    ko: "\uC81C \uB9E4\uB274\uC5BC\uC5D0 \uD655\uBCF4 \uB2E8\uACC4\uAC00 \uB204\uB77D\uB418\uC5C8\uAD70\uC694.
      \uC989\uC2DC \uC5C5\uB370\uC774\uD2B8\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Principled_1
    ko: "\uCD94\uAC00 \uC9C0\uCE68\uC744 \uACF5\uC2DD \uADDC\uCE59\uC73C\uB85C \uC218\uC6A9\uD574
      \uC644\uBCBD\uD788 \uC774\uD589\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Guardian_101
    ko: "\uB124... \uADF8\uB7F0\uB370 \uC790\uC138\uAC00 \uB9DE\uB294\uB370 \uC65C
      \uACF5\uC740 \uBABB \uC7A1\uB294 \uAC78\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Guardian_1
    ko: "\uC6D0\uCE59\uB9CC \uB418\uC0C8\uAE30\uBA70 \uBC1C\uC804 \uC5C6\uC774 \uC81C\uC790\uB9AC\uC5D0
      \uBA38\uBB3C\uB800\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Tactician_101
    ko: "\uD569\uB9AC\uC801\uC774\uB124\uC694. \uD558\uC9C0\uB9CC \uADF8\uAC74 \uC774\uBBF8
      \uC54C\uACE0 \uC788\uB294 \uB370\uC774\uD130\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Tactician_1
    ko: "\uC7AC\uD655\uC778 \uC218\uC900\uC5D0 \uADF8\uCCD0 \uC804\uC220\uC801 \uBC1C\uC804\uC774
      \uBA48\uCD94\uACE0 \uC815\uCCB4\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Exemplary_101
    ko: "\uC608, \uAC10\uB3C5\uB2D8. \uD558\uC9C0\uB9CC \uC815\uC11D\uB300\uB85C
      \uD588\uB294\uB370 \uC548 \uB41C \uAC74 \uC6B4\uC774 \uC5C6\uB358 \uAC70 \uC544\uB2D0\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Exemplary_1
    ko: "\uC644\uBCBD\uC8FC\uC758\uC5D0 \uD0C0\uD611\uC774 \uC0DD\uACA8 \uACB0\uACFC
      \uC9C0\uD5A5\uC801 \uD0DC\uB3C4\uAC00 \uC0AC\uB77C\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Ch_Discipline_002
    ko: "\uC6D0\uCE59\uB9CC \uC9C0\uD0A8\uB2E4\uACE0 \uB2E4\uAC00 \uC544\uB2C8\uB2E4.
      \uACF5\uB3C4 \uBABB \uC7A1\uB294 \uB188\uC774 \uBB34\uC2A8 \uC815\uC11D\uC744
      \uB17C\uD574. \uAE38 \uB9C9\uC9C0 \uB9D0\uACE0 \uBE44\uCF1C\uB77C."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Principled_201
    ko: "\uC804 \uC2DC\uD0A4\uC2E0 \uB300\uB85C \uD588\uC2B5\uB2C8\uB2E4. \uAE30\uC900\uC774
      \uBC14\uB00C\uB294 \uAC70\uB77C\uBA74 \uB0A9\uB4DD\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Principled_2
    ko: "\uACF5\uC815\uC131\uC5D0 \uC758\uBB38\uC744 \uD488\uACE0 \uAC10\uB3C5 \uC9C0\uC2DC
      \uC790\uCCB4\uB97C \uAC70\uBD80\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Guardian_201
    ko: "\uC81C\uAC00 \uD300\uC5D0 \uC9D0\uC774 \uB418\uC5C8\uAD70\uC694... \uB0B4\uC77C\uC740
      \uC8FD\uAE30 \uC0B4\uAE30\uB85C \uC7A1\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Guardian_2
    ko: "\uC2E4\uC810\uC744 \uC790\uAC01\uD558\uACE0 \uACF5 \uD655\uBCF4\uB77C\uB294
      \uC0C8\uB85C\uC6B4 \uBC29\uC5B4 \uB300\uC0C1\uC744 \uC138\uC6E0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Tactician_201
    ko: "\uC218\uB2E8\uACFC \uBAA9\uC801\uC744 \uD63C\uB3D9\uD558\uC2DC\uB294 \uAC74
      \uAC10\uB3C5\uB2D8 \uC544\uB2D9\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Tactician_2
    ko: "\uB17C\uB9AC\uC801 \uBAA8\uC21C\uC5D0 \uBC18\uBC1C\uD574 \uC804\uC220\uC801
      \uC2E0\uB8B0\uB97C \uC644\uC804\uD788 \uAC70\uB480\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Exemplary_201
    ko: "\uD300\uC6D0\uB4E4 \uC55E\uC5D0\uC11C... \uC81C\uAC00 \uADF8\uB807\uAC8C
      \uBB34\uB2A5\uD574 \uBCF4\uC600\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Exemplary_2
    ko: "\uADC0\uAC10\uC774 \uB3FC\uC57C \uD55C\uB2E4\uB294 \uACF5\uD3EC\uC5D0 \uACBD\uD569
      \uC790\uCCB4\uB97C \uD53C\uD558\uAC8C \uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Ch_Discipline_003
    ko: "\uB178\uD2B8\uB97C \uBE8F\uC5B4 \uBD89\uC740 \uD39C\uC73C\uB85C \uB9AC\uBC14\uC6B4\uB4DC
      \uD544\uC218\uB77C\uACE0 \uC801\uACE0 \uACF5\uC744 \uD22D \uB358\uC838\uC900\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Principled_301
    ko: "\uBA85\uD655\uD558\uAE34 \uD55C\uB370... \uAD73\uC774 \uC774\uB807\uAC8C\uAE4C\uC9C0
      \uD558\uC2E4 \uD544\uC694\uAC00 \uC788\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Principled_3
    ko: "\uACFC\uACA9\uD55C \uD589\uB3D9\uC774 \uBD88\uD544\uC694\uD55C \uC704\uC555\uAC10\uC73C\uB85C
      \uB2E4\uAC00\uC640 \uD6A8\uC728\uC774 \uB5A8\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uB178\uB825\uC744 \uBB34\uC2DC\uD558\uC2DC\uB294
      \uAC81\uB2C8\uAE4C? \uBB34\uC12D\uAC8C \uC65C \uADF8\uB7EC\uC138\uC694..."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Guardian_3
    ko: "\uC720\uB300\uAC10\uC774 \uAE68\uC9C0\uBA70 \uC2EC\uB9AC\uC801 \uC704\uCD95\uC774
      \uD50C\uB808\uC774 \uC800\uD558\uB85C \uC774\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Tactician_301
    ko: "\uC218\uB2E8\uBCF4\uB2E4 \uBAA9\uC801\uC774 \uC6B0\uC120\uC774\uB77C\uB294
      \uB73B\uC774\uAD70\uC694. \uB85C\uC9C1 \uC218\uC815 \uC644\uB8CC\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Tactician_3
    ko: "\uBA85\uD655\uD55C \uC2E0\uD638\uB97C \uC218\uC6A9\uD574 \uC989\uC2DC \uCD5C\uC801\uD654\uB41C
      \uB3D9\uC120\uC744 \uC124\uACC4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Exemplary_301
    ko: "\uC774\uAC8C \uB0B4\uC77C\uBD80\uD130 \uC6B0\uB9AC \uD300\uC758 \uC0C8\uB85C\uC6B4
      \uAE30\uC900\uC785\uB2C8\uB2E4. \uC81C\uAC00 \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Exemplary_3
    ko: "\uBCF8\uC9C8\uC801\uC778 \uC131\uACFC\uB97C \uB0B4\uAE30 \uC704\uD574 \uADF8
      \uC5B4\uB290 \uB54C\uBCF4\uB2E4 \uAC15\uB825\uD558\uAC8C \uAC01\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Bond_001
    ko: "\uD6C8\uB828 \uC804 \uAC10\uB3C5\uB2D8\uC774 \uAC15\uC870\uD55C \uC624\uB298
      \uBC15\uC2A4\uC544\uC6C3 \uC790\uC138 \uC548 \uBB34\uB108\uC9C0\uAC8C \uC2E0\uACBD
      \uC368!\uB77C\uB294 \uB9D0\uC744 \uD300\uC744 \uC704\uD55C \uACFC\uC81C\uB85C
      \uC0BC\uC740 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Bond_002
    ko: "\uD6C8\uB828\uC774 \uB05D\uB098\uACE0 \uAC10\uB3C5\uB2D8\uC774 \uC544\uBB34
      \uB9D0 \uC5C6\uC774 \uCF54\uD2B8\uB97C \uB5A0\uB098\uB824 \uD558\uC790, \uC120\uC218\uB294
      \uD669\uAE09\uD788 \uB2EC\uB824\uC640 \uB2F9\uC2E0\uC758 \uC55E\uAE38\uC744
      \uB9C9\uC544\uC12D\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Bond_003
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uAC00\uB974\uCE5C \uADDC\uC728\uC744 100% \uC774\uD589\uD588\uC73C\uB2C8
      \uC790\uC2E0\uC740 \uD2C0\uB9AC\uC9C0 \uC54A\uC558\uB2E4\uB294 \uD655\uB2F5\uC744
      \uB4E3\uACE0 \uC2F6\uC5B4 \uBEE3\uBEE3\uD558\uAC8C \uBC84\uD2F0\uB294 \uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Bond_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00021_Ch_Bond_001
    ko: "\uC57D\uC18D \uC9C0\uD0A4\uB290\uB77C \uACE0\uC0DD\uD588\uACE0 \uC790\uC138\uB294
      \uC644\uBCBD\uD558\uB2E4. \uC774\uC81C \uACF5\uAE4C\uC9C0 \uB124 \uAC78\uB85C
      \uB9CC\uB4E4\uC5B4\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Kind_101
    ko: "\uC5ED\uC2DC \uC54C\uC544\uC8FC\uC2E4 \uC904 \uC54C\uC558\uC5B4\uC694! \uB0B4\uC77C\uC740
      \uACF5\uAE4C\uC9C0 \uAF2D \uC7A1\uC544\uC11C \uD300\uC6D0\uB4E4\uC744 \uB3C4\uC6B8\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Kind_1
    ko: "\uD300 \uAE30\uC5EC \uC758\uC9C0\uAC00 \uCD5C\uACE0\uC870\uC5D0 \uB2EC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Loyal_101
    ko: "\uAC10\uC0AC\uD569\uB2C8\uB2E4! \uC5ED\uC2DC \uAC10\uB3C5\uB2D8 \uC9C0\uC2DC\uB300\uB85C\uB9CC
      \uD558\uBA74 \uD2C0\uB9B4 \uAC8C \uC5C6\uB124\uC694. \uB0B4\uC77C\uB3C4 \uC774
      \uC790\uC138 \uC720\uC9C0\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Loyal_1
    ko: "\uAD50\uC870\uC801 \uD0DC\uB3C4\uAC00 \uAC15\uD654\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Sincere_101
    ko: "\uB124, \uB0B4\uC77C\uC740 \uBC15\uC2A4\uC544\uC6C3 100\uD68C, \uB9AC\uBC14\uC6B4\uB4DC
      \uC2DC\uB3C4 100\uD68C \uAE30\uB85D\uD574\uC11C \uBCF4\uACE0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Sincere_1
    ko: "\uC735\uD1B5\uC131 \uC5C6\uB294 \uD0DC\uB3C4\uAC00 \uAC15\uD654\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Moodmaker_101
    ko: "\uC5ED\uC2DC \uC6B0\uB9AC \uAC10\uB3C5\uB2D8! \uB9C8\uC74C\uC774 \uD0DC\uD3C9\uC591
      \uAC19\uC73C\uC2DC\uB124! \uB0B4\uC77C\uC740 \uC81C\uAC00 \uCF54\uD2B8 \uB4A4\uC9D1\uC5B4
      \uB193\uC744\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Moodmaker_1
    ko: "\uC2A4\uC2A4\uB85C \uC5F0\uC2B5 \uAC15\uB3C4\uB97C \uB0AE\uCDC4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Ch_Bond_002
    ko: "\uACF5\uB3C4 \uBABB \uC7A1\uB294 \uB188\uC774 \uBB34\uC2A8 \uBC15\uC2A4\uC544\uC6C3\uC774\uB0D0.
      \uD300\uC5D0 \uBBFC\uD3D0\uB2C8\uAE4C \uB2F9\uC7A5 \uBE44\uCF1C\uB77C."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Kind_201
    ko: "\uC804 \uC57D\uC18D\uC744 \uC9C0\uD0A4\uB824\uB358 \uAC74\uB370... \uC81C\uAC00
      \uADF8\uB807\uAC8C\uAE4C\uC9C0 \uD300\uC5D0 \uBC29\uD574\uAC00 \uB410\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Kind_2
    ko: "\uACF5\uD3EC\uC5D0 \uC9C8\uB824 \uC790\uCC45\uC5D0 \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Loyal_201
    ko: "\uC81C\uAC00 \uBA4D\uCCAD\uD588\uC2B5\uB2C8\uB2E4. \uC57D\uC18D\uBCF4\uB2E4
      \uC911\uC694\uD55C \uAC74 \uACB0\uACFC\uC778\uB370... \uB0B4\uC77C\uC740 \uC8FD\uC5B4\uB3C4
      \uACF5 \uC548 \uB193\uCE69\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Loyal_2
    ko: "\uB9F9\uBAA9\uC801\uC778 \uB3C5\uAE30\uB85C \uBCC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Sincere_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uC81C\uAC00 \uC720\uD1B5\uAE30\uD55C \uC9C0\uB09C
      \uACE0\uC9D1\uC744 \uD53C\uC6E0\uAD70\uC694. \uBE44\uD0A4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Sincere_2
    ko: "\uC218\uB3D9\uC801 \uC0C1\uD0DC\uB85C \uBCC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Moodmaker_201
    ko: "\uC5D0\uACE0, \uAC10\uB3C5\uB2D8 \uAE30\uBD84 \uC548 \uC88B\uC73C\uC2DC\uB124...
      \uC77C\uB2E8 \uC81C\uAC00 \uBD84\uC704\uAE30 \uD30C\uC545\uD558\uACE0 \uB098\uC911\uC5D0
      \uC62C\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Moodmaker_2
    ko: "\uC2E4\uB825 \uD53C\uB4DC\uBC31\uC744 \uC78A\uC5B4\uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Ch_Bond_003
    ko: "\uB178\uD2B8\uB97C \uBE8F\uC5B4 \uBC15\uC2A4\uC544\uC6C3 \uC606\uC5D0 \uB9AC\uBC14\uC6B4\uB4DC
      \uD544\uC218\uB77C\uACE0 \uC801\uACE0, \uACF5\uC744 \uAC00\uC2B4\uC5D0 \uAC15\uD558\uAC8C
      \uB358\uC838\uC900\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Kind_301
    ko: "\uC9C0\uC2DC\uD558\uC2E0 \uAC74 \uC54C\uACA0\uB294\uB370... \uAC10\uB3C5\uB2D8\uC774
      \uD654\uB098\uC2E0 \uAC83 \uAC19\uC544 \uB108\uBB34 \uBB34\uC11C\uC6CC\uC694."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Kind_3
    ko: "\uD50C\uB808\uC774\uAC00 \uACBD\uC9C1\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Loyal_301
    ko: "\uC9C1\uC811 \uC801\uC5B4\uC8FC\uC2E0 \uC774 \uB178\uD2B8... \uC81C \uBCF4\uBB3C
      1\uD638\uC785\uB2C8\uB2E4. \uC5ED\uC2DC \uC800\uB9CC \uD2B9\uBCC4\uD558\uAC8C
      \uBBFF\uC73C\uC2DC\uB294 \uAC70\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Loyal_3
    ko: "\uAC1C\uC778\uC801 \uBC00\uCC29\uC5D0\uB9CC \uBAB0\uB450\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Sincere_301
    ko: "\uB9D0\uB85C \uD558\uC2E4 \uB54C\uBCF4\uB2E4 \uD6E8\uC52C \uBA85\uD655\uD558\uB124\uC694.
      \uC81C \uBAA9\uD45C\uB294 \uC774\uC81C \uC774 \uBE68\uAC04 \uAE00\uC528\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Sincere_3
    ko: "\uAC15\uB825\uD558\uAC8C \uB3D9\uAE30\uBD80\uC5EC\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Moodmaker_301
    ko: "\uC624! \uC774\uB7F0 \uC2A4\uD30C\uB974\uD0C0\uC2DD \uAD50\uC815 \uC644\uC804
      \uC81C \uC2A4\uD0C0\uC77C\uC778\uB370\uC694? \uB0B4\uC77C \uCF54\uD2B8\uC5D0\uC11C
      \uBC14\uB85C \uAC1A\uC544\uB4DC\uB9B4\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Moodmaker_3
    ko: "\uD6C8\uB828\uC5D0 \uC7AC\uBBF8\uB97C \uB290\uB07C\uBA70 \uAC01\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Cold_001
    ko: "\uD6C8\uB828 \uC804 \uAC10\uB3C5\uB2D8\uC774 \uAC15\uC870\uD55C \uC624\uB298
      \uBC15\uC2A4\uC544\uC6C3 \uC790\uC138 \uC548 \uBB34\uB108\uC9C0\uAC8C \uC2E0\uACBD
      \uC368!\uB77C\uB294 \uB9D0\uC744 \uC2DC\uC2A4\uD15C\uC758 \uC808\uB300 \uC6D0\uCE59\uC73C\uB85C
      \uC785\uB825\uD55C \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Cold_002
    ko: "\uADF8\uB294 \uACF5\uC744 \uB193\uCE58\uB294 \uB9AC\uC2A4\uD06C\uB97C \uAC10\uC218\uD558\uB354\uB77C\uB3C4
      \uAC10\uB3C5\uB2D8\uC774 \uC9C0\uC2DC\uD55C \uC790\uC138 \uC720\uC9C0\uB77C\uB294
      \uACF5\uC815\uC744 \uC644\uBCBD\uD788 \uC218\uD589\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Cold_003
    ko: "\uD558\uC9C0\uB9CC \uD6C8\uB828 \uD6C4 \uAC10\uB3C5\uB2D8\uC774 \uADF8\uB0E5
      \uC9C0\uB098\uCE58\uB824 \uD558\uC790, \uC790\uC2E0\uC758 \uD504\uB85C\uC138\uC2A4\uC5D0
      \uC624\uB958\uAC00 \uC788\uC5C8\uB294\uC9C0 \uD655\uC778\uD558\uAE30 \uC704\uD574
      \uC55E\uAE38\uC744 \uB9C9\uC544\uC12D\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Cold_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00021_Ch_Cold_001
    ko: "\uC57D\uC18D \uC9C0\uD0A4\uB290\uB77C \uACE0\uC0DD\uD588\uACE0 \uC790\uC138\uB294
      \uC644\uBCBD\uD558\uB2E4. \uC774\uC81C \uACF5\uAE4C\uC9C0 \uB124 \uAC78\uB85C
      \uB9CC\uB4E4\uC5B4\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Planner_101
    ko: "\uACA9\uB824\uB294 \uC81C \uACC4\uC0B0\uC5D0 \uB3C4\uC6C0\uC774 \uC548 \uB429\uB2C8\uB2E4.
      \uACF5 \uD655\uBCF4 \uD655\uB960\uC744 \uB192\uC77C \uAD6C\uCCB4\uC801\uC778
      \uC9C0\uD45C\uB97C \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Planner_1
    ko: "\uC124\uACC4\uB97C \uC2DC\uC791\uD558\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Opportunist_101
    ko: "\uC81C \uC790\uC138\uAC00 \uC778\uC815\uBC1B\uC558\uC73C\uB2C8 \uB2E4\uD589\uC774\uB124\uC694.
      \uADF8\uB7FC \uB0B4\uC77C\uBD80\uD130\uB294 \uACF5\uAE4C\uC9C0 \uCC59\uACA8\uC11C
      \uC81C \uAC00\uCE58\uB97C \uB354 \uB192\uC5EC\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Opportunist_1
    ko: "\uACB0\uACFC\uBB3C\uC5D0 \uC9D1\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Cunning_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uC81C \uB178\uB825\uC744 \uC54C\uC544\uC8FC\uC2DC\uB294\uAD70\uC694.
      \uB0B4\uC77C\uB3C4 \uC774 \uC644\uBCBD\uD55C \uC790\uC138\uB97C \uC720\uC9C0\uD558\uB294
      \uB370 \uCD5C\uC120\uC744 \uB2E4\uD560\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Cunning_1
    ko: "\uD3B8\uD55C \uC790\uC138\uB9CC \uC720\uC9C0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Believer_101
    ko: "\uC81C \uC815\uC11D\uC774 \uC633\uB2E4\uB294 \uAC78 \uD655\uC778\uD574\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uACB0\uACFC\uAC00 \uB098\uC62C \uB54C\uAE4C\uC9C0
      \uC774 \uC790\uC138\uB97C \uACE0\uC218\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Believer_1
    ko: "\uD6A8\uC728 \uB0AE\uC740 \uC790\uC138\uB9CC \uBB34\uD55C \uBC18\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Ch_Cold_002
    ko: "\uACF5\uB3C4 \uBABB \uC7A1\uB294 \uB188\uC774 \uBB34\uC2A8 \uBC15\uC2A4\uC544\uC6C3\uC774\uB0D0.
      \uD300\uC5D0 \uBBFC\uD3D0\uB2C8\uAE4C \uB2F9\uC7A5 \uBE44\uCF1C\uB77C."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Planner_201
    ko: "\uC9C0\uC2DC\uD558\uC2E0 \uB85C\uC9C1\uB300\uB85C \uC218\uD589\uD55C \uACB0\uACFC\uC785\uB2C8\uB2E4.
      \uACB0\uACFC\uB9CC \uBCF4\uACE0 \uACFC\uC815\uC744 \uBE44\uB09C\uD558\uC2DC\uBA74
      \uB2E4\uC74C \uD50C\uB79C\uC740 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Planner_2
    ko: "\uB3C5\uC790 \uB178\uC120\uC744 \uAC77\uAE30 \uC2DC\uC791\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Opportunist_201
    ko: "\uAE30\uBD84\uC774 \uC548 \uC88B\uC73C\uC2E0 \uBAA8\uC591\uC774\uB124\uC694.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uBE44\uD0AC \uD14C\uB2C8 \uB098\uC911\uC5D0
      \uB2E4\uC2DC \uC774\uC57C\uAE30\uD558\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Opportunist_2
    ko: "\uC77C\uB2E8 \uC790\uB9AC\uB97C \uD53C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Cunning_201
    ko: "\uAC10\uB3C5\uB2D8 \uB208\uC740 \uBABB \uC18D\uC774\uACA0\uB124\uC694. \uC54C\uACA0\uC2B5\uB2C8\uB2E4.
      \uB0B4\uC77C\uBD80\uD130\uB294 \uB354 \uD655\uC2E4\uD55C \uACB0\uACFC\uB97C
      \uD6D4\uCCD0\uC624\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Cunning_2
    ko: "\uC218\uB2E8\uC744 \uAC00\uB9AC\uC9C0 \uC54A\uACE0 \uAC01\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Believer_201
    ko: "\uC6D0\uCE59 \uC5C6\uB294 \uACB0\uACFC\uB294 \uC694\uD589\uC77C \uBFD0\uC785\uB2C8\uB2E4.
      \uAC10\uB3C5\uB2D8\uC758 \uC2E4\uB9DD\uC740 \uC81C \uB17C\uB9AC\uC801\uC778
      \uACB0\uB860\uC744 \uBC14\uAFC0 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Believer_2
    ko: "\uB17C\uC7C1\uC744 \uBA48\uCD94\uC9C0 \uC54A\uACE0 \uBC84\uD17C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Ch_Cold_003
    ko: "\uB178\uD2B8\uB97C \uBE8F\uC5B4 \uBC15\uC2A4\uC544\uC6C3 \uC606\uC5D0 \uB9AC\uBC14\uC6B4\uB4DC
      \uD544\uC218\uB77C\uACE0 \uC801\uACE0, \uACF5\uC744 \uAC00\uC2B4\uC5D0 \uAC15\uD558\uAC8C
      \uB358\uC838\uC900\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Planner_301
    ko: "\uC218\uB2E8\uBCF4\uB2E4 \uBAA9\uC801\uC774 \uC6B0\uC120\uC774\uB77C\uB294
      \uBCC0\uC218\uB97C \uD655\uC778\uD588\uC2B5\uB2C8\uB2E4. \uC989\uC2DC \uC804\uCCB4
      \uB85C\uC9C1\uC744 \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Planner_3
    ko: "\uC989\uAC01 \uAC01\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Opportunist_301
    ko: "\uC774\uB7F0 \uBB34\uB840\uD55C \uBC29\uC2DD\uC740 \uACE4\uB780\uD569\uB2C8\uB2E4.
      \uACF5\uC744 \uB358\uC9C0\uB294 \uAC74 \uC81C \uBAB8\uAC12\uC744 \uAE4E\uC544\uBA39\uB294
      \uD589\uB3D9 \uC544\uB2CC\uAC00\uC694?"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Opportunist_3
    ko: "\uD0DC\uC5C5\uC744 \uACE0\uBBFC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Cunning_301
    ko: "\uBB34\uC2A8 \uB9D0\uC500\uC778\uC9C0 \uC54C\uACA0\uC73C\uB2C8 \uACF5\uC740
      \uCE58\uC6B0\uC2DC\uC8E0. \uB2E4\uC74C\uBD80\uD130\uB294 \uADF8\uB0E5 \uB9D0\uB85C
      \uD558\uC154\uB3C4 \uC54C\uC544\uB4E3\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Cunning_3
    ko: "\uD589\uB3D9\uC5D0 \uD718\uB458\uB9AC\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Believer_301
    ko: "\uB9D0\uBCF4\uB2E4 \uAC15\uD55C \uD655\uC2E0\uC744 \uC8FC\uC2DC\uB294\uAD70\uC694.
      \uACF5 \uD655\uBCF4\uB97C \uC81C \uC0C8\uB85C\uC6B4 \uC2E0\uB150\uC73C\uB85C
      \uCD94\uAC00\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Believer_3
    ko: "\uC0C8\uB85C\uC6B4 \uC2E0\uB150\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC \uAC01\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Instinct_001
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC2DC\uD0A8 \uBC15\uC2A4\uC544\uC6C3 \uC790\uC138\uB97C
      \uC790\uC2E0\uC758 \uC601\uC5ED\uC744 \uC9C0\uD0A4\uB294 \uC2F8\uC6C0\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC778 \uC120\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Instinct_002
    ko: "\uD558\uC9C0\uB9CC \uC790\uC138\uC5D0 \uB108\uBB34 \uD798\uC744 \uC900 \uB098\uBA38\uC9C0
      \uC815\uC791 \uACF5\uC740 \uBA38\uB9AC \uC704\uB85C \uB2E4 \uB0A0\uB824\uBC84\uB838\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Instinct_003
    ko: "\uD6C8\uB828 \uD6C4 \uAC10\uB3C5\uB2D8\uC774 \uBB34\uC2EC\uD558\uAC8C \uB5A0\uB098\uB824
      \uD558\uC790, \uC790\uC2E0\uC758 \uC874\uC7AC\uAC10\uC774 \uBD80\uC815\uB2F9\uD588\uB2E4\uACE0
      \uB290\uB080 \uC9D0\uC2B9 \uAC19\uC740 \uBCF8\uB2A5\uC774 \uAFC8\uD2C0\uAC70\uB9BD\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Instinct_004
    ko: "\uADF8\uB294 \uC55E\uAE38\uC744 \uBEE3\uBEE3\uD558\uAC8C \uB9C9\uC544\uC120
      \uCC44, \uAC10\uB3C5\uB2D8\uC758 \uB208\uC744 \uB611\uBC14\uB85C \uCCD0\uB2E4\uBCF4\uBA70
      \uC790\uC2E0\uC758 \uD22C\uC7C1\uC774 \uD2C0\uB9AC\uC9C0 \uC54A\uC558\uC74C\uC744
      \uD655\uC778\uBC1B\uC73C\uB824 \uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Instinct_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00021_Ch_Instinct_001
    ko: "\uC790\uC138 \uC720\uC9C0\uD558\uB290\uB77C \uACE0\uC0DD\uD588\uACE0 \uD798\uB3C4
      \uCDA9\uBD84\uD558\uB2E4. \uC774\uC81C \uADF8 \uD798\uC73C\uB85C \uB0B4\uC77C\uC740
      \uACF5\uAE4C\uC9C0 \uC539\uC5B4 \uC0BC\uCF1C\uBD10\uB77C."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Bluffer_101
    ko: "\uB2F9\uC5F0\uD788 \uC81C \uC790\uC138\uB294 \uC644\uBCBD\uD558\uC8E0! \uACF5\uC740
      \uC77C\uBD80\uB7EC \uC591\uBCF4\uD55C \uAC81\uB2C8\uB2E4. \uB0B4\uC77C\uC740
      \uB2E4 \uC81C \uAC70\uC608\uC694!"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Bluffer_1
    ko: "\uC81C\uC790\uB9AC\uC5D0 \uBA38\uBB3C\uB800\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Wild_101
    ko: "\uC790\uC138\uAC00 \uC88B\uC73C\uBA74 \uBB50\uD569\uB2C8\uAE4C? \uACF5\uC744
      \uBABB \uC7A1\uC558\uB294\uB370. \uAC10\uB3C5\uB2D8\uC740 \uC704\uB85C \uB9D0\uACE0\uB294
      \uD558\uC2E4 \uB9D0\uC500 \uC5C6\uC73C\uC138\uC694?"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Wild_1
    ko: "\uAC10\uB3C5\uC744 \uC595\uC7A1\uC544 \uBCF4\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Egoist_101
    ko: "\uC5ED\uC2DC \uC81C \uC7A0\uC7AC\uB825\uC744 \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694.
      \uADF8\uB7FC\uC694, \uC81C\uAC00 \uB9C8\uC74C\uB9CC \uBA39\uC73C\uBA74 \uACF5
      \uD655\uBCF4 \uC815\uB3C4\uB294 \uC77C\uB3C4 \uC544\uB2C8\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Egoist_1
    ko: "\uACF5 \uD655\uBCF4\uC5D0 \uBC14\uB85C \uB6F0\uC5B4\uB4E4\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Fighter_101
    ko: "\uACE0\uC0DD\uD588\uB2E4\uACE0\uC694? \uC804 \uC544\uC9C1 \uBC30\uACE0\uD508\uB370
      \uAC10\uB3C5\uB2D8\uC740 \uBC8C\uC368 \uB9CC\uC871\uD558\uC2E0 \uAC81\uB2C8\uAE4C?
      \uC2E4\uB9DD\uC774\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Fighter_1
    ko: "\uD6C8\uB828\uC5D0 \uD765\uBBF8\uB97C \uC783\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Ch_Instinct_002
    ko: "\uACF5\uB3C4 \uBABB \uC7A1\uB294 \uB188\uC774 \uBB34\uC2A8 \uBC15\uC2A4\uC544\uC6C3\uC774\uB0D0.
      \uB369\uCE58\uAC12 \uBABB \uD560 \uAC70\uBA74 \uB2F9\uC7A5 \uBE44\uCF1C\uB77C."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Bluffer_201
    ko: "\uC800\uD55C\uD14C \uBBFC\uD3D0\uB77C\uACE0\uC694? \uC81C\uAC00 \uC5C6\uC73C\uBA74
      \uC774 \uD300\uC774 \uB3CC\uC544\uAC08 \uAC83 \uAC19\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Bluffer_2
    ko: "\uD300 \uBD84\uC704\uAE30\uB97C \uD750\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Wild_201
    ko: "\uBBFC\uD3D0? \uADF8 \uACF5 \uC81C\uAC00 \uB2E4 \uCC22\uC5B4\uB193\uC73C\uBA74
      \uB418\uACA0\uB124\uC694. \uBE44\uD0A4\uC138\uC694, \uAC1C\uC778 \uD6C8\uB828
      \uB354 \uD558\uB7EC \uAC00\uC57C \uD558\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Wild_2
    ko: "\uB9AC\uBC14\uC6B4\uB4DC\uC5D0 \uC9D1\uCC29\uD558\uAE30 \uC2DC\uC791\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Egoist_201
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uBB58 \uBAA8\uB974\uC2DC\uB124. \uC81C \uC790\uC138\uAC00
      \uC5BC\uB9C8\uB098 \uC644\uBCBD\uD588\uB294\uC9C0 \uB098\uC911\uC5D0 \uBE44\uB514\uC624\uB098
      \uB2E4\uC2DC \uBCF4\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Egoist_2
    ko: "\uC9C0\uC2DC\uB97C \uB530\uB974\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Fighter_201
    ko: "\uD300\uC5D0 \uBBFC\uD3D0\uB77C\uACE0\uC694? \uADF8\uB7FC \uB2F9\uC7A5 \uC800\uB791
      1\uB3001 \uD574\uC11C \uACF5 \uBE8F\uC5B4\uBCF4\uC2DC\uB4E0\uAC00\uC694."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Fighter_2
    ko: "\uAE30 \uC2F8\uC6C0\uC5D0 \uC5D0\uB108\uC9C0\uB97C \uB2E4 \uC37C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Ch_Instinct_003
    ko: "\uB178\uD2B8\uB97C \uBE8F\uC5B4 \uBC15\uC2A4\uC544\uC6C3 \uC606\uC5D0 \uB9AC\uBC14\uC6B4\uB4DC
      \uD544\uC218\uB77C\uACE0 \uC801\uACE0, \uACF5\uC744 \uAC00\uC2B4\uC5D0 \uAC15\uD558\uAC8C
      \uB358\uC838\uC900\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Bluffer_301
    ko: "\uC624, \uC9C1\uC811 \uC801\uC5B4\uC8FC\uC2DC\uB294 \uAC70\uC608\uC694?
      \uC88B\uC2B5\uB2C8\uB2E4. \uC774 \uD544\uC218\uB77C\uB294 \uB2E8\uC5B4, \uB0B4\uC77C
      \uCF54\uD2B8\uC5D0\uC11C \uC2E4\uD604\uD574 \uBCF4\uC774\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Bluffer_3
    ko: "\uACB0\uACFC\uB97C \uBCF4\uC5EC\uC8FC\uB824 \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Wild_301
    ko: "\uACF5 \uB358\uC9C0\uB294 \uAC74 \uC88B\uC740\uB370, \uB178\uD2B8\uC5D0
      \uC801\uB294 \uAC74 \uC81C \uC2A4\uD0C0\uC77C \uC544\uB2C8\uB124\uC694. \uACF5\uB9CC
      \uC788\uC73C\uBA74 \uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Wild_3
    ko: "\uD6C8\uB828 \uD6A8\uACFC\uAC00 \uBC18\uAC10\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Egoist_301
    ko: "\uC81C \uC18C\uC911\uD55C \uB178\uD2B8\uC5D0 \uBA4B\uB300\uB85C \uB099\uC11C\uD558\uC9C0
      \uB9C8\uC138\uC694. \uADF8\uB9AC\uACE0 \uACF5 \uB358\uC9C0\uB294 \uAC70, \uC0C1\uB2F9\uD788
      \uBB34\uB840\uD558\uC2DC\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Egoist_3
    ko: "\uD611\uC870\uC801\uC778 \uD0DC\uB3C4\uB97C \uC644\uC804\uD788 \uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Desc_Fighter_301
    ko: "\uC774 \uACF5 \uC7A1\uC73C\uB77C\uB294 \uAC70\uC8E0? \uC88B\uC2B5\uB2C8\uB2E4.
      \uB0B4\uC77C\uBD80\uD130 \uACF5 \uC7A1\uC73C\uB824\uB2E4 \uB2E4\uCE58\uB294
      \uB188\uB4E4 \uB098\uC640\uB3C4 \uC804 \uBAA8\uB985\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00021_Rs_Fighter_3
    ko: "\uBAA8\uB4E0 \uACF5\uC744 \uC2F9\uC4F8\uC774\uD558\uB824 \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Discipline_001
    ko: "\uC624\uB298 \uB9AC\uBC14\uC6B4\uB4DC \uD6C8\uB828\uC5D0\uC11C \uAE38\uC744
      \uD130\uC8FC\uBA74, \uAC00\uB4DC\uB4E4\uC774 \uB4E4\uC5B4\uC640 \uACF5\uC744
      \uB09A\uC544\uCC44\uB294 \uC5F0\uACC4 \uD50C\uB808\uC774\uB97C \uC644\uC131\uD558\uB77C\uACE0
      \uC9C0\uC2DC\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Discipline_002
    ko: "\uADDC\uC728 \uC131\uD5A5\uC778 \uC774 \uC120\uC218\uB294 \uC774 \uC9C0\uC2DC\uB97C
      \uC808\uB300\uC801\uC778 \uD589\uB3D9 \uAC15\uB839\uC73C\uB85C \uBC1B\uC544\uB4E4\uC600\uC2B5\uB2C8\uB2E4.
      \uADF8\uB294 \uC790\uAE30 \uC190\uC5D0 \uACF5\uC774 \uB5A8\uC5B4\uC9C0\uB294
      \uC644\uBCBD\uD55C \uAE30\uD68C\uC5D0\uC11C\uB3C4,"
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Discipline_003
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uB9D0\uD55C \uAE38\uC744 \uD130\uC8FC\uB294 \uC5ED\uD560\uC744
      \uC644\uC218\uD558\uAE30 \uC704\uD574 \uACF5\uC744 \uC7A1\uC9C0 \uC54A\uACE0
      \uC0C1\uB300 \uACF5\uACA9\uC218\uB97C \uBC00\uC5B4\uB0B4\uB294 \uB370\uB9CC
      \uC9D1\uCC29\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Discipline_004
    ko: "\uADF8\uB294 \uC790\uC2E0\uC758 \uC704\uCE58\uB97C \uC0AC\uC218\uD558\uB294
      \uADDC\uC728\uC744 \uC9C0\uD0A4\uB290\uB77C \uACF5\uC744 \uCCD0\uB2E4\uBCF4\uC9C0\uB3C4
      \uC54A\uC558\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Discipline_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00022_Ch_Discipline_001
    ko: "\uC2DC\uD55C \uC5ED\uD560\uC744 \uC218\uD589\uD558\uB824\uB294 \uCC45\uC784\uAC10\uC740
      \uD6CC\uB96D\uD558\uB2E4. \uD558\uC9C0\uB9CC \uB09A\uC544\uCC44\uB294 \uC720\uC5F0\uD568\uB3C4
      \uADDC\uCE59\uC5D0 \uCD94\uAC00\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Principled_101
    ko: "\uC784\uBB34\uC758 \uCD5C\uC885 \uBAA9\uC801\uC774 \uACF5 \uD655\uBCF4\uC784\uC744
      \uC778\uC9C0\uD588\uC2B5\uB2C8\uB2E4. \uC989\uC2DC \uB9E4\uB274\uC5BC\uC744
      \uC218\uC815\uD558\uC5EC \uB0B4\uC77C\uC740 \uACB0\uACFC\uB85C \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Principled_1
    ko: "\uC0C8\uB85C\uC6B4 \uAC00\uC774\uB4DC\uB77C\uC778\uC73C\uB85C \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Guardian_101
    ko: "\uC88B\uC740 \uB9D0\uC500\uC774\uC9C0\uB9CC... \uC81C\uAC00 \uACF5\uC744
      \uD3EC\uAE30\uD574\uC11C \uD300 \uD750\uB984\uC744 \uB04A\uC5C8\uB2E4\uB294
      \uC0AC\uC2E4\uC774 \uBCC0\uD558\uC9C4 \uC54A\uC2B5\uB2C8\uB2E4. \uB9C8\uC74C\uC774
      \uBB34\uAC81\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Guardian_1
    ko: "\uC758\uAE30\uC18C\uCE68\uD568\uC774 \uC9C0\uC18D\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Tactician_101
    ko: "\uC704\uB85C\uB294 \uB410\uC2B5\uB2C8\uB2E4. \uACF5\uAC04 \uD655\uBCF4 \uC784\uBB34\uB97C
      \uC5B4\uB290 \uC2DC\uC810\uC5D0 \uC911\uB2E8\uD558\uACE0 \uB9AC\uBC14\uC6B4\uB4DC\uB85C
      \uC804\uD658\uD574\uC57C \uD558\uB294\uC9C0 \uC815\uD655\uD55C \uB370\uC774\uD130\uB97C
      \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Tactician_1
    ko: "\uC804\uC220 \uC218\uC815\uC774 \uC815\uCCB4\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Exemplary_101
    ko: "\uC5ED\uC2DC \uC81C \uC784\uBB34 \uC218\uD589\uC740 \uC644\uBCBD\uD588\uC8E0?
      \uACF5\uC744 \uB193\uCE5C \uAC74 \uAC00\uB4DC\uB4E4 \uD0D3\uC774\uB2C8, \uB0B4\uC77C\uB3C4
      \uD754\uB4E4\uB9AC\uC9C0 \uC54A\uB294 \uC790\uC138\uB97C \uBCF4\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Exemplary_1
    ko: "\uC790\uC2E0\uC758 \uACE0\uC9D1\uC744 \uBAA8\uBC94\uC73C\uB85C \uCC29\uAC01\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Ch_Discipline_002
    ko: "\uADDC\uCE59\uC5D0\uB9CC \uB9E4\uBAB0\uB3FC \uC2E4\uC804\uC744 \uB9DD\uCE60
      \uC148\uC774\uB0D0. \uC735\uD1B5\uC131 \uC5C6\uB294 \uC644\uBCBD\uC8FC\uC758\uB294
      \uD300 \uC218\uBE44\uB97C \uB9DD\uCE58\uB294 \uB3C5\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Principled_201
    ko: "\uAE38\uC744 \uD130\uC8FC\uB77C\uACE0 \uBA85\uB839\uD558\uC2E0 \uAC74 \uAC10\uB3C5\uB2D8\uC785\uB2C8\uB2E4.
      \uC6D0\uCE59\uC744 \uC9C0\uD0A8 \uACB0\uACFC\uB85C \uC800\uB97C \uC9C8\uCC45\uD558\uC2E0\uB2E4\uBA74
      \uB354\uB294 \uB530\uB974\uAE30 \uC5B4\uB835\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Principled_2
    ko: "\uB9C8\uC74C\uC744 \uB2EB\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Guardian_201
    ko: "\uC81C\uAC00 \uADDC\uC728 \uB4A4\uC5D0 \uC228\uC5B4 \uD300\uC6D0\uB4E4\uC744
      \uC704\uD5D8\uD558\uAC8C \uD588\uAD70\uC694. \uB0B4\uC77C\uBD80\uD130\uB294
      \uD615\uC2DD\uBCF4\uB2E4 \uD300\uC758 \uACF5\uC744 \uC9C0\uD0A4\uB294 \uB370
      \uC9D1\uC911\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Guardian_2
    ko: "\uC548\uC804\uC744 \uD574\uCCE4\uB2E4\uB294 \uBCF8\uC9C8\uC744 \uC790\uAC01\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Tactician_201
    ko: "\uC9C0\uC2DC \uC0AC\uD56D \uAC04\uC758 \uCDA9\uB3CC\uC744 \uBD84\uC11D \uC911\uC778
      \uC800\uB97C \uBE44\uB09C\uD558\uC2DC\uB294\uAD70\uC694. \uC774\uB7F0 \uAC10\uC815\uC801
      \uB300\uC751\uC740 \uD300 \uBC1C\uC804\uC5D0 \uB3C4\uC6C0\uC774 \uC548 \uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Tactician_2
    ko: "\uAC10\uB3C5\uC744 \uD3C9\uAC00\uC808\uD558\uD558\uBA70 \uBB34\uC2DC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Exemplary_201
    ko: "\uD300\uC6D0\uB4E4\uC774 \uBCF4\uB294\uB370 \uADF8\uB807\uAC8C \uB9D0\uC500\uD558\uC154\uC57C
      \uD588\uB098\uC694... \uC218\uCE58\uC2A4\uB7EC\uC6CC\uC11C \uACE0\uAC1C\uB97C
      \uB4E4 \uC218\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4. \uC77C\uB2E8 \uBE44\uD0A4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Exemplary_2
    ko: "\uB208\uCE58\uB9CC \uC0B4\uD53C\uAC8C \uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Ch_Discipline_003
    ko: "\uB178\uD2B8\uB97C \uB09A\uC544\uCC44 \uACF5\uAC04 \uD655\uBCF4 \uC704\uC5D0
      \uB9AC\uBC14\uC6B4\uB4DC\uAC00 \uBCF8\uC9C8\uC774\uB77C \uC801\uACE0, \uD488\uC5D0
      \uAC15\uD558\uAC8C \uBC15\uC544\uB123\uB4EF \uB358\uC838\uC900\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Principled_301
    ko: "\uBA54\uC2DC\uC9C0\uB294 \uC774\uD574\uD588\uC2B5\uB2C8\uB2E4. \uD558\uC9C0\uB9CC
      \uC81C \uC804\uC220 \uB178\uD2B8\uB97C \uD6FC\uC190\uD558\uBA74\uC11C\uAE4C\uC9C0
      \uC804\uB2EC\uD558\uC154\uC57C \uD588\uB358 \uD569\uB9AC\uC801\uC778 \uC774\uC720\uAC00
      \uC788\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Principled_3
    ko: "\uB17C\uB9AC\uC801 \uAC70\uBD80\uAC10\uC744 \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Guardian_301
    ko: "\uC81C \uACE0\uBBFC\uC774 \uADF8\uB807\uAC8C \uC6B0\uC2A4\uC6B0\uC2E0\uAC00\uC694?
      \uAC10\uB3C5\uB2D8\uAED8 \uC800\uB294 \uADF8\uC800 \uC2DC\uD0A4\uB294 \uB300\uB85C
      \uC6C0\uC9C1\uC774\uB294 \uAE30\uACC4\uC77C \uBFD0\uC785\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Guardian_3
    ko: "\uC720\uB300\uAC10\uC774 \uB04A\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Tactician_301
    ko: "\uB3C4\uAD6C\uC5D0 \uB9E4\uBAB0\uB418\uC5C8\uB358 \uC624\uB958\uB97C \uD655\uC778\uD588\uC2B5\uB2C8\uB2E4.
      \uBAA9\uC801 \uB2EC\uC131\uC744 \uC704\uD55C \uCD5C\uC801\uC758 \uD310\uB2E8
      \uB85C\uC9C1\uC73C\uB85C \uC7AC\uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Tactician_3
    ko: "\uC804\uC220 \uC218\uC815 \uD53C\uB4DC\uBC31\uC73C\uB85C \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Exemplary_301
    ko: "\uAE30\uB85D\uBCF4\uB2E4 \uD589\uB3D9\uC774 \uC55E\uC11C\uC57C \uD55C\uB2E4\uB294
      \uAC00\uB974\uCE68\uC73C\uB85C \uBC1B\uB4E4\uACA0\uC2B5\uB2C8\uB2E4. \uB0B4\uC77C\uBD80\uD130
      \uC81C\uAC00 \uD300\uC758 \uC9C4\uC815\uD55C \uAE30\uC900\uC774 \uB418\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Exemplary_3
    ko: "\uC131\uACFC \uC911\uC2EC \uC120\uC218\uB85C \uAC01\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Bond_001
    ko: "\uAC10\uB3C5\uB2D8\uC740 \uC624\uB298 \uB9AC\uBC14\uC6B4\uB4DC \uD6C8\uB828\uC5D0\uC11C
      \uACE8\uBC11\uC5D0\uC11C \uAE38\uC744 \uD130\uC8FC\uBA74, \uAC00\uB4DC\uB4E4\uC774
      \uB4E4\uC5B4\uC640 \uACF5\uC744 \uB09A\uC544\uCC44\uB294 \uC5F0\uACC4 \uD50C\uB808\uC774\uB97C
      \uC644\uC131\uD558\uB77C\uACE0 \uC9C0\uC2DC\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Bond_002
    ko: "\uC774 \uC120\uC218\uB294 \uD300\uC6D0\uB4E4\uC5D0\uAC8C \uAE30\uD68C\uB97C
      \uC591\uBCF4\uD558\uB77C\uB294 \uB73B\uC73C\uB85C \uC774\uD574\uD558\uACE0,"
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Bond_003
    ko: "\uC790\uAE30\uAC00 \uACF5\uC744 \uC7A1\uC744 \uC218 \uC788\uB294 \uC0C1\uD669\uC5D0\uC11C\uB3C4
      \uAD73\uC774 \uB3D9\uB8CC\uC5D0\uAC8C \uACF5\uC744 \uB118\uAE30\uB824\uB2E4
      \uB9AC\uBC14\uC6B4\uB4DC \uD0C0\uC774\uBC0D\uC744 \uACC4\uC18D \uB193\uCCE4\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Bond_004
    ko: "\uACB0\uAD6D \uC0C1\uB300 \uD300\uC5D0\uAC8C \uACF5\uACA9\uAD8C\uC744 \uD5CC\uB0A9\uD558\uBA70
      \uC5F0\uACC4 \uD50C\uB808\uC774\uB294\uCEE4\uB155 \uD300\uC758 \uC0AC\uAE30\uB9CC
      \uAEBE\uC600\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Bond_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00022_Ch_Bond_001
    ko: "\uC9C4\uC9DC \uBC30\uB824\uB294 \uACF5\uC744 \uB530\uB0B4\uC11C \uC804\uB2EC\uD558\uB294
      \uAC70\uB2E4. \uB530\uB73B\uD55C \uB9C8\uC74C\uC744 \uD655\uC2E4\uD55C \uC18C\uC720\uB85C
      \uBCF4\uC5EC\uC918\uB77C."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC81C \uC9C4\uC2EC\uC744 \uC54C\uC544\uC8FC\uC2DC\uB2C8
      \uB108\uBB34 \uAE30\uBED0\uC694! \uB0B4\uC77C\uC740 \uC81C\uAC00 \uD655\uC2E4\uD788
      \uC7A1\uC544\uC11C \uC6B0\uB9AC \uAC00\uB4DC\uB4E4\uC5D0\uAC8C \uC120\uBB3C\uD560\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Kind_1
    ko: "\uD589\uBCF5\uAC10\uC744 \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Loyal_101
    ko: "\uAC10\uC0AC\uD569\uB2C8\uB2E4! \uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uC81C
      \uD5CC\uC2E0\uC744 \uC54C\uC544\uC8FC\uC2DC\uB294\uAD70\uC694. \uB0B4\uC77C\uB3C4
      \uD300\uC6D0\uB4E4\uC744 \uC704\uD574 \uCD5C\uC120\uC744 \uB2E4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Loyal_1
    ko: "\uCC29\uD55C \uC120\uC218\uB85C \uB0A8\uC73C\uB824 \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Sincere_101
    ko: "\uB124, \uB0B4\uC77C\uC740 \uC591\uBCF4 \uD69F\uC218\uC640 \uC131\uACF5\uB960\uC744
      \uB354 \uC138\uBC00\uD558\uAC8C \uAE30\uB85D\uD574\uC11C \uBCF4\uACE0\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uC9C0\uCF1C\uBD10 \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Sincere_1
    ko: "\uD50C\uB808\uC774\uAC00 \uB354 \uAF2C\uC774\uACE0 \uB290\uB824\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Moodmaker_101
    ko: "\uC5ED\uC2DC \uC6B0\uB9AC \uAC10\uB3C5\uB2D8 \uCFE8\uAC00\uC774! \uC81C\uAC00
      \uB0B4\uC77C \uACE8\uBC11 \uD30C\uD2F0 \uD55C \uBC88 \uC81C\uB300\uB85C \uC5F4\uC5B4\uBCFC\uAC8C\uC694.
      \uBBFF\uC73C\uC2DC\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Moodmaker_1
    ko: "\uC7A5\uB09C\uC2A4\uB7EC\uC6B4 \uD0DC\uB3C4\uB85C \uB3CC\uC544\uAC14\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Ch_Bond_002
    ko: "\uC6B0\uC720\uBD80\uB2E8\uD558\uAC8C \uAD74\uC5B4 \uB9AC\uB4EC\uC744 \uC783\uAC8C
      \uD558\uC9C0 \uB9C8\uB77C. \uACF5 \uD558\uB098 \uC81C\uB300\uB85C \uBABB \uC950\uB294
      \uB188\uC740 \uB2F9\uC7A5 \uBE44\uCF1C\uB77C."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Kind_201
    ko: "\uC804 \uC815\uB9D0 \uB3C4\uC640\uC8FC\uACE0 \uC2F6\uC5C8\uC744 \uBFD0\uC778\uB370...
      \uC81C\uAC00 \uD300\uC6D0\uB4E4\uC5D0\uAC8C \uC9D0\uC774 \uB418\uC5C8\uB2E4\uB2C8,
      \uC774\uC81C \uC5BC\uAD74\uC744 \uC5B4\uB5BB\uAC8C \uBCF4\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Kind_2
    ko: "\uD300 \uC870\uD654\uB97C \uAE7C\uB2E4\uB294 \uC808\uB9DD\uC5D0 \uBE60\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Loyal_201
    ko: "\uC81C \uD310\uB2E8 \uCC29\uC624\uB85C \uAC10\uB3C5\uB2D8\uC758 \uC804\uC220\uC744
      \uB9DD\uCCE4\uAD70\uC694. \uB0B4\uC77C\uBD80\uD130\uB294 \uC790\uBE44 \uC5C6\uB294
      \uB9AC\uBC14\uC6B4\uB4DC\uB85C \uCDA9\uC131\uC2EC\uC744 \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Loyal_2
    ko: "\uC218\uB2E8\uACFC \uBC29\uBC95\uC744 \uAC00\uB9AC\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Sincere_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uC81C\uAC00 \uBD80\uC871\uD588\uC2B5\uB2C8\uB2E4.
      \uBE44\uD0AC \uD14C\uB2C8 \uAC00\uBCF4\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Sincere_2
    ko: "\uAE30\uACC4\uC801\uC778 \uC6C0\uC9C1\uC784\uB9CC \uBCF4\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Moodmaker_201
    ko: "\uC544\uC774\uACE0, \uBD84\uC704\uAE30 \uC0B4\uBC8C\uD558\uB124... \uC54C\uACA0\uC2B5\uB2C8\uB2E4!
      \uC77C\uB2E8 \uC81C\uAC00 \uC880 \uB354 \uC2E0\uACBD \uC368\uBCFC\uAC8C\uC694.
      \uC9C4\uC815\uD558\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Moodmaker_2
    ko: "\uC804\uC220\uC801 \uD53C\uB4DC\uBC31\uC774 \uADC0\uC5D0 \uB4E4\uC5B4\uC624\uC9C0
      \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Ch_Bond_003
    ko: "\uB178\uD2B8\uB97C \uBE8F\uC5B4 \uC591\uBCF4 \uC704\uC5D0 \uC6B0\uC120 \uD655\uBCF4
      \uD6C4 \uC5F0\uACC4\uB77C\uACE0 \uC801\uACE0, \uACF5\uC744 \uC120\uC218\uC758
      \uAC00\uC2B4\uC5D0 \uBB35\uC9C1\uD558\uAC8C \uB358\uC838\uC900\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Kind_301
    ko: "\uBB34\uC2A8 \uB73B\uC778\uC9C0 \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uADF8\uB7F0\uB370...
      \uC81C\uAC00 \uAC10\uB3C5\uB2D8\uC744 \uD654\uB098\uAC8C \uD574\uB4DC\uB9B0
      \uAC74\uAC00\uC694? \uC8C4\uC1A1\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Kind_3
    ko: "\uB208\uCE58\uB9CC \uBCF4\uAC8C \uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Loyal_301
    ko: "\uC774\uB807\uAC8C \uC9C1\uC811 \uC801\uC5B4\uC8FC\uC2DC\uB2E4\uB2C8, \uC800\uB97C
      \uC815\uB9D0 \uAC01\uBCC4\uD558\uAC8C \uC0DD\uAC01\uD558\uC2DC\uB294 \uAC70\uC8E0?
      \uAE30\uB300\uC5D0 \uAF2D \uBD80\uC751\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Loyal_3
    ko: "\uAE30\uBD84\uC744 \uB9DE\uCD94\uB294 \uB370\uB9CC \uD608\uC548\uC774 \uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Sincere_301
    ko: "\uBCF5\uC7A1\uD558\uAC8C \uC0DD\uAC01\uD588\uB358 \uAC8C \uC2E4\uC218\uC600\uC2B5\uB2C8\uB2E4.
      \uAE30\uB85D\uBCF4\uB2E4 \uC774 \uACF5 \uD558\uB098\uB97C \uC9C0\uD0A4\uB294
      \uAC8C \uC81C \uC9C4\uC9DC \uC784\uBB34\uC784\uC744 \uC54C\uC558\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Sincere_3
    ko: "\uAC00\uC7A5 \uD6A8\uC728\uC801\uC73C\uB85C \uC6C0\uC9C1\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Moodmaker_301
    ko: "\uC624! \uAC10\uB3C5\uB2D8 \uBC29\uAE08 \uC880 \uBA4B\uC788\uC73C\uC168\uB294\uB370\uC694?
      \uC774 \uACF5, \uB0B4\uC77C\uBD80\uD134 \uC808\uB300 \uC544\uBB34\uD55C\uD14C\uB3C4
      \uC548 \uBE8F\uAE41\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Moodmaker_3
    ko: "\uD6C8\uB828\uC5D0 \uD65C\uB825\uC744 \uB418\uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Cold_001
    ko: "\uAC10\uB3C5\uB2D8\uC740 \uC624\uB298 \uB9AC\uBC14\uC6B4\uB4DC \uD6C8\uB828\uC5D0\uC11C
      \uACE8\uBC11\uC5D0\uC11C \uAE38\uC744 \uD130\uC8FC\uBA74 \uAC00\uB4DC\uB4E4\uC774
      \uB4E4\uC5B4\uC640 \uACF5\uC744 \uB09A\uC544\uCC44\uB294 \uC5F0\uACC4 \uD50C\uB808\uC774\uB97C
      \uC644\uC131\uD558\uB77C\uACE0 \uC9C0\uC2DC\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Cold_002
    ko: "\uC774 \uC120\uC218\uB294 \uC774\uB97C \uC644\uBCBD\uD55C \uD6A8\uC728\uC801
      \uBD84\uC5C5\uC73C\uB85C \uC815\uC758\uD588\uC2B5\uB2C8\uB2E4. \uADF8\uB294
      \uC790\uC2E0\uC758 \uC5ED\uD560\uC778 \uACF5\uAC04 \uD655\uBCF4\uC5D0\uB9CC
      100%\uC758 \uC5D0\uB108\uC9C0\uB97C \uC3DF\uAE30\uB85C \uACC4\uC0B0\uD588\uACE0,"
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Cold_003
    ko: "\uC790\uAE30 \uC190\uC5D0 \uACF5\uC774 \uB2FF\uB294 \uAC70\uB9AC\uC784\uC5D0\uB3C4
      \uC774\uAC74 \uAC00\uB4DC\uC758 \uC601\uC5ED\uC774\uB2E4\uB77C\uBA70 \uCCA0\uC800\uD788
      \uBB34\uC2DC\uD588\uC2B5\uB2C8\uB2E4.\uAC00\uB4DC\uB4E4\uC758 \uBC18\uC751\uC774
      \uB2A6\uC5B4 \uACF5\uC774 \uC0C1\uB300\uC5D0\uAC8C \uB118\uC5B4\uAC00\uB3C4,"
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Cold_004
    ko: "\uADF8\uB294 \uC790\uC2E0\uC758 \uACC4\uC0B0\uC5D0 \uC624\uB958\uAC00 \uC5C6\uC5C8\uC73C\uBBC0\uB85C
      \uBBF8\uB3D9\uC870\uCC28 \uD558\uC9C0 \uC54A\uC558\uC2B5\uB2C8\uB2E4. \uACB0\uAD6D
      \uB9AC\uBC14\uC6B4\uB4DC \uC218\uCE58\uB294 \uCC98\uCC38\uD558\uAC8C \uB9DD\uAC00\uC84C\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Cold_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00022_Ch_Cold_001
    ko: "\uBD84\uC11D\uB825\uC740 \uCD5C\uACE0\uB2E4. \uD558\uC9C0\uB9CC \uC815\uAD50\uD55C
      \uC124\uACC4\uC5D0 \uC720\uB3D9\uC801 \uC810\uC720\uB77C\uB294 \uBCC0\uC218\uB97C
      \uCD5C\uC6B0\uC120\uC73C\uB85C \uB123\uC5B4\uB77C."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Planner_101
    ko: "\uC704\uB85C\uB294 \uB410\uC2B5\uB2C8\uB2E4. \uAC00\uB4DC\uC758 \uBC18\uC751
      \uC18D\uB3C4 \uBCC0\uC218\uB97C \uD3EC\uD568\uD55C \uB354 \uC815\uAD50\uD55C
      \uC5F0\uACC4 \uD0C0\uC774\uBC0D \uB370\uC774\uD130\uB97C \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Planner_1
    ko: "\uD6C8\uB828\uC774 \uC815\uCCB4\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Opportunist_101
    ko: "\uC81C \uAC00\uCE58\uB97C \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694. \uB0B4\uC77C\uBD80\uD130\uB294
      \uD655\uB960\uC774 \uC544\uB2C8\uB77C \uD655\uC2E4\uD55C \uC810\uC720\uB85C
      \uC81C \uBAB8\uAC12\uC744 \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Opportunist_1
    ko: "\uC2E4\uC9C8\uC801\uC778 \uC131\uACFC\uB97C \uB0B4\uAE30\uB85C \uACB0\uC2EC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Cunning_101
    ko: "\uC5ED\uC2DC \uC81C \uB178\uB825\uC744 \uC54C\uC544\uC8FC\uC2DC\uB294\uAD70\uC694.
      \uB0B4\uC77C\uB3C4 \uC774 \uC644\uBCBD\uD55C \uC704\uCE58\uB97C \uC0AC\uC218\uD558\uBA70
      \uAE30\uD68C\uB97C \uC5FF\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Cunning_1
    ko: "\uCE6D\uCC2C\uBC1B\uC740 \uC704\uCE58 \uC120\uC815\uB9CC \uACE0\uC218\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Believer_101
    ko: "\uC81C \uC124\uACC4\uAC00 \uC633\uB2E4\uB294 \uAC78 \uD655\uC778\uD574\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uACB0\uACFC\uAC00 \uB098\uC62C \uB54C\uAE4C\uC9C0
      \uC774 \uBD84\uC5C5 \uBC29\uC2DD\uC744 \uACE0\uC218\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Believer_1
    ko: "\uBC1C\uC804\uC744 \uAC00\uB85C\uB9C9\uB294 \uB3C5\uC774 \uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Ch_Cold_002
    ko: "\uBA38\uB9AC \uAD74\uB9AC\uB290\uB77C \uACF5\uC744 \uB193\uCE58\uACE0 \uACB0\uACFC\uAC12\uB3C4
      \uBABB \uBF51\uC544\uB0B4\uB294 \uACC4\uC0B0\uAE30\uB294 \uBE44\uD6A8\uC728\uC758
      \uADF9\uCE58\uB2C8 \uB2F9\uC7A5 \uBE44\uCF1C\uB77C."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Planner_201
    ko: "\uC9C0\uC2DC\uD558\uC2E0 \uB85C\uC9C1\uB300\uB85C \uBD84\uC5C5\uD588\uC2B5\uB2C8\uB2E4.
      \uC2DC\uC2A4\uD15C\uC758 \uACB0\uD568\uC744 \uC218\uD589\uC790 \uD0D3\uC73C\uB85C
      \uB3CC\uB9AC\uB294 \uAC74 \uBE44\uD569\uB9AC\uC801\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Planner_2
    ko: "\uC124\uACC4 \uB2A5\uB825 \uC790\uCCB4\uB97C \uBD88\uC2E0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Opportunist_201
    ko: "\uAE30\uBD84\uC774 \uC548 \uC88B\uC73C\uC2E0 \uAC83 \uAC19\uC73C\uB2C8 \uC77C\uB2E8
      \uBE44\uD0A4\uACA0\uC2B5\uB2C8\uB2E4. \uB098\uC911\uC5D0 \uB2E4\uC2DC \uD6A8\uC728\uC801\uC778
      \uB300\uD654\uB97C \uD558\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Opportunist_2
    ko: "\uB2E4\uC74C \uC720\uB9AC\uD55C \uD0C0\uC774\uBC0D\uC744 \uC5FF\uBCF4\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Cunning_201
    ko: "\uAC10\uB3C5\uB2D8 \uB208\uC740 \uBABB \uC18D\uC774\uACA0\uB124\uC694. \uC54C\uACA0\uC2B5\uB2C8\uB2E4.
      \uB0B4\uC77C\uBD80\uD130\uB294 \uAC00\uB4DC \uB530\uC704 \uC548 \uAE30\uB2E4\uB9AC\uACE0
      \uC81C\uAC00 \uB2E4 \uBE8F\uC5B4\uC624\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Cunning_2
    ko: "\uD0DC\uB3C4\uB97C \uC989\uAC01 \uC218\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Believer_201
    ko: "\uC6D0\uCE59 \uC5C6\uB294 \uACB0\uACFC\uB294 \uC694\uD589\uC77C \uBFD0\uC785\uB2C8\uB2E4.
      \uAC10\uB3C5\uB2D8\uC758 \uC2E4\uB9DD\uC740 \uC81C \uB17C\uB9AC\uC801\uC778
      \uACB0\uB860\uC744 \uBC14\uAFC0 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Believer_2
    ko: "\uB17C\uB9AC\uC801 \uACB0\uB860\uC744 \uAD7D\uD788\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Ch_Cold_003
    ko: "\uB178\uD2B8\uB97C \uB09A\uC544\uCC44 \uAD6C\uC5ED \uC120\uC810 \uC704\uC5D0
      \uACF5 \uD655\uBCF4\uAC00 \uBCF8\uC9C8\uC774\uB77C \uD718\uAC08\uAE34 \uB4A4,
      \uAC00\uC2B4\uC5D0 \uAC15\uD558\uAC8C \uB358\uC838\uC900\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Planner_301
    ko: "\uB370\uC774\uD130\uC758 \uC885\uCC29\uC9C0\uAC00 \uC810\uC720\uC600\uC74C\uC744
      \uD655\uC778\uD588\uC2B5\uB2C8\uB2E4. \uC989\uC2DC \uC804\uCCB4 \uB85C\uC9C1\uC744
      \uC218\uC815\uD574\uC11C \uB0B4\uC77C \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Planner_3
    ko: "\uC2DC\uC2A4\uD15C \uC5C5\uB370\uC774\uD2B8\uC5D0 \uCC29\uC218\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Opportunist_301
    ko: "\uC774\uB7F0 \uBC29\uC2DD\uC740 \uC0C1\uB2F9\uD788 \uBD88\uCF8C\uD558\uAD70\uC694.
      \uC81C \uC804\uBB38\uC131\uC744 \uC874\uC911\uD558\uC9C0 \uC54A\uB294 \uACF3\uC5D0
      \uD5CC\uC2E0\uD560 \uC774\uC720\uB294 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Opportunist_3
    ko: "\uB9C8\uC74C\uC744 \uB2EB\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Cunning_301
    ko: "\uBB34\uC2A8 \uB9D0\uC500\uC778\uC9C0 \uC54C\uACA0\uC73C\uB2C8 \uACF5\uC740
      \uCE58\uC6B0\uC2DC\uC8E0. \uB2E4\uC74C\uBD80\uD130\uB294 \uADF8\uB0E5 \uB9D0\uB85C
      \uD558\uC154\uB3C4 \uB2E4 \uC54C\uC544\uB4E3\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Cunning_3
    ko: "\uC0C1\uD669\uC758 \uC2EC\uAC01\uC131\uC744 \uAC00\uBCCD\uAC8C \uB118\uACA8\uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Believer_301
    ko: "\uB9D0\uBCF4\uB2E4 \uAC15\uD55C \uD655\uC2E0\uC744 \uC8FC\uC2DC\uB294\uAD70\uC694.
      \uACF5 \uC810\uC720\uB97C \uC81C \uC0C8\uB85C\uC6B4 \uC2DC\uC2A4\uD15C \uC2E0\uB150\uC73C\uB85C
      \uCD94\uAC00\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Believer_3
    ko: "\uC790\uC2E0\uC758 \uC2DC\uC2A4\uD15C\uC5D0 \uC2E0\uB150\uC73C\uB85C \uC774\uC2DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Instinct_001
    ko: "\uAC10\uB3C5\uB2D8\uC740 \uC624\uB298 \uB9AC\uBC14\uC6B4\uB4DC \uD6C8\uB828\uC5D0\uC11C
      \uAE38\uC744 \uD130\uC8FC\uBA74 \uAC00\uB4DC\uB4E4\uC774 \uACF5\uC744 \uB09A\uC544\uCC44\uB294
      \uC5F0\uACC4 \uD50C\uB808\uC774\uB97C \uC644\uC131\uD558\uB77C\uACE0 \uC9C0\uC2DC\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Instinct_002
    ko: "\uC774 \uC120\uC218\uB294 \uC774\uB97C \uAC00\uB4DC\uB97C \uC704\uD55C \uC0AC\uB0E5\uD130
      \uC870\uC131\uC73C\uB85C \uBC1B\uC544\uB4E4\uC600\uC2B5\uB2C8\uB2E4. \uADF8\uB294
      \uC9D0\uC2B9 \uAC19\uC740 \uAE30\uC138\uB85C \uC0C1\uB300 \uACF5\uACA9\uC218\uB97C
      \uC9D3\uB20C\uB7EC \uAE38\uC744 \uD130\uC8FC\uC5C8\uC9C0\uB9CC,"
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Instinct_003
    ko: "\uC815\uC791 \uC790\uAE30 \uCF54\uC55E\uC73C\uB85C \uACF5\uC774 \uB5A8\uC5B4\uC838\uB3C4
      \uC774\uAC74 \uB0B4 \uBA39\uC774\uAC00 \uC544\uB2C8\uB2E4\uB77C\uB294 \uC9C0\uC2DC\uC5D0
      \uC5B5\uC9C0\uB85C \uBAB8\uC744 \uAD73\uD788\uBA70 \uACF5\uC744 \uC678\uBA74\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Instinct_004
    ko: "\uC57C\uC131\uC744 \uC5B5\uB204\uB978 \uCC44 \uAE30\uACC4\uC801\uC73C\uB85C
      \uC9C0\uC2DC\uB97C \uB530\uB974\uB2E4 \uBCF4\uB2C8 \uC0AC\uB0E5\uAC10\uC744
      \uB208\uC55E\uC5D0 \uB450\uACE0\uB3C4 \uB193\uCE58\uB294 \uAF34\uC774 \uB418\uC5C8\uACE0,
      \uD300\uC758 \uACE8\uBC11\uC740 \uCC98\uCC38\uD558\uAC8C \uB6AB\uB838\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Instinct_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00022_Ch_Instinct_001
    ko: "\uAE30\uC138\uB294 \uC88B\uC558\uB2E4. \uC9C4\uC9DC \uAC15\uD55C \uB188\uC740
      \uACF5\uC744 \uC954 \uB188\uC774\uB2C8 \uC57C\uC131\uC73C\uB85C \uACF5\uAE4C\uC9C0
      \uC539\uC5B4 \uC0BC\uCF1C\uBD10\uB77C."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Bluffer_101
    ko: "\uD750\uD750... \uB2F9\uC5F0\uD788 \uC81C\uAC00 \uCD5C\uACE0\uC8E0! \uB450\uACE0
      \uBCF4\uC138\uC694! \uADF8 \uAE30\uB300, \uD658\uD638\uC131\uC73C\uB85C \uBC14\uAFD4\uC904\uD14C\uB2C8!"
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Bluffer_1
    ko: "\uC790\uC2E0\uAC10\uC744 \uBF50\uB0C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Wild_101
    ko: "\uC704\uB85C \uB9D0\uACE0\uB294 \uD558\uC2E4 \uB9D0\uC500 \uC5C6\uC73C\uC138\uC694?
      \uC790\uC138\uAC00 \uC88B\uC73C\uBA74 \uBB50\uD569\uB2C8\uAE4C, \uACF5\uC744
      \uB193\uCCE4\uB294\uB370."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Wild_1
    ko: "\uAE34\uC7A5\uAC10\uC744 \uB193\uC544\uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Egoist_101
    ko: "\uC704\uB85C \uB9D0\uACE0\uB294 \uD558\uC2E4 \uB9D0\uC500 \uC5C6\uC73C\uC138\uC694?
      \uC790\uC138\uAC00 \uC88B\uC73C\uBA74 \uBB50\uD569\uB2C8\uAE4C, \uACF5\uC744
      \uB193\uCCE4\uB294\uB370."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Egoist_1
    ko: "\uAE34\uC7A5\uAC10\uC744 \uB193\uC544\uBC84\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Fighter_101
    ko: "\uCE6D\uCC2C\uC740 \uB410\uACE0, \uB2E4\uC74C\uBD80\uD134 \uC81C \uBCF8\uB2A5\uB300\uB85C
      \uB6F0\uAC8C \uD574\uC8FC\uC2DC\uC8E0. \uB0A8 \uC88B\uC740 \uC77C \uC2DC\uD0A4\uB290\uB77C
      \uB0B4 \uAE30\uB85D \uB9DD\uCE58\uB294 \uAC74 \uC9C8\uC0C9\uC774\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Fighter_1
    ko: "\uC790\uC2E0\uC758 \uC57C\uC131\uC774 \uC5B5\uB20C\uB9B0 \uAC83\uC5D0\uB9CC
      \uC9D1\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Ch_Instinct_002
    ko: "\uD798\uB9CC \uC4F4\uB2E4\uACE0 \uB2E4\uAC00 \uC544\uB2C8\uB2E4. \uACF5
      \uD558\uB098 \uBABB \uC7A1\uB294 \uB188\uC740 \uD300\uC5D0 \uBBFC\uD3D0\uB2C8
      \uB369\uCE58\uAC12 \uBABB \uD560 \uAC70\uBA74 \uBE44\uCF1C\uB77C."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Bluffer_201
    ko: "\uC2E4\uB825\uC774 \uC5C6\uC5B4\uC11C \uB193\uCE5C \uC904 \uC544\uC138\uC694?
      \uC624\uB298\uC740 \uADF8\uB0E5 \uCEE8\uB514\uC158 \uC870\uC808\uD55C \uAC81\uB2C8\uB2E4.
      \uADF8\uB807\uAC8C \uD654\uB0B4\uC2E4 \uAC70\uAE4C\uC9C4 \uC5C6\uC796\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Bluffer_2
    ko: "\uBED4\uBED4\uD558\uAC8C \uC751\uC218\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Wild_201
    ko: "\uBBFC\uD3D0\uB77C\uACE0\uC694? \uADF8 \uACF5 \uC81C\uAC00 \uB2E4 \uCC22\uC5B4\uB193\uC73C\uBA74
      \uB418\uACA0\uB124\uC694. \uBE44\uD0A4\uC138\uC694, \uAC1C\uC778 \uD6C8\uB828
      \uB354 \uD558\uB7EC \uAC08 \uAC70\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Wild_2
    ko: "\uB3C5\uAE30\uAC00 \uC62C\uB790\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Egoist_201
    ko: "\uBBFC\uD3D0\uB77C\uACE0\uC694? \uADF8 \uACF5 \uC81C\uAC00 \uB2E4 \uCC22\uC5B4\uB193\uC73C\uBA74
      \uB418\uACA0\uB124\uC694. \uBE44\uD0A4\uC138\uC694, \uAC1C\uC778 \uD6C8\uB828
      \uB354 \uD558\uB7EC \uAC08 \uAC70\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Egoist_2
    ko: "\uB3C5\uAE30\uAC00 \uC62C\uB790\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Fighter_201
    ko: "\uB0B4\uAC00 \uBBFC\uD3D0\uB77C\uACE0? \uADF8\uB7FC \uB098 \uC5C6\uC774
      \uC5BC\uB9C8\uB098 \uC798\uD558\uB098 \uBCF4\uC2DC\uC8E0. \uB09C \uB0B4 \uBC29\uC2DD\uB300\uB85C\uB9CC
      \uB701\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Fighter_2
    ko: "\uACE0\uC758\uB85C \uD0DC\uC5C5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Ch_Instinct_003
    ko: "\uB178\uD2B8\uB97C \uBC14\uB2E5\uC5D0 \uB358\uC9C0\uACE0, \uC228\uC774 \uD131
      \uB9C9\uD790 \uC815\uB3C4\uB85C \uAC15\uD558\uAC8C \uACF5\uC744 \uB358\uC838\uC900\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Bluffer_301
    ko: "\uC9C0\uAE08 \uBB50 \uD558\uC2DC\uB294 \uAC81\uB2C8\uAE4C? \uC0AC\uB78C\uB4E4
      \uB2E4 \uBCF4\uB294\uB370 \uC774\uB534 \uB300\uC811\uBC1B\uC73C\uBA74\uC11C
      \uB18D\uAD6C\uD560 \uC0DD\uAC01 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Bluffer_3
    ko: "\uAC10\uB3C5\uC5D0 \uB300\uD55C \uC6D0\uD55C\uC73C\uB85C \uBCC0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Wild_301
    ko: "\uACF5 \uB358\uC9C0\uB294 \uAC74 \uC88B\uC740\uB370 \uC81C \uBB3C\uAC74\uC5D0
      \uC190\uB300\uC9C0 \uB9C8\uC2DC\uC8E0. \uB2E4\uC74C\uC5D4 \uC81C\uAC00 \uB358\uC9C8\uC9C0\uB3C4
      \uBAA8\uB985\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Wild_3
    ko: "\uB2E8\uC21C\uD55C \uAE30 \uC2F8\uC6C0\uC73C\uB85C\uB9CC \uC778\uC2DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Egoist_301
    ko: "\uACF5 \uB358\uC9C0\uB294 \uAC74 \uC88B\uC740\uB370 \uC81C \uBB3C\uAC74\uC5D0
      \uC190\uB300\uC9C0 \uB9C8\uC2DC\uC8E0. \uB2E4\uC74C\uC5D4 \uC81C\uAC00 \uB358\uC9C8\uC9C0\uB3C4
      \uBAA8\uB985\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Egoist_3
    ko: "\uB2E8\uC21C\uD55C \uAE30 \uC2F8\uC6C0\uC73C\uB85C\uB9CC \uC778\uC2DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00022_Desc_Fighter_301
    ko: "\uADF8\uB798, \uC774\uAC70\uC9C0. \uB0B4 \uB208\uC55E\uC5D0 \uC624\uB294
      \uAC74 \uC774\uC81C \uB2E4 \uB0B4 \uAC81\uB2C8\uB2E4. \uAC00\uB4DC\uB4E4\uC774
      \uC624\uAC74 \uB9D0\uAC74 \uC0C1\uAD00 \uC548 \uD574\uC694."
    en: 
    ja: 
  - stringKey: Event_00022_Rs_Fighter_3
    ko: "\uAC1C\uC778\uC758 \uC131\uCDE8\uC695\uC774 \uD3ED\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Discipline_001
    ko: "\uCD5C\uADFC \uB9AC\uBC14\uC6B4\uB4DC \uD6C8\uB828\uC5D0\uC11C \uC774 \uC120\uC218\uB294
      \uAE30\uB85D\uC0C1\uC73C\uB85C\uB294 \uC644\uBCBD\uD558\uC9C0\uB9CC, \uAE30\uB300\uCE58\uC5D0
      \uBE44\uD574 \uACB0\uC815\uC801\uC778 \uACBD\uAE30 \uD750\uB984\uC744 \uAC00\uC838\uC624\uB294
      \uC555\uB3C4\uC801\uC778 \uC704\uC555\uAC10\uC774 \uBD80\uC871\uD558\uB2E4\uB294
      \uD3C9\uAC00\uB97C \uBC1B\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Discipline_002
    ko: "\uBCF8\uC778 \uC2A4\uC2A4\uB85C\uB3C4 \uC815\uD574\uC9C4 \uC704\uCE58\uC5D0\uC11C
      \uC815\uD574\uC9C4 \uBC15\uC2A4\uC544\uC6C3\uB9CC \uD558\uB294 \uC790\uC2E0\uC758
      \uD50C\uB808\uC774\uAC00 \uC548\uC804\uD558\uC9C0\uB9CC \uD30C\uAD34\uB825\uC740
      \uC5C6\uB2E4\uB294 \uC0AC\uC2E4\uC744 \uAE68\uB2EB\uACE0 \uAE4A\uC740 \uACE0\uBBFC\uC5D0
      \uBE60\uC84C\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Discipline_003
    ko: "\uD6C8\uB828\uC774 \uB05D\uB09C \uD6C4, \uC120\uC218\uB294 \uC815\uAC08\uD558\uAC8C
      \uC815\uB9AC\uB41C \uC790\uC2E0\uC758 \uD6C8\uB828 \uC77C\uC9C0\uB97C \uB4E4\uACE0
      \uB2F9\uC2E0\uC744 \uCC3E\uC544\uC654\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Discipline_004
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00023_Ch_Discipline_001
    ko: "\uAE30\uCD08\uAC00 \uB110 \uC9C0\uD0F1\uD558\uB294 \uD798\uC774\uC9C0\uB9CC
      \uC774\uC81C\uB294 \uBCF8\uB2A5\uC744 \uC11E\uC5B4\uB77C. \uB0B4\uC77C\uBD80\uD134
      \uD310\uB2E8\uB300\uB85C \uAC70\uCE60\uAC8C \uD280\uC5B4 \uB098\uAC00\uB77C."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Principled_101
    ko: "\uC2E4\uD328\uB97C \uD3EC\uD568\uD55C \uC131\uC7A5\uC744 \uACF5\uC2DD \uC6D0\uCE59\uC73C\uB85C
      \uC218\uC6A9\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uB0B4\uC77C\uBD80\uD130\uB294
      \uACC4\uC0B0\uB418\uC9C0 \uC54A\uC740 \uC6C0\uC9C1\uC784\uB3C4 \uC2DC\uB3C4\uD574
      \uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Principled_1
    ko: "\uC2E4\uD5D8\uC801\uC778 \uD50C\uB808\uC774\uC5D0 \uB3C4\uC804\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Guardian_101
    ko: "\uC81C \uD310\uB2E8\uC774 \uD2C0\uB824 \uB9AC\uBC14\uC6B4\uB4DC\uB97C \uB193\uCE58\uBA74
      \uC6B0\uB9AC \uC218\uBE44\uB294 \uB204\uAC00 \uC9C0\uD0B5\uB2C8\uAE4C? \uC544\uC9C1\uC740
      \uC548\uC804\uD55C \uBC29\uC2DD\uC774 \uB9C8\uC74C \uD3B8\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Guardian_1
    ko: "\uC120\uB73B \uD2C0\uC744 \uAE68\uC9C0 \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Tactician_101
    ko: "\uBCF8\uB2A5\uC774\uB77C\uB294 \uB2E8\uC5B4\uB294 \uB108\uBB34 \uCD94\uC0C1\uC801\uC785\uB2C8\uB2E4.
      \uBC15\uC2A4\uC544\uC6C3 \uC810\uC720\uC728\uC744 \uBA87 % \uD3EC\uAE30\uD588\uC744
      \uB54C \uC810\uD504\uB97C \uC2DC\uB3C4\uD574\uC57C \uD569\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Tactician_1
    ko: "\uBA85\uD655\uD55C \uC9C0\uD45C\uB97C \uC6D0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Exemplary_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uB3C4 \uC81C \uAE30\uCD08\uB97C \uC778\uC815\uD558\uC2DC\uB294\uAD70\uC694!
      \uC77C\uB2E8\uC740 \uC9C0\uAE08\uC758 \uC644\uBCBD\uD568\uC744 \uC720\uC9C0\uD558\uB294
      \uB370 \uC9D1\uC911\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Exemplary_1
    ko: "\uD604\uC7AC\uC758 \uD50C\uB808\uC774\uC5D0 \uC548\uC8FC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Ch_Discipline_002
    ko: "\uB18D\uAD6C\uB294 \uBA38\uB9AC\uAC00 \uC544\uB2C8\uB77C \uBAB8\uC73C\uB85C
      \uD558\uB294 \uAC70\uB2E4. \uBC94\uC0DD\uC774 \uAC19\uC740 \uD50C\uB808\uC774\uAC00
      \uC57C\uC131\uC744 \uC8FD\uC774\uB2C8 \uB2F9\uC7A5 \uBE44\uCF1C\uB77C."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Principled_201
    ko: "\uC774\uC131\uC801\uC778 \uBD84\uC11D\uC744 \uAC70\uBD80\uD558\uC2DC\uB294\uAD70\uC694.
      \uBB34\uC9C0\uC131\uC801\uC778 \uD50C\uB808\uC774\uAC00 \uC815\uB2F5\uC774\uB77C\uBA74
      \uC81C\uAC00 \uBC30\uC6B8 \uAC74 \uB354 \uC774\uC0C1 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Principled_2
    ko: "\uC9C0\uB3C4 \uCCA0\uD559\uC5D0 \uAC15\uD55C \uC758\uAD6C\uC2EC\uC744 \uD488\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Guardian_201
    ko: "\uC81C \uC548\uC77C\uD568\uC774 \uD300\uC758 \uAE30\uC138\uB97C \uAE4E\uC544\uBA39\uACE0
      \uC788\uC5C8\uAD70\uC694. \uB0B4\uC77C\uBD80\uD130\uB294 \uC695\uC744 \uBA39\uB354\uB77C\uB3C4
      \uB354 \uB3C5\uD558\uAC8C \uACE8\uBC11\uC744 \uC539\uC5B4\uBA39\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Guardian_2
    ko: "\uD300\uC744 \uC9C0\uD0A4\uB294 \uBC95\uC744 \uACE0\uBBFC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Tactician_201
    ko: "\uC9C0\uB2A5\uC801\uC778 \uD50C\uB808\uC774\uC758 \uAC00\uCE58\uB97C \uBAA8\uB974\uC2DC\uB294\uAD70\uC694.
      \uC57C\uC131\uB9CC \uAC15\uC870\uD558\uB294 \uAC10\uB3C5\uB2D8 \uBC11\uC5D0\uC120
      \uC81C \uC7AC\uB2A5\uC774 \uB0AD\uBE44\uB420 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Tactician_2
    ko: "\uB3C5\uC790\uC801\uC778 \uB178\uC120\uC744 \uAC77\uAE30\uB85C \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Exemplary_201
    ko: "\uB0A8\uB4E4 \uC55E\uC5D0\uC11C \uC81C \uB18D\uAD6C\uB97C \uBD80\uC815\uD558\uC2DC\uB2E4\uB2C8...
      \uC2E4\uB9DD\uC2A4\uB7FD\uC2B5\uB2C8\uB2E4. \uC77C\uB2E8 \uC81C\uAC00 \uC54C\uC544\uC11C
      \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Exemplary_2
    ko: "\uAC70\uB9AC\uAC10\uC744 \uB450\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Ch_Discipline_003
    ko: "\uC77C\uC9C0 \uCCAB \uD398\uC774\uC9C0\uB97C \uAC70\uCE60\uAC8C \uCC22\uC5B4\uBC84\uB9AC\uACE0,
      \uBC18\uC751\uD560 \uD2C8\uB3C4 \uC5C6\uC774 \uC5BC\uAD74 \uCABD\uC73C\uB85C
      \uACF5\uC744 \uAC15\uD558\uAC8C \uB358\uC9C4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Principled_301
    ko: "\uC774\uAC8C... \uBB34\uC2A8 \uC804\uC220\uC801 \uC758\uBBF8\uAC00 \uC788\uB294
      \uD589\uB3D9\uC785\uB2C8\uAE4C? \uAE30\uB85D\uC744 \uD30C\uAD34\uD55C\uB2E4\uACE0
      \uC2E4\uB825\uC774 \uB290\uB294 \uAC74 \uC544\uB2D0 \uD150\uB370\uC694."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Principled_3
    ko: "\uB2F9\uD669\uD558\uC5EC \uC77C\uC2DC \uC815\uC9C0\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Guardian_301
    ko: "\uC800\uB294 \uB2F5\uC744 \uB4E3\uACE0 \uC2F6\uC5C8\uC744 \uBFD0\uC778\uB370...
      \uC774\uB7F0 \uC2DD\uC758 \uD3ED\uB825\uC801\uC778 \uC18C\uD1B5\uC740 \uC800\uB97C
      \uB354 \uBD88\uC548\uD558\uAC8C \uB9CC\uB4E4 \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Guardian_3
    ko: "\uC2E0\uB8B0\uD560 \uC218 \uC5C6\uB294 \uC704\uD5D8 \uC694\uC18C\uB85C \uADDC\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Tactician_301
    ko: "\uACFC\uAC70\uC758 \uB370\uC774\uD130\uC5D0 \uBB36\uC5EC \uBC18\uC751 \uC18D\uB3C4\uAC00
      \uB2A6\uC5B4\uC9C0\uACE0 \uC788\uC5C8\uAD70\uC694. \uD14D\uC2A4\uD2B8\uAC00
      \uC544\uB2CC \uAC10\uAC01\uC5D0 \uC9D1\uC911\uD558\uB294 \uB85C\uC9C1\uC744
      \uC9DC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Tactician_3
    ko: "\uC9C1\uAD00\uC801\uC778 \uC804\uC220 \uC2E0\uD638\uB85C \uC774\uD574\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Exemplary_301
    ko: "\uD615\uC2DD\uC801\uC778 \uAE30\uB85D\uC740 \uD544\uC694 \uC5C6\uB2E4\uB294
      \uB73B\uC774\uAD70\uC694. \uB0B4\uC77C\uBD80\uD130 \uCF54\uD2B8 \uC704\uC5D0\uC11C
      \uC81C \uC874\uC7AC\uAC10\uC73C\uB85C \uB2F5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Exemplary_3
    ko: "\uD30C\uAD34\uB825 \uC788\uB294 \uBAA8\uBC94\uC774 \uB418\uACE0\uC790 \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Bond_001
    ko: "\uC5D0\uC774\uC2A4\uAE09 \uC7A0\uC7AC\uB825\uC744 \uAC00\uC9C4 \uC774 \uC120\uC218\uB294
      \uD300\uC758 \uD654\uD569\uC744 \uCD5C\uC6B0\uC120\uC73C\uB85C \uC0DD\uAC01\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Bond_002
    ko: "\uADF8\uB798\uC11C \uB9AC\uBC14\uC6B4\uB4DC \uB54C\uB3C4 \uB3D9\uB8CC\uC758
      \uAD6C\uC5ED\uC744 \uCE68\uBC94\uD558\uC9C0 \uC54A\uACE0 \uC81C\uC790\uB9AC\uB9CC
      \uC9C0\uD0A4\uB294 \uCC29\uD55C \uB18D\uAD6C\uB97C \uD574\uC654\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Bond_003
    ko: "\uD558\uC9C0\uB9CC \uCD5C\uADFC \uACB0\uC815\uC801\uC778 \uC2B9\uBD80\uCC98\uC5D0\uC11C
      \uC0C1\uB300\uC758 \uAE30\uB97C \uAEBE\uB294 \uD30C\uAD34\uB825\uC774 \uBD80\uC871\uD558\uB2E4\uB294
      \uBE44\uD310\uC744 \uB4E3\uC790, \uC790\uC2E0\uC758 \uBC30\uB824\uAC00 \uC624\uD788\uB824
      \uD300\uC5D0 \uBBFC\uD3D0\uAC00 \uB418\uB294 \uAC83\uC740 \uC544\uB2CC\uC9C0
      \uC790\uCC45\uD558\uAE30 \uC2DC\uC791\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Bond_004
    ko: "\uD6C8\uB828 \uD6C4, \uC120\uC218\uB294 \uD300\uC6D0\uB4E4\uC758 \uC7A5\uB2E8\uC810\uC774
      \uBE7C\uACE1\uD788 \uC801\uD78C \uD6C8\uB828 \uC77C\uC9C0\uB97C \uC18C\uC911\uD558\uAC8C
      \uD488\uACE0 \uB2F9\uC2E0\uC744 \uCC3E\uC544\uC654\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Bond_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00023_Ch_Bond_001
    ko: "\uC9C4\uC815\uD55C \uB9AC\uB354\uB294 \uC704\uAE30 \uB54C \uACF5\uC744 \uBE8F\uC5B4
      \uC548\uACA8\uC8FC\uB294 \uC0AC\uB78C\uC774\uB2E4. \uB3D9\uB8CC\uB97C \uBBFF\uACE0
      \uB354 \uAC70\uCE60\uAC8C \uB0A0\uB6F0\uC5B4\uB77C."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Kind_101
    ko: "\uC81C \uBC30\uB824\uAC00 \uD300\uC6D0\uB4E4\uC5D0\uAC8C \uD798\uC774 \uB41C\uB2E4\uB2C8
      \uB2E4\uD589\uC774\uC5D0\uC694. \uB0B4\uC77C\uC740 \uADF8\uB4E4\uC744 \uC704\uD574
      \uC81C\uAC00 \uAF2D \uACF5\uC744 \uBE8F\uC5B4\uC62C\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Kind_1
    ko: "\uC548\uB3C4\uD558\uBA70 \uAC01\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Loyal_101
    ko: "\uAC10\uC0AC\uD569\uB2C8\uB2E4! \uAC10\uB3C5\uB2D8\uC774 \uBBFF\uC5B4\uC8FC\uC2DC\uB2C8
      \uD798\uC774 \uB098\uB124\uC694. \uC9C0\uAE08\uCC98\uB7FC \uD300\uC6D0\uB4E4\uC744
      \uC798 \uCC59\uAE30\uBA70 \uC5F4\uC2EC\uD788 \uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Loyal_1
    ko: "\uCC29\uD55C \uC120\uC218\uB85C \uB0A8\uC73C\uB824 \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Sincere_101
    ko: "\uB124, \uB3D9\uB8CC\uB4E4\uC758 \uC6C0\uC9C1\uC784\uC744 \uB354 \uC644\uBCBD\uD558\uAC8C
      \uBD84\uC11D\uD574\uC11C \uADF8\uB4E4\uC774 \uAC00\uC7A5 \uD3B8\uD558\uAC8C
      \uACF5\uC744 \uC7A1\uC744 \uC218 \uC788\uAC8C \uB3D5\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Sincere_1
    ko: "\uD50C\uB808\uC774\uAC00 \uB290\uB824\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Moodmaker_101
    ko: "\uC5ED\uC2DC \uC6B0\uB9AC \uAC10\uB3C5\uB2D8! \uC81C\uAC00 \uB0B4\uC77C\uBD80\uD130
      \uACE8\uBC11 \uD30C\uD2F0 \uD55C \uBC88 \uC81C\uB300\uB85C \uC5F4\uC5B4\uBCFC\uAC8C\uC694.
      \uAC71\uC815 \uB9C8\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Moodmaker_1
    ko: "\uC6D0\uB798\uC758 \uD50C\uB808\uC774\uB97C \uBC18\uBCF5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Ch_Bond_002
    ko: "\uACE8\uBC11\uC5D0\uC11C \uBC00\uB9AC\uB2C8 \uD300\uC6D0\uB4E4\uC774 \uBD88\uC548\uD574\uD55C\uB2E4.
      \uC804\uC7C1\uD130\uC5D0\uC11C \uC591\uBCF4\uB098 \uD560 \uAC70\uBA74 \uB2F9\uC7A5
      \uC9D0 \uC2F8\uC11C \uB098\uAC00\uB77C."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Kind_201
    ko: "\uC804 \uC815\uB9D0 \uD300\uC744 \uC0DD\uAC01\uD574\uC11C \uADF8\uB7AC\uB358
      \uAC74\uB370... \uC81C\uAC00 \uADF8\uB7F0 \uC2DD\uC73C\uB85C \uBCF4\uC600\uB2E4\uB2C8
      \uC815\uB9D0 \uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uB354\uB294 \uBABB \uD558\uACA0\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Kind_2
    ko: "\uC874\uC7AC \uAC00\uCE58\uB97C \uC0C1\uC2E4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Loyal_201
    ko: "\uC81C\uAC00 \uAC10\uB3C5\uB2D8\uC758 \uC804\uC220\uC744 \uB9DD\uCE58\uACE0
      \uC788\uC5C8\uAD70\uC694. \uB0B4\uC77C\uBD80\uD130\uB294 \uC790\uBE44 \uC5C6\uB294
      \uB9AC\uBC14\uC6B4\uB4DC\uB85C \uC81C \uCDA9\uC131\uC2EC\uC744 \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Loyal_2
    ko: "\uC218\uB2E8\uACFC \uBC29\uBC95\uC744 \uAC00\uB9AC\uC9C0 \uC54A\uACE0 \uAC70\uCE60\uC5B4\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Sincere_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uC81C\uAC00 \uBD80\uC871\uD588\uC2B5\uB2C8\uB2E4.
      \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C \uB354 \uB3C5\uD574\uC9C0\uB3C4\uB85D
      \uB178\uB825\uC740 \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Sincere_2
    ko: "\uAE30\uACC4\uC801\uC778 \uC6C0\uC9C1\uC784\uB9CC \uBCF4\uC600\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Moodmaker_201
    ko: "\uC544\uC774\uACE0, \uBB34\uC12D\uAC8C \uC65C \uADF8\uB7EC\uC138\uC694.
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4! \uC81C\uAC00 \uC880 \uB354 \uD30C\uC774\uD305
      \uB118\uCE58\uAC8C \uB6F0\uC5B4\uBCFC\uAC8C\uC694. \uC9C4\uC815\uD558\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Moodmaker_2
    ko: "\uD50C\uB808\uC774 \uC218\uC815 \uC758\uC9C0\uB294 \uC57D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Ch_Bond_003
    ko: "\uC77C\uC9C0\uB97C \uB36E\uACE0 \uB540 \uC816\uC740 \uC190\uC744 \uAF49
      \uB9DE\uC7A1\uC740 \uB4A4 \uACE8\uB300 \uBC11 \uB9AC\uBC14\uC6B4\uB4DC \uC9C0\uC810\uC744
      \uAC15\uD558\uAC8C \uAC00\uB9AC\uD0A8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uBBFF\uC74C\uC740 \uB290\uAEF4\uC9C0\uC9C0\uB9CC...
      \uC81C\uAC00 \uACE8\uBC11\uC5D0\uC11C \uC5B4\uB5BB\uAC8C \uD574\uC57C \uB3D9\uB8CC\uB4E4\uC774
      \uC6C3\uC744 \uC218 \uC788\uC744\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Kind_3
    ko: "\uC5EC\uC804\uD788 \uD63C\uB780\uC2A4\uB7EC\uC6CC\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8, \uD654\uB098\uC2E0 \uAC70 \uC544\uB2C8\uC8E0? \uC81C\uAC00
      \uC798\uBABB\uD588\uC2B5\uB2C8\uB2E4. \uC2DC\uD0A4\uB294 \uAC74 \uBB50\uB4E0
      \uD560 \uD14C\uB2C8 \uC81C\uBC1C \uADF8\uB807\uAC8C \uBCF4\uC9C0 \uB9C8\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Loyal_3
    ko: "\uAE30\uBD84\uC744 \uB9DE\uCD94\uB294 \uB370\uB9CC \uD608\uC548\uC774 \uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Sincere_301
    ko: "\uAE30\uB85D\uBCF4\uB2E4 \uC911\uC694\uD55C \uAC8C \uBB34\uC5C7\uC778\uC9C0
      \uAE68\uB2EC\uC558\uC2B5\uB2C8\uB2E4. \uC774\uC81C \uD39C\uC744 \uB193\uACE0
      \uBAB8\uC73C\uB85C \uD300\uC758 \uC2B9\uB9AC\uB97C \uC9C0\uD0A4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Sincere_3
    ko: "\uAC00\uC7A5 \uD6A8\uC728\uC801\uC73C\uB85C \uBC18\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Moodmaker_301
    ko: "\uC624! \uAC10\uB3C5\uB2D8 \uC190 \uC5C4\uCCAD \uB728\uAC70\uC6B0\uC2DC\uB124\uC694.
      \uC774 \uC5D0\uB108\uC9C0 \uADF8\uB300\uB85C \uBC1B\uC544\uC11C \uB0B4\uC77C
      \uACE8\uBC11 \uB2E4 \uBC15\uC0B4 \uB0B4\uBC84\uB9AC\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Moodmaker_3
    ko: "\uD65C\uAE30\uB97C \uB418\uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Cold_001
    ko: "\uC5D0\uC774\uC2A4\uAE09 \uC7A0\uC7AC\uB825\uC744 \uAC00\uC9C4 \uC774 \uC120\uC218\uB294
      \uB9AC\uBC14\uC6B4\uB4DC \uC0C1\uD669\uC744 \uCCA0\uC800\uD55C \uD655\uB960
      \uAC8C\uC784\uC73C\uB85C \uC811\uADFC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Cold_002
    ko: "\uADF8\uB294 \uB3D9\uB8CC\uB4E4\uC774 \uAC01\uC790\uC758 \uAD6C\uC5ED\uC744
      \uC9C0\uD0A4\uB294 \uAC83\uC774 \uAC00\uC7A5 \uD6A8\uC728\uC801\uC774\uB77C
      \uD310\uB2E8\uD558\uC5EC, \uC790\uAE30 \uADFC\uCC98\uC5D0 \uACF5\uC774 \uC640\uB3C4
      \uB3D9\uB8CC\uC758 \uAD6C\uC5ED\uC774\uB77C\uBA74 \uC190\uC744 \uB300\uC9C0
      \uC54A\uB294 \uAE30\uACC4\uC801\uC778 \uD50C\uB808\uC774\uB97C \uACE0\uC218\uD574
      \uC654\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Cold_003
    ko: "\uD558\uC9C0\uB9CC \uCD5C\uADFC \uC2B9\uBD80\uCC98\uC5D0\uC11C \uC774\uB7F0
      \uCCA0\uC800\uD55C \uBD84\uC5C5\uC774 \uC624\uD788\uB824 \uC0C1\uB300\uC758
      \uBCC0\uCE59\uC801\uC778 \uACF5\uACA9\uC5D0 \uBB34\uB108\uC9C0\uB294 \uAC83\uC744
      \uBAA9\uACA9\uD558\uC790, \uC790\uC2E0\uC758 \uACC4\uC0B0 \uB85C\uC9C1\uC5D0
      \uC2EC\uAC01\uD55C \uACB0\uD568\uC774 \uC788\uC74C\uC744 \uC9C1\uAC10\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Cold_004
    ko: "\uD6C8\uB828 \uD6C4, \uC120\uC218\uB294 \uC790\uC2E0\uC758 \uB9AC\uBC14\uC6B4\uB4DC
      \uB3D9\uC120\uACFC \uD300\uC6D0\uB4E4\uC758 \uC704\uCE58\uAC00 \uC815\uBC00\uD558\uAC8C
      \uBD84\uC11D\uB41C \uD0DC\uBE14\uB9BF PC\uB97C \uB4E4\uACE0 \uB2F9\uC2E0\uC744
      \uCC3E\uC544\uC654\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Cold_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00023_Ch_Cold_001
    ko: "\uBD84\uC11D\uC740 \uC815\uAD50\uD558\uB098 \uB9AC\uBC14\uC6B4\uB4DC\uB294
      \uC810\uC720\uC758 \uC601\uC5ED\uC774\uB2E4. \uAC00\uB4DC\uC758 \uC601\uC5ED\uAE4C\uC9C0
      \uACC4\uC0B0\uC5D0 \uB123\uACE0 \uCE68\uBC94\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Planner_101
    ko: "\uAC00\uB4DC\uC758 \uAD6C\uC5ED\uAE4C\uC9C0 \uC81C \uD1B5\uC81C \uBC94\uC704\uB85C
      \uD655\uC7A5\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uB354 \uACF5\uACA9\uC801\uC778
      \uB9AC\uBC14\uC6B4\uB4DC \uACF5\uC2DD\uC744 \uC124\uACC4\uD574\uC11C \uB0B4\uC77C
      \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Planner_1
    ko: "\uB354 \uB113\uC740 \uBC94\uC704\uC758 \uC804\uC220\uC744 \uC124\uACC4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Opportunist_101
    ko: "\uC81C\uAC00 \uBB34\uB9AC\uD558\uAC8C \uCE68\uBC94\uD558\uB2E4\uAC00 \uC81C
      \uC2E4\uCC45\uC774 \uB298\uC5B4\uB098\uBA74 \uC81C \uD3C9\uAC00\uB294 \uC5B4\uB5BB\uAC8C
      \uB429\uB2C8\uAE4C? \uD655\uC2E4\uD55C \uBCF4\uC0C1\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Opportunist_1
    ko: "\uC704\uD5D8\uC744 \uAC10\uC218\uD560 \uD544\uC694\uC131\uC744 \uB290\uB07C\uC9C0
      \uBABB\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Cunning_101
    ko: "\uC5ED\uC2DC \uC81C \uC2A4\uB9C8\uD2B8\uD568\uC744 \uC54C\uC544\uC8FC\uC2DC\uB294\uAD70\uC694.
      \uB0B4\uC77C\uB3C4 \uBB34\uB9AC\uD558\uC9C0 \uC54A\uB294 \uC120\uC5D0\uC11C
      \uC81C \uC601\uC5ED\uC740 \uD655\uC2E4\uD788 \uC9C0\uD0A4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Cunning_1
    ko: "\uD798\uB4E0 \uBAB8\uC2F8\uC6C0\uC740 \uD53C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Believer_101
    ko: "\uC81C \uBD84\uC11D\uC774 \uD2C0\uB9AC\uC9C0 \uC54A\uC558\uC74C\uC744 \uD655\uC778\uD588\uC2B5\uB2C8\uB2E4.
      \uD6A8\uC728\uC801\uC778 \uBD84\uC5C5 \uC2DC\uC2A4\uD15C\uC774 \uC815\uCC29\uB420
      \uB54C\uAE4C\uC9C0 \uC774 \uBC29\uC2DD\uC744 \uBC00\uACE0 \uB098\uAC00\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Believer_1
    ko: "\uAE30\uC874\uC758 \uACBD\uC9C1\uB41C \uD50C\uB808\uC774\uB97C \uACE0\uC218\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Ch_Cold_002
    ko: "\uB370\uC774\uD130 \uB4A4\uC5D0 \uBE44\uAC81\uD558\uAC8C \uC228\uC5B4 \uC8FC\uCDA4\uD560
      \uB54C \uD300 \uBD84\uC704\uAE30\uAC00 \uC8FD\uB294\uB2E4. \uACC4\uC0B0\uAE30\uB294
      \uCF54\uD2B8 \uC704\uC5D0 \uD544\uC694 \uC5C6\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Planner_201
    ko: "\uCD5C\uC801\uC758 \uD6A8\uC728\uC744 \uCC3E\uB294 \uAC83\uC774 \uC65C \uBE44\uAC81\uD55C
      \uC77C\uC785\uB2C8\uAE4C? \uAC10\uB3C5\uB2D8\uC758 \uAC10\uC815\uC801\uC778
      \uD53C\uB4DC\uBC31\uC740 \uC81C \uBC1C\uC804\uC5D0 \uB3C4\uC6C0\uC774 \uC548
      \uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Planner_2
    ko: "\uB9AC\uB354\uC2ED\uC744 \uBD88\uC2E0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Opportunist_201
    ko: "\uC81C \uAC00\uCE58\uAC00 \uB5A8\uC5B4\uC9C4\uB2E4\uB294 \uB73B\uC73C\uB85C
      \uB4E4\uB9AC\uB124\uC694. \uC88B\uC2B5\uB2C8\uB2E4. \uB0B4\uC77C\uBD80\uD130\uB294
      \uB0A8\uC758 \uB5A1\uAE4C\uC9C0 \uB2E4 \uBE8F\uC5B4\uC640\uC11C \uC81C \uAC00\uCE58\uB97C
      \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Opportunist_2
    ko: "\uC989\uAC01 \uD0DC\uB3C4\uB97C \uBC14\uAFE8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Cunning_201
    ko: "\uD558\uD558, \uB4E4\uCF30\uB098\uC694? \uC54C\uACA0\uC2B5\uB2C8\uB2E4.
      \uB0B4\uC77C\uBD80\uD130\uB294 \uC544\uC8FC \uC57C\uC0DD\uB9C8\uCC98\uB7FC
      \uB0A0\uB6F0\uC5B4\uBCFC \uD14C\uB2C8 \uC9C0\uCF1C\uBD10 \uC8FC\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Cunning_2
    ko: "\uBCF8\uB2A5\uC801\uC778 \uD50C\uB808\uC774\uB97C \uC5F0\uAE30\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Believer_201
    ko: "\uAC10\uC815\uC801\uC778 \uC9C8\uCC45\uC740 \uC81C \uB17C\uB9AC\uB97C \uBC14\uAFC0
      \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uB9AC\uBC14\uC6B4\uB4DC\uB294 \uACB0\uAD6D
      \uC704\uCE58 \uC120\uC815\uACFC \uD655\uB960\uC758 \uBB38\uC81C\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Believer_2
    ko: "\uB17C\uB9AC\uC801 \uC2E0\uB150\uC744 \uAD7D\uD788\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Ch_Cold_003
    ko: "\uD0DC\uBE14\uB9BF \uD654\uBA74\uC744 \uC190\uC73C\uB85C \uB36E\uC740 \uB4A4,
      \uACE8\uB300\uC5D0 \uACF5\uC744 \uB358\uC838 \uD280\uC5B4 \uC624\uB974\uB294
      \uAC83\uC744 \uC9C1\uC811 \uBCF4\uAC8C \uB9CC\uB4E0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Planner_301
    ko: "\uC2E4\uC804 \uBC18\uC751 \uC18D\uB3C4\uB97C \uB192\uC774\uB77C\uB294 \uB73B\uC785\uB2C8\uAE4C?
      \uC544\uB2C8\uBA74 \uB099\uAD6C \uC9C0\uC810 \uC608\uCE21 \uBAA8\uB378\uC744
      \uC0C8\uB85C \uC9DC\uB77C\uB294 \uB73B\uC785\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Planner_3
    ko: "\uD63C\uB780\uC744 \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Opportunist_301
    ko: "\uC81C \uBD84\uC11D \uB3C4\uAD6C\uB97C \uC774\uB7F0 \uC2DD\uC73C\uB85C \uB2E4\uB8E8\uB294
      \uBD84\uACFC\uB294 \uB354 \uC774\uC0C1 \uB300\uD654\uD558\uACE0 \uC2F6\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4. \uC81C \uBC29\uC2DD\uB300\uB85C \uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Opportunist_3
    ko: "\uD30C\uD2B8\uB108\uC2ED\uC774 \uB05D\uB0AC\uB2E4\uACE0 \uD310\uB2E8\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Cunning_301
    ko: "\uC640, \uAC10\uB3C5\uB2D8 \uB9AC\uBC14\uC6B4\uB4DC \uC2E4\uB825 \uC5EC\uC804\uD558\uC2DC\uB124\uC694!
      \uBB34\uC2A8 \uB9D0\uC500\uC778\uC9C0 \uC54C\uACA0\uC73C\uB2C8 \uC77C\uB2E8
      \uC9C4\uC815\uD558\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Cunning_3
    ko: "\uC9C4\uC9C0\uD55C \uBCC0\uD654 \uC5C6\uC774 \uC0C1\uD669\uC744 \uD68C\uD53C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Believer_301
    ko: "\uD654\uBA74 \uC18D\uC758 \uC810\uBCF4\uB2E4 \uB0A0\uC544\uAC00\uB294 \uACF5\uC774
      \uB354 \uD655\uC2E4\uD55C \uB370\uC774\uD130\uAD70\uC694. \uC81C \uC2E0\uB150\uC758
      \uC6B0\uC120\uC21C\uC704\uB97C \uC810\uC720\uB85C \uC7AC\uC124\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Believer_3
    ko: "\uC2E0\uB150 \uCCB4\uACC4\uB97C \uC989\uC2DC \uC218\uC815\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Instinct_001
    ko: "\uC5D0\uC774\uC2A4\uAE09 \uC7A0\uC7AC\uB825\uC744 \uAC00\uC9C4 \uC774 \uC120\uC218\uB294
      \uBCF8\uB798 \uCF54\uD2B8 \uC704\uC758 \uD3EC\uC2DD\uC790 \uAC19\uC740 \uC57C\uC131\uC744
      \uAC00\uC84C\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Instinct_002
    ko: "\uD558\uC9C0\uB9CC \uCD5C\uADFC \uADF8\uB294 \uB354 \uB192\uC740 \uC218\uC900\uC758
      \uB18D\uAD6C\uB97C \uD558\uACA0\uB2E4\uBA70 \uC790\uC2E0\uC758 \uAC10\uAC01\uC744
      \uC5B5\uB204\uB974\uACE0 \uBAA8\uB4E0 \uC0C1\uD669\uC744 \uB370\uC774\uD130\uB85C
      \uBD84\uC11D\uD558\uB824 \uC560\uC4F0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Instinct_003
    ko: "\uB3D9\uB8CC\uC758 \uAD6C\uC5ED\uC744 \uCE68\uBC94\uD558\uC9C0 \uC54A\uB294
      \uAC83\uC774 \uD6A8\uC728\uC801\uC774\uB77C\uB294 '\uACC4\uC0B0'\uC5D0 \uAC07\uD600,
      \uC815\uC791 \uB208\uC55E\uC758 \uACF5\uC744 \uBCF4\uACE0\uB3C4 \uBAB8\uC774
      \uAD73\uC5B4\uBC84\uB9AC\uB294 \uC5ED\uC124\uC801\uC778 \uC0C1\uD669\uC5D0
      \uCC98\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Instinct_004
    ko: "\uC790\uC2E0\uC758 \uC57C\uC131\uC774 \uC0AC\uB77C\uC9C4 \uC790\uB9AC\uC5D0
      \uB0A8\uC740 \uBE44\uD6A8\uC728\uC801\uC778 \uC218\uCE58\uB4E4\uC5D0 \uAD34\uB85C\uC6CC\uD558\uB358
      \uADF8\uB294 \uACB0\uAD6D \uD55C\uACC4\uB97C \uB290\uB07C\uACE0 \uB2F9\uC2E0\uC744
      \uCC3E\uC544\uC654\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Instinct_005
    ko: "\uC120\uC218\uC5D0\uAC8C \uC5B4\uB5A4 \uC870\uC5B8\uC744 \uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00023_Ch_Instinct_001
    ko: "\uC9C4\uC9DC \uD798\uC740 \uACC4\uC0B0\uC774 \uC544\uB2C8\uB77C \uACF5\uC744
      \uAC08\uAD6C\uD558\uB294 \uC57C\uC131\uC5D0\uC11C \uB098\uC628\uB2E4. \uBCF8\uB2A5\uC774
      \uC774\uB044\uB294 \uB300\uB85C \uB09A\uC544\uCC44\uB77C."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uC81C \uD074\uB77C\uC2A4\uB97C \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694!
      \uB0B4\uC77C\uBD80\uD130 \uC81C \uC57C\uC131\uC774 \uCF54\uD2B8\uB97C \uC5B4\uB5BB\uAC8C
      \uCC22\uC5B4\uB193\uB294\uC9C0 \uB611\uB611\uD788 \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Bluffer_1
    ko: "\uC790\uC2E0\uAC10\uC744 \uD68C\uBCF5\uD558\uBA70 \uC758\uC695\uC744 \uBD88\uD0DC\uC6E0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Wild_101
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4... \uADF8\uB7F0\uB370 \uC815\uB9D0 \uADF8\uB0E5
      \uC81C \uB9C8\uC74C\uB300\uB85C \uD574\uB3C4 \uD300\uC5D0 \uBB38\uC81C\uAC00
      \uC5C6\uC744\uAE4C\uC694? \uC870\uAE08 \uB354 \uD655\uC2E0\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Wild_1
    ko: "\uB2E4\uC2DC \uBBF8\uC9C0\uADFC\uD55C \uC0C1\uD0DC\uB85C \uB3CC\uC544\uAC14\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Egoist_101
    ko: "\uC81C \uBCF8\uB2A5\uB300\uB85C \uB6F0\uBA74 \uC81C \uB9AC\uBC14\uC6B4\uB4DC
      \uC22B\uC790\uB294 \uD655\uC2E4\uD788 \uB298\uC5B4\uB098\uACA0\uC8E0? \uADF8\uB7FC
      \uC77C\uB2E8 \uADF8\uB807\uAC8C \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Egoist_1
    ko: "\uC2A4\uD0EF \uBCC0\uD654\uB9CC \uBA38\uB9BF\uC18D\uC73C\uB85C \uACC4\uC0B0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Fighter_101
    ko: "\uADF8\uB0E5 \uC5F4\uC2EC\uD788 \uD558\uB77C\uB294 \uC18C\uB9AC\uB791 \uBB50\uAC00
      \uB2E4\uB985\uB2C8\uAE4C? \uC880 \uB354 \uD655\uC2E4\uD558\uAC8C \uC81C \uC2EC\uC7A5\uC744
      \uB6F0\uAC8C \uD574\uC904 \uB2F5\uC744 \uC6D0\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Fighter_1
    ko: "\uBBF8\uC628\uC801\uC774\uB77C\uACE0 \uB290\uB07C\uBA70 \uC2E4\uB9DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Ch_Instinct_002
    ko: "\uC218\uCE58 \uB530\uC9C0\uB290\uB77C \uC8FC\uCDA4\uAC70\uB9AC\uB294 \uAE30\uACC4\uAC00
      \uB420 \uAC70\uBA74 \uCF54\uD2B8 \uC704\uC5D0\uC11C \uC0AC\uB0E5\uAC10\uC774
      \uB420 \uBFD0\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Bluffer_201
    ko: "\uAC81\uC7C1\uC774\uB77C\uB2C8\uC694, \uB9D0\uC774 \uC2EC\uD558\uC2DC\uB124!
      \uC774\uAC74 \uADF8\uB0E5 \uCD5C\uC2E0 \uD2B8\uB80C\uB4DC\uB97C \uD30C\uC545\uD574
      \uBCF8 \uAC83\uBFD0\uC785\uB2C8\uB2E4. \uC800 \uC548 \uC8FD\uC5C8\uC5B4\uC694!"
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Bluffer_2
    ko: "\uC18D\uC73C\uB85C\uB294 \uBAB9\uC2DC \uBD88\uC548\uD574\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Wild_201
    ko: "\uB204\uAC00 \uC0AC\uB0E5\uAC10\uC774\uB77C\uB294 \uAC70\uC57C... \uADF8
      \uC785 \uB2E4\uBB3C\uAC8C \uD574\uB4DC\uB9AC\uC8E0. \uB0B4\uC77C\uBD80\uD130
      \uCF54\uD2B8 \uC704\uC758 \uACF5\uC740 \uB2E4 \uC81C \uC785\uC18D\uC73C\uB85C
      \uB4E4\uC5B4\uAC08 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Wild_2
    ko: "\uC5D0\uC774\uC2A4 \uAE30\uC9C8\uC774 \uB418\uC0B4\uC544\uB0AC\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Egoist_201
    ko: "\uB098\uB984\uB300\uB85C \uD300 \uC2B9\uB9AC \uD655\uB960\uC744 \uB192\uC774\uB824\uACE0
      \uACF5\uBD80\uD55C \uC800\uB97C \uBB34\uC2DC\uD558\uC2DC\uB124\uC694. \uC88B\uC2B5\uB2C8\uB2E4,
      \uC800 \uC5C6\uC774 \uC5BC\uB9C8\uB098 \uC798\uB418\uB294\uC9C0 \uBCF4\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Egoist_2
    ko: "\uAC15\uD55C \uC801\uB300\uAC10\uC744 \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Fighter_201
    ko: "\uB0B4\uAC00 \uC0AC\uB0E5\uAC10\uC774\uB77C\uACE0? \uADF8\uB7FC \uB2F9\uC2E0\uBD80\uD130
      \uC0AC\uB0E5\uD574\uC904\uAE4C? \uB2F9\uC7A5 \uB098\uC640\uC11C \uB098\uB791
      \uACF5 \uBE8F\uAE30 \uD55C \uD310 \uD574!"
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Fighter_2
    ko: "\uAC10\uB3C5\uACFC\uC758 \uC2F8\uC6C0\uC5D0 \uBAB0\uB450\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Ch_Instinct_003
    ko: "\uACF5\uC744 \uC120\uC218\uC758 \uC5BC\uAD74\uC744 \uD5A5\uD574 \uC804\uB825\uC73C\uB85C
      \uAC15\uD558\uAC8C \uB358\uC9C4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Bluffer_301
    ko: "\uC9C0\uAE08 \uBB50 \uD558\uC2DC\uB294 \uAC81\uB2C8\uAE4C? \uC544\uBB34\uB9AC
      \uAC10\uB3C5\uB2D8\uC774\uB77C\uB3C4 \uC81C \uC7A5\uBE44\uB97C \uC774\uB807\uAC8C
      \uB2E4\uB8E8\uB294 \uAC74 \uBABB \uCC38\uC2B5\uB2C8\uB2E4. \uC0AC\uB78C \uC6B0\uC2A4\uC6CC\uC694?"
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Bluffer_3
    ko: "\uBD84\uB178\uD558\uBA70 \uB9C8\uC74C\uC744 \uB2EB\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Wild_301
    ko: "\uACF5 \uB358\uC9C0\uB294 \uAC74 \uC88B\uC740\uB370, \uC81C \uBB3C\uAC74
      \uB358\uC9C4 \uAC74 \uC0AC\uACFC\uD558\uC154\uC57C \uD560 \uAC81\uB2C8\uB2E4.
      \uC800\uB3C4 \uAC00\uB9CC\uD788 \uC788\uC9C0\uB294 \uC54A\uAC70\uB4E0\uC694."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Wild_3
    ko: "\uAC10\uB3C5\uACFC \uAE30 \uC2F8\uC6C0\uC744 \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Egoist_301
    ko: "\uADF8\uB798, \uC774\uAC70\uC9C0. \uBCF5\uC7A1\uD55C \uAC74 \uCCB4\uC9C8\uC5D0
      \uC548 \uB9DE\uC558\uC5B4. \uC774\uC81C \uB0B4 \uC55E\uC5D0 \uBCF4\uC774\uB294
      \uACF5\uC740 \uB2E4 \uB0B4 \uAC70\uB2C8\uAE4C \uC544\uBB34\uB3C4 \uAC74\uB4DC\uB9AC\uC9C0
      \uB9C8."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Egoist_3
    ko: "\uC790\uC2E0\uC758 \uC695\uB9DD\uC5D0 \uC9D1\uC911\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Desc_Fighter_301
    ko: "\uB9D0\uBCF4\uB2E4 \uD589\uB3D9\uC774 \uBE60\uB974\uC2DC\uB124. \uC88B\uC2B5\uB2C8\uB2E4.
      \uB0B4\uC77C\uBD80\uD130 \uCF54\uD2B8 \uC704\uC5D0\uC11C \uD53C \uB0C4\uC0C8
      \uC880 \uB098\uB3C4 \uC800\uB294 \uBA48\uCD94\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00023_Rs_Fighter_3
    ko: "\uC804\uD22C \uC0C1\uD0DC\uB85C \uB3CC\uC785\uD574 \uC644\uC804\uD788 \uAC01\uC131\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Discipline_001
    ko: "\uD6C8\uB828\uC774 \uB05D\uB09C \uBE48 \uCF54\uD2B8,  \uC120\uC218\uB294
      \uD63C\uC790 \uB0A8\uC544 \uBCBD\uC5D0 \uACF5\uC744 \uD280\uAE30\uBA70 \uB9AC\uBC14\uC6B4\uB4DC
      \uC5F0\uC2B5\uC744 \uBC18\uBCF5\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Discipline_002
    ko: "\uADF8\uB294 \uACF5\uC744 \uC7A1\uC744 \uB54C\uB9C8\uB2E4 \uC790\uC2E0\uC758
      \uBC1C \uC704\uCE58\uC640 \uBB34\uB98E \uAC01\uB3C4\uAC00 \uAC10\uB3C5\uB2D8\uC758
      \uC9C0\uC2DC\uC640 \uC870\uAE08\uC774\uB77C\uB3C4 \uB2E4\uB974\uBA74 \uC2E0\uACBD\uC9C8\uC801\uC73C\uB85C
      \uACF5\uC744 \uB0B4\uB358\uC9C0\uACE0 \uCC98\uC74C\uBD80\uD130 \uB2E4\uC2DC
      \uC2DC\uC791\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Discipline_003
    ko: "\uC644\uBCBD\uD55C \uC790\uC138\uAC00 \uB098\uC62C \uB54C\uAE4C\uC9C0 \uC790\uC2E0\uC744
      \uD639\uC0AC\uC2DC\uD0A4\uB290\uB77C \uC774\uBBF8 \uCCB4\uB825\uC740 \uBC14\uB2E5\uB0AC\uACE0,
      \uB208\uC740 \uCDA9\uD608\uB418\uC5B4 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Discipline_004
    ko: "\uC555\uB3C4\uC801\uC778 \uC7AC\uB2A5\uC744 \uAC00\uC84C\uC74C\uC5D0\uB3C4
      \uC2A4\uC2A4\uB85C \uB9CC\uB4E0 \uADDC\uC728\uC758 \uAC10\uC625\uC5D0 \uAC07\uD600
      \uD55C \uBC1C\uC9DD\uB3C4 \uB098\uC544\uAC00\uC9C0 \uBABB\uD558\uACE0 \uB059\uB059\uAC70\uB9AC\uB294
      \uADF8\uC758 \uB4B7\uBAA8\uC2B5\uC774 \uC704\uD0DC\uB85C\uC6CC \uBCF4\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Discipline_005
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00024_Ch_Discipline_001
    ko: "\uC7AC\uB2A5\uC740 \uC2EC\uC7A5\uC5D0\uC11C \uB098\uC624\uB2C8 \uB0B4\uC77C\uC740
      \uADDC\uC728\uC744 \uC78A\uACE0 \uBAB8\uC774 \uC2DC\uD0A4\uB294 \uB300\uB85C
      \uB0A0\uC544\uC62C\uB77C\uB77C."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Principled_101
    ko: "\uC7AC\uB2A5\uC744 \uC4F0\uB294 \uAC83\uB3C4 \uADDC\uC728\uC758 \uC77C\uBD80\uB77C\uB294
      \uB9D0\uC500\uC774\uC2DC\uAD70\uC694. \uB0B4\uC77C\uBD80\uD130\uB294 \uC81C
      \uB192\uC774\uC758 \uD55C\uACC4\uB97C \uC9C1\uC811 \uC2DC\uD5D8\uD574 \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Principled_1
    ko: "\uAC15\uBC15\uC5D0\uC11C \uBC97\uC5B4\uB098 \uC790\uC2E0\uC744 \uBBFF\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Guardian_101
    ko: "\uAC10\uB3C5\uB2D8\uC740 \uAD1C\uCC2E\uB2E4\uACE0 \uD558\uC2DC\uC9C0\uB9CC...
      \uC81C\uAC00 \uC6D0\uCE59\uC744 \uC5B4\uAE30\uACE0 \uC2E4\uC218\uD558\uBA74
      \uACE8\uBC11\uC740 \uB204\uAC00 \uCC45\uC784\uC9C0\uB098\uC694. \uC804 \uC544\uC9C1
      \uBD88\uC548\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Guardian_1
    ko: "\uBD88\uC548\uD574\uD558\uBA70 \uC790\uC138\uC5D0 \uBBF8\uB828\uC744 \uB450\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Tactician_101
    ko: "\uC704\uB85C\uB294 \uB410\uC2B5\uB2C8\uB2E4. \uAC01\uB3C4\uAC00 \uBA87 \uB3C4\uAE4C\uC9C0
      \uD2C0\uC5B4\uC838\uB3C4 \uB9AC\uBC14\uC6B4\uB4DC \uC810\uC720\uC728\uC5D0
      \uC9C0\uC7A5\uC774 \uC5C6\uB294\uC9C0 \uC784\uACC4 \uB370\uC774\uD130\uB97C
      \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Tactician_1
    ko: "\uC218\uCE58\uC801 \uAC00\uC774\uB4DC\uB97C \uC6D0\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Exemplary_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uC81C \uB178\uB825\uC744 \uC54C\uC544\uC8FC\uC2DC\uB294\uAD70\uC694!
      \uB0B4\uC77C\uB3C4 \uC774 \uC644\uBCBD\uD55C \uAC01\uB3C4\uB97C \uC720\uC9C0\uD558\uBA70
      \uD300\uC758 \uBAA8\uBC94\uC774 \uB418\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Exemplary_1
    ko: "\uBC1C\uC804 \uC5C6\uC774 \uACBD\uC9C1\uB41C \uC5F0\uC2B5\uC744 \uACC4\uC18D\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Ch_Discipline_002
    ko: "\uC790\uAE30\uB9CC\uC871\uC73C\uB85C \uC7AC\uB2A5\uC744 \uC369\uD790 \uAC70\uBA74
      \uB2F9\uC7A5 \uCF54\uD2B8\uC5D0\uC11C \uB098\uAC00\uB77C."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Principled_201
    ko: "\uC6D0\uCE59\uC744 \uC9C0\uD0A4\uB824\uB294 \uB178\uB825\uC774 \uC65C \uBA4D\uCCAD\uD55C
      \uC9D3\uC785\uB2C8\uAE4C? \uAE30\uC900 \uC5C6\uB294 \uB18D\uAD6C\uB294 \uACB0\uAD6D
      \uBB34\uB108\uC9C8 \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Principled_2
    ko: "\uBC18\uBC1C\uC2EC\uC744 \uAC00\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Guardian_201
    ko: "\uC81C \uACB0\uBCBD\uC99D\uC774 \uD300\uC758 \uC804\uB825\uC744 \uB0AD\uBE44\uC2DC\uD0A4\uACE0
      \uC788\uC5C8\uAD70\uC694. \uB0B4\uC77C\uBD80\uD130\uB294 \uD300\uC744 \uC704\uD574
      \uC81C \uC7AC\uB2A5\uC744 \uC544\uB07C\uC9C0 \uC54A\uACE0 \uC3DF\uC544\uBD93\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Guardian_2
    ko: "\uC790\uC2E0\uC758 \uD2C0\uC744 \uAE68\uC57C \uD568\uC744 \uC790\uAC01\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Tactician_201
    ko: "\uC804\uC220\uC801 \uC644\uC131\uB3C4\uB97C \uB192\uC774\uB824\uB294 \uC2DC\uB3C4\uB97C
      \uBB34\uC2DC\uD558\uC2DC\uB294\uAD70\uC694. \uAC10\uB3C5\uB2D8\uC758 \uC9C1\uAD00\uC5D0\uB9CC
      \uC758\uC874\uD558\uB294 \uBC29\uC2DD\uC740 \uAC70\uBD80\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Tactician_2
    ko: "\uBAA8\uC695\uAC10\uC744 \uB290\uB07C\uACE0 \uB3C5\uC790 \uB178\uC120\uC744
      \uD0DD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Exemplary_201
    ko: "\uD63C\uC790 \uC5F0\uC2B5\uD558\uB294 \uAC8C \uC798\uBABB\uC740 \uC544\uB2C8\uC9C0
      \uC54A\uC2B5\uB2C8\uAE4C... \uAE30\uBD84\uC774 \uC548 \uC88B\uC73C\uC2E0 \uAC83
      \uAC19\uC73C\uB2C8 \uC774\uB9CC \uAC00\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Exemplary_2
    ko: "\uC218\uCE58\uC2EC\uC744 \uB290\uB07C\uACE0 \uC11C\uB458\uB7EC \uC790\uB9AC\uB97C
      \uD53C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Ch_Discipline_003
    ko: "\uACF5\uC744 \uBE8F\uC5B4 \uCC28\uBC84\uB9AC\uACE0 \uB4B7\uB35C\uBBF8\uB97C
      \uC7A1\uC544 \uC138\uC6CC \uACE8\uB300\uB97C \uC815\uBA74\uC73C\uB85C \uC751\uC2DC\uD558\uAC8C
      \uB9CC\uB4E0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Principled_301
    ko: "\uAC11\uC790\uAE30 \uACF5\uC740 \uC65C... \uC774 \uD589\uB3D9\uC774 \uC81C
      \uB9AC\uBC14\uC6B4\uB4DC \uBA54\uCEE4\uB2C8\uC998 \uC218\uC815\uACFC \uC5B4\uB5A4
      \uC0C1\uAD00\uAD00\uACC4\uAC00 \uC788\uB294\uC9C0 \uC124\uBA85\uD574 \uC8FC\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Principled_3
    ko: "\uC804\uC220\uC801 \uC758\uB3C4\uB97C \uBD84\uC11D\uD558\uB290\uB77C \uC5BC\uC5B4\uBD99\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Guardian_301
    ko: "\uC548 \uADF8\uB798\uB3C4 \uAD34\uB85C\uC6CC \uC8FD\uACA0\uB294\uB370 \uAF2D
      \uC774\uB7F0 \uC2DD\uC73C\uB85C \uD558\uC154\uC57C \uD588\uB098\uC694? \uAC10\uB3C5\uB2D8\uAED8
      \uC800\uB294 \uADF8\uB0E5 \uBD80\uC11C\uC838\uB3C4 \uB418\uB294 \uBB3C\uAC74\uC778\uAC00\uC694?"
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Guardian_3
    ko: "\uBC84\uB824\uC84C\uB2E4\uB294 \uB290\uB08C\uC5D0 \uC2EC\uB9AC\uC801\uC73C\uB85C
      \uBB34\uB108\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Tactician_301
    ko: "\uC218\uCE58\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uBCF8\uC9C8\uC744 \uB193\uCCE4\uAD70\uC694.
      \uC989\uC2DC \uC2E4\uC804 \uB370\uC774\uD130 \uC911\uC2EC\uC73C\uB85C \uC81C
      \uC804\uC220 \uB85C\uC9C1\uC744 \uC7AC\uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Tactician_3
    ko: "\uBAA9\uC801\uC9C0\uC5D0 \uC9D1\uC911\uD558\uB77C\uB294 \uC2E0\uD638\uB97C
      \uC218\uC6A9\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Exemplary_301
    ko: "\uC794\uAE30\uC220\uC740 \uD544\uC694 \uC5C6\uB2E4\uB294 \uB73B\uC73C\uB85C
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uB0B4\uC77C \uCF54\uD2B8 \uC704\uC5D0\uC11C
      \uC81C \uC555\uB3C4\uC801\uC778 \uC7AC\uB2A5\uC73C\uB85C \uB2F5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Exemplary_3
    ko: "\uD30C\uAD34\uC801 \uBAA8\uBC94\uC774 \uB418\uACE0\uC790 \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Bond_001
    ko: "\uD6C8\uB828\uC774 \uB05D\uB09C \uBE48 \uCF54\uD2B8,  \uC5D0\uC774\uC2A4
      \uC13C\uD130\uC778 \uC774 \uC120\uC218\uB294 \uD63C\uC790 \uB0A8\uC544 \uB9AC\uBC14\uC6B4\uB4DC
      \uC5F0\uC2B5\uC744 \uBC18\uBCF5\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Bond_002
    ko: "\uADF8\uB294 \uACF5\uC744 \uC7A1\uC744 \uB54C\uB9C8\uB2E4 \uC790\uC2E0\uC758
      \uBC1C \uC704\uCE58\uAC00 \uB3D9\uB8CC\uB4E4\uC758 \uB3D9\uC120\uC744 \uBC29\uD574\uD558\uC9C0
      \uC54A\uC558\uB294\uC9C0, \uC790\uC2E0\uC758 \uC790\uC138\uAC00 \uD300 \uC804\uC220\uC758
      \uC815\uC11D\uC5D0\uC11C \uBC97\uC5B4\uB098\uC9C0 \uC54A\uC558\uB294\uC9C0
      \uAC15\uBC15\uC801\uC73C\uB85C \uD655\uC778\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Bond_003
    ko: "\uC870\uAE08\uC774\uB77C\uB3C4 \uC5B4\uAE0B\uB098\uBA74 \uD300\uC6D0\uB4E4\uC5D0\uAC8C
      \uBBFC\uD3D0\uB97C \uB07C\uCCE4\uB2E4\uB294 \uC0DD\uAC01\uC5D0 \uAD34\uB85C\uC6CC\uD558\uBA70
      \uC2A4\uC2A4\uB85C\uB97C \uD639\uC0AC\uC2DC\uD0A4\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Bond_004
    ko: "\uC774\uBBF8 \uB208\uC740 \uCDA9\uD608\uB418\uACE0 \uCCB4\uB825\uC740 \uBC14\uB2E5\uB0AC\uC9C0\uB9CC,
      \uB0B4\uAC00 \uC644\uBCBD\uD574\uC57C \uD300\uC774 \uD589\uBCF5\uD558\uB2E4\uB294
      \uC720\uB300 \uC131\uD5A5 \uD2B9\uC720\uC758 \uCC45\uC784\uAC10 \uB54C\uBB38\uC5D0
      \uBA48\uCD94\uC9C0 \uBABB\uD558\uACE0 \uB059\uB059\uB300\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Bond_005
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00024_Ch_Bond_001
    ko: "\uD300\uC6D0\uB4E4\uC740 \uC644\uBCBD\uD55C \uC790\uC138\uBCF4\uB2E4 \uB124\uAC00
      \uC990\uAC81\uAC8C \uACF5\uC744 \uC7A1\uC544\uC8FC\uAE38 \uBC14\uB77C\uACE0
      \uC788\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Kind_101
    ko: "\uD300\uC6D0\uB4E4\uC774 \uC800 \uB54C\uBB38\uC5D0 \uBD88\uD3B8\uD560\uAE4C
      \uBD10 \uAC71\uC815\uD588\uB294\uB370... \uAC10\uB3C5\uB2D8 \uB9D0\uC500 \uB4E4\uC73C\uB2C8
      \uB9C8\uC74C\uC774 \uB193\uC5EC\uC694. \uB0B4\uC77C\uC740 \uB354 \uBC1D\uAC8C
      \uB6F8\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Kind_1
    ko: "\uB9C8\uC74C\uC758 \uC9D0\uC744 \uB35C\uACE0 \uBBF8\uC18C\uB97C \uB418\uCC3E\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC740 \uCC29\uD558\uC2DC\uB2C8\uAE4C \uC800\uB97C \uC704\uB85C\uD574\uC8FC\uC2DC\uB294
      \uAC70\uACA0\uC8E0. \uD558\uC9C0\uB9CC \uC804 \uAC10\uB3C5\uB2D8\uC758 \uC644\uBCBD\uD55C
      \uC13C\uD130\uAC00 \uB418\uACE0 \uC2F6\uC2B5\uB2C8\uB2E4. \uC870\uAE08\uB9CC
      \uB354 \uD560\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Loyal_1
    ko: "\uACC4\uC18D \uC790\uC2E0\uC744 \uCC44\uCC0D\uC9C8\uD558\uB824 \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Sincere_101
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C
      \uB0B4\uC77C\uC740 \uC990\uAC70\uC6B4 \uB9C8\uC74C\uC73C\uB85C \uB450 \uBC30
      \uB354 \uC5F0\uC2B5\uD574\uC11C \uC644\uBCBD\uC744 \uAE30\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Sincere_1
    ko: "\uD6C8\uB828 \uAC15\uB3C4\uB97C \uB354 \uB192\uC77C \uACC4\uD68D\uC744 \uC138\uC6E0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Moodmaker_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8! \uC800 \uC0AC\uC2E4 \uB108\uBB34 \uD798\uB4E4\uC5C8\uAC70\uB4E0\uC694.
      \uADF8\uB7FC \uC800 \uB0B4\uC77C\uC740 \uADF8\uB0E5 \uC2E0\uB098\uAC8C \uB180\uBA74\uC11C
      \uB18D\uAD6C\uD574\uB3C4 \uB418\uB294 \uAC70\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Moodmaker_1
    ko: "\uAE34\uC7A5\uC744 \uD480\uACE0 \uACE0\uCE58\uB824\uB294 \uB178\uB825\uC744
      \uBA48\uCDC4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Ch_Bond_002
    ko: "\uC790\uCC45\uD558\uBA70 \uC9C4 \uBE7C\uB294 \uAC74 \uD300\uC744 \uB9DD\uCE58\uB294
      \uC77C\uC774\uB2C8 \uB2F9\uC7A5 \uB098\uAC00\uC11C \uC7A0\uC774\uB098 \uC790\uB77C."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Kind_201
    ko: "\uC804 \uC815\uB9D0 \uC798\uD558\uACE0 \uC2F6\uC5B4\uC11C \uADF8\uB7F0 \uAC74\uB370...
      \uC81C\uAC00 \uD300\uC5D0 \uBC29\uD574\uB9CC \uB418\uB294 \uC874\uC7AC\uC600\uB098
      \uBCF4\uB124\uC694. \uC8C4\uC1A1\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Kind_2
    ko: "\uAE4A\uC740 \uC0C1\uCC98\uB97C \uC785\uACE0 \uC758\uC695\uC744 \uC0C1\uC2E4\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Loyal_201
    ko: "\uC81C \uCEE8\uB514\uC158 \uAD00\uB9AC\uAC00 \uAC10\uB3C5\uB2D8\uC744 \uC704\uD55C
      \uAE38\uC784\uC744 \uC78A\uC5C8\uC2B5\uB2C8\uB2E4. \uB2F9\uC7A5 \uC911\uB2E8\uD558\uACE0
      \uB0B4\uC77C \uCD5C\uC0C1\uC758 \uC0C1\uD0DC\uB85C \uBCF5\uADC0\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Loyal_2
    ko: "\uCDA9\uC131 \uACFC\uC81C\uB85C \uBC1B\uC544\uB4E4\uC774\uACE0 \uC989\uC2DC
      \uBCF5\uC885\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Sincere_201
    ko: "\uB124... \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uC774
      \uC633\uC2B5\uB2C8\uB2E4. \uC624\uB298\uC740 \uC774\uB9CC \uB4E4\uC5B4\uAC00\uC11C
      \uC26C\uB3C4\uB85D \uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Sincere_2
    ko: "\uC5EC\uC804\uD788 \uC5F0\uC2B5 \uBD80\uC871\uC774\uB77C\uB294 \uBD88\uC548\uAC10\uC744
      \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Moodmaker_201
    ko: "\uC5D0\uC774, \uAC10\uB3C5\uB2D8 \uBB34\uC12D\uAC8C \uC65C \uADF8\uB7EC\uC138\uC694!
      \uC81C\uAC00 \uB0B4\uC77C \uB369\uD06C \uD55C \uBC29 \uC2DC\uC6D0\uD558\uAC8C
      \uAF42\uC73C\uBA74 \uD654 \uD480\uB9AC\uC2E4 \uAC70\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Moodmaker_2
    ko: "\uB18D\uB2F4\uC73C\uB85C \uC0C1\uD669\uC744 \uB118\uAE30\uB824 \uD574 \uBCC0\uD654\uAC00
      \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Ch_Bond_003
    ko: "\uACF5\uC744 \uCE58\uC6CC\uBC84\uB9AC\uACE0 \uB5A8\uACE0 \uC788\uB294 \uC120\uC218\uC758
      \uC5B4\uAE68\uB97C \uC9DA\uC73C\uBA70 \uACE0\uAC1C\uB97C \uB044\uB355\uC5EC\uC900\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Kind_301
    ko: "\uAC10\uC0AC\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uAC10\uB3C5\uB2D8, \uC81C\uAC00
      \uC870\uAE08\uB9CC \uB354 \uD558\uBA74 \uC644\uBCBD\uD558\uAC8C \uD560 \uC218
      \uC788\uC744 \uAC83 \uAC19\uC740\uB370... \uC815\uB9D0 \uADF8\uB9CC\uD560\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Kind_3
    ko: "\uC644\uBCBD\uD558\uC9C0 \uBABB\uD558\uB2E4\uB294 \uC0AC\uC2E4\uC5D0 \uBBF8\uB828\uC744
      \uAC00\uC84C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8, \uC81C\uAC00 \uBD80\uC871\uD574\uC11C \uD654\uB098\uC2E0
      \uAC70\uC8E0? \uC81C\uBC1C \uD3EC\uAE30\uD558\uC9C0\uB9CC \uB9D0\uC544\uC8FC\uC138\uC694.
      \uC2DC\uD0A4\uB294 \uAC74 \uBB50\uB4E0 \uB354 \uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Loyal_3
    ko: "\uB208\uCE58\uB97C \uBCF4\uB290\uB77C \uC815\uC2E0\uC801\uC73C\uB85C \uB354
      \uC704\uCD95\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Sincere_301
    ko: "\uC774\uC81C \uADF8\uB9CC\uD574\uB3C4 \uB41C\uB2E4\uACE0 \uD655\uC2E0\uC744
      \uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uAE30\uB85D\uBCF4\uB2E4
      \uC911\uC694\uD55C \uAC8C \uBB54\uC9C0 \uC774\uC81C \uC880 \uC54C \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Sincere_3
    ko: "\uBB34\uAC70\uC6E0\uB358 \uCC45\uC784\uAC10\uC5D0\uC11C \uC644\uC804\uD788
      \uD574\uBC29\uB410\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Moodmaker_301
    ko: "\uAC10\uB3C5\uB2D8 \uC190 \uC815\uB9D0 \uB530\uB73B\uD558\uC2DC\uB124\uC694.
      \uD63C\uC790 \uB059\uB059\uB308 \uB550 \uBAB0\uB790\uB294\uB370, \uC5ED\uC2DC
      \uC804 \uD300\uC774\uB791 \uC788\uC744 \uB54C \uC81C\uC77C \uD798\uC774 \uB098\uB098
      \uBD10\uC694!"
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Moodmaker_3
    ko: "\uB4E0\uB4E0\uD55C \uC720\uB300\uAC10\uC744 \uB290\uB07C\uBA70 \uC5D0\uB108\uC9C0\uB97C
      \uCDA9\uC804\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Cold_001
    ko: "\uD6C8\uB828\uC774 \uB05D\uB09C \uBE48 \uCF54\uD2B8, \uC5D0\uC774\uC2A4
      \uC13C\uD130\uC778 \uC774 \uC120\uC218\uB294 \uD640\uB85C \uB0A8\uC544 \uD0DC\uBE14\uB9BF
      PC\uC640 \uB9AC\uBC14\uC6B4\uB4DC \uAE30\uACC4\uB97C \uC5F0\uB3D9\uD574\uB450\uACE0
      \uBB34\uD55C \uBC18\uBCF5 \uC5F0\uC2B5 \uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Cold_002
    ko: "\uADF8\uB294 \uACF5\uC744 \uC7A1\uC744 \uB54C\uB9C8\uB2E4 \uD0DC\uBE14\uB9BF\uC5D0
      \uAE30\uB85D\uB418\uB294 \uC790\uC2E0\uC758 \uBB34\uAC8C \uC911\uC2EC \uC774\uB3D9
      \uACBD\uB85C\uC640 \uCC29\uC9C0 \uC9C0\uC810 \uC624\uCC28\uB97C \uD655\uC778\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Cold_003
    ko: "\uC624\uCC28\uAC00 0.1cm\uB77C\uB3C4 \uBC1C\uC0DD\uD558\uBA74 \uBB34\uD45C\uC815\uD55C
      \uC5BC\uAD74\uB85C \uC790\uC2E0\uC758 \uBEA8\uC744 \uAC15\uD558\uAC8C \uB54C\uB9AC\uAC70\uB098
      \uAC70\uCE60\uAC8C \uC228\uC744 \uBAB0\uC544\uC26C\uBA70 \uB2E4\uC2DC \uCC98\uC74C\uBD80\uD130
      \uC2DC\uC791\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Cold_004
    ko: "\uADF8\uB294 \uD300\uC758 \uC2B9\uB9AC \uD655\uB960\uC744 \uADF9\uB300\uD654\uD558\uAE30
      \uC704\uD574 \uC790\uC2E0\uC744 \uC644\uBCBD\uD55C \uC120\uC218\uB85C \uB9CC\uB4E4\uB824\uB294
      \uACC4\uC0B0\uC801 \uAC15\uBC15\uC5D0 \uAC07\uD600, \uCCB4\uB825\uC774 \uBC14\uB2E5\uB09C
      \uC904\uB3C4 \uBAA8\uB974\uACE0 \uC2DC\uC2A4\uD15C\uC758 \uB178\uC608\uCC98\uB7FC
      \uC6C0\uC9C1\uC774\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Cold_005
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00024_Ch_Cold_001
    ko: "\uC815\uAD50\uD568\uC740 \uC88B\uC73C\uB098 \uBAB8\uC740 \uAE30\uACC4\uAC00
      \uC544\uB2C8\uB2C8 \uCF54\uD2B8 \uC804\uCCB4\uC758 \uD750\uB984\uC744 \uC77D\uB294
      \uB370 \uC368\uB77C."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Planner_101
    ko: "\uC624\uCC28 \uBC94\uC704\uB97C \uD3EC\uD568\uD55C \uC0C8\uB85C\uC6B4 \uD655\uB960
      \uBAA8\uB378\uC744 \uAD6C\uCD95\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uB0B4\uC77C\uBD80\uD130\uB294
      \uB354 \uC720\uC5F0\uD55C \uC124\uACC4\uB97C \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Planner_1
    ko: "\uAC00\uC774\uB4DC\uB77C\uC778\uC744 \uC218\uC6A9\uD574 \uC124\uACC4 \uBC94\uC704\uB97C
      \uD655\uC7A5\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Opportunist_101
    ko: "\uC2DC\uC57C\uB97C \uB113\uD788\uBA74 \uC81C \uAC1C\uC778 \uB9AC\uBC14\uC6B4\uB4DC
      \uC810\uC720\uC728\uC740 \uB5A8\uC5B4\uC9C8 \uD150\uB370, \uADF8\uAC8C \uC81C
      \uAC00\uCE58 \uC99D\uBA85\uC5D0 \uB3C4\uC6C0\uC774 \uB429\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Opportunist_1
    ko: "\uAC1C\uC778 \uAE30\uB85D\uC5D0 \uC774\uB4DD\uC77C\uC9C0 \uBAB0\uB77C \uBBF8\uC628\uC801\uC73C\uB85C
      \uBC18\uC751\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Cunning_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uC81C \uC2A4\uD0C0\uC77C\uC744 \uC798
      \uC544\uC2DC\uB124\uC694. \uADF8\uB7FC \uB0B4\uC77C\uC740 \uC880 \uB354 '\uC5EC\uC720
      \uC788\uAC8C' \uCF54\uD2B8\uB97C \uD6D1\uC5B4\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Cunning_1
    ko: "\uAC89\uC73C\uB85C\uB9CC \uD558\uB294 \uCC99\uD558\uBA70 \uD798\uB4E0 \uD6C8\uB828\uC744
      \uD53C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Believer_101
    ko: "\uC81C \uC815\uAD50\uD568\uC744 \uC778\uC815\uD574\uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4.
      \uC644\uBCBD\uD55C \uC0C1\uC218\uAC00 \uB420 \uB54C\uAE4C\uC9C0 \uC774 \uB8E8\uD2F4\uC744
      \uBA48\uCD94\uC9C0 \uC54A\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Believer_1
    ko: "\uBC29\uC2DD\uC774 \uC633\uB2E4\uB294 \uC2E0\uB150\uC774 \uAD73\uC5B4\uC838
      \uACE0\uC9D1\uC744 \uD53C\uC6E0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Ch_Cold_002
    ko: "\uC790\uAE30 \uBAB8\uB3C4 \uAD00\uB9AC \uBABB \uD558\uB294 \uACC4\uC0B0\uAE30\uB294
      \uC4F0\uB808\uAE30\uB2C8 \uBE44\uD6A8\uC728\uC801\uC73C\uB85C \uC2DC\uAC04
      \uBC84\uB9AC\uC9C0 \uB9C8\uB77C."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Planner_201
    ko: "\uC2DC\uC2A4\uD15C\uC758 \uC644\uC131\uB3C4\uB97C \uB192\uC774\uB294 \uACFC\uC815\uC744
      \uC2DC\uAC04 \uB0AD\uBE44\uB85C \uBCF4\uC2DC\uB294\uAD70\uC694. \uAC10\uB3C5\uB2D8\uACFC\uB294
      \uC9C0\uD5A5\uC810\uC774 \uB108\uBB34 \uB2E4\uB985\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Planner_2
    ko: "\uAC10\uB3C5\uC758 \uBD84\uC11D \uB2A5\uB825\uC744 \uBD88\uC2E0\uD558\uBA70
      \uB9C8\uC74C\uC744 \uB2EB\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Opportunist_201
    ko: "\uC81C \uAC00\uCE58\uAC00 \uB0AE\uAC8C \uD3C9\uAC00\uB418\uB294 \uAC74 \uCC38\uC744
      \uC218 \uC5C6\uB124\uC694. \uB0B4\uC77C\uBD80\uD130\uB294 \uC218\uCE58\uBCF4\uB2E4
      \uC555\uB3C4\uC801\uC778 \uACB0\uACFC\uB85C \uC81C \uBAB8\uAC12\uC744 \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Opportunist_2
    ko: "\uC5D0\uC774\uC2A4 \uC790\uB9AC\uB97C \uC9C0\uD0A4\uAE30 \uC704\uD574 \uC989\uAC01
      \uD0DC\uB3C4\uB97C \uACE0\uCCE4\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Cunning_201
    ko: "\uD558\uD558, \uC81C\uAC00 \uB108\uBB34 \uAE4A\uAC8C \uD30C\uACE0\uB4E4\uC5C8\uB098
      \uBCF4\uB124\uC694. \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C \uB0B4\uC77C\uBD80\uD130\uB294
      \uC880 \uB354 \uAC70\uCE60\uAC8C \uAC00\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Cunning_2
    ko: "\uBE44\uC704\uB97C \uB9DE\uCD94\uAE30 \uC704\uD574 \uBCF8\uB2A5\uC801\uC778
      \uCC99 \uC5F0\uAE30\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Believer_201
    ko: "\uAC10\uC815\uC801\uC778 \uC9C8\uCC45\uC740 \uC81C \uC2DC\uC2A4\uD15C\uC744
      \uBCF4\uC815\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uB18D\uAD6C\uB294 \uACB0\uAD6D
      \uC218\uCE58\uC640 \uD655\uB960\uC758 \uC2F8\uC6C0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Believer_2
    ko: "\uBB34\uC2DC\uD558\uACE0 \uC790\uC2E0\uC758 \uB17C\uB9AC\uC801 \uC2E0\uB150\uC744
      \uAD7D\uD788\uC9C0 \uC54A\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Ch_Cold_003
    ko: "\uD0DC\uBE14\uB9BF\uC744 \uB044\uACE0 \uACF5\uC744 \uB358\uC838 \uC120\uC218\uAC00
      \uBB34\uC758\uC2DD\uC801\uC73C\uB85C \uACF5\uC744 \uB09A\uC544\uCC44\uAC8C
      \uB9CC\uB4E0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Planner_301
    ko: "\uBC29\uAE08 \uD589\uB3D9\uC73C\uB85C \uC624\uB298 \uB204\uC801\uB41C \uB370\uC774\uD130\uC758
      15%\uAC00 \uB0A0\uC544\uAC14\uC2B5\uB2C8\uB2E4. \uC774 \uC190\uC2E4\uC744 \uBA54\uC6B8
      \uB300\uC548\uC774 \uC788\uC73C\uC2E0 \uAC81\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Planner_3
    ko: "\uB370\uC774\uD130 \uC190\uC2E4\uC5D0 \uB300\uD574 \uB17C\uB9AC\uC801 \uAC70\uBD80\uAC10\uC744
      \uB290\uAF08\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Opportunist_301
    ko: "\uC81C \uBD84\uC11D \uB3C4\uAD6C\uB97C \uC874\uC911\uD558\uC9C0 \uC54A\uB294
      \uACF3\uC5D0\uC11C \uC81C \uC7AC\uB2A5\uC744 \uB0AD\uBE44\uD560 \uC774\uC720\uB294
      \uC5C6\uC2B5\uB2C8\uB2E4. \uC774\uB9CC \uAC00\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Opportunist_3
    ko: "\uD22C\uC790 \uAC00\uCE58 \uD558\uB77D\uC73C\uB85C \uBCF4\uACE0 \uD300\uC5D0
      \uC815\uC744 \uB5D0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Cunning_301
    ko: "\uC640, \uAC10\uB3C5\uB2D8 \uC29B \uD3FC \uC5EC\uC804\uD558\uC2DC\uB124\uC694!
      \uAE30\uACC4 \uB044\uB294 \uBC29\uC2DD\uB3C4 \uC544\uC8FC \uD30C\uACA9\uC801\uC774\uC2DC\uACE0\uC694.
      \uC7AC\uBC0C\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Cunning_3
    ko: "\uB18D\uB2F4\uCC98\uB7FC \uB118\uAE30\uBA70 \uD68C\uD53C\uD574 \uC9C4\uC9C0\uD55C
      \uBCC0\uD654\uAC00 \uC5C6\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Believer_301
    ko: "\uAEBC\uC9C4 \uD654\uBA74\uBCF4\uB2E4 \uB0A0\uC544\uC624\uB294 \uACF5\uC774
      \uB354 \uD655\uC2E4\uD55C \uC9C0\uD45C\uAD70\uC694. \uC81C \uC2E0\uB150\uC758
      \uC911\uC2EC\uC744 \uB370\uC774\uD130\uC5D0\uC11C \uD604\uC7A5\uC73C\uB85C
      \uC62E\uAE30\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Believer_3
    ko: "\uD604\uC7A5\uC131\uC774 \uCD5C\uACE0\uC758 \uB17C\uB9AC\uC784\uC744 \uAE68\uB2EC\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Instinct_001
    ko: "\uD6C8\uB828\uC774 \uB05D\uB09C \uBE48 \uCF54\uD2B8, \uC5D0\uC774\uC2A4
      \uC13C\uD130\uC778 \uC774 \uC120\uC218\uB294 \uB053\uC5B4\uC624\uB974\uB294
      \uD608\uAE30\uB97C \uC8FC\uCCB4\uD558\uC9C0 \uBABB\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Instinct_002
    ko: "\uB9AC\uBC14\uC6B4\uB4DC \uC5F0\uC2B5\uC744 \uD55C\uB2F5\uC2DC\uACE0 \uACE8\uB300
      \uBC11\uC5D0\uC11C \uAC70\uCE60\uAC8C \uACF5\uC744 \uB09A\uC544\uCC44\uB294\uB370,
      \uADF8 \uAE30\uC138\uAC00 \uB108\uBB34 \uACFC\uD574 \uACE8\uB300 \uC9C0\uC9C0\uB300\uB97C
      \uBC1C\uB85C \uCC28\uAC70\uB098 \uACF5\uC744 \uBC14\uB2E5\uC5D0 \uD130\uC9C8
      \uB4EF\uC774 \uB0B4\uB3D9\uB315\uC774\uCE69\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Instinct_003
    ko: "\uC606\uC5D0 \uC138\uC6CC\uB454 \uD6C8\uB828\uC6A9 \uB9C8\uB124\uD0B9\uC740
      \uC774\uBBF8 \uADF8\uC758 \uAC70\uCE5C \uBAB8\uC2F8\uC6C0\uC5D0 \uBC15\uC0B4
      \uB098 \uB4B9\uAD74\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Instinct_004
    ko: "\uADF8\uB294 \uC790\uC2E0\uC758 \uD798\uC744 \uC5B4\uB514\uC5D0, \uC5B4\uB5BB\uAC8C
      \uC3DF\uC544\uC57C \uD560\uC9C0 \uBAB0\uB77C \uC9D0\uC2B9\uCC98\uB7FC \uC529\uC529\uAC70\uB9AC\uBA70
      \uC2A4\uC2A4\uB85C\uC758 \uC57C\uC131\uC5D0 \uC7A1\uC544\uBA39\uD788\uACE0
      \uC788\uB294 \uBAA8\uC2B5\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Instinct_005
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00024_Ch_Instinct_001
    ko: "\uAE30\uC138\uB294 \uC88B\uC73C\uB098 \uC9C4\uC9DC \uD3EC\uC2DD\uC790\uB294
      \uC0AC\uB0E5 \uC9C1\uC804\uAE4C\uC9C0 \uC228\uC744 \uC8FD\uC77C \uC904 \uC54C\uC544\uC57C
      \uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uC81C \uC704\uC555\uAC10\uC744 \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694.
      \uC88B\uC2B5\uB2C8\uB2E4, \uB0B4\uC77C\uC740 \uC880 \uB354 \uC138\uB828\uB41C
      \uC0AC\uB0E5\uC774 \uBB54\uC9C0 \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Bluffer_1
    ko: "\uD488\uACA9\uC744 \uC9C0\uD0A4\uAE30 \uC704\uD574 \uC6B0\uC544\uD558\uAC8C
      \uD798\uC744 \uC870\uC808\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Wild_101
    ko: "\uC228\uC744 \uC8FD\uC774\uB77C\uB2C8\uC694... \uC804 \uADF8\uB0E5 \uB4E4\uC774\uBC1B\uB294
      \uAC8C \uCCB4\uC9C8\uC785\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8 \uBC29\uC2DD\uC740
      \uC800\uB791 \uC548 \uB9DE\uB294 \uAC83 \uAC19\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Wild_1
    ko: "\uC57C\uC131\uC744 \uC57D\uD558\uAC8C \uB9CC\uB4E0\uB2E4\uBA70 \uAC10\uB3C5\uC744
      \uC800\uD3C9\uAC00\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Egoist_101
    ko: "\uC81C \uD798\uC744 \uC9D1\uC911\uD558\uBA74 \uB9AC\uBC14\uC6B4\uB4DC 20\uAC1C\uB294
      \uCC0D\uACA0\uB124\uC694. \uADF8\uB7FC \uB0B4\uC77C\uC740 \uC81C \uAC1C\uC778
      \uAE30\uB85D \uACBD\uC2E0\uD558\uB294 \uB0A0\uB85C \uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Egoist_1
    ko: "\uD300\uBCF4\uB2E4 \uC790\uC2E0\uC758 \uAE30\uB85D\uC774 \uB3CB\uBCF4\uC77C
      \uC9C0\uC810\uB9CC \uC0DD\uAC01\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Fighter_101
    ko: "\uC88B\uC740 \uB9D0\uC740 \uC720\uCE58\uC6D0\uC0DD\uD55C\uD14C\uB098 \uD574\uC8FC\uC2DC\uC8E0.
      \uC804 \uC9C0\uAE08 \uB2F9\uC7A5 \uB204\uAD6C\uB77C\uB3C4 \uB4E4\uC774\uBC1B\uACE0
      \uC2F6\uC740 \uAE30\uBD84\uC774\uB2C8\uAE4C\uC694."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Fighter_1
    ko: "\uB354 \uC790\uADF9\uC801\uC774\uACE0 \uAC70\uCE5C \uD53C\uB4DC\uBC31\uC744
      \uC6D0\uD558\uBA70 \uC9C0\uB8E8\uD574\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Ch_Instinct_002
    ko: "\uC81C \uBD84\uD480\uC774\uB3C4 \uD1B5\uC81C \uBABB \uD574 \uBD84\uC704\uAE30
      \uB9DD\uCE58\uB294 \uC9D0\uC2B9\uC740 \uC11C\uCEE4\uC2A4\uC7A5\uC5D0\uB098
      \uC5B4\uC6B8\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Bluffer_201
    ko: "\uB9D0\uC500\uC774 \uC880 \uC9C0\uB098\uCE58\uC2DC\uB124\uC694! \uC81C\uAC00
      \uADF8\uB0E5 \uC758\uC695\uC774 \uC880 \uB118\uCCD0\uC11C \uADF8\uB7F0 \uAC70\uC9C0,
      \uC11C\uCEE4\uC2A4\uB77C\uB2C8\uC694. \uCC38 \uB098."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Bluffer_2
    ko: "\uC790\uC874\uC2EC\uC774 \uC0C1\uD588\uC9C0\uB9CC \uC5C6\uC5B4 \uBCF4\uC77C\uAE4C
      \uBD10 \uD654\uB97C \uCC38\uC558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Wild_201
    ko: "\uC9D0\uC2B9 \uC18C\uB9AC \uC548 \uB4E3\uAC8C \uD574\uB4DC\uB9AC\uC8E0.
      \uB0B4\uC77C \uCF54\uD2B8 \uC704\uC5D0\uC11C \uC81C \uC57C\uC131\uC774 \uC5B4\uB5BB\uAC8C
      \uC810\uC218\uB85C \uBC14\uB00C\uB294\uC9C0 \uB611\uB611\uD788 \uBCF4\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Wild_2
    ko: "\uBA85\uD655\uD55C \uD0C0\uAC9F\uC744 \uCC3E\uC544 \uD22C\uC9C0\uB97C \uC2E4\uC804\uC73C\uB85C
      \uB3CC\uB838\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Egoist_201
    ko: "\uB098\uBCF4\uACE0 \uB098\uAC00\uB77C\uACE0? \uC88B\uC2B5\uB2C8\uB2E4. \uB098
      \uC5C6\uC774 \uACE8\uBC11\uC774 \uC5B4\uB5BB\uAC8C \uBC15\uC0B4 \uB098\uB294\uC9C0
      \uAD6C\uACBD\uC774\uB098 \uD558\uC2DC\uC8E0. \uC804 \uAC11\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Egoist_2
    ko: "\uAE30\uBD84\uC774 \uC6B0\uC120\uC774\uB77C \uD6C8\uB828\uC744 \uAC70\uBD80\uD558\uACE0
      \uC774\uD0C8\uD558\uB824 \uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Fighter_201
    ko: "\uC11C\uCEE4\uC2A4? \uADF8\uB7FC \uB2F9\uC2E0\uC774 \uC870\uB828\uC0AC\uB77C\uB3C4
      \uB418\uB294 \uC904 \uC54C\uC544? \uC5B4\uB514 \uD55C\uBC88 \uB098\uB97C \uAE38\uB4E4\uC5EC\uBCF4\uC2DC\uC9C0,
      \uB2F9\uC7A5!"
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Fighter_2
    ko: "\uAC10\uB3C5\uC744 \uC2F8\uC6CC\uC57C \uD560 \uB300\uC0C1\uC73C\uB85C \uC815\uD558\uACE0
      \uB300\uB9BD\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Ch_Instinct_003
    ko: "\uACF5\uC744 \uBC1F\uC544 \uC138\uC6B4 \uB4A4 \uC120\uC218\uC758 \uB208\uC744
      \uB178\uB824\uBCF4\uBA70 \uAC00\uC2B4\uD30D\uC744 \uC190\uAC00\uB77D\uC73C\uB85C
      \uD22D\uD22D \uCE5C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Bluffer_301
    ko: "\uC9C0\uAE08 \uC81C \uBAB8\uC5D0 \uC190\uB300\uC2E0 \uAC81\uB2C8\uAE4C?
      \uC544\uBB34\uB9AC \uAC10\uB3C5\uB2D8\uC774\uB77C\uB3C4 \uC774\uB7F0 \uC2DD\uC758
      \uBB34\uB840\uD568\uC740 \uC800\uB3C4 \uC548 \uCC38\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Bluffer_3
    ko: "\uC0AC\uB78C\uB4E4 \uC55E\uC5D0\uC11C \uB9DD\uC2E0\uC744 \uC92C\uB2E4\uACE0
      \uC0DD\uAC01\uD574 \uC6D0\uD55C\uC744 \uD488\uC5C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Wild_301
    ko: "\uB208\uBE5B \uC88B\uC73C\uC2DC\uB124\uC694. \uC54C\uACA0\uC2B5\uB2C8\uB2E4.
      \uC624\uB298 \uACF5\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB9CC \uCC28\uC8E0. \uB300\uC2E0
      \uB0B4\uC77C\uC740 \uB9D0\uB9AC\uC9C0 \uB9C8\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Wild_3
    ko: "\uC704\uCD95\uB410\uC9C0\uB9CC \uC9C0\uC9C0 \uC54A\uC73C\uB824\uB294 \uBCF8\uB2A5\uC5D0
      \uD33D\uD33D\uD788 \uB300\uCE58\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Egoist_301
    ko: "\uC774 \uAC00\uC2B4 \uC18D\uC5D0 \uC788\uB294 \uAC78 \uB044\uC9D1\uC5B4\uB0B4\uB77C\uB294
      \uAC70\uC8E0? \uC7AC\uBBF8\uC788\uACA0\uB124\uC694. \uB0B4\uC77C\uBD80\uD130
      \uC81C \uC601\uC5ED\uC740 \uAC74\uB4DC\uB9AC\uC9C0 \uB9C8\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00024_Rs_Egoist_3
    ko: "\uAC10\uB3C5\uC758 \uAC15\uD568\uC5D0 \uB9E4\uB8CC\uB418\uC5B4 \uC131\uACFC
      \uC695\uAD6C\uAC00 \uD3ED\uBC1C\uD588\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00024_Desc_Fighter_301
    ko: "\uC88B\uC544, \uADF8 \uB208\uBE5B \uB9D8\uC5D0 \uB4DC\uB124\uC694. \uB0B4\uC77C
      \uC81C\uAC00 \uC0C1\uB300\uBC29 \uB2E4 \uCC22\uC5B4\uB193\uC744 \uB54C \uBCA4\uCE58\uC5D0\uC11C
      \uAD6C\uACBD\uC774\uB098 \uC798 \uD558\uC138\uC694."
    en: 
