    ja: 
  - stringKey: Event_00005_Desc_Believer_301
    ko: "\uAC10\uB3C5\uC758 \uCE68\uBB35\uC774 \uBB34\uAC70\uC6CC \uB208\uCE58\uB97C
      \uBCF4\uBA70 \uD3C9\uC18C \uD398\uC774\uC2A4\uB300\uB85C \uD6C8\uB828\uD568"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Believer_3
    ko: "\uBD84\uC704\uAE30\uBA54\uC774\uCEE4\uB2F5\uAC8C \uCE68\uBB35\uC744 \uAE68\uC9C0
      \uC54A\uC73C\uB824 \uC870\uC6A9\uD788 \uD6C8\uB828 \uC720\uC9C0"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Instinct_001
    ko: "\uC120\uC218\uAC00 3\uC810 \uB77C\uC778 \uB4A4\uC5D0\uC11C \uBB35\uBB35\uD788
      \uC29B\uC744 \uB358\uC9C0\uB294 \uB8E8\uD2F4 \uD6C8\uB828 \uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Instinct_002
    ko: "\uC774\uBBF8 90\uAC1C\uC9F8\uC5D0 \uC811\uC5B4\uB4E4\uC5B4 \uB2E4\uB9AC\uB294
      \uD6C4\uB4E4\uAC70\uB9AC\uACE0 \uC29B \uD3FC\uC740 \uB208\uC5D0 \uB744\uAC8C
      \uD750\uD2B8\uB7EC\uC84C\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Instinct_003
    ko: "\uD558\uC9C0\uB9CC \uC120\uC218\uB294 100\uAC1C\uB77C\uB294 \uC790\uC2E0\uACFC\uC758
      \uC57D\uC18D\uC744 \uC9C0\uD0A4\uAE30 \uC704\uD574, \uC228\uC744 \uBAB0\uC544\uC26C\uBA70
      \uB2E4\uC2DC \uAD74\uB7EC\uC628 \uACF5\uC744 \uC90D\uAE30 \uC704\uD574 \uBAB8\uC744
      \uB358\uC9D1\uB2C8\uB2E4"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Instinct_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Instinct_001
    ko: "\uB124 \uC548\uC758 \uAC70\uCE5C \uC9D0\uC2B9\uC744 \uAE68\uC6CC\uB77C.
      \uD0C0\uC778\uC758 \uC2DC\uC120\uC740 \uC78A\uACE0, \uB124\uAC00 \uB290\uB07C\uB294
      \uADF8 \uCDA9\uB3D9\uB300\uB85C \uCF54\uD2B8\uB97C \uC9C0\uBC30\uD574. \uADF8\uAC8C
      \uBC14\uB85C \uB108\uB2E4\uC6B4 \uB18D\uAD6C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Bluffer_101
    ko: "\uC2DC\uB828\uC740 \uC8FC\uC778\uACF5\uC744 \uB354 \uBE5B\uB098\uAC8C \uD558\uC9C0!
      \uB0B4 \uD22C\uD63C\uC774 \uB9BC\uC5D0 \uAF42\uD788\uB294 \uC21C\uAC04\uC744
      \uB611\uB611\uD788 \uBD10\uB450\uB77C\uACE0!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Bluffer_1
    ko: "\uCE6D\uCC2C\uC744 \uC790\uAE30 \uC11C\uC0AC\uC758 \uC815\uC810\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC784"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Wild_101
    ko: "\uB9D0\uC5C6\uC774 \uAC70\uCE5C \uC228\uC744 \uB0B4\uBC49\uC73C\uBA70 \uAC10\uAC01\uC5D0\uB9CC
      \uC9D1\uC911"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Wild_1
    ko: "\uC678\uBD80 \uC5B8\uC5B4\uBCF4\uB2E4 \uC2E0\uCCB4\uC801 \uB9AC\uB4EC\uC744
      \uC6B0\uC120\uC21C\uC704\uC5D0 \uB460"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Egoist_101
    ko: "\uACA9\uB824\uB294 \uB410\uACE0... \uB0B4 \uD398\uC774\uC2A4\uB300\uB85C
      \uB358\uC9C0\uAC8C \uD574\uC918. \uC774\uAC74 \uB0B4 \uBC29\uC2DD\uB300\uB85C
      \uC644\uC131\uD574\uC57C \uD558\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Egoist_1
    ko: "\uD0C0\uC778\uC758 \uD3C9\uAC00\uBCF4\uB2E4 \uB098\uC758 \uB3C5\uB9BD\uC801
      \uC644\uC131 \uC911\uC2DC"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Fighter_101
    ko: "\uC9D0\uC2B9\uC744 \uAE68\uC6B0\uB77C\uACE0\uC694? \uB9C8\uCE68 \uC798\uB410\uC2B5\uB2C8\uB2E4.
      \uB2E4\uB9AC\uAC00 \uBD80\uB7EC\uC838\uB3C4 \uC800 \uB9BC\uC744 \uBC15\uC0B4
      \uB0B4\uACE0 \uC4F0\uB7EC\uC9C0\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Fighter_1
    ko: "\uACA9\uB824\uB97C \uD22C\uC7C1\uC744 \uC704\uD55C \uC804\uD22C \uBA85\uB839\uC73C\uB85C
      \uC2B9\uD654"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Instinct_002
    ko: "\uADDC\uCE59\uB3C4, \uCCB4\uACC4\uB3C4 \uC5C6\uC774 \uAC10\uAC01\uB9CC \uBBFF\uACE0
      \uB0A0\uB6F0\uB294 \uAC74 \uC57C\uC218\uC77C \uBFD0\uC774\uB2E4. \uADF8\uB807\uAC8C
      \uC81C\uBA4B\uB300\uB85C \uAD74 \uAC70\uBA74 \uD300\uC5D0\uC11C \uB098\uAC00.
      \uB10C \uC9C0\uAE08 \uB18D\uAD6C\uB97C \uD558\uB294 \uAC8C \uC544\uB2C8\uB77C
      \uD749\uB0B4\uB9CC \uB0B4\uACE0 \uC788\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Bluffer_201
    ko: "\uD3FC\uC774 \uBB34\uB108\uC838? \uB0B4 \uC57C\uC131\uC774 \uB9BC\uC744
      \uCC22\uACE0 \uC788\uB294 \uAC74\uB370 \uAC10\uD788 \uB0B4 \uB18D\uAD6C\uC5D0
      \uD1A0\uB97C \uB2EC\uC544?"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Bluffer_2
    ko: "\uC790\uC874\uC2EC\uC744 \uAC74\uB4DC\uB824 \uAC10\uB3C5\uACFC \uC815\uBA74
      \uB300\uB9BD\uD568"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Wild_201
    ko: "\uC18C\uB9AC \uC9C0\uB974\uC9C0 \uB9C8! \uB9AC\uB4EC \uB04A\uAE30\uC796\uC544.
      \uB0B4 \uC57C\uC0DD\uC758 \uAC10\uAC01\uC744 \uBC29\uD574\uD558\uC9C0 \uB9D0\uB77C\uACE0!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Wild_2
    ko: "\uAC04\uC12D\uC744 \uBCF8\uB2A5\uC801\uC778 \uB178\uC774\uC988\uB85C \uC778\uC2DD\uD568"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Egoist_201
    ko: "\uAC10\uB3C5\uC758 \uC9C0\uC801\uC744 \uD758\uB824\uB4E3\uACE0 \uC790\uC2E0\uC758
      \uC29B \uADA4\uC801\uC5D0\uB9CC \uBAB0\uC785\uD568"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Egoist_2
    ko: "\uC678\uBD80 \uD3C9\uAC00\uB294 \uB098\uC758 \uC131\uC7A5\uC5D0 \uC911\uC694\uD558\uC9C0
      \uC54A\uC74C"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Fighter_201
    ko: "\uC785\uC220\uC744 \uD53C\uAC00 \uB098\uAC8C \uAE68\uBB3C\uBA70 \uB9D0\uC5C6\uC774
      \uACF5\uC744 \uC90D\uB294\uB2E4"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Fighter_2
    ko: "\uC9C8\uCC45\uC744 \uBC84\uD2F0\uBA70 \uC2A4\uC2A4\uB85C\uB97C \uADF9\uD55C\uC73C\uB85C
      \uBAB0\uC544\uBD99\uC784"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Instinct_003
    ko: "\uAC10\uB3C5\uC740 \uCF54\uD2B8 \uADFC\uCC98\uC5D0\uB3C4 \uC624\uC9C0 \uC54A\uB294\uB2E4.
      \uC29B\uC774 \uBE57\uB098\uAC08 \uB54C\uB9C8\uB2E4 \uC120\uC218\uAC00 \uB0B4\uBC49\uB294
      \uAC70\uCE5C \uC228\uC18C\uB9AC\uC640 \uBC14\uB2E5\uC744 \uBC15\uCC28\uB294
      \uC18C\uB9AC\uC5D0\uB9CC \uADC0\uB97C \uAE30\uC6B8\uC774\uBA70 \uC9C0\uCF1C\uBCF8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Bluffer_301
    ko: "\uC228\uC774 \uCC28\uB3C4 \uCD5C\uACE0\uC758 \uC29B \uD3FC\uC744 \uC720\uC9C0\uD558\uBA70
      \uB354 \uD654\uB824\uD55C \uB3D9\uC791 \uAD6C\uC0AC"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Bluffer_3
    ko: "\uAD00\uC911\uC774 \uC5C6\uC5B4\uB3C4 \uC2A4\uC2A4\uB85C\uB97C \uC8FC\uC778\uACF5\uC73C\uB85C
      \uC778\uC2DD\uD568"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Wild_301
    ko: "\uB4DC\uB514\uC5B4 \uC815\uC801\uBFD0\uC774\uB2E4... \uB9BC\uC774 \uB0B4
      \uBAB8\uC758 \uC77C\uBD80\uCC98\uB7FC \uB290\uAEF4\uC838. \uC644\uBCBD\uD55C
      \uBAB0\uC785\uC774\uC57C."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Wild_3
    ko: "\uAC04\uC12D \uC5C6\uB294 \uD658\uACBD\uC744 \uBCF8\uB2A5\uC801 \uCD5C\uC0C1
      \uC0C1\uD0DC\uB85C \uC778\uC2DD"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Egoist_301
    ko: "\uAC04\uC12D\uC774 \uC5C6\uC73C\uB2C8 \uBE44\uB85C\uC18C \uC644\uBCBD\uD574.
      \uC774 \uACE0\uC694\uD568 \uC18D\uC5D0\uC11C \uB0B4 \uB18D\uAD6C\uAC00 \uC644\uC131\uB418\uACE0
      \uC788\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Egoist_3
    ko: "\uC790\uAE30 \uC644\uC131\uC744 \uC704\uD55C \uCD5C\uC801\uC758 \uC0C1\uD0DC\uB85C
      \uD574\uC11D"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Fighter_301
    ko: "\uC774 \uACE0\uB3C5\uD55C \uBC29\uCE58\uB294 \uC9C0\uACB9\uB2E4. \uB2F9\uC7A5
      \uBD99\uC744 \uC0C1\uB300\uAC00 \uD544\uC694\uD558\uB2E4\uACE0!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Fighter_3
    ko: "\uC815\uC801\uC778 \uC0C1\uD669\uC5D0 \uB300\uD55C \uADFC\uBCF8\uC801\uC778
      \uAC08\uC99D \uBC1C\uC0DD"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Discipline_001
    ko: "\uC120\uC218\uB294 \uC790\uC2E0\uC758 \uC288\uD305 \uB370\uC774\uD130\uB97C
      \uC218\uCC9C \uBC88 \uBD84\uC11D\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Discipline_002
    ko: "\uADF8\uB294 \uB9BC\uC744 \uC678\uBA74\uD558\uB294 3\uC810\uC29B\uC758 \uC6D0\uC778\uC774
      '\uD314\uAFC8\uCE58 \uAC01\uB3C4'\uC640 '\uB9B4\uB9AC\uC2A4 \uD0C0\uC774\uBC0D'\uC758
      \uBBF8\uC138\uD55C \uBD88\uC77C\uCE58 \uB54C\uBB38\uC774\uB77C\uB294 \uACB0\uB860\uC744
      \uB0B4\uB9AC\uACE0,"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Discipline_003
    ko: "\uAC10\uB3C5\uC5D0\uAC8C \uD3FC \uC218\uC815\uC744 \uC704\uD55C \uBD84\uC11D
      \uC790\uB8CC\uB97C \uC81C\uC2DC\uD558\uBA70 \uC870\uC5B8\uC744 \uAD6C\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Discipline_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Discipline_001
    ko: "\uAE30\uBCF8\uAE30\uC640 \uB124 \uBD84\uC11D\uC744 \uC870\uD654\uB86D\uAC8C
      \uC11E\uC5B4\uBCF8\uB2E4\uBA74 \uB10C \uBD84\uBA85 \uD300\uC758 \uD6CC\uB96D\uD55C
      \uBB34\uAE30\uAC00 \uB420 \uAC70\uC57C. \uD568\uAED8 \uB354 \uC88B\uC740 \uBC29\uBC95\uC744
      \uCC3E\uC544\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Principled_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uBC30\uB824\uC5D0 \uAC10\uC0AC\uB4DC\uB9BD\uB2C8\uB2E4.
      \uADDC\uC728 \uC548\uC5D0\uC11C \uC81C \uC6D0\uCE59\uC744 \uCD5C\uC801\uD654\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Principled_1
    ko: "\uC790\uC2E0\uC758 \uC6D0\uCE59\uC744 \uD300\uC758 \uADDC\uC728\uACFC \uC131\uACF5\uC801\uC73C\uB85C
      \uACB0\uD569\uD558\uC5EC \uC288\uD305\uC758 \uC644\uC131\uB3C4\uB97C \uB192\uC784"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Guardian_101
    ko: "\uD300\uC758 \uADDC\uC728\uC744 \uC9C0\uD0A4\uBA70 \uC81C \uC29B \uD3FC\uC744
      \uBCF4\uC644\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Guardian_1
    ko: "\uACA9\uB824\uB97C \uBC1B\uC558\uC9C0\uB9CC \uD300 \uC804\uCCB4\uC758 \uC288\uD305
      \uBC38\uB7F0\uC2A4\uB97C \uBA3C\uC800 \uC0DD\uAC01\uD558\uB290\uB77C \uAE30\uC874
      \uD3FC \uACE0\uC218"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Tactician_101
    ko: "\uB370\uC774\uD130\uC0C1 \uCD5C\uC120\uC774\uC5C8\uC73C\uB098, \uC804\uC220\uC801
      \uC870\uD654\uB97C \uC704\uD574 \uAE30\uBCF8 \uD2C0\uC744 \uB530\uB974\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Tactician_1
    ko: "\uC804\uC220\uC801 \uD6A8\uC728\uC744 \uC6B0\uC120\uC2DC\uD558\uB290\uB77C
      \uB370\uC774\uD130\uB97C \uD3FC\uC5D0 \uBC18\uC601\uD558\uC9C0 \uBABB\uD558\uACE0
      \uC8FC\uC800\uD568"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Exemplary_101
    ko: "\uD300\uC758 \uAE30\uC900\uC774 \uB418\uB294 \uADDC\uC728\uC744 \uC900\uC218\uD558\uBA70
      \uC815\uAD50\uD568\uC744 \uB354\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Exemplary_1
    ko: "\uC790\uC2E0\uC758 \uD3FC \uC218\uC815\uC744 \uBAA8\uBC94\uC801\uC778 \uC218\uC900
      \uB0B4\uC5D0\uC11C \uC870\uC808\uD558\uBA70 \uD3C9\uC815\uC2EC \uC720\uC9C0"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Discipline_002
    ko: "\uD300\uC740 \uB370\uC774\uD130 \uC5F0\uAD6C\uC2E4\uC774 \uC544\uB2C8\uB2E4.
      \uADDC\uC728 \uC5C6\uB294 \uC989\uD765\uC801\uC778 \uD3FC \uBCC0\uACBD\uC740
      \uD300 \uC804\uCCB4\uC758 \uC29B \uBC38\uB7F0\uC2A4\uB97C \uBB34\uB108\uB728\uB9B4
      \uBFD0\uC774\uC57C. \uAE30\uBCF8\uAE30\uBD80\uD130 \uB2E4\uC2DC \uB2E4\uC838\uB77C."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Principled_201
    ko: "\uC81C \uBD84\uC11D\uC774 \uADDC\uC728\uBCF4\uB2E4 \uC55E\uC130\uC74C\uC744
      \uAE68\uB2EC\uC558\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Principled_2
    ko: "\uC9C8\uCC45\uC744 \uD1B5\uD574 \uB370\uC774\uD130 \uBD84\uC11D\uC758 \uD55C\uACC4\uB97C
      \uC778\uC815\uD558\uACE0 \uAE30\uBCF8\uAE30\uB85C \uD68C\uADC0\uD558\uC5EC
      \uC815\uCCB4"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Guardian_201
    ko: "\uD300\uC758 \uC29B \uBC38\uB7F0\uC2A4\uB97C \uD574\uCCD0 \uC8C4\uC1A1\uD569\uB2C8\uB2E4.
      \uAE30\uBCF8\uC73C\uB85C \uB3CC\uC544\uAC00\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Guardian_2
    ko: "\uD300\uC758 \uBC38\uB7F0\uC2A4\uB97C \uD574\uCCE4\uB2E4\uB294 \uC790\uCC45\uAC10\uC774
      \uB9B4\uB9AC\uC2A4 \uBC38\uB7F0\uC2A4\uB97C \uBB34\uB108\uB728\uB9BC"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Tactician_201
    ko: "\uC9C0\uC801\uD558\uC2E0 \uD6A8\uC728\uC758 \uBB38\uC81C\uB97C \uB2E4\uC2DC
      \uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uB17C\uB9AC\uC801\uC778 \uC804\uC220 \uD53C\uB4DC\uBC31\uC73C\uB85C
      \uC218\uC6A9\uD558\uC5EC \uC288\uD305 \uD6A8\uC728 \uADF9\uB300\uD654"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Exemplary_201
    ko: "\uBAA8\uBC94\uC774 \uB418\uC5B4\uC57C \uD560 \uC81C\uAC00 \uD3FC \uC218\uC815\uC5D0\uB9CC
      \uB9E4\uBAB0\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Exemplary_2
    ko: "\uADDC\uC728\uC744 \uC5B4\uACBC\uB2E4\uB294 \uC8C4\uCC45\uAC10\uC774 \uC120\uC218\uC758
      \uC790\uC874\uAC10\uC744 \uAEBE\uC5B4 \uC288\uD305 \uC2AC\uB7FC\uD504 \uC720\uBC1C"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Discipline_003
    ko: "\uAC10\uB3C5\uC740 \uC120\uC218\uAC00 \uB0B4\uBBFC \uB370\uC774\uD130\uB97C
      \uD790\uB057 \uBCF4\uB354\uB2C8, \uC544\uBB34\uB7F0 \uB9D0 \uC5C6\uC774 \uCCB4\uC721\uAD00
      \uC678\uACFD\uC758 \uB0A1\uC740 \uC288\uD305 \uBA38\uC2E0\uC73C\uB85C \uC190\uC9D3\uD558\uACE0\uB294
      \uBCA4\uCE58\uB85C \uAC78\uC5B4\uAC00 \uD314\uC9F1\uC744 \uB080 \uCC44 \uB208\uC744
      \uAC10\uB294\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Principled_301
    ko: "\uCE68\uBB35 \uC18D\uC5D0 \uC81C \uB370\uC774\uD130\uC758 \uC624\uB958\uB97C
      \uCC3E\uC544\uB0B4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Principled_3
    ko: "\uAC10\uB3C5\uC758 \uCE68\uBB35\uC744 \uB370\uC774\uD130 \uBD84\uC11D\uC5D0
      \uB300\uD55C \uC804\uBA74 \uBD80\uC815\uC73C\uB85C \uD574\uC11D\uD558\uC5EC
      \uC758\uC695 \uC800\uD558"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uBB34\uC5B8\uC758 \uAC00\uB974\uCE68\uC744 \uB530\uB77C
      \uB9BC\uC744 \uB178\uB9AC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Guardian_3
    ko: "\uAC10\uB3C5\uC758 \uBC29\uCE58\uB97C \uD300\uC5D0 \uAE30\uC5EC\uD558\uAE30
      \uC704\uD55C \uBB35\uBB35\uD55C \uB178\uB825\uC758 \uAE30\uD68C\uB85C \uC0BC\uC544
      \uC2A4\uD0EF \uD5A5\uC0C1"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Tactician_301
    ko: "\uCE68\uBB35 \uC18D\uC5D0\uC11C \uB370\uC774\uD130\uC640 \uD3FC\uC758 \uC624\uCC28\uB97C
      \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Tactician_3
    ko: "\uBC29\uCE58\uB41C \uC0C1\uD669\uC744 \uB370\uC774\uD130\uC640 \uC2E4\uC804
      \uAC04\uC758 \uAD34\uB9AC\uB97C \uC881\uD788\uB294 \uD6C8\uB828 \uACFC\uC815\uC73C\uB85C
      \uC0BC\uC74C"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Exemplary_301
    ko: "\uC9C0\uCF1C\uBCF4\uACE0 \uACC4\uC2EC\uC744 \uC78A\uC9C0 \uC54A\uACE0 \uBB35\uBB35\uD788
      \uD3FC\uC744 \uC644\uC131\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Exemplary_3
    ko: "\uAC10\uB3C5\uC758 \uBC29\uCE58\uB97C \uC2E4\uB825\uC744 \uC2E4\uB825\uC73C\uB85C
      \uC785\uC99D\uD558\uB77C\uB294 \uC2E0\uD638\uB85C \uD574\uC11D\uD558\uC5EC
      \uC2A4\uC2A4\uB85C \uD3FC \uC218\uC815 \uC131\uACF5"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Bond_001
    ko: "\uC120\uC218\uB294 \uC218\uCC9C \uBC88\uC758 \uC288\uD305 \uB370\uC774\uD130\uB97C
      \uBD84\uC11D\uD55C \uB05D\uC5D0"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Bond_002
    ko: "\uC790\uC2E0\uC758 3\uC810\uC29B \uC2E4\uD328 \uC6D0\uC778\uC774 '\uD314\uAFC8\uCE58
      \uAC01\uB3C4'\uC640 '\uB9B4\uB9AC\uC2A4 \uD0C0\uC774\uBC0D'\uC758 \uBBF8\uC138\uD55C
      \uBD88\uC77C\uCE58\uC784\uC744 \uD655\uC2E0\uD558\uACE0 \uBD84\uC11D \uC790\uB8CC\uB97C
      \uAC10\uB3C5\uC5D0\uAC8C \uC81C\uC2DC\uD558\uBA70 \uC870\uC5B8\uC744 \uAD6C\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Bond_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Bond_001
    ko: "\uAE30\uBCF8\uAE30\uC640 \uB124 \uBD84\uC11D\uC744 \uC870\uD654\uB86D\uAC8C
      \uC11E\uC5B4\uBCF8\uB2E4\uBA74 \uB10C \uBD84\uBA85 \uD300\uC758 \uD6CC\uB96D\uD55C
      \uBB34\uAE30\uAC00 \uB420 \uAC70\uC57C. \uD568\uAED8 \uB354 \uC88B\uC740 \uBC29\uBC95\uC744
      \uCC3E\uC544\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uB530\uB73B\uD55C \uACA9\uB824 \uB355\uBD84\uC5D0
      \uB9C8\uC74C\uC774 \uD3B8\uD574\uC84C\uC2B5\uB2C8\uB2E4. \uB3D9\uB8CC\uB4E4\uACFC
      \uD568\uAED8 \uC5F0\uC2B5\uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Kind_1
    ko: "\uAC10\uB3C5\uC758 \uB530\uB73B\uD55C \uD53C\uB4DC\uBC31\uC774 \uC120\uC218\uC758
      \uC2EC\uB9AC\uC801 \uC548\uC815\uAC10\uC744 \uC8FC\uC5B4 \uC288\uD305 \uC2DC
      \uC190\uB05D\uC758 \uAC10\uAC01\uC774 \uC815\uAD50\uD574\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uAE30\uB300\uC5D0 \uBCF4\uB2F5\uD558\uAE30 \uC704\uD574
      \uBD84\uC11D\uD55C \uB0B4\uC6A9\uC744 \uCDA9\uC2E4\uD788 \uC774\uD589\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Loyal_1
    ko: "\uACA9\uB824\uB97C \uBC1B\uC558\uC73C\uB098 \uC6D0\uB798\uC758 \uC2A4\uD0C0\uC77C\uB300\uB85C
      \uBB35\uBB35\uD788 \uCDA9\uC131\uD558\uBA70 \uB8E8\uD2F4\uC744 \uC774\uD589\uD568"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Sincere_101
    ko: "\uACA9\uB824\uD574\uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4\uB9CC,
      \uBD84\uC11D\uD55C \uB8E8\uD2F4\uC744 \uBC84\uB9B4 \uC218 \uC5C6\uC5B4 \uD63C\uB780\uC2A4\uB7FD\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Sincere_1
    ko: "\uAC10\uB3C5\uC758 \uACA9\uB824\uAC00 \uBD84\uC11D\uD55C \uB8E8\uD2F4\uC744
      \uBCC0\uD615\uD558\uB77C\uB294 \uC555\uBC15\uC73C\uB85C \uB290\uAEF4\uC838
      \uD63C\uB780 \uAC00\uC911"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Moodmaker_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8! \uC81C \uBD84\uC11D\uC744 \uC54C\uC544\uC8FC\uC2DC\uB2E4\uB2C8,
      \uB2F9\uC7A5 \uD300\uC6D0\uB4E4\uD55C\uD14C\uB3C4 \uC54C\uB824\uC918\uC57C\uACA0\uC5B4\uC694!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Moodmaker_1
    ko: "\uAC10\uB3C5\uC758 \uC9C0\uC9C0\uC5D0 \uD798\uC785\uC5B4 \uD300\uC6D0\uB4E4
      \uC55E\uC5D0\uC11C \uBC1D\uAC8C \uBD84\uC11D \uC790\uB8CC\uB97C \uACF5\uC720\uD558\uBA70
      \uC5D0\uB108\uC9C0\uB97C \uBC1C\uC0B0"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Bond_002
    ko: "\uB370\uC774\uD130 \uBD84\uC11D\uC5D0\uB9CC \uB108\uBB34 \uBAB0\uB450\uD558\uBA74
      \uB3D9\uB8CC\uB4E4\uACFC\uC758 \uD638\uD761\uC744 \uB193\uCE58\uAE30 \uC27D\uB2E4.
      \uB18D\uAD6C\uB294 \uAC10\uC815\uC744 \uB098\uB204\uB294 \uD300 \uC2A4\uD3EC\uCE20\uC57C.
      \uAE30\uBCF8\uBD80\uD130 \uB2E4\uC2DC \uB2E4\uC838\uB77C."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Kind_201
    ko: "\uBD84\uC11D\uBCF4\uB2E4 \uB3D9\uB8CC\uAC00 \uBA3C\uC800\uB77C\uB2C8...
      \uC81C \uB178\uB825\uC774 \uD300\uC744 \uC704\uD55C \uAC8C \uC544\uB2C8\uC5C8\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Kind_2
    ko: "\uD300\uC744 \uC704\uD55C \uC21C\uC218\uD55C \uB178\uB825\uC774 \uBD80\uC815\uB2F9\uD588\uB2E4\uACE0
      \uB290\uAEF4 \uC0C1\uCC98\uB97C \uBC1B\uACE0 \uC288\uD305 \uC9D1\uC911\uB825
      \uC800\uD558"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Loyal_201
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uB9D0\uC500\uC774 \uB9DE\uC2B5\uB2C8\uB2E4. \uBD84\uC11D
      \uC790\uB8CC\uBCF4\uB2E4 \uD300\uC744 \uD5A5\uD55C \uD5CC\uC2E0\uC744 \uC6B0\uC120\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Loyal_2
    ko: "\uAC10\uB3C5\uC758 \uC9C8\uCC45\uC744 \uD300\uC744 \uC704\uD55C \uD5CC\uC2E0
      \uC694\uAD6C\uB85C \uBC1B\uC544\uB4E4\uC5EC \uD300 \uD50C\uB808\uC774 \uC801\uD569\uB3C4\uAC00
      \uC0C1\uC2B9"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Sincere_201
    ko: "\uC9C8\uCC45\uD558\uC2E0 \uB300\uB85C \uAE30\uBCF8\uAE30\uC5D0 \uC9D1\uC911\uD558\uBA70
      \uAFB8\uC900\uD788 \uB358\uC9C0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Sincere_2
    ko: "\uC790\uC2E0\uC758 \uC131\uC2E4\uD568\uC744 \uB418\uC0C8\uAE30\uBA70 \uC9C0\uC801\uBC1B\uC740
      \uAE30\uBCF8\uAE30\uB97C \uAFB8\uC900\uD788 \uD6C8\uB828\uD558\uB294 \uC0C1\uD0DC"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Moodmaker_201
    ko: "\uBD84\uC704\uAE30\uAC00 \uB108\uBB34 \uBB34\uAC81\uB124\uC694... \uBD84\uC11D\uC774
      \uC7AC\uBBF8\uC5C6\uC5C8\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Moodmaker_2
    ko: "\uC9C8\uCC45\uC73C\uB85C \uC778\uD574 \uBD84\uC704\uAE30\uAC00 \uAC00\uB77C\uC549\uC790
      \uC758\uAE30\uC18C\uCE68\uD574\uC838 \uC288\uD305 \uAC10\uAC01\uAE4C\uC9C0
      \uC800\uD558"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Bond_003
    ko: "\uAC10\uB3C5\uC740 \uC120\uC218\uAC00 \uB0B4\uBBFC \uB370\uC774\uD130\uB97C
      \uD790\uB057 \uBCF4\uB354\uB2C8, \uC544\uBB34\uB7F0 \uB9D0 \uC5C6\uC774 \uCCB4\uC721\uAD00
      \uC678\uACFD\uC758 \uB0A1\uC740 \uC288\uD305 \uBA38\uC2E0\uC73C\uB85C \uC190\uC9D3\uD558\uACE0\uB294
      \uBCA4\uCE58\uB85C \uAC78\uC5B4\uAC00 \uD314\uC9F1\uC744 \uB080 \uCC44 \uB208\uC744
      \uAC10\uB294\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Kind_301
    ko: "\uAC10\uB3C5\uC758 \uBB34\uAD00\uC2EC\uC5D0 \uC11C\uC6B4\uD558\uC9C0\uB9CC
      \uD640\uB85C \uC5F0\uC2B5\uC744 \uC9C0\uC18D\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Kind_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uAD00\uC2EC\uC5D0\uB3C4 \uBD88\uAD6C\uD558\uACE0
      \uC2A4\uC2A4\uB85C\uC758 \uCE5C\uC808\uD568\uC73C\uB85C \uC5F0\uC2B5\uC744
      \uC774\uC5B4\uAC00\uC9C0\uB9CC \uB2A5\uB825\uCE58 \uBCC0\uD654\uB294 \uC5C6\uC74C"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8\uAED8\uC11C \uC800\uB97C \uBC84\uB9AC\uC2E0 \uAC74\uAC00\uC694?
      \uC758\uC695\uC774 \uC0AC\uB77C\uC9D1\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Loyal_3
    ko: "\uC790\uC2E0\uC758 \uCDA9\uC131\uC2EC\uC774 \uBD80\uC815\uB2F9\uD588\uB2E4\uACE0
      \uB290\uAEF4 \uAC10\uB3C5\uC5D0 \uB300\uD55C \uC2E0\uB8B0 \uD558\uB77D \uBC0F
      3\uC810\uC29B \uB9B4\uB9AC\uC2A4 \uBB34\uB108\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Sincere_301
    ko: "\uC544\uBB34 \uB9D0\uC500 \uC5C6\uC73C\uC168\uC9C0\uB9CC, \uBB35\uBB35\uD788
      \uC81C \uC790\uB9AC\uC5D0\uC11C \uBD84\uC11D\uB300\uB85C \uC5F0\uC2B5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Sincere_3
    ko: "\uAC10\uB3C5\uC758 \uBC29\uCE58\uB97C \uBB35\uBB35\uD788 \uC790\uC2E0\uC758
      \uD6C8\uB828\uC744 \uC644\uC131\uD558\uB77C\uB294 \uB73B\uC73C\uB85C \uD574\uC11D\uD558\uC5EC
      3\uC810\uC29B \uC131\uACF5\uB960 \uC0C1\uC2B9"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Moodmaker_301
    ko: "\uCE68\uBB35\uC5D0 \uBD84\uC704\uAE30\uB97C \uB9DE\uCD94\uB290\uB77C, \uC5F0\uC2B5\uC5D0
      \uC9D1\uC911\uD558\uC9C0 \uBABB\uD558\uACE0 \uC29B\uC744 \uB09C\uC0AC\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Moodmaker_3
    ko: "\uAC10\uB3C5\uC758 \uCE68\uBB35\uC744 \uBD84\uC704\uAE30 \uC804\uD658\uC758
      \uC2E0\uD638\uB85C \uC624\uD574\uD558\uC5EC, \uD6C8\uB828\uC5D0 \uBAB0\uC785\uD558\uC9C0
      \uBABB\uD558\uACE0 \uC29B\uC744 \uB09C\uC0AC\uD568"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Cold_001
    ko: "\uC120\uC218\uB294 \uC218\uCC9C \uBC88\uC758 \uC288\uD305 \uB370\uC774\uD130\uB97C
      \uBD84\uC11D\uD55C \uB05D\uC5D0"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Cold_002
    ko: "\uC790\uC2E0\uC758 3\uC810\uC29B \uC2E4\uD328 \uC6D0\uC778\uC774 '\uD314\uAFC8\uCE58
      \uAC01\uB3C4'\uC640 '\uB9B4\uB9AC\uC2A4 \uD0C0\uC774\uBC0D'\uC758 \uBBF8\uC138\uD55C
      \uBD88\uC77C\uCE58\uC784\uC744 \uD655\uC2E0\uD558\uACE0 \uBD84\uC11D \uC790\uB8CC\uB97C
      \uAC10\uB3C5\uC5D0\uAC8C \uC81C\uC2DC\uD558\uBA70 \uC870\uC5B8\uC744 \uAD6C\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Cold_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Cold_001
    ko: "\uB124\uAC00 \uBD84\uC11D\uD55C \uC774 \uC218\uCE58\uB4E4\uC774 \uB124 \uC2E4\uC804
      \uACBD\uAE30\uC5D0\uC11C \uD6A8\uC728\uC801\uC778 \uB4DD\uC810\uC73C\uB85C
      \uC774\uC5B4\uC9C0\uB3C4\uB85D \uCCB4\uACC4\uC801\uC73C\uB85C \uC218\uC815\uD574
      \uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Planner_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uC870\uC5B8\uB300\uB85C \uCD5C\uC801\uC758 \uC288\uD305
      \uBA54\uCEE4\uB2C8\uC998\uC744 \uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Planner_1
    ko: "\uC790\uC2E0\uC758 \uCCB4\uACC4\uC801\uC778 \uBD84\uC11D\uC774 \uC778\uC815\uC744
      \uBC1B\uC790, \uB354\uC6B1 \uC815\uAD50\uD55C \uC29B \uBA54\uCEE4\uB2C8\uC998\uC744
      \uC124\uACC4\uD558\uC5EC \uC288\uD305 \uD6A8\uC728 \uADF9\uB300\uD654"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Opportunist_101
    ko: "\uB370\uC774\uD130\uB97C \uD65C\uC6A9\uD574 \uC2E4\uC804\uC5D0\uC11C \uC989\uAC01\uC801\uC778
      \uB4DD\uC810\uC744 \uB9CC\uB4E4\uC5B4\uB0B4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Opportunist_1
    ko: "\uACA9\uB824\uB97C \uC774\uC6A9\uD574 \uD6C8\uB828\uC744 \uC815\uB2F9\uD654\uD558\uB824
      \uD558\uC9C0\uB9CC \uC2E4\uC9C8\uC801\uC778 \uAE30\uC220 \uC2B5\uB4DD\uC740
      \uBBF8\uBBF8\uD568"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Cunning_101
    ko: "\uB370\uC774\uD130\uB97C \uD65C\uC6A9\uD574 \uC0C1\uB300 \uC218\uBE44\uB97C
      \uC18D\uC77C \uC218 \uC788\uB294 \uC29B\uC744 \uC5F0\uB9C8\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Cunning_1
    ko: "\uC790\uC2E0\uC758 \uBD84\uC11D\uC774 \uCE6D\uCC2C\uBC1B\uC790 \uBC29\uC2EC\uD558\uC5EC
      \uD6C8\uB828\uC758 \uAE34\uC7A5\uAC10\uC774 \uD480\uC5B4\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Believer_101
    ko: "\uC81C \uBD84\uC11D\uC774 \uC633\uC74C\uC744 \uACB0\uACFC\uB85C \uC99D\uBA85\uD574
      \uBCF4\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Believer_1
    ko: "\uC790\uC2E0\uC758 \uB17C\uB9AC\uC801 \uACB0\uB860\uC5D0 \uD655\uC2E0\uC744
      \uC5BB\uC5B4 \uD754\uB4E4\uB9BC \uC5C6\uC774 \uC288\uD305 \uB8E8\uD2F4 \uD655\uB9BD"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Cold_002
    ko: "\uB370\uC774\uD130\uC5D0 \uC9C0\uB098\uCE58\uAC8C \uB9E4\uBAB0\uB418\uC5B4
      \uC815\uC791 \uC911\uC694\uD55C \uD604\uC7A5 \uAC10\uAC01\uC744 \uC783\uACE0
      \uC788\uB2E4. \uB370\uC774\uD130\uB294 \uCC38\uACE0\uC77C \uBFD0, \uC9C0\uAE08
      \uB2F9\uC7A5 \uAC10\uAC01\uC744 \uCC3E\uB294 \uD6C8\uB828\uC5D0 \uC9D1\uC911\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Planner_201
    ko: "\uC218\uCE58\uC801 \uBD84\uC11D\uACFC \uC2E4\uC804\uC758 \uAD34\uB9AC\uB97C
      \uB2E4\uC2DC \uAC80\uD1A0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Planner_2
    ko: "\uC9C8\uCC45\uC744 \uD1B5\uD574 \uC790\uC2E0\uC758 \uB17C\uB9AC\uC801 \uD5C8\uC810\uC744
      \uBCF4\uC644\uD558\uB824\uB294 \uACFC\uC815\uC5D0 \uC788\uC5B4 \uB2A5\uB825\uCE58
      \uBCC0\uD654 \uC5C6\uC74C"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Opportunist_201
    ko: "\uB370\uC774\uD130\uAC00 \uC800\uC5D0\uAC8C \uBD88\uB9AC\uD558\uAC8C \uC791\uC6A9\uD55C\uB2E4\uB294
      \uB9D0\uC500\uC778\uAC00\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Opportunist_2
    ko: "\uC790\uC2E0\uC758 \uC601\uB9AC\uD55C \uBD84\uC11D\uC774 \uBB34\uC2DC\uB2F9\uD558\uC790
      \uAE30\uD68C\uC8FC\uC758\uC801 \uD0DC\uB3C4\uAC00 \uC18C\uADF9\uC801\uC73C\uB85C
      \uBCC0\uD568"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Cunning_201
    ko: "\uC81C \uBD84\uC11D\uC774 \uBD80\uC871\uD588\uAD70\uC694. \uB354 \uD655\uC2E4\uD55C
      \uC57D\uC810\uC744 \uD30C\uACE0\uB4E4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Cunning_2
    ko: "\uC9C8\uCC45\uC744 \uD1B5\uD574 \uB354 \uC644\uBCBD\uD55C \uC29B \uD3FC\uC744
      \uB9CC\uB4DC\uB294 \uBC29\uBC95\uC744 \uCC3E\uC544\uB0B4\uC5B4 \uC29B \uC815\uD655\uB3C4
      \uD5A5\uC0C1"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Believer_201
    ko: "\uB370\uC774\uD130\uB294 \uAC70\uC9D3\uB9D0\uC744 \uD558\uC9C0 \uC54A\uB294\uB370,
      \uC65C \uBD80\uC815\uD558\uC2DC\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Believer_2
    ko: "\uC790\uC2E0\uC758 \uC2E0\uB150\uC744 \uBD80\uC815\uB2F9\uD588\uB2E4\uACE0
      \uD310\uB2E8, \uC288\uD305 \uB9AC\uB4EC\uC774 \uBD95\uAD34\uB418\uC5B4 \uC29B
      \uAC10\uAC01 \uC0C1\uC2E4"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Cold_003
    ko: "\uAC10\uB3C5\uC740 \uC120\uC218\uAC00 \uB0B4\uBBFC \uC790\uB8CC\uB97C \uBB35\uBB35\uD788
      \uBC1B\uC544\uB4E4\uACE0\uB294, \uC544\uBB34 \uB9D0 \uC5C6\uC774 \uD39C\uC744
      \uB4E4\uC5B4 \uADF8 \uC704 \uBB34\uC5B8\uAC00\uB97C \uD718\uAC08\uACA8 \uC4F4
      \uB4A4 \uC120\uC218\uC5D0\uAC8C \uD22D \uB358\uC9C0\uACE0 \uCF54\uD2B8 \uBC18\uB300\uD3B8\uC73C\uB85C
      \uAC78\uC5B4\uAC00 \uBC84\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Planner_301
    ko: "\uBD84\uC11D \uB0B4\uC6A9\uC774 \uBD80\uC815\uB2F9\uD55C \uAC74\uC9C0 \uD63C\uB780\uC2A4\uB7FD\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Planner_3
    ko: "\uBD84\uC11D\uC801 \uC811\uADFC\uC774 \uBD80\uC815\uB2F9\uD588\uB2E4\uACE0
      \uB290\uAEF4 \uB17C\uB9AC\uC801 \uD68C\uB85C\uAC00 \uAF2C\uC774\uBA70 \uC288\uD305
      \uC790\uC2E0\uAC10 \uD558\uB77D"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Opportunist_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uD589\uB3D9\uC5D0\uC11C \uC29B\uC758 \uD575\uC2EC\uC744
      \uAC04\uD30C\uD574 \uB0B4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Opportunist_3
    ko: "\uAC10\uB3C5\uC758 \uD589\uB3D9\uC5D0\uC11C \uC2E4\uB9AC\uB97C \uD3EC\uCC29,
      \uC2A4\uC2A4\uB85C \uD3FC\uC744 \uC218\uC815\uD558\uC5EC \uC989\uAC01\uC801\uC778
      \uB4DD\uC810\uB825 \uC0C1\uC2B9"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Cunning_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uC758\uB3C4\uB97C \uD30C\uC545\uD558\uAE30 \uC704\uD574
      \uB370\uC774\uD130\uB97C \uC7AC\uC870\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Cunning_3
    ko: "\uAC10\uB3C5\uC758 \uC758\uC911\uC744 \uD30C\uC545\uD558\uB290\uB77C \uC624\uD788\uB824
      \uB370\uC774\uD130 \uC218\uC815\uC5D0\uB9CC \uB9E4\uB2EC\uB9AC\uB294 \uC815\uCCB4
      \uC0C1\uD0DC"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Believer_301
    ko: "\uC81C \uC2E0\uB150\uB300\uB85C \uBB35\uBB35\uD788 \uBD84\uC11D \uACB0\uACFC\uB97C
      \uC2E4\uD589\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Believer_3
    ko: "\uAC10\uB3C5\uC758 \uBC18\uC751\uACFC \uBB34\uAD00\uD558\uAC8C \uC790\uC2E0\uC758
      \uC2E0\uB150\uC744 \uBC00\uC5B4\uBD99\uC774\uBA70 \uAE30\uC874\uACFC \uB3D9\uC77C\uD55C
      \uC218\uC900 \uC720\uC9C0"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Instinct_001
    ko: "\uC120\uC218\uB294 \uC218\uCC9C \uBC88\uC758 \uC288\uD305 \uB370\uC774\uD130\uB97C
      \uBD84\uC11D\uD55C \uB05D\uC5D0"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Instinct_002
    ko: "\uC790\uC2E0\uC758 3\uC810\uC29B \uC2E4\uD328 \uC6D0\uC778\uC774 '\uD314\uAFC8\uCE58
      \uAC01\uB3C4'\uC640 '\uB9B4\uB9AC\uC2A4 \uD0C0\uC774\uBC0D'\uC758 \uBBF8\uC138\uD55C
      \uBD88\uC77C\uCE58\uC784\uC744 \uD655\uC2E0\uD558\uACE0 \uBD84\uC11D \uC790\uB8CC\uB97C
      \uAC10\uB3C5\uC5D0\uAC8C \uC81C\uC2DC\uD558\uBA70 \uC870\uC5B8\uC744 \uAD6C\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Instinct_003
    ko: "\uBD84\uC11D \uC790\uB8CC\uB294 \uC644\uBCBD\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC
      \uC81C \uBAB8\uC774 \uB290\uB07C\uB294 \uBCF8\uB2A5\uC801\uC778 \uC57C\uC131\uB3C4
      \uBBFF\uACE0 \uC2F6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Instinct_004
    ko: "\uC774 \uB370\uC774\uD130\uB97C \uC81C \uC57C\uC0DD\uC801\uC778 \uD3FC\uC73C\uB85C
      \uAD6C\uD604\uD574\uB3C4 \uB420\uAE4C\uC694?"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Instinct_005
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Instinct_001
    ko: "\uC88B\uB2E4! \uB370\uC774\uD130\uB85C \uCC3E\uC740 \uADF8 \uC6D0\uB9AC\uB97C
      \uB124 \uBCF8\uB2A5\uC5D0 \uB179\uC5EC\uBD10\uB77C. \uADF8 \uC57C\uC131\uC801\uC778
      \uAC10\uAC01\uACFC \uBD84\uC11D\uB41C \uB17C\uB9AC\uAC00 \uD569\uCCD0\uC9C4\uB2E4\uBA74
      \uB204\uAD6C\uB3C4 \uB9C9\uC744 \uC218 \uC5C6\uB294 \uC29B\uC774 \uB420 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Bluffer_101
    ko: "\uC81C \uAC10\uAC01\uACFC \uBD84\uC11D\uB825\uC774\uB77C\uBA74, \uC774 \uCF54\uD2B8\uC758
      \uC9C0\uBC30\uC790\uB294 \uC811\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Bluffer_1
    ko: "\uC790\uC2E0\uC758 \uC7A0\uC7AC\uB825\uC744 \uC778\uC815\uBC1B\uC790 \uADFC\uAC70
      \uC788\uB294 \uC790\uC2E0\uAC10\uC774 \uADF9\uB300\uD654\uB418\uC5B4 3\uC810\uC29B
      \uC131\uACF5\uB960 \uAE09\uC99D"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Wild_101
    ko: "\uB370\uC774\uD130\uB294 \uC871\uC1C4\uC600\uAD70\uC694! \uC774\uC81C \uBCF8\uB2A5\uB300\uB85C
      \uB9BC\uC744 \uCC22\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Wild_1
    ko: "\uB370\uC774\uD130 \uBD84\uC11D\uB9C8\uC800 \uC57C\uC131\uC801 \uBCF8\uB2A5\uC73C\uB85C
      \uB300\uCCB4\uD558\uB824\uB2E4 \uD3FC\uC774 \uC644\uC804\uD788 \uBB34\uB108\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Egoist_101
    ko: "\uC81C \uAC10\uAC01\uC774 \uC633\uB2E4\uB294 \uAC78 \uC99D\uBA85\uD560 \uC644\uBCBD\uD55C
      \uAE30\uD68C\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Egoist_1
    ko: "\uACA9\uB824\uC870\uCC28 \uC790\uC2E0\uC758 \uB9CC\uC871\uC744 \uC704\uD55C
      \uB3C4\uAD6C\uB85C \uD65C\uC6A9\uD558\uBA70 \uD3C9\uC18C \uD3FC \uC720\uC9C0"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Fighter_101
    ko: "\uBD84\uC11D\uC744 \uB6AB\uACE0 \uB098\uC624\uB294 \uC774 \uC9DC\uB9BF\uD568!
      \uACBD\uC7C1\uC744 \uC990\uAE30\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Fighter_1
    ko: "\uC790\uC2E0\uC758 \uC57C\uC131\uC801 \uBD84\uC11D\uB825\uC744 \uC9C0\uC9C0\uBC1B\uC790
      \uACBD\uC7C1\uC2EC\uC774 \uBD88\uD0C0\uC62C\uB77C \uC29B \uC801\uC911\uB960
      \uC0C1\uC2B9"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Instinct_002
    ko: "\uB370\uC774\uD130\uC640 \uBCF8\uB2A5 \uC0AC\uC774\uC5D0\uC11C \uAC08\uD321\uC9C8\uD321\uD558\uC9C0
      \uB9C8\uB77C. \uB18D\uAD6C\uB294 \uB124 \uBA38\uB9BF\uC18D \uACC4\uC0B0\uAE30\uAC00
      \uC544\uB2C8\uB77C, \uCF54\uD2B8 \uC704\uC5D0\uC11C \uD130\uC838 \uB098\uC624\uB294
      \uB3D9\uBB3C\uC801\uC778 \uAC10\uAC01\uC73C\uB85C \uACB0\uC815\uB418\uB294
      \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Bluffer_201
    ko: "\uC81C \uACC4\uC0B0\uC774 \uD2C0\uB838\uAD70\uC694. \uAC10\uAC01\uC73C\uB85C
      \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Bluffer_2
    ko: "\uC9C8\uCC45\uC744 \uD1B5\uD574 \uD5C8\uC138\uC758 \uADFC\uAC70\uB97C \uCC3E\uC73C\uB824
      \uC560\uC4F0\uBA70 \uD6C8\uB828\uC744 \uC9C0\uC18D\uD558\uB294 \uC815\uCCB4
      \uC0C1\uD0DC"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Wild_201
    ko: "\uAE38\uB4E4\uC5EC\uC9C0\uC9C0 \uC54A\uC740 \uC29B\uC774\uC57C\uB9D0\uB85C
      \uC81C\uAC00 \uC6D0\uD558\uB294 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Wild_2
    ko: "\uAE38\uB4E4\uC5EC\uC9C0\uC9C0 \uC54A\uB294 \uBCF8\uB2A5\uC744 \uC790\uADF9\uBC1B\uC544
      \uC704\uAE30 \uC0C1\uD669\uC5D0\uC11C \uC29B \uAC10\uAC01 \uD3ED\uBC1C"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Egoist_201
    ko: "\uB0B4 \uBC29\uC2DD\uC774 \uBD80\uC815\uB2F9\uD588\uB2E4\uB294 \uAC74\uAC00?
      \uAC10\uB3C5\uB2D8 \uC548\uBAA9\uC774 \uC758\uC2EC\uB418\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Egoist_2
    ko: "\uC790\uC2E0\uC758 \uBC29\uC2DD\uC774 \uBD80\uC815\uB2F9\uD558\uC790 \uAC10\uB3C5\uC5D0
      \uB300\uD55C \uBC18\uD56D\uC2EC\uC73C\uB85C \uC778\uD574 \uC29B \uB9AC\uB4EC
      \uD30C\uAD34"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Fighter_201
    ko: "\uBD80\uC815\uB2F9\uD560\uC218\uB85D \uC624\uAE30\uAC00 \uC0DD\uAE30\uB124\uC694.
      \uB450\uACE0 \uBCF4\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Fighter_2
    ko: "\uAC10\uB3C5\uACFC\uC758 \uD22C\uC7C1 \uC2EC\uB9AC\uAC00 \uC29B \uB9B4\uB9AC\uC2A4\uC758
      \uC815\uAD50\uD568\uC744 \uAC09\uC544\uBA39\uC5B4 \uC288\uD305 \uC2AC\uB7FC\uD504
      \uC720\uBC1C"
    en: 
    ja: 
  - stringKey: Event_00006_Ch_Instinct_003
    ko: "\uAC10\uB3C5\uC740 \uC120\uC218\uAC00 \uB0B4\uBBFC \uBD84\uC11D \uC790\uB8CC\uB97C
      \uB09A\uC544\uCC44\uB4EF \uAC00\uC838\uAC00\uB354\uB2C8, \uCCB4\uC721\uAD00
      \uBCBD\uC5D0 \uBD99\uC5B4\uC788\uB294 \uB0A1\uC740 \uB18D\uAD6C \uACE8\uB300
      \uCABD\uC73C\uB85C \uC885\uC774\uB97C \uAD6C\uACA8 \uB358\uC838\uBC84\uB9AC\uACE0\uB294
      \uB4F1\uC744 \uB3CC\uB9B0 \uCC44 \uCF54\uD2B8\uB97C \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Bluffer_301
    ko: "\uBB34\uC2DC\uB2F9\uD558\uB2E4\uB2C8... \uB0B4 \uC874\uC7AC\uAC10\uC774
      \uC774 \uC815\uB3C4\uBFD0\uC778\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Bluffer_3
    ko: "\uC790\uC2E0\uC758 \uAC00\uCE58\uAC00 \uBB34\uC2DC\uB2F9\uD588\uB2E4\uACE0
      \uB290\uAEF4 \uC790\uC874\uAC10\uC774 \uAEBE\uC774\uBA70 \uC29B \uBC38\uB7F0\uC2A4
      \uBD95\uAD34"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Wild_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uCE68\uBB35\uC740 \uBCF8\uB2A5\uC744 \uAE68\uC6B0\uB77C\uB294
      \uC2E0\uD638\uACA0\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Wild_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uAD00\uC2EC\uC744 \uBCF8\uB2A5\uC801\uC778 \uD22C\uC7C1\uC758
      \uC2DC\uC791\uC73C\uB85C \uAC04\uC8FC\uD558\uC5EC \uBB35\uBB35\uD788 \uD6C8\uB828"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Egoist_301
    ko: "\uB204\uAD6C\uC758 \uAC04\uC12D\uB3C4 \uC5C6\uC774, \uC624\uC9C1 \uB098\uB9CC\uC758
      \uC29B\uC744 \uC644\uC131\uD558\uACA0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Egoist_3
    ko: "\uC678\uBD80\uC758 \uAC04\uC12D \uC5C6\uB294 \uC644\uBCBD\uD55C \uB3C5\uC790\uC801\uC778
      \uD6C8\uB828 \uD658\uACBD\uC5D0\uC11C \uC29B \uBA54\uCEE4\uB2C8\uC998 \uCD5C\uC801\uD654"
    en: 
    ja: 
  - stringKey: Event_00006_Desc_Fighter_301
    ko: "\uB0A0 \uBC29\uCE58\uD574? \uD765\uBBF8\uB86D\uAD70. \uC774 \uB09C\uAD00\uC744
      \uC29B\uC73C\uB85C \uB6AB\uC5B4\uBCF4\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00006_Rs_Fighter_3
    ko: "\uAC10\uB3C5\uC758 \uBC29\uCE58\uB97C \uB610 \uB2E4\uB978 \uACBD\uC7C1\uC73C\uB85C
      \uC778\uC2DD\uD558\uC5EC \uC29B \uAC10\uAC01\uC744 \uBCBC\uB9AC\uB294 \uC911"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Discipline_001
    ko: "\uCD5C\uADFC \uC815\uD574\uC9C4 \uADDC\uC728\uB300\uB85C \uC815\uC11D\uC801\uC778
      \uC29B \uD3FC\uC744 \uBC18\uBCF5\uD558\uB358 \uC120\uC218\uAC00,"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Discipline_002
    ko: "\uC5B4\uC81C \uBCF8 \uD504\uB85C \uC120\uC218\uC758 \uD654\uB824\uD55C '\uD035
      \uB9B4\uB9AC\uC2A4' \uC29B\uC744 \uD749\uB0B4 \uB0B4\uAE30 \uC2DC\uC791\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Discipline_003
    ko: "\uB9BC\uC744 \uD5A5\uD574 \uC3D8\uB294 \uC29B\uC758 \uADA4\uC801\uC740 \uBCC0\uCE59\uC801\uC774\uACE0
      \uBD88\uC548\uC815\uD558\uBA70, \uD300\uC774 \uC815\uD55C \uAE30\uBCF8 \uB8E8\uD2F4\uC5D0\uC11C
      \uC644\uC804\uD788 \uBC97\uC5B4\uB098 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Discipline_004
    ko: "\uC120\uC218\uB294 \uC790\uC2E0\uC758 \uC0C8\uB85C\uC6B4 \uC2DC\uB3C4\uAC00
      \uD601\uC2E0\uC801\uC778 \uBC1C\uC804\uC774\uB77C\uACE0 \uBBFF\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Discipline_005
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Discipline_001
    ko: "\uC0C8\uB85C\uC6B4 \uAE30\uC220\uC744 \uD0D0\uAD6C\uD558\uB294 \uAC74 \uC88B\uB2E4.
      \uD558\uC9C0\uB9CC \uAE30\uBCF8\uC774 \uC5C6\uB294 \uC751\uC6A9\uC740 \uC0AC\uC0C1\uB204\uAC01\uC774\uC9C0. 
      \uC815\uC11D\uC744 \uBA3C\uC800 \uC644\uBCBD\uD788 \uB2E4\uC9C4 \uD6C4\uC5D0
      \uC2DC\uB3C4\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Principled_101
    ko: "\uAC10\uB3C5\uB2D8, \uC81C\uAC00 \uC0DD\uAC01\uC774 \uC9E7\uC558\uC2B5\uB2C8\uB2E4.
      \uD601\uC2E0\uB3C4 \uAE30\uBCF8\uAE30\uAC00 \uC644\uBCBD\uD574\uC57C \uC758\uBBF8\uAC00
      \uC788\uB294\uB370, \uC81C\uAC00 \uC21C\uC11C\uB97C \uB193\uCCE4\uB124\uC694.
      \uB2E4\uC2DC \uC29B \uD3FC \uAE30\uCD08\uBD80\uD130 \uB2E4\uC9C0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Principled_1
    ko: "\uAC10\uB3C5\uC758 \uC870\uC5B8\uC744 \uB17C\uB9AC\uC801\uC73C\uB85C \uC218\uC6A9\uD574
      \uC2A4\uC2A4\uB85C \uD6C8\uB828 \uB8E8\uD2F4\uC744 \uC7AC\uC815\uB9BD\uD568"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Guardian_101
    ko: "\uB124, \uBA85\uC2EC\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uD300\uC744 \uC704\uD574
      \uC815\uC11D\uB300\uB85C \uC3D8\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Guardian_1
    ko: "\uACA9\uB824\uB294 \uC88B\uC9C0\uB9CC, \uD300\uC744 \uC9C0\uCF1C\uC57C \uD55C\uB2E4\uB294
      \uAC15\uBC15 \uB54C\uBB38\uC5D0 \uCC3D\uC758\uC801 \uB3C4\uC804\uC744 \uBA48\uCD94\uACE0
      \uD604\uC0C1 \uC720\uC9C0\uD568"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Tactician_101
    ko: "\uAC10\uB3C5\uB2D8, \uAC10\uC131\uC801\uC778 \uC870\uC5B8\uBCF4\uB2E4 \uC81C
      \uC288\uD305 \uADA4\uC801 \uB370\uC774\uD130\uBD80\uD130 \uBD10\uC8FC\uC138\uC694.
      \uC81C \uBCC0\uCE59 \uD3FC\uC774 \uC815\uC11D\uBCF4\uB2E4 \uD6A8\uC728\uC801\uC778
      \uAD6C\uAC04\uC774 \uBD84\uBA85\uD788 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Tactician_1
    ko: "\uB370\uC774\uD130\uC640 \uBD84\uC11D\uC744 \uC911\uC2DC\uD558\uB294\uB370
      \uC6D0\uCE59\uB9CC\uC744 \uAC15\uC870\uD558\uB294 \uACA9\uB824\uB294 '\uBE44\uB17C\uB9AC\uC801'\uC774\uB77C
      \uB290\uAEF4 \uBC18\uBC1C\uD568"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Exemplary_101
    ko: "\uAC10\uB3C5\uB2D8 \uB9D0\uC500\uC774 \uB2E4 \uB9DE\uC8E0. \uC81C\uAC00
      \uBAA8\uBC94\uC778\uB370 \uC774 \uC815\uB3C4 \uD3FC\uC740 \uCDA9\uBD84\uD788
      \uC18C\uD654\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Exemplary_1
    ko: "\uC2A4\uC2A4\uB85C \uC644\uBCBD\uD558\uB2E4\uACE0 \uCC29\uAC01\uD558\uC5EC
      \uD6C8\uB828\uC758 \uAE34\uC7A5\uAC10\uC744 \uB193\uACE0 \uAE30\uC220\uC801
      \uC815\uCCB4\uAE30\uC5D0 \uBE60\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Discipline_002
    ko: "\uB204\uAC00 \uB124 \uB9D8\uB300\uB85C \uD3FC\uC744 \uBC14\uAFB8\uB77C\uACE0
      \uD588\uC9C0? \uC6B0\uB9AC \uD300\uC740 \uC57D\uC18D\uB41C \uB8E8\uD2F4\uC73C\uB85C
      \uC2B9\uB9AC\uD55C\uB2E4. \uC9C0\uAE08 \uB2F9\uC7A5 \uADF8 \uBCC0\uCE59\uC801\uC778
      \uC790\uC138 \uBC84\uB9AC\uACE0, \uCC98\uC74C\uBD80\uD130 \uB2E4\uC2DC \uC815\uC11D\uB300\uB85C
      \uB358\uC838."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Principled_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uD765\uBD84\uD574\uC11C \uD300 \uADDC\uCE59\uC744
      \uC78A\uC5C8\uC2B5\uB2C8\uB2E4. \uC9C0\uAE08 \uB2F9\uC7A5 \uC815\uC11D \uB8E8\uD2F4\uBD80\uD130
      \uB2E4\uC2DC \uC2DC\uC791\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Principled_2
    ko: "\uC9C8\uCC45\uC744 \uC218\uC6A9\uD558\uC9C0\uB9CC, \uC2A4\uC2A4\uB85C \uD310\uB2E8\uD558\uAE30\uBCF4\uB2E4
      \uC9C0\uC2DC\uB97C \uAE30\uACC4\uC801\uC73C\uB85C \uC218\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Guardian_201
    ko: "\uC81C \uC695\uC2EC \uB54C\uBB38\uC5D0 \uD300 \uC9C8\uC11C\uB97C \uD750\uB838\uC2B5\uB2C8\uB2E4.
      \uD300\uC6D0\uB4E4\uC5D0\uAC8C \uBBF8\uC548\uD574\uC11C\uB77C\uB3C4, \uC774\uC81C\uBD80\uD130
      \uC9C4\uC9DC FM\uB300\uB85C \uC815\uC11D \uD3FC\uB9CC \uACE0\uC9D1\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Guardian_2
    ko: "\uD300\uC758 \uC9C8\uC11C\uB97C \uBC14\uB85C\uC7A1\uC73C\uB77C\uB294 \uC9C8\uCC45\uC5D0
      \uAC15\uD55C \uCC45\uC784\uAC10\uC744 \uB290\uAEF4 \uAC00\uC7A5 \uC815\uAD50\uD55C
      \uC29B\uC744 \uBCF4\uC5EC\uC90C"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Tactician_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uBCC0\uCE59 \uB8E8\uD2F4\uC740 \uD3D0\uAE30\uD558\uC8E0.
      \uB9D0\uC500\uD558\uC2E0 \uB300\uB85C \uC815\uC11D \uD3FC\uC73C\uB85C \uC804\uD658\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uC218\uC6A9\uD558\uC9C0\uB9CC, \uD6A8\uC728\uC131\uC5D0
      \uB300\uD55C \uB370\uC774\uD130 \uC99D\uBA85\uC774 \uC5C6\uC73C\uBBC0\uB85C
      \uAE30\uACC4\uC801\uC73C\uB85C\uB9CC \uB530\uB984."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Exemplary_201
    ko: "\uC81C\uAC00 \uD300\uC758 \uBCF8\uBCF4\uAE30\uC778\uB370... \uACBD\uC194\uD588\uC2B5\uB2C8\uB2E4.
      \uB2E4\uB978 \uC120\uC218\uB4E4\uC774 \uBCF4\uACE0 \uBC30\uC6B8 \uC218 \uC788\uAC8C,
      \uC774\uC81C\uBD80\uD130 \uAC00\uC7A5 \uC815\uC11D\uC801\uC778 \uC29B \uD3FC\uB9CC
      \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Exemplary_2
    ko: "\uD0C0\uC778\uC5D0\uAC8C \uBCF4\uC5EC\uC9C0\uB294 \uBAA8\uC2B5\uC744 \uC911\uC2DC\uD558\uBBC0\uB85C,
      \uC9C8\uCC45\uC744 \uAE30\uD68C\uB85C \uC0BC\uC544 \uC2A4\uC2A4\uB85C\uB97C
      \uB354\uC6B1 \uC5C4\uACA9\uD558\uAC8C \uD1B5\uC81C\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Discipline_003
    ko: "\uAC10\uB3C5\uB2D8\uC740 \uC544\uBB34 \uB9D0 \uC5C6\uC774 \uCF54\uD2B8 \uAD6C\uC11D\uC5D0
      \uC549\uC544 \uC120\uC218\uAC00 \uC2A4\uC2A4\uB85C \uBCC0\uCE59\uC801 \uD3FC\uC73C\uB85C
      \uBA87 \uBC88\uC758 \uC2E4\uC218\uB97C \uACAA\uB294\uC9C0 \uB0C9\uC815\uD558\uAC8C
      \uAD00\uCC30\uD558\uBA70, \uACB0\uACFC\uB97C \uB370\uC774\uD130\uB85C \uAE30\uB85D\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC544\uBB34 \uB9D0\uC500\uB3C4 \uC5C6\uC73C\uC2E0
      \uAC74... \uB0B4 \uD3FC\uC774 \uADDC\uC900\uC5D0\uC11C \uBC97\uC5B4\uB0AC\uB2E4\uB294
      \uB73B\uC778\uAC00? \uAE30\uC900\uC744 \uBABB \uC9C0\uD0A4\uB294 \uB0B4 \uC29B\uC740
      \uC758\uBBF8\uAC00 \uC5C6\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Principled_3
    ko: "\uD53C\uB4DC\uBC31 \uC5C6\uB294 \uCE68\uBB35\uC744 \uADDC\uC728 \uC704\uBC18\uC5D0
      \uB300\uD55C \uAC15\uB825\uD55C \uBE44\uB09C\uC73C\uB85C \uC624\uD574\uD574
      \uC2EC\uB9AC\uC801 \uBC38\uB7F0\uC2A4 \uBD95\uAD34"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uB098\uB97C \uC548 \uBCF4\uC2DC\uB124... \uB0B4\uAC00
      \uD300\uC758 \uC6D0\uCE59\uC744 \uC5B4\uAE34 \uAC74\uAC00? \uBD88\uC548\uD574\uC11C
      \uC29B\uC774 \uC790\uAFB8 \uB9BC\uC744 \uBE57\uB098\uAC00..."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Guardian_3
    ko: "\uAC10\uB3C5\uC758 \uAD00\uC2EC\uC774 \uACE7 \uD300\uC758 \uBCF4\uD638\uB77C
      \uC0DD\uAC01\uD558\uB294\uB370, \uBC29\uCE58\uB418\uC790 \uBCF4\uD638\uB9DD\uC774
      \uC0AC\uB77C\uC84C\uB2E4\uACE0 \uB290\uAEF4 \uC29B \uBC38\uB7F0\uC2A4 \uBD95\uAD34"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Tactician_301
    ko: "\uB0B4 \uC29B \uD0C4\uB3C4\uAC00 \uC815\uC11D\uBCF4\uB2E4 5\uB3C4 \uB0AE\uAD70.
      \uC774 \uB370\uC774\uD130\uBA74 \uD655\uB960\uC774 \uB5A8\uC5B4\uC838. \uC2A4\uC2A4\uB85C
      \uADA4\uC801\uC744 5\uB3C4 \uC62C\uB9AC\uC790."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Tactician_3
    ko: "\uC2A4\uC2A4\uB85C \uB370\uC774\uD130\uB97C \uBD84\uC11D\uD574 \uC624\uB958\uB97C
      \uC218\uC815\uD558\uBBC0\uB85C, \uC678\uBD80 \uAC1C\uC785\uC774 \uC5C6\uC5B4\uB3C4
      \uAC00\uC7A5 \uC644\uBCBD\uD55C \uD3FC\uC744 \uCC3E\uC544\uB0C4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Exemplary_301
    ko: "\uC544\uBB34\uB3C4 \uC548 \uBCF4\uB098? \uAC10\uB3C5\uB2D8\uC774 \uBCF4\uACE0
      \uACC4\uC2E4\uC9C0 \uBAA8\uB974\uB2C8 \uC77C\uB2E8 \uC815\uC11D \uD3FC\uC73C\uB85C
      \uC3D8\uB294 \uBAA8\uC2B5\uB9CC \uC720\uC9C0\uD574\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Exemplary_3
    ko: "\uC2E4\uB825\uC744 \uAE30\uB974\uB294 \uAC8C \uC544\uB2C8\uB77C \uAC10\uB3C5\uC758
      \uD3C9\uAC00\uB97C \uAD00\uB9AC\uD558\uB294 \uB370 \uAE09\uAE09\uD574 \uBCF8\uC9C8\uC801\uC778
      \uC131\uC7A5\uC774 \uB354\uB524."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bond_001
    ko: "\uD300\uC758 \uC5D0\uC774\uC2A4\uAE09 \uC120\uC218\uAC00 \uC5B4\uC81C \uBCF8
      \uD504\uB85C \uC120\uC218\uC758 '\uD035 \uB9B4\uB9AC\uC2A4'\uB97C \uD749\uB0B4
      \uB0B4\uAE30 \uC2DC\uC791\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bond_002
    ko: "\uD300\uC758 \uC815\uC11D \uB8E8\uD2F4\uC740 \uBB34\uC2DC\uB41C \uCC44,
      \uC120\uC218\uC758 \uBCC0\uCE59\uC801\uC778 \uC29B\uC740 \uACC4\uC18D\uD574\uC11C
      \uB9BC\uC744 \uC678\uBA74\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bond_003
    ko: "\uD558\uC9C0\uB9CC \uC120\uC218\uB294 \uC774 \uD3FC\uC774 \uD300\uC744 \uC6B0\uC2B9\uC73C\uB85C
      \uC774\uB04C '\uD601\uC2E0'\uC774\uB77C \uAD73\uAC8C \uBBFF\uC73C\uBA70, \uB208\uC744
      \uBC18\uC9DD\uC774\uBA70 \uAC10\uB3C5\uC744 \uCCD0\uB2E4\uBCF4\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bond_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Bond_001
    ko: "\uB124\uAC00 \uD300\uC744 \uC0DD\uAC01\uD558\uB294 \uB9C8\uC74C\uC740 \uC798
      \uC54C\uACA0\uC5B4. \uAE30\uD2B9\uD558\uB2E4. \uD558\uC9C0\uB9CC \uC57D\uC18D\uB41C
      \uB8E8\uD2F4\uC774 \uD754\uB4E4\uB9AC\uBA74 \uBAA8\uB450\uAC00 \uD798\uB4E4\uC5B4\uC838.
      \uC6B0\uB9AC \uAC19\uC774 \uB2E4\uC2DC \uAE30\uBCF8\uBD80\uD130 \uB2E4\uC838\uBCF4\uC9C0
      \uC54A\uC744\uB798?"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uB9C8\uC74C\uC744 \uC54C\uC544\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD574\uC694. \uAC10\uB3C5\uB2D8\uACFC \uC57D\uC18D\uD55C \uC815\uC11D
      \uD3FC\uBD80\uD130 \uB2E4\uC2DC \uC2DC\uC791\uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Kind_1
    ko: "\uAC10\uB3C5\uC758 \uC778\uC815\uC744 \uBC1B\uC544 \uC2EC\uB9AC\uC801 \uC548\uC815\uAC10
      \uD68C\uBCF5."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8 \uC9C0\uC2DC\uB77C\uBA74 \uB2F9\uC5F0\uD788 \uB530\uB974\uACA0\uC2B5\uB2C8\uB2E4.
      \uC815\uC11D\uB300\uB85C \uC3E0\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Loyal_1
    ko: "\uAC10\uB3C5\uC5D0 \uC21C\uC751\uD558\uC9C0\uB9CC \uC790\uBC1C\uC801 \uAE30\uB7C9
      \uBC1C\uC804\uC740 \uC801\uC74C."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Sincere_101
    ko: "\uAC10\uB3C5\uB2D8\uAED8\uC11C \uD300\uC744 \uC704\uD574 \uBC29\uD5A5\uC744
      \uC7A1\uC544\uC8FC\uC2DC\uB2C8 \uC774\uC81C\uC57C \uC911\uC2EC\uC774 \uC7A1\uD799\uB2C8\uB2E4.
      \uB9D0\uC500\uD558\uC2E0 \uB300\uB85C \uC815\uC11D \uD3FC\uBD80\uD130 \uB2E4\uC2DC
      \uC131\uC2E4\uD788 \uB2E4\uC9C0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Sincere_1
    ko: "\uAC10\uB3C5\uC758 \uACA9\uB824\uB97C \uB8E8\uD2F4 \uC644\uC131\uC758 \uC774\uC815\uD45C\uB85C
      \uBC1B\uC544\uB4E4\uC784"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Moodmaker_101
    ko: "\uC624, \uC5ED\uC2DC \uAC10\uB3C5\uB2D8 \uCFE8\uD558\uC2EC! \uD558\uD558,
      \uB2E4\uC2DC \uC81C\uB300\uB85C \uC3E0\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Moodmaker_1
    ko: "\uAE30\uBD84\uC740 \uC88B\uC9C0\uB9CC \uB180\uC774\uCC98\uB7FC \uC5EC\uACA8
      \uC2E4\uB825 \uD5A5\uC0C1\uC740 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Bond_002
    ko: "\uC774\uAC74 \uD300\uC744 \uC704\uD55C \uAC8C \uC544\uB2C8\uB77C \uB124
      \uAC1C\uC778\uC801\uC778 \uC695\uC2EC\uC774\uC57C. \uD300 \uC804\uCCB4\uAC00
      \uBD88\uC548\uD574\uD558\uACE0 \uC788\uB2E4. \uB2F9\uC7A5 \uADF8 \uD3FC \uBC84\uB9AC\uACE0
      \uC6D0\uB798\uB300\uB85C \uB3CC\uC544\uAC00."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Kind_201
    ko: "\uD300\uC744 \uC704\uD55C \uB9C8\uC74C\uC774\uC5C8\uB294\uB370... \uAC10\uB3C5\uB2D8\uAED8
      \uC695\uC2EC\uC7C1\uC774\uB77C\uB294 \uC18C\uB9AC\uB97C \uB4E3\uB2E4\uB2C8
      \uB108\uBB34 \uC2AC\uD37C\uC694..."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Kind_2
    ko: "\uC778\uACA9\uC801 \uAC70\uC808\uB85C \uBC1B\uC544\uB4E4\uC5EC \uC758\uC695
      \uC0C1\uC2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Loyal_201
    ko: "\uC2E0\uB8B0\uB97C \uBB34\uB108\uB728\uB838\uC2B5\uB2C8\uB2E4! \uC624\uB298
      \uC548\uC5D0 \uC644\uBCBD\uD788 \uBCF5\uAD6C\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC744 \uBBFF\uC74C\uC758 \uCC44\uCC0D\uC9C8\uB85C \uD574\uC11D\uD574
      \uD22C\uC9C0 \uD3ED\uBC1C."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Sincere_201
    ko: "\uC9C0\uC2DC \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uC9C0\uAE08\uBD80\uD130 100\uAC1C
      \uBC18\uBCF5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Sincere_2
    ko: "\uCC45\uC744 \uC131\uC2E4\uD788 \uC218\uC6A9\uD574 \uAE30\uACC4\uC801\uC73C\uB85C
      \uC774\uD589."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Moodmaker_201
    ko: "\uC544... \uD300 \uBD84\uC704\uAE30 \uB9DD\uCCE4\uB124\uC694. \uACF5 \uC7A1\uAE30\uAC00
      \uBB34\uC11C\uC6CC\uC694."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Moodmaker_2
    ko: "\uD300 \uD654\uD569\uC744 \uAE7C\uB2E4\uB294 \uC790\uCC45\uC5D0 \uC29B \uC2DC\uB3C4
      \uC790\uCCB4\uB97C \uB450\uB824\uC6CC\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Bond_003
    ko: "\uAC10\uB3C5\uC740 \uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uC758 \uBCC0\uCE59
      \uC29B\uC744 \uC9C0\uCF1C\uBCF4\uB2E4\uAC00, \uC9E7\uC740 \uD55C\uC228\uACFC
      \uD568\uAED8 \uACE0\uAC1C\uB97C \uC800\uC73C\uBA70 \uB4F1\uC744 \uB3CC\uB824
      \uB2E4\uB978 \uC120\uC218\uC5D0\uAC8C \uAC00\uBC84\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Kind_301
    ko: "\uC800 \uBBF8\uC6B0\uC2E0 \uAC74\uAC00\uC694? "
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Kind_3
    ko: "\uCE68\uBB35\uC744 \uAD00\uACC4 \uB2E8\uC808\uB85C \uD574\uC11D\uD574 \uBD88\uC548\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Loyal_301
    ko: "\uB0B4\uAC00 \uC2E0\uB8B0\uB97C \uC783\uC5C8\uB098... \uC774\uC81C \uB18D\uAD6C
      \uBABB \uD558\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Loyal_3
    ko: "\uAD00\uACC4 \uB04A\uAE40\uC73C\uB85C \uD310\uB2E8\uD574 \uC815\uC2E0\uC801
      \uACF5\uD669."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Sincere_301
    ko: "\uC2E4\uB9DD\uD558\uC168\uC73C\uB2C8 \uC2A4\uC2A4\uB85C \uC2DC\uC2A4\uD15C\uC744
      \uC7AC\uC810\uAC80\uD558\uC790."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Sincere_3
    ko: "\uBB35\uC744 \uC5C4\uACA9\uD55C \uAE30\uC900\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uC2A4\uC2A4\uB85C \uC644\uBCBD\uD788 \uBCF5\uAD6C."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Moodmaker_301
    ko: "\uB354 \uD654\uB824\uD558\uAC8C \uC131\uACF5\uD574\uC11C \uAC10\uB3C5\uB2D8
      \uC2DC\uC120\uC744 \uBE8F\uC5B4\uC57C\uC9C0!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Moodmaker_3
    ko: "\uAC10\uB3C5\uC758 \uC2DC\uC120\uC744 \uB04C\uAE30 \uC704\uD574 \uBCC0\uCE59
      \uC29B\uC744 \uAC08\uACE0\uB2E6\uC544 \uC2E4\uB825 \uAE09\uC131\uC7A5."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cold_001
    ko: "\uD300\uC758 \uC5D0\uC774\uC2A4\uAE09 \uC120\uC218\uAC00 \uD504\uB85C\uC758
      '\uD035 \uB9B4\uB9AC\uC2A4'\uB97C \uD749\uB0B4 \uB0B4\uAE30 \uC2DC\uC791\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cold_002
    ko: "\uC120\uC218\uB294 \uC774 \uBCC0\uCE59\uC801\uC778 \uC29B \uD3FC\uC774 \uC790\uC2E0\uC758
      \uC7A0\uC7AC\uB825\uC744 \uADF9\uB300\uD654\uD560 '\uCD5C\uC801\uC758 \uC124\uACC4'\uB77C\uACE0
      \uBBFF\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cold_003
    ko: "\uADF8\uB7EC\uB098 \uAC10\uB3C5\uC774 \uBD84\uC11D\uD55C \uB370\uC774\uD130\uC5D0
      \uB530\uB974\uBA74, \uD604\uC7AC \uC120\uC218\uC758 \uBCC0\uCE59 \uC29B\uC740
      \uC131\uACF5\uB960\uC774 \uB9E4\uC6B0 \uB0AE\uC73C\uBA70 \uD300\uC758 \uACF5\uACA9
      \uC804\uC220\uACFC \uC815\uBA74\uC73C\uB85C \uBC30\uCE58\uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cold_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Cold_001
    ko: "\uB124\uAC00 \uC0C8\uB85C\uC6B4 \uAC01\uB3C4\uB97C \uC5F0\uAD6C\uD558\uBA70
      \uAE30\uC220\uC801 \uB3CC\uD30C\uAD6C\uB97C \uCC3E\uB294 \uB370\uC774\uD130\uC801
      \uD638\uAE30\uC2EC\uC740 \uC815\uB9D0 \uD6CC\uB96D\uD558\uB2E4. \uD558\uC9C0\uB9CC
      \uC9C0\uAE08 \uC2DC\uC2A4\uD15C\uC758 \uC77C\uAD00\uC131\uC744 \uC720\uC9C0\uD558\uB294
      \uAC8C \uC131\uC7A5\uC5D0 \uB354 \uC720\uB9AC\uD574."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Planner_101
    ko: "\uC81C \uD638\uAE30\uC2EC\uC744 \uAE0D\uC815\uD574\uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4.
      \uD6A8\uC728\uC744 \uC704\uD574 \uB8E8\uD2F4\uACFC \uACB0\uD569\uD558\uC5EC
      \uC218\uCE58\uAC12\uC744 \uBCF4\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Planner_1
    ko: "\uB370\uC774\uD130\uC801 \uC811\uADFC\uC744 \uACA9\uB824\uBC1B\uC790 \uC989\uAC01\uC801\uC73C\uB85C
      \uC804\uB7B5\uC744 \uCD5C\uC801\uD654\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Opportunist_101
    ko: "\uB370\uC774\uD130\uB97C \uD65C\uC6A9\uD574 \uC81C \uC29B\uC744 \uCD5C\uC801\uD654\uD55C\uB2E4\uB294
      \uC811\uADFC \uC88B\uB124\uC694. \uC815\uC11D\uB300\uB85C \uD558\uBA74\uC11C
      \uD2C8\uC744 \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Opportunist_1
    ko: "\uACA9\uB824\uB97C \uBC1B\uACE0 \uB530\uB974\uC9C0\uB9CC, \uAE30\uC220\uC801
      \uAE68\uB2EC\uC74C\uBCF4\uB2E4\uB294 \uC2E4\uB9AC \uCC59\uAE30\uAE30\uC5D0
      \uADF8\uCE68."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cunning_101
    ko: "\uD1B5\uACC4\uC801 \uD638\uAE30\uC2EC\uC744 \uC778\uC815\uD574\uC8FC\uC2DC\uB2C8
      \uC601\uAD11\uC785\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC81C \uAC10\uAC01\uC740
      \uB354 \uC815\uAD50\uD558\uB2C8 \uB05D\uAE4C\uC9C0 \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Cunning_1
    ko: "\uACA9\uB824\uB97C \uC774\uC6A9\uD574 \uC790\uC2E0\uC758 \uBCC0\uCE59 \uD3FC\uC744
      \uB05D\uAE4C\uC9C0 \uACE0\uC9D1\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Believer_101
    ko: "\uB370\uC774\uD130\uC801 \uACA9\uB824\uB294 \uAC10\uC0AC\uD569\uB2C8\uB2E4\uB9CC,
      \uC81C \uC29B \uD3FC\uC740 \uBBF8\uB798\uB97C \uC704\uD55C \uD601\uC2E0\uC785\uB2C8\uB2E4.
      \uBA48\uCD94\uC9C0 \uC54A\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Believer_1
    ko: "\uACA9\uB824\uC870\uCC28 \uBCF8\uC778\uC758 \uC2E0\uB150\uC744 \uAEBE\uC9C0
      \uBABB\uD574 \uB3C5\uB2E8\uC801\uC778 \uBC29\uD5A5\uC73C\uB85C \uACE0\uC9D1\uC744
      \uD53C\uC6C0."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Cold_002
    ko: "\uAE30\uBCF8 \uB8E8\uD2F4\uC744 \uBB34\uC2DC\uD558\uB294 \uAC74 \uAC1C\uC778\uC758
      \uC695\uC2EC\uC774\uB2E4. \uC131\uACF5\uB960\uC774 \uB2F4\uBCF4\uB418\uC9C0
      \uC54A\uB294 \uBCC0\uCE59 \uC29B\uC740 \uD300\uC758 \uBC38\uB7F0\uC2A4\uB97C
      \uBB34\uB108\uB728\uB9AC\uACE0 \uC788\uC5B4. \uB2F9\uC7A5 \uD3FC \uAD50\uC815\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Planner_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uD300\uC758 \uBC38\uB7F0\uC2A4\uAC00 \uC6B0\uC120\uC774\uBBC0\uB85C
      \uC9C0\uC2DC\uB300\uB85C \uB530\uB974\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Planner_2
    ko: "\uAC10\uC815 \uC5C6\uC774 \uD6A8\uC728\uC131\uB9CC \uBCF4\uACE0 \uC9C0\uC2DC\uB97C
      \uAE30\uACC4\uC801\uC73C\uB85C \uC218\uC6A9\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Opportunist_201
    ko: "\uAC1C\uC778 \uC695\uC2EC\uC774\uB77C\uB2C8\uC694, \uC81C \uC7A0\uC7AC\uB825\uC744
      \uBCF4\uC5EC\uC904 \uAE30\uD68C\uB97C \uC65C \uB9C9\uC73C\uC2DC\uB294 \uAC70\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Opportunist_2
    ko: "\uC9C8\uCC45\uC744 \uC790\uC2E0\uC758 \uAC00\uCE58 \uBC1C\uD604 \uAE30\uD68C
      \uBC15\uD0C8\uB85C \uBCF4\uC544 \uD6C8\uB828 \uC758\uC695 \uC0C1\uC2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cunning_201
    ko: "\uD6A8\uC728\uC131\uC744 \uC704\uD574 \uC81C \uC695\uC2EC\uC744 \uBC84\uB9AC\uACE0
      \uC815\uC11D \uD3FC\uC744 \uC644\uBCBD\uD788 \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Cunning_2
    ko: "\uC9C8\uCC45\uC744 \uACBD\uACE0\uB85C \uBC1B\uC544\uB4E4\uC5EC \uC790\uAE30
      \uB2A5\uB825\uC744 \uC99D\uBA85\uD558\uAE30 \uC704\uD574 \uD3FC\uC744 \uC5F0\uCD9C\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Believer_201
    ko: "\uAC10\uB3C5\uB2D8 \uD310\uB2E8\uC744 \uC874\uC911\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uC815\uC11D\uB300\uB85C \uD6C8\uB828\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Believer_2
    ko: "\uC790\uC2E0\uC758 \uC2E0\uB150\uC744 \uAD7D\uD788\uACE0 \uC2F6\uC9C0 \uC54A\uC9C0\uB9CC
      \uB300\uC2B9\uC801\uC778 \uCC28\uC6D0\uC5D0\uC11C \uC9C0\uC2DC\uB97C \uB530\uB984."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Cold_003
    ko: "\uAC10\uB3C5\uC740 \uBB34\uD45C\uC815\uD558\uAC8C \uAE30\uB85D\uC9C0\uB9CC
      \uCCD0\uB2E4\uBCF8\uB2E4. \uC120\uC218\uAC00 \uC29B\uC744 \uC3E0 \uB54C\uB9C8\uB2E4
      \uC2E4\uD328 \uC5EC\uBD80\uB9CC \uCCB4\uD06C\uD558\uACE0, \uC544\uBB34\uB7F0
      \uD53C\uB4DC\uBC31 \uC5C6\uC774 \uC218\uCCA9\uC5D0 '\uAE30\uBCF8 \uB8E8\uD2F4
      \uC704\uBC18'\uC774\uB77C\uACE0 \uC801\uB294\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Planner_301
    ko: "\uAE30\uBCF8 \uB8E8\uD2F4 \uC704\uBC18\uC774\uB77C \uC801\uC73C\uC168\uC5B4...
      \uB0B4 \uC124\uACC4\uAC00 \uADFC\uBCF8\uC801\uC73C\uB85C \uD2C0\uB838\uB2E4\uB294
      \uB73B\uC778\uAC00? \uC544\uBB34\uAC83\uB3C4 \uC190\uC5D0 \uC548 \uC7A1\uD600."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Planner_3
    ko: "\uCE68\uBB35\uACFC \uAE30\uB85D\uC744 \uC804\uB7B5\uC801 \uC2E4\uD328\uB85C
      \uAC04\uC8FC\uD574 \uD3FC\uC774 \uC644\uC804\uD788 \uBD95\uAD34\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Opportunist_301
    ko: "\uC88B\uC544, \uC9C0\uAE08 \uAE30\uB85D\uC744 \uC548 \uC88B\uAC8C \uBC1B\uC544\uB450\uACE0
      \uB098\uC911\uC5D0 \uBAB0\uB798 \uC774 \uC29B\uC744 \uC644\uC131\uD574\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Opportunist_3
    ko: "\uAC04\uC12D\uC774 \uC5C6\uC744 \uB54C \uC790\uAE30\uB9CC\uC758 \uBB34\uAE30\uB97C
      \uC644\uC131\uD558\uC5EC \uAC1C\uC778\uC801\uC778 \uC131\uCDE8\uB97C \uB3C4\uBAA8\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Cunning_301
    ko: "\uC77C\uB2E8 \uC9C0\uAE08\uC740 \uC815\uC11D\uB300\uB85C \uC3D8\uB294 \uCC99\uD574\uC57C\uC9C0.
      \uB098\uC911\uC5D0 \uD63C\uC790 \uC5F0\uC2B5\uD558\uBA74 \uB3FC."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Cunning_3
    ko: "\uAC10\uB3C5\uC758 \uB208\uCE58\uB97C \uBCF4\uB290\uB77C \uD6C8\uB828 \uC9D1\uC911\uB825\uC774
      \uBD84\uC0B0\uB418\uC5B4 \uAE30\uC220 \uC9C4\uC804 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Believer_301
    ko: "\uB9D0\uC500\uC774 \uC5C6\uB294 \uAC74 \uB0B4 \uC7A0\uC7AC\uB825\uC744 \uBCF4\uC2E0
      \uAC70\uC57C. \uB098\uB97C \uBBFF\uACE0 \uB05D\uAE4C\uC9C0 \uBC00\uACE0 \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Believer_3
    ko: "\uAC04\uC12D\uC774 \uC5C6\uC790 \uC790\uAE30 \uD655\uC2E0\uC774 \uCEE4\uC838
      \uAE30\uC220\uC744 \uB05D\uAE4C\uC9C0 \uC644\uC131\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Instinct_001
    ko: "\uD300\uC758 \uAE30\uBCF8 \uB8E8\uD2F4\uC744 \uC131\uC2E4\uD788 \uC218\uD589\uD558\uB358
      \uC5D0\uC774\uC2A4 \uC120\uC218\uAC00 \uD504\uB85C\uC758 '\uD035 \uB9B4\uB9AC\uC2A4'\uB97C
      \uD749\uB0B4 \uB0B4\uAE30 \uC2DC\uC791\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Instinct_002
    ko: "\uC120\uC218\uB294 \uC774 \uBCC0\uCE59\uC801\uC778 \uC29B \uD3FC\uC774 \uC790\uC2E0\uC758
      \uD0C0\uACE0\uB09C \uAC10\uAC01\uC744 \uADF9\uB300\uD654\uD560 '\uC2E0\uC758
      \uD55C \uC218'\uB77C\uACE0 \uAD73\uAC8C \uBBFF\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Instinct_003
    ko: "\uADF8\uB7EC\uB098 \uC120\uC218\uC758 \uC29B\uC740 \uB9BC\uC744 \uD06C\uAC8C
      \uBC97\uC5B4\uB098\uACE0 \uC788\uC73C\uBA70, \uD300\uC758 \uC804\uCCB4\uC801\uC778
      \uD6C8\uB828 \uD750\uB984\uC744 \uB04A\uC5B4\uBA39\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Instinct_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Instinct_001
    ko: "\uB108\uC758 \uADF8 \uACFC\uAC10\uD55C \uC2DC\uB3C4\uC640 \uC29B \uB9B4\uB9AC\uC2A4
      \uAC10\uAC01\uC740 \uC815\uB9D0 \uD0C0\uACE0\uB09C \uAC83 \uAC19\uB2E4. \uADF8\uB7F0
      \uBCF8\uB2A5\uC801\uC778 \uAC10\uAC01\uC744 \uC0B4\uB9AC\uBA74\uC11C\uB3C4,
      \uD300\uC758 \uC815\uC11D \uD3FC\uACFC \uACB0\uD569\uD574 \uB108\uB9CC\uC758
      \uD544\uC0B4\uAE30\uB85C \uC644\uC131\uD574\uBCF4\uB294 \uAC74 \uC5B4\uB54C?"
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uC81C \uC7AC\uB2A5\uC744 \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694!
      \uAC10\uB3C5\uB2D8 \uC870\uC5B8\uB300\uB85C \uC81C \uD3FC\uACFC \uACB0\uD569\uD574\uC11C
      \uC9C4\uC9DC \uC29B\uC744 \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Bluffer_1
    ko: "\uBCF8\uC778\uC758 \uB2A5\uB825\uC744 \uC778\uC815\uBC1B\uC558\uB2E4\uACE0
      \uB290\uAEF4 \uC790\uC874\uAC10\uC774 \uACE0\uCDE8\uB418\uBA70 \uAE30\uC220
      \uC2B5\uB4DD\uC5D0 \uBAB0\uC785\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Wild_101
    ko: "\uC81C \uC57C\uC131\uC801\uC778 \uAC10\uAC01\uC774 \uC815\uC11D\uACFC \uB9CC\uB098\uBA74
      \uB204\uAD6C\uB3C4 \uB9C9\uC9C0 \uBABB\uD560 \uAC81\uB2C8\uB2E4. \uB2F9\uC7A5
      \uC2DC\uC791\uD558\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Wild_1
    ko: "\uC790\uC2E0\uC758 \uBCF8\uB2A5\uC801 \uAC10\uAC01\uC744 \uC778\uC815\uBC1B\uC544
      \uD300 \uD6C8\uB828\uC5D0 \uC801\uADF9\uC801\uC73C\uB85C \uD611\uC870\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Egoist_101
    ko: "\uACB0\uAD6D \uC81C \uCC9C\uC7AC\uC131\uC744 \uBCF4\uC168\uAD70\uC694. \uC815\uC11D\uACFC
      \uACB0\uD569\uD558\uBA74 \uC644\uBCBD\uD55C \uBB34\uAE30\uAC00 \uB420 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Egoist_1
    ko: "\uC790\uC2E0\uC758 \uB2A5\uB825\uC744 \uC99D\uBA85\uD558\uB824\uB294 \uC695\uAD6C\uC640
      \uAC10\uB3C5\uC758 \uC778\uC815\uC744 \uACB0\uD569\uD558\uC5EC \uD3ED\uBC1C\uC801\uC778
      \uC2DC\uB108\uC9C0\uB97C \uB0C4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Fighter_101
    ko: "\uC81C \uD0C0\uACE0\uB09C \uAC10\uAC01\uC744 \uBBFF\uC5B4\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uB8E8\uD2F4\uC744 \uC815\uBCF5\uD574\uC11C
      \uC644\uBCBD\uD55C \uC288\uD130\uAC00 \uB418\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Fighter_1
    ko: "\uB3C4\uC804\uC744 \uC88B\uC544\uD558\uB294 \uC131\uD5A5\uC774\uB77C \uC815\uC11D
      \uB8E8\uD2F4\uC744 \uC815\uBCF5 \uB300\uC0C1\uC73C\uB85C \uC0BC\uC544 \uBE60\uB974\uAC8C
      \uC2B5\uB4DD\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Instinct_002
    ko: "\uADF8\uAC74 \uAE30\uC220\uC774 \uC544\uB2C8\uB77C \uADF8\uC800 \uAC10\uAC01\uC5D0
      \uC758\uC874\uD55C \uBB34\uBAA8\uD55C \uB3C4\uBC15\uC77C \uBFD0\uC774\uC57C.
      \uB124 \uC5D0\uACE0\uB9CC \uC55E\uC138\uC6B0\uB2E4\uAC04 \uD300 \uC804\uCCB4\uAC00
      \uBB34\uB108\uC9C4\uB2E4. \uB2F9\uC7A5 \uADF8 \uD3FC \uBC84\uB9AC\uACE0 \uC6D0\uCE59\uC73C\uB85C
      \uB3CC\uC544\uC640."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bluffer_201
    ko: "\uC81C \uC2A4\uD0C0\uC77C\uC744 \uBB34\uC2DC\uD558\uC2DC\uB2E4\uB2C8...
      \uC624\uB298 \uC29B\uC774 \uC548 \uB4E4\uC5B4\uAC00\uB294 \uAC74 \uAC10\uB3C5\uB2D8
      \uB54C\uBB38\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Bluffer_2
    ko: "\uC9C8\uCC45\uC744 \uC790\uC874\uC2EC\uC5D0 \uB300\uD55C \uACF5\uACA9\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uAC10\uB3C5\uACFC \uB300\uB9BD\uD558\uACE0 \uD6C8\uB828\uC744
      \uAC70\uBD80\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Wild_201
    ko: "\uBCF8\uB2A5\uC744 \uC8FD\uC774\uB77C\uB294 \uAC81\uB2C8\uAE4C? \uADF8\uB7FC
      \uC800\uB294 \uC544\uBB34\uAC83\uB3C4 \uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Wild_2
    ko: "\uAC10\uAC01\uC744 \uC5B5\uC555\uB2F9\uD55C\uB2E4\uACE0 \uB290\uAEF4 \uC758\uC695\uC744
      \uC644\uC804\uD788 \uC0C1\uC2E4\uD558\uACE0 \uAE30\uB7C9\uC774 \uD1F4\uBCF4\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Egoist_201
    ko: "\uC81C \uD601\uC2E0\uC744 \uC774\uD574 \uBABB \uD558\uC2DC\uB124\uC694.
      \uC81C\uAC00 \uC65C \uAC10\uB3C5\uB2D8 \uD300\uC5D0\uC11C \uB18D\uAD6C\uB97C
      \uD574\uC57C \uD558\uB294\uC9C0 \uC758\uBB38\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Egoist_2
    ko: "\uC790\uC874\uC2EC\uC744 \uC2EC\uAC01\uD558\uAC8C \uD6FC\uC190\uB2F9\uD574
      \uAC10\uB3C5\uACFC \uC804\uBA74\uC804(\uAC08\uB4F1)\uC744 \uBC8C\uC784."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Fighter_201
    ko: "\uC9C8\uCC45\uD558\uC2DC\uB2C8 \uB354 \uC624\uAE30\uAC00 \uC0DD\uAE41\uB2C8\uB2E4.
      \uC81C\uAC00 \uC815\uC11D \uB8E8\uD2F4\uAE4C\uC9C0 \uC644\uBCBD\uD558\uAC8C
      \uC18C\uD654\uD574\uC11C \uCF54\uB97C \uB0A9\uC791\uD558\uAC8C \uD574\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Fighter_2
    ko: "\uD22C\uC7C1\uC2EC\uC744 \uC790\uADF9\uBC1B\uC544 \uAC10\uB3C5\uC744 \uC774\uAE30\uAE30
      \uC704\uD574 \uC644\uBCBD\uD55C \uD3FC\uC73C\uB85C \uBCF5\uADC0\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Ch_Instinct_003
    ko: "\uAC10\uB3C5\uC740 \uBB34\uD45C\uC815\uD558\uAC8C \uAE30\uB85D\uC9C0\uB9CC
      \uCCD0\uB2E4\uBCF8\uB2E4. \uC120\uC218\uAC00 \uC29B\uC744 \uC3E0 \uB54C\uB9C8\uB2E4
      \uC2E4\uD328 \uC5EC\uBD80\uB9CC \uCCB4\uD06C\uD558\uACE0, \uC544\uBB34\uB7F0
      \uD53C\uB4DC\uBC31 \uC5C6\uC774 \uC218\uCCA9\uC5D0 '\uD1B5\uC81C \uBD88\uB2A5'\uC774\uB77C\uACE0
      \uC801\uB294\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Bluffer_301
    ko: "\uB098\uB97C \uBB34\uC2DC\uD574? \uC88B\uC544, \uB2E4\uB4E4 \uBCF4\uB294
      \uC55E\uC5D0\uC11C \uAC00\uC7A5 \uD654\uB824\uD55C \uC29B\uC744 \uC131\uACF5\uC2DC\uCF1C\uC11C
      \uAE5C\uC9DD \uB180\uB77C\uAC8C \uD574\uC8FC\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Bluffer_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uAD00\uC2EC\uC744 \uC790\uC2E0\uC758 \uC874\uC7AC\uAC10\uC744
      \uB4DC\uB7EC\uB0BC \uAE30\uD68C\uB85C \uC0BC\uC544 \uBB34\uB9AC\uD558\uAC8C
      \uC2DC\uB3C4\uD558\uB2E4\uAC00 \uB8E8\uD2F4 \uC790\uCCB4\uAC00 \uBD95\uAD34\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Wild_301
    ko: "\uC800 \uC218\uCCA9\uC5D0 \uB300\uCCB4 \uBB50\uB77C\uACE0 \uC801\uC73C\uC2DC\uB294
      \uAC70\uC9C0? \uB0B4 \uAC10\uAC01\uC744 \uD1B5\uC81C\uD558\uC2DC\uB824\uACE0?
      \uB09C \uB0B4 \uBC29\uC2DD\uB300\uB85C \uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Wild_3
    ko: "\uB3D9\uC758 \uC81C\uC57D\uC744 \uB290\uAEF4 \uAC10\uB3C5\uC758 \uC9C0\uC2DC\uB97C
      \uC815\uBA74\uC73C\uB85C \uAC70\uC2A4\uB974\uACE0 \uB3C5\uC790\uC801\uC778
      \uBCC0\uCE59 \uD3FC\uC744 \uB05D\uAE4C\uC9C0 \uACE0\uC9D1\uD568."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Egoist_301
    ko: "\uB204\uAC00 \uBB50\uB798\uB3C4 \uB0B4\uAC00 \uCD5C\uACE0\uB2E4. \uB0B4
      \uC29B\uC774 \uB4E4\uC5B4\uAC00\uAE30 \uC2DC\uC791\uD558\uBA74 \uB2E4\uB4E4
      \uB098\uD55C\uD14C \uBB34\uB98E \uAFC7\uAC8C \uB420 \uAC70\uC57C."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Egoist_3
    ko: "\uC678\uBD80 \uD53C\uB4DC\uBC31\uC744 \uCC28\uB2E8\uD558\uACE0 \uC2A4\uC2A4\uB85C
      \uC99D\uBA85\uD558\uACA0\uB2E4\uB294 \uB3C5\uAE30\uAC00 \uC62C\uB77C \uAE30\uC220\uC801
      \uB3CC\uD30C\uAD6C\uB97C \uCC3E\uC544\uB0C4."
    en: 
    ja: 
  - stringKey: Event_00007_Desc_Fighter_301
    ko: "\uB098\uB97C \uD1B5\uC81C\uD558\uB824\uACE0 \uD574? \uB09C \uC774 \uB8E8\uD2F4\uC744
      \uAE68\uBD80\uC218\uACE0 \uB354 \uAC15\uD55C \uBCC0\uCE59\uC744 \uB9CC\uB4E4
      \uAC70\uC57C."
    en: 
    ja: 
  - stringKey: Event_00007_Rs_Fighter_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uAD00\uC2EC\uC744 \uACBD\uC7C1\uC73C\uB85C \uC778\uC2DD\uD574
      \uB8E8\uD2F4\uC744 \uD30C\uAD34\uD558\uB294 \uBCC0\uCE59 \uC29B\uC5D0\uB9CC
      \uC9D1\uCC29\uD558\uAC8C \uB428."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Discipline_001
    ko: "\uC0C8\uBCBD 5\uC2DC, \uC548\uAC1C \uC790\uC6B1\uD55C \uCCB4\uC721\uAD00.
      3\uC810 \uC29B \uC7A0\uC7AC\uB825\uC774 \uB192\uC740 \uC120\uC218\uAC00 \uB9BC\uC758
      \uD0C4\uC131, \uACF5\uC758 \uD68C\uC804\uC218, \uB9B4\uB9AC\uC2A4 \uAC01\uB3C4\uB97C
      1\uB3C4 \uB2E8\uC704\uB85C \uC815\uBC00\uD558\uAC8C \uC870\uC815\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Discipline_002
    ko: "\uC790\uC2E0\uC758 \uB8E8\uD2F4\uC774 \uC870\uAE08\uC774\uB77C\uB3C4 \uD2C0\uC5B4\uC9C0\uBA74
      \uCC98\uC74C\uBD80\uD130 \uB2E4\uC2DC \uC2DC\uC791\uD558\uB294 \uAC15\uBC15\uC801\uC778
      \uD6C8\uB828\uC774 \uACC4\uC18D\uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Discipline_003
    ko: "\uBC14\uB2E5\uC5D0\uB294 \uC131\uACF5\uC744 \uC704\uD55C \uC218\uB9CE\uC740
      \uC218\uC2DD\uC774 \uC801\uD78C \uB178\uD2B8\uB97C \uD3BC\uCCD0\uB193\uC740
      \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Discipline_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Discipline_001
    ko: "\uADF8 \uC815\uBC00\uD568\uC740 \uC815\uB9D0 \uD6CC\uB96D\uD558\uB2E4. \uD558\uC9C0\uB9CC
      \uC218\uC2DD\uC5D0\uB9CC \uB9E4\uBAB0\uB418\uBA74 \uBAB8\uC774 \uAE30\uC5B5\uD558\uB294
      \uAC10\uAC01\uC774 \uBB34\uB38C\uC9C8 \uC218 \uC788\uC5B4.\uC774\uC81C\uB294
      \uB124 \uBAB8\uC774 \uC774\uB044\uB294 \uB9AC\uB4EC\uC5D0 10% \uC815\uB3C4\uB294
      \uB354 \uB9E1\uACA8\uBCF4\uB294 \uAC8C \uC5B4\uB5A8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Principled_101
    ko: "\uB370\uC774\uD130\uC640 \uAC10\uAC01\uC758 \uC870\uD654\uB77C... \uC218\uC6A9\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uB9AC\uB4EC\uC744 \uB8E8\uD2F4\uC5D0 \uC815\uC2DD\uC73C\uB85C \uD3B8\uC785\uC2DC\uD0A4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Principled_1
    ko: "\uAC10\uB3C5\uC758 \uB17C\uB9AC\uC801\uC778 \uC81C\uC548\uC744 \uC790\uC2E0\uC758
      \uC6D0\uCE59\uC5D0 \uD3EC\uD568\uC2DC\uCF1C \uC989\uAC01 \uBCF4\uC644\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Guardian_101
    ko: "\uC81C \uBD84\uC11D\uC774 \uBD80\uC871\uD588\uAD70\uC694. \uD300\uC758 \uC9C8\uC11C\uB97C
      \uC9C0\uD0A4\uAE30 \uC704\uD574 \uAC10\uAC01\uAE4C\uC9C0 \uC644\uBCBD\uD788
      \uB9C8\uC2A4\uD130\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Guardian_1
    ko: "\uAC10\uB3C5\uC758 \uC870\uC5B8\uC744 \uD300\uC744 \uBCF4\uD638\uD558\uAE30
      \uC704\uD55C \uC9C0\uCE68\uC73C\uB85C \uD574\uC11D\uD558\uC5EC \uD22C\uC9C0\uB97C
      \uBD88\uD0DC\uC6C0."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Tactician_101
    ko: "\uC218\uCE58\uB294 \uC808\uB300\uC801\uC785\uB2C8\uB2E4. \uAC10\uAC01\uC744
      \uACB0\uD569\uD558\uB294 \uAC83\uBCF4\uB2E8 \uC774 \uC218\uC2DD \uADF8\uB300\uB85C
      \uC218\uD589\uD558\uB294 \uAC8C \uC2B9\uB960\uC774 \uB192\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Tactician_1
    ko: "\uB370\uC774\uD130\uC801 \uC2E0\uB150\uC774 \uAC15\uD574 \uAC10\uB3C5\uC758
      \uAC10\uAC01\uC801 \uC870\uC5B8\uC744 \uB17C\uB9AC\uC801\uC73C\uB85C \uAC70\uBD80\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Exemplary_101
    ko: "\uAC10\uC0AC\uD569\uB2C8\uB2E4! \uC5ED\uC2DC \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uC774
      \uC633\uC73C\uC2ED\uB2C8\uB2E4. \uD300\uC6D0\uB4E4\uB3C4 \uC81C \uAC10\uAC01\uC801\uC778
      \uC29B\uC744 \uBC30\uC6B0\uBA74 \uC88B\uC544\uD560 \uAC70\uC608\uC694."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Exemplary_1
    ko: "\uAC10\uB3C5\uC758 \uC778\uC815\uC744 \uBC1B\uC790 \uC790\uC874\uAC10\uC774
      \uB192\uC544\uC838 \uAE0D\uC815\uC801\uC778 \uBD84\uC704\uAE30\uB85C \uD6C8\uB828\uC744
      \uC774\uC5B4\uAC10."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Discipline_002
    ko: "0.1\uB3C4\uC758 \uC624\uCC28\uB97C \uB530\uC9C0\uB294 \uAC74 \uD6C8\uB828\uC774
      \uC544\uB2C8\uB77C \uBD88\uC548\uC758 \uC0B0\uBB3C\uC77C \uBFD0\uC774\uC57C.
      \uACB0\uACFC\uAC00 \uB098\uC624\uC9C0 \uC54A\uB294 \uC644\uBCBD\uC8FC\uC758\uB294
      \uB3C5\uC774\uB2E4. \uB2F9\uC7A5 \uB178\uD2B8 \uCE58\uC6B0\uACE0 \uBAB8\uC73C\uB85C
      \uC9C1\uC811 \uBD80\uB52A\uD788\uB294 \uD6C8\uB828\uC73C\uB85C \uBC14\uAFD4\uB77C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Principled_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uC6D0\uCE59\uC744 \uC138\uC6B0\uB294 \uAC83\uC774
      \uC911\uC694\uD558\uBBC0\uB85C \uC9C0\uC2DC\uD558\uC2E0 \uB300\uB85C \uC989\uC2DC
      \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Principled_2
    ko: "\uC9C8\uCC45\uC744 \uC0C8\uB85C\uC6B4 \uC6D0\uCE59\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uAE30\uACC4\uC801\uC73C\uB85C \uC218\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Guardian_201
    ko: "\uC81C \uAC15\uBC15\uC774 \uD300\uC758 \uC815\uB3C8\uB41C \uBD84\uC704\uAE30\uB97C
      \uD574\uCE58\uACE0 \uC788\uB098\uC694? \uB108\uBB34 \uC8C4\uC1A1\uD569\uB2C8\uB2E4.
      \uBC14\uB85C \uBC14\uAFB8\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Guardian_2
    ko: "\uC9C8\uCC45\uC744 \uD300 \uC804\uCCB4\uC5D0 \uB300\uD55C \uBC29\uD574\uB85C
      \uB290\uAEF4 \uC8C4\uCC45\uAC10\uC5D0 \uD3FC\uC774 \uBB34\uB108\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Tactician_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uBAB8\uC73C\uB85C \uBD80\uB52A\uD788\uB294
      \uD6C8\uB828 \uB370\uC774\uD130\uAC00 \uB354 \uD6A8\uC728\uC801\uC774\uB77C\uBA74
      \uC989\uC2DC \uC804\uD658\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uC804\uC220\uC801 \uD6A8\uC728\uC131\uC5D0 \uB530\uB978
      \uBA85\uB839\uC73C\uB85C \uC778\uC2DD\uD574 \uAD70\uB9D0 \uC5C6\uC774 \uB530\uB984."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Exemplary_201
    ko: "\uB124, \uBC14\uB85C \uB178\uD2B8 \uCE58\uC6B0\uACA0\uC2B5\uB2C8\uB2E4.
      \uB2E4\uB978 \uC120\uC218\uB4E4\uB3C4 \uC800\uB97C \uB530\uB77C\uC624\uAC8C\uB054
      \uB2F9\uC7A5 \uBC29\uC2DD\uC744 \uBC14\uAFB8\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Exemplary_2
    ko: "\uD0C0\uC778\uC758 \uC2DC\uC120\uC744 \uC758\uC2DD\uD574 \uC9C8\uCC45\uC744
      \uBAA8\uBA74\uD558\uACE0 \uBC14\uB85C \uB2E4\uB978 \uBC29\uC2DD\uC758 \uBAA8\uBC94\uC774
      \uB418\uB824 \uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Discipline_003
    ko: "\uAC10\uB3C5\uC740 \uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC29B \uADA4\uC801\uC744
      3\uBD84\uAC04 \uC9C0\uCF1C\uBCF4\uB2E4\uAC00, \uC218\uCCA9\uC5D0 '\uC2E0\uCCB4
      \uD53C\uB85C \uB204\uC801 \uC8FC\uC758'\uB77C\uACE0 \uC801\uACE0, \uC120\uC218\uC758
      \uC5B4\uAE68\uB97C \uD55C \uBC88 \uD22D \uCE58\uACE0\uB294 \uC544\uBB34\uB7F0
      \uD53C\uB4DC\uBC31 \uC5C6\uC774 \uCCB4\uC721\uAD00\uC744 \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uD53C\uB85C\uB97C \uC5B8\uAE09\uD558\uC168\uC5B4...
      \uC774\uB300\uB85C\uBA74 \uB0B4 \uC6D0\uCE59\uC774 \uBB34\uB108\uC9C8 \uC218\uB3C4
      \uC788\uB2E4. \uC2EC\uB9AC\uC801 \uD0C0\uACA9\uC774 \uCEE4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Principled_3
    ko: "\uBB34\uC5B8\uC758 \uC9C0\uC801\uC744 \uC790\uAE30\uAD00\uB9AC\uC5D0 \uC2E4\uD328\uD588\uB2E4\uB294
      \uC2E0\uD638\uB85C \uBC1B\uC544\uB4E4\uC5EC \uADF9\uB3C4\uB85C \uBD88\uC548\uD574\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uB098\uB97C \uC9C0\uCF1C\uBCF4\uC168\uC5B4. \uB0B4\uAC00
      \uCCB4\uACC4\uC801\uC73C\uB85C \uD6C8\uB828\uD558\uACE0 \uC788\uB2E4\uB294
      \uAC78 \uC778\uC815\uBC1B\uC740 \uAC70\uC57C. \uB354 \uC644\uBCBD\uD574\uC838\uC57C
      \uD574."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Guardian_3
    ko: "\uCE68\uBB35 \uC18D\uC758 \uAD00\uCC30\uC744 \uC2E0\uB8B0\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uD6C8\uB828 \uD6A8\uC728\uC774 \uADF9\uB300\uD654\uB428."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Tactician_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uB178\uD2B8 \uB0B4\uC6A9\uC740 \uC815\uBCF4\uC785\uB2C8\uB2E4.
      \uD53C\uB85C \uB370\uC774\uD130\uB97C \uACE0\uB824\uD574 \uB8E8\uD2F4\uC744
      \uC7AC\uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Tactician_3
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uB294 \uD589\uB3D9\uC5D0\uC11C\uB3C4 \uB370\uC774\uD130\uB97C
      \uCD94\uCD9C\uD558\uC5EC \uC790\uAE30\uB9CC\uC758 \uD6C8\uB828 \uACC4\uD68D\uC744
      \uC7AC\uAD6C\uC131\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Exemplary_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC81C \uB8E8\uD2F4\uC5D0 \uC9C1\uC811 \uD53C\uB4DC\uBC31\uC744
      \uC548 \uC8FC\uC2DC\uACE0 \uADF8\uB0E5 \uAC00\uC168\uC5B4... \uB098\uB97C \uB354
      \uC774\uC0C1 \uBAA8\uBC94\uC73C\uB85C \uC548 \uBCF4\uC2DC\uB294 \uAC74\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Exemplary_3
    ko: "\uCE68\uBB35\uC744 \uBB34\uAD00\uC2EC\uC73C\uB85C \uAC04\uC8FC\uD558\uC5EC
      \uC2A4\uC2A4\uB85C \uC815\uCCB4\uC131\uC744 \uC783\uACE0 \uD6C8\uB828 \uC790\uCCB4\uAC00
      \uBD95\uAD34\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bond_001
    ko: "\uC0C8\uBCBD 5\uC2DC, \uC548\uAC1C \uC790\uC6B1\uD55C \uCCB4\uC721\uAD00.
      3\uC810 \uC29B \uC7A0\uC7AC\uB825\uC774 \uB192\uC740 \uC120\uC218\uAC00 \uB9BC\uC758
      \uD0C4\uC131, \uACF5\uC758 \uD68C\uC804\uC218, \uB9B4\uB9AC\uC2A4 \uAC01\uB3C4\uB97C
      1\uB3C4 \uB2E8\uC704\uB85C \uC815\uBC00\uD558\uAC8C \uC870\uC815\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bond_002
    ko: "\uC790\uC2E0\uC758 \uB8E8\uD2F4\uC774 \uC870\uAE08\uC774\uB77C\uB3C4 \uD2C0\uC5B4\uC9C0\uBA74
      \uCC98\uC74C\uBD80\uD130 \uB2E4\uC2DC \uC2DC\uC791\uD558\uB294 \uAC15\uBC15\uC801\uC778
      \uD6C8\uB828\uC774 \uACC4\uC18D\uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bond_003
    ko: "\uBC14\uB2E5\uC5D0\uB294 \uC131\uACF5\uC744 \uC704\uD55C \uC218\uB9CE\uC740
      \uC218\uC2DD\uC774 \uC801\uD78C \uB178\uD2B8\uB97C \uD3BC\uCCD0\uB193\uC740
      \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bond_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Bond_001
    ko: "\uC774\uB807\uAC8C\uAE4C\uC9C0 \uC815\uBC00\uD558\uAC8C \uB178\uB825\uD558\uB294
      \uBAA8\uC2B5\uC774 \uC815\uB9D0 \uB300\uACAC\uD558\uB2E4. \uD558\uC9C0\uB9CC
      \uC774\uC81C\uB294 \uC218\uC2DD\uBCF4\uB2E4\uB294 \uB124\uAC00 \uAC00\uC9C4
      \uB530\uB73B\uD55C \uAC10\uAC01\uC744 \uBBFF\uACE0 \uACF5\uC744 \uB358\uC838\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uC81C \uB178\uB825\uC744 \uC54C\uC544\uC8FC\uC154\uC11C
      \uC815\uB9D0 \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C
      \uC774\uC81C \uC81C \uAC10\uAC01\uC744 \uBBFF\uC5B4\uBCFC\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Kind_1
    ko: "\uC815\uC11C\uC801 \uC9C0\uC9C0\uB97C \uBC1B\uC790 \uAE34\uC7A5\uC774 \uD480\uB9AC\uBA70
      \uD3B8\uC548\uD558\uAC8C \uC29B \uBC38\uB7F0\uC2A4\uB97C \uCC3E\uC74C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uAED8\uC11C \uC800\uB97C \uBBFF\uC5B4\uC8FC\uC2E0\uB2E4\uBA74,
      \uC81C \uAC10\uAC01\uC744 \uB8E8\uD2F4\uC5D0 \uB179\uC5EC\uB0B4\uC5B4 \uAF2D
      \uACB0\uACFC\uB97C \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Loyal_1
    ko: "\uAC10\uB3C5\uC758 \uACA9\uB824\uB97C \uC0AC\uBA85\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uB354 \uB192\uC740 \uD5CC\uC2E0\uC73C\uB85C \uD6C8\uB828\uC5D0 \uC784\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Sincere_101
    ko: "\uC218\uC2DD\uACFC \uAC10\uAC01\uC744 \uBCD1\uD589\uD558\uB294 \uAC83\uC774
      \uB354 \uD6A8\uC728\uC801\uC778 \uD6C8\uB828\uBC95\uC774 \uB420 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
      \uADF8\uB807\uAC8C \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Sincere_1
    ko: "\uAC10\uB3C5\uC758 \uACA9\uB824\uB97C \uCCB4\uACC4\uC801 \uC131\uC7A5\uC758
      \uAE30\uD68C\uB85C \uC0BC\uC544 \uB354 \uD6A8\uC728\uC801\uC778 \uD6C8\uB828
      \uB8E8\uD2F4\uC744 \uC7AC\uC124\uACC4\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Moodmaker_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8 \uCD5C\uACE0! \uD558\uD558, \uAC10\uB3C5\uB2D8
      \uCE6D\uCC2C \uB4E4\uC73C\uB2C8\uAE4C \uB9BC\uC774 \uB354 \uB113\uC5B4 \uBCF4\uC774\uB294
      \uAC83 \uAC19\uC544\uC694!"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Moodmaker_1
    ko: "\uAC10\uB3C5\uC758 \uB530\uB73B\uD55C \uB9D0 \uD55C\uB9C8\uB514\uC5D0 \uC790\uC2E0\uAC10\uC774
      \uD3ED\uBC1C\uD558\uBA70 \uC29B \uCEE8\uB514\uC158\uC774 \uADF9\uC0C1\uC73C\uB85C
      \uCE58\uC19F\uC74C."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Bond_002
    ko: "\uC0C8\uBCBD\uBD80\uD130 \uB178\uD2B8\uB97C \uBD99\uC7A1\uACE0 \uC788\uB294
      \uAC74 \uD6C8\uB828\uC774 \uC544\uB2C8\uB77C \uBD88\uC548\uC758 \uD45C\uCD9C\uC774\uC57C.
      \uB108\uC758 \uADF8 \uAC15\uBC15\uC774 \uD300 \uBD84\uC704\uAE30\uB97C \uC5BC\uB9C8\uB098
      \uACBD\uC9C1\uB418\uAC8C \uB9CC\uB4DC\uB294\uC9C0 \uC544\uB098? \uB2F9\uC7A5
      \uB178\uD2B8 \uCE58\uC6B0\uACE0 \uC0DD\uAC01 \uC5C6\uC774 \uBAB8\uC744 \uC6C0\uC9C1\uC5EC."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Kind_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4... \uC81C\uAC00 \uD300\uC5D0 \uD3D0\uB97C
      \uB07C\uCE58\uACE0 \uC788\uC5C8\uAD70\uC694. \uC815\uB9D0 \uC8C4\uC1A1\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Kind_2
    ko: "\uC9C8\uCC45\uC744 \uAD00\uACC4\uC801 \uBD80\uC815\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uC758\uAE30\uC18C\uCE68\uD574\uC9C0\uACE0 \uC29B \uAC10\uAC01\uC744 \uC783\uC74C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Loyal_201
    ko: "\uC81C \uAC15\uBC15\uC774 \uD300\uC758 \uBC29\uD574\uAC00 \uB41C\uB2E4\uBA74...
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uB2F9\uC7A5 \uB178\uD2B8\uB97C \uBC84\uB9AC\uACE0
      \uAC10\uB3C5\uB2D8\uC774 \uC6D0\uD558\uC2DC\uB294 \uBC29\uC2DD\uC73C\uB85C
      \uBC14\uAFB8\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC744 \uCDA9\uC131\uC2EC\uC5D0 \uB300\uD55C \uACBD\uACE0\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uC989\uC2DC \uC9C0\uC2DC\uB97C \uC218\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Sincere_201
    ko: "\uBD88\uC548\uC758 \uC0B0\uBB3C\uC774\uB77C\uB2C8... \uC81C\uAC00 \uD574\uC628
      \uBD84\uC11D\uC774 \uD2C0\uB838\uB2E4\uB294 \uB9D0\uC500\uC774\uC2ED\uB2C8\uAE4C?
      \uC81C \uB8E8\uD2F4\uC744 \uB2E4\uC2DC \uC810\uAC80\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Sincere_2
    ko: "\uBD84\uC11D\uC801 \uB178\uB825\uC744 \uBD80\uC815\uB2F9\uD558\uC790 \uD070
      \uD63C\uB780\uC744 \uACAA\uC73C\uBA70 \uB8E8\uD2F4\uC774 \uC77C\uC2DC\uC801\uC73C\uB85C
      \uBD95\uAD34\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Moodmaker_201
    ko: "\uC81C \uB178\uD2B8\uAC00 \uD300\uC744 \uACBD\uC9C1\uC2DC\uD0A8\uB2E4\uACE0\uC694?
      \uB18D\uB2F4\uC774\uC2DC\uC8E0? \uB108\uBB34 \uB531\uB531\uD558\uAC8C \uAD74\uC9C0
      \uB9C8\uC138\uC694 \uAC10\uB3C5\uB2D8!"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Moodmaker_2
    ko: "\uC9C8\uCC45\uC5D0 \uBC18\uD56D\uC2EC\uC744 \uB290\uB07C\uBA70 \uC624\uD788\uB824
      \uD6C8\uB828 \uC9D1\uC911\uB3C4\uB97C \uB5A8\uC5B4\uB728\uB9AC\uACE0 \uB534\uCCAD\uC744
      \uD53C\uC6C0."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Bond_003
    ko: "\uAC10\uB3C5\uC740 \uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uC758 \uC29B\uC744
      3\uBD84\uAC04 \uC9C0\uCF1C\uBCF4\uB2E4\uAC00, \uC120\uC218\uC758 \uB178\uD2B8
      \uC704\uC5D0 \uC790\uC2E0\uC758 \uB530\uB73B\uD55C \uCEE4\uD53C \uD55C \uC794\uC744
      \uC870\uC6A9\uD788 \uC62C\uB824\uB450\uACE0, \uC5B4\uAE68\uB97C \uAC00\uBCCD\uAC8C
      \uD1A0\uB2E5\uC778 \uB4A4 \uB9D0\uC5C6\uC774 \uCCB4\uC721\uAD00\uC744 \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uCEE4\uD53C\uB97C... \uC800\uB97C \uAC71\uC815\uD558\uACE0
      \uACC4\uC168\uAD70\uC694. \uB2E4\uC2DC \uD3C9\uC815\uC2EC\uC744 \uCC3E\uACE0
      \uAE30\uBCF8\uBD80\uD130 \uD560\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Kind_3
    ko: "\uCE68\uBB35 \uC18D\uC758 \uBC30\uB824\uB97C \uD655\uC778\uD558\uACE0 \uC2EC\uB9AC\uC801
      \uC548\uC815\uAC10\uC744 \uC989\uC2DC \uD68C\uBCF5\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Loyal_301
    ko: "\uC800\uB97C \uBBFF\uACE0 \uAE30\uB2E4\uB824\uC8FC\uC2DC\uB294\uAD70\uC694.
      \uAC10\uB3C5\uB2D8\uC744 \uC704\uD574\uC11C\uB77C\uB3C4 \uC774 \uC0C8\uBCBD
      \uD6C8\uB828\uC744 \uC808\uB300 \uBA48\uCD9C \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Loyal_3
    ko: "\uC2E0\uB8B0\uC758 \uD589\uB3D9\uC744 \uD655\uC778\uD558\uACE0 \uB354 \uAC15\uD55C
      \uCC45\uC784\uAC10\uC744 \uB290\uAEF4 \uD6C8\uB828\uC758 \uBC00\uB3C4\uB97C
      \uB192\uC784."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Sincere_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC81C \uB178\uD2B8\uC5D0 \uCEE4\uD53C\uB97C...
      \uC81C\uAC00 \uB193\uCE58\uACE0 \uC788\uB358 \uC2EC\uB9AC\uC801 \uC548\uC815\uC774
      \uB370\uC774\uD130\uC600\uAD70\uC694. \uAE30\uB85D\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Sincere_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uC5B8\uC758 \uACA9\uB824\uC5D0\uC11C \uC0C8\uB85C\uC6B4
      \uD6C8\uB828 \uB370\uC774\uD130\uB97C \uB3C4\uCD9C\uD558\uC5EC \uC131\uC2E4\uD788
      \uBCF5\uAD6C\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Moodmaker_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uB2E4\uB140\uAC00\uC168\uB124! \uB098 \uC9C0\uCF1C\uBCF4\uC2DC\uB294\uAD6C\uB098.
      \uB354 \uC5F4\uC2EC\uD788 \uD574\uC11C \uD300 \uBD84\uC704\uAE30\uB97C \uB744\uC6CC\uC57C\uC9C0!"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Moodmaker_3
    ko: "\uAD00\uC2EC\uC744 \uD655\uC778\uBC1B\uACE0 \uC2E0\uC774 \uB098\uC11C \uBB34\uB9AC\uD558\uAC8C
      \uD37C\uD3EC\uBA3C\uC2A4\uB97C \uD558\uB824\uB2E4 \uC29B \uD3FC\uC774 \uB2E4\uC18C
      \uAC70\uCE60\uC5B4\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cold_001
    ko: "\uC0C8\uBCBD 5\uC2DC, \uC548\uAC1C \uC790\uC6B1\uD55C \uCCB4\uC721\uAD00.
      3\uC810 \uC29B \uC7A0\uC7AC\uB825\uC774 \uB192\uC740 \uC120\uC218\uAC00 \uB9BC\uC758
      \uD0C4\uC131, \uACF5\uC758 \uD68C\uC804\uC218, \uB9B4\uB9AC\uC2A4 \uAC01\uB3C4\uB97C
      1\uB3C4 \uB2E8\uC704\uB85C \uC815\uBC00\uD558\uAC8C \uC870\uC815\uD558\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cold_002
    ko: "\uC790\uC2E0\uC758 \uB8E8\uD2F4\uC774 \uC870\uAE08\uC774\uB77C\uB3C4 \uD2C0\uC5B4\uC9C0\uBA74
      \uCC98\uC74C\uBD80\uD130 \uB2E4\uC2DC \uC2DC\uC791\uD558\uB294 \uAC15\uBC15\uC801\uC778
      \uD6C8\uB828\uC774 \uACC4\uC18D\uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cold_003
    ko: "\uBC14\uB2E5\uC5D0\uB294 \uC131\uACF5\uC744 \uC704\uD55C \uC218\uB9CE\uC740
      \uC218\uC2DD\uC774 \uC801\uD78C \uB178\uD2B8\uB97C \uD3BC\uCCD0\uB193\uC740
      \uC0C1\uD0DC\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cold_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Cold_001
    ko: "\uC9C0\uAE08 \uB108\uC758 \uC218\uC2DD\uACFC \uB370\uC774\uD130 \uBD84\uC11D\uC740
      \uB9E4\uC6B0 \uD6CC\uB96D\uD558\uB2E4. \uD558\uC9C0\uB9CC \uBCC0\uC218 \uD1B5\uC81C\uB9CC\uC73C\uB85C\uB294
      \uD55C\uACC4\uAC00 \uC788\uC5B4. \uB8E8\uD2F4\uC5D0 '\uC720\uC5F0\uC131'\uC774\uB77C\uB294
      \uC218\uCE58\uB97C \uCD94\uAC00\uD574 \uBCF4\uB294 \uAC74 \uC5B4\uB5A8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Planner_101
    ko: "\uC720\uC5F0\uC131\uC774\uB77C\uB294 \uBCC0\uC218\uB97C \uB193\uCCE4\uAD70\uC694.
      \uB2F9\uC7A5 \uC624\uCC28 \uBC94\uC704\uB97C \uC218\uC2DD\uC5D0 \uCD94\uAC00\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uD6E8\uC52C \uD6A8\uC728\uC801\uC774\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Planner_1
    ko: "\uAC10\uB3C5\uC758 \uC81C\uC548\uC744 \uB17C\uB9AC\uC801 \uBCF4\uC644\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uD6C8\uB828\uC758 \uC9C8\uC744 \uB192\uC784."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Opportunist_101
    ko: "\uC720\uC5F0\uC131 \uBCC0\uC218\uB97C \uCD94\uAC00\uD558\uBA74 \uC81C \uC29B\uC774
      \uB354 \uC644\uBCBD\uD574\uC9C0\uACA0\uAD70\uC694. \uC88B\uC740 \uC804\uB7B5\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Opportunist_1
    ko: "\uACA9\uB824\uB97C \uD1B5\uD574 \uC790\uC2E0\uC758 \uC29B\uC744 \uB354 \uC815\uAD50\uD558\uAC8C
      \uB9CC\uB4E4 \uAE30\uD68C\uB85C \uC0BC\uC74C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cunning_101
    ko: "\uC720\uC5F0\uC131 \uC218\uCE58\uB77C... \uADF8\uAC74 \uC81C \uAC10\uAC01\uC758
      \uC601\uC5ED\uC785\uB2C8\uB2E4. \uC81C \uBC29\uC2DD\uB300\uB85C \uB05D\uAE4C\uC9C0
      \uACE0\uC218\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Cunning_1
    ko: "\uAC10\uB3C5\uC758 \uC81C\uC548\uC744 \uC790\uC2E0\uC758 \uD1B5\uC81C\uAD8C\uC744
      \uCE68\uD574\uD558\uB294 \uAC83\uC73C\uB85C \uAC04\uC8FC\uD558\uC5EC \uAC70\uBD80\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Believer_101
    ko: "\uB370\uC774\uD130 \uBD84\uC11D\uC740 \uCDA9\uBD84\uD569\uB2C8\uB2E4. \uC81C
      \uC218\uC2DD\uC5D0 \uC720\uC5F0\uC131 \uBCC0\uC218\uB97C \uB123\uB294 \uAC74
      \uC81C \uB17C\uB9AC\uC5D0 \uC5B4\uAE0B\uB0A9\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Believer_1
    ko: "\uC790\uC2E0\uC758 \uB370\uC774\uD130\uC801 \uC2E0\uB150\uC774 \uB108\uBB34
      \uAC15\uD574 \uAC10\uB3C5\uC758 \uC81C\uC548\uC744 \uB17C\uB9AC\uC801\uC73C\uB85C
      \uAC70\uBD80\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Cold_002
    ko: "\uC9C0\uAE08 \uB124 \uD6C8\uB828 \uBC29\uC2DD\uC740 \uBE44\uD6A8\uC728\uC758
      \uADF9\uCE58\uB2E4. 0.1\uB3C4\uC758 \uC624\uCC28\uB97C \uC7A1\uB290\uB77C \uC804\uCCB4\uC801\uC778
      \uD6C8\uB828\uB7C9\uACFC \uC2E0\uCCB4 \uBC38\uB7F0\uC2A4\uB97C \uD574\uCE58\uACE0
      \uC788\uC5B4. \uB8E8\uD2F4\uC744 \uC7AC\uC124\uACC4\uD558\uB77C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Planner_201
    ko: "\uD22C\uC790 \uB300\uBE44 \uD6A8\uC728\uC774 \uB0AE\uB2E4\uB294 \uC9C0\uC801,
      \uC218\uAE0D\uD569\uB2C8\uB2E4. \uC815\uC11D\uC801\uC778 \uC804\uCCB4 \uB8E8\uD2F4\uC73C\uB85C
      \uBCF5\uADC0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Planner_2
    ko: "\uC218\uCE58\uC801 \uBE44\uD6A8\uC728\uC744 \uC9C0\uC801\uBC1B\uC790 \uC989\uAC01\uC801\uC73C\uB85C
      \uC804\uB7B5\uC744 \uC218\uC815\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Opportunist_201
    ko: "\uC81C \uBD84\uC11D\uC758 \uD5C8\uC810\uC744 \uC9C0\uC801\uD558\uC2DC\uB2C8
      \uD560 \uB9D0\uC774 \uC5C6\uB124\uC694. \uD6A8\uC728\uC801\uC778 \uBC29\uC2DD\uC73C\uB85C
      \uBC14\uAFB8\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Opportunist_2
    ko: "\uC790\uC2E0\uC758 \uBD84\uC11D\uC774 \uD2C0\uB838\uC74C\uC744 \uC778\uC815\uD558\uACE0
      \uAC10\uB3C5\uC758 \uB17C\uB9AC\uC5D0 \uC989\uAC01 \uC21C\uC751\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cunning_201
    ko: "\uC1A1\uAD6C\uD569\uB2C8\uB2E4. \uD6A8\uC728\uC801\uC778 \uD6C8\uB828\uC73C\uB85C
      \uC989\uC2DC \uBCC0\uACBD\uD558\uC5EC \uACB0\uACFC\uB85C \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Cunning_2
    ko: "\uB17C\uB9AC\uC801 \uC9C8\uCC45\uC744 \uAD8C\uC704\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uAC89\uC73C\uB85C\uB294 \uC989\uC2DC \uC218\uC6A9\uD558\uACE0 \uC5F0\uCD9C\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Believer_201
    ko: "\uB370\uC774\uD130 \uAD00\uC810\uC5D0\uC11C \uC81C\uAC00 \uBE44\uD6A8\uC728\uC801\uC774\uAD70\uC694.
      \uD300\uC758 \uC2B9\uB960\uC744 \uC704\uD574 \uC989\uC2DC \uC7AC\uC124\uACC4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Believer_2
    ko: "\uC790\uC2E0\uC758 \uC2E0\uB150\uC744 \uAD7D\uD788\uACE0 \uC2F6\uC9C0 \uC54A\uC9C0\uB9CC,
      '\uC2B9\uB960'\uC774\uB77C\uB294 \uB370\uC774\uD130\uC801 \uBA85\uBD84\uC774
      \uC8FC\uC5B4\uC9C0\uC790 \uC804\uB7B5\uC801\uC73C\uB85C \uC218\uC6A9\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Cold_003
    ko: "\uAC10\uB3C5\uC740  \uBB34\uD45C\uC815\uD558\uAC8C \uC218\uC2DD \uBA87 \uAD70\uB370\uC5D0
      \uBC11\uC904\uC744 \uAE0B\uACE0, '\uD658\uACBD \uBCC0\uC218 \uB204\uB77D'\uC774\uB77C\uB294
      \uBA54\uBAA8\uB97C \uB0A8\uAE34 \uCC44 \uB9D0\uC5C6\uC774 \uCCB4\uC721\uAD00\uC744
      \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Planner_301
    ko: "\uD658\uACBD \uBCC0\uC218\uB97C \uB193\uCCE4\uB2E4\uB2C8... \uC644\uBCBD\uD558\uC9C0
      \uC54A\uC740 \uB0B4 \uB370\uC774\uD130\uB294 \uBB34\uAC00\uCE58\uD574. \uCC98\uC74C\uBD80\uD130
      \uB2E4\uC2DC \uC124\uACC4\uD558\uC790."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Planner_3
    ko: "\uC790\uC2E0\uC758 \uC644\uBCBD\uD588\uB358 \uC218\uC2DD\uC774 \uBD80\uC815\uB2F9\uD588\uB2E4\uACE0
      \uD310\uB2E8\uD574 \uC2A4\uC2A4\uB85C \uBD95\uAD34\uB428."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Opportunist_301
    ko: "\uD658\uACBD \uBCC0\uC218... \uADF8\uB798, \uB9BC\uC758 \uD0C4\uC131\uAE4C\uC9C0
      \uACE0\uB824\uD558\uBA74 \uB0B4 \uC29B\uC740 \uC808\uB300 \uC548 \uB9C9\uD788\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Opportunist_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uC5B8\uC758 \uD53C\uB4DC\uBC31\uC744 \uD1B5\uD574
      \uC790\uAE30\uB9CC\uC758 \uD544\uC0B4\uAE30\uB97C \uC644\uC131\uD558\uB294
      \uB370 \uC9D1\uC911\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Cunning_301
    ko: "\uD658\uACBD \uBCC0\uC218 \uB204\uB77D\uC774\uB77C\uB2C8... \uC77C\uB2E8\uC740
      \uAC10\uB3C5\uB2D8 \uC9C0\uC2DC\uB97C \uB530\uB974\uB294 \uCC99\uD558\uBA70
      \uB098\uC911\uC5D0 \uBAB0\uB798 \uC218\uC815\uD574\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Cunning_3
    ko: "\uAC10\uB3C5\uC758 \uD589\uB3D9\uC744 \uC804\uB7B5\uC801 \uBC29\uD574\uB85C
      \uC778\uC2DD\uD574 \uD6C8\uB828 \uC9D1\uC911\uB825\uC774 \uC800\uD558\uB428."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Believer_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC544\uBB34\uB7F0 \uB9D0\uC500\uC774 \uC5C6\uC73C\uC2DC\uB124...
      \uB0B4 \uB370\uC774\uD130\uB294 \uC774\uC81C \uAC00\uCE58\uAC00 \uC5C6\uB294
      \uAC74\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Believer_3
    ko: "\uCE68\uBB35\uC744 '\uB370\uC774\uD130\uC801 \uD3D0\uAE30'\uB85C \uD574\uC11D\uD558\uC5EC
      \uADF9\uC2EC\uD55C \uACE0\uB9BD\uAC10\uC5D0 \uBE60\uC838 \uC2A4\uC2A4\uB85C
      \uB8E8\uD2F4\uC744 \uBB34\uB108\uB728\uB9BC."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Instinct_001
    ko: "\uC0C8\uBCBD 5\uC2DC, \uC548\uAC1C \uC790\uC6B1\uD55C \uCCB4\uC721\uAD00.
      3\uC810 \uC29B \uC7A0\uC7AC\uB825\uC774 \uB192\uC740 \uC120\uC218\uAC00 1\uB3C4
      \uB2E8\uC704\uB85C \uAC01\uB3C4\uB97C \uC870\uC815\uD558\uBA70 \uD6C8\uB828
      \uC911\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Instinct_002
    ko: "\uC218\uC2DD \uB178\uD2B8\uB97C \uD3B4\uB193\uACE0 \uC644\uBCBD\uC5D0 \uC9D1\uCC29\uD558\uB294
      \uBAA8\uC2B5\uC740 \uBCF8\uB2A5\uC801\uC778 \uAC10\uAC01\uC744 \uC5B5\uC9C0\uB85C
      \uC218\uCE58\uD654\uD558\uB824\uB294 \uB4EF \uBCF4\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Instinct_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Instinct_001
    ko: "\uADF8\uB807\uAC8C \uC815\uBC00\uD558\uAC8C \uC870\uC815\uD558\uB824\uB2C8
      \uC624\uD788\uB824 \uB124 \uD0C0\uACE0\uB09C \uC29B \uAC10\uAC01\uC774 \uAC07\uD788\uB294
      \uAC83 \uAC19\uAD6C\uB098.  \uB124 \uC190\uB05D\uC5D0 \uB290\uAEF4\uC9C0\uB294
      \uACF5\uC758 \uBB34\uAC8C\uC640 \uB9BC\uC758 \uB192\uC774\uB9CC \uBBFF\uACE0
      \uB358\uC838\uBD10\uB77C. \uB108\uB9CC\uC758 \uBCF8\uB2A5\uC774 \uB2F5\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uC81C \uC7AC\uB2A5\uC744 \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694!
      \uC218\uC2DD \uBC84\uB9AC\uACE0 \uC81C \uC2E4\uB825\uC744 \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Bluffer_1
    ko: "\uBCF8\uC778\uC758 \uB2A5\uB825\uC744 \uC778\uC815\uBC1B\uC558\uB2E4\uACE0
      \uB290\uAEF4 \uC790\uC874\uAC10\uC774 \uACE0\uCDE8\uB418\uBA70 \uAE30\uC220
      \uC2B5\uB4DD\uC5D0 \uBAB0\uC785\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Wild_101
    ko: "\uC218\uC2DD \uC5C6\uC774 \uB358\uC9C0\uB2C8 \uD6E8\uC52C \uD3B8\uD558\uB124\uC694.
      \uC5ED\uC2DC \uC81C \uBCF8\uB2A5\uC774 \uB9DE\uC558\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Wild_1
    ko: "\uBCF8\uB2A5\uC801 \uAC10\uAC01\uC744 \uC778\uC815\uBC1B\uC544 \uD6C8\uB828\uC5D0
      \uBAB0\uC785\uD558\uB098 \uBCC4\uB3C4\uC758 \uAE30\uC220\uC801 \uC131\uC7A5\uC740
      \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Egoist_101
    ko: "\uAC10\uAC01\uC744 \uC0B4\uB9AC\uB77C\uACE0\uC694? \uC81C \uC218\uC2DD\uC774
      \uC644\uBCBD\uD55C\uB370 \uC65C \uBC29\uD574\uD558\uC2DC\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Egoist_1
    ko: "\uC790\uC2E0\uC758 \uB17C\uB9AC\uB97C \uD1B5\uC81C\uD558\uB824 \uD55C\uB2E4\uACE0
      \uD310\uB2E8\uD574 \uAC10\uB3C5\uC758 \uC81C\uC548\uC744 \uC804\uBA74 \uAC70\uBD80\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Fighter_101
    ko: "\uC81C \uB8E8\uD2F4\uC740 \uC81C\uAC00 \uC815\uD569\uB2C8\uB2E4. \uACA9\uB824\uB294
      \uAC10\uC0AC\uD558\uC9C0\uB9CC \uC218\uC2DD\uC740 \uADF8\uB300\uB85C \uB458
      \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Fighter_1
    ko: "\uB3C4\uC804\uC744 \uC88B\uC544\uD558\uB294 \uC131\uD5A5\uC774\uB098 \uAC10\uB3C5\uC758
      \uC870\uC5B8\uC774 \uC790\uC2E0\uC758 \uB8E8\uD2F4\uC744 \uC815\uBCF5\uD558\uB294
      \uB370 \uBC29\uD574\uAC00 \uB41C\uB2E4\uACE0 \uD310\uB2E8\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Instinct_002
    ko: "\uADF8 \uB178\uD2B8\uC5D0 \uC801\uD78C \uAC74 \uB18D\uAD6C\uAC00 \uC544\uB2C8\uB77C
      \uC218\uD559\uC774\uC57C. \uC29B\uC740 \uBA38\uB9AC\uB85C \uC3D8\uB294 \uAC8C
      \uC544\uB2C8\uB77C \uBAB8\uC73C\uB85C \uB290\uB07C\uB294 \uAC70\uB2E4. \uADF8\uB7F0
      \uAC15\uBC15\uC801\uC778 \uACC4\uC0B0\uC740 \uB124 \uBCF8\uB2A5\uC744 \uC8FD\uC774\uB294
      \uB3C5\uC774\uC57C. \uB2F9\uC7A5 \uB178\uD2B8 \uCE58\uC6CC\uB77C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bluffer_201
    ko: "\uC81C \uC2A4\uD0C0\uC77C\uC744 \uBB34\uC2DC\uD558\uC2DC\uB2E4\uB2C8...
      \uC624\uB298 \uC29B \uC548 \uB4E4\uC5B4\uAC00\uB294 \uAC74 \uAC10\uB3C5\uB2D8
      \uB54C\uBB38\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Bluffer_2
    ko: "\uC9C8\uCC45\uC744 \uC790\uC874\uC2EC\uC5D0 \uB300\uD55C \uACF5\uACA9\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uAC10\uB3C5\uACFC \uB300\uB9BD\uD558\uACE0 \uD6C8\uB828\uC744
      \uAC70\uBD80\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Wild_201
    ko: "\uC774 \uC9C0\uAE0B\uC9C0\uAE0B\uD55C \uACC4\uC0B0\uC5D0\uC11C \uD574\uBC29\uC2DC\uCF1C
      \uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uC774\uC81C\uC57C \uC9C4\uC9DC
      \uC81C \uC29B\uC774 \uB098\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Wild_2
    ko: "\uAC10\uAC01\uC744 \uC5B5\uC555\uD558\uB358 \uAC15\uBC15\uC774 \uD574\uC18C\uB418\uC790
      \uC7A0\uC7AC\uB825\uC774 \uC989\uC2DC \uD3ED\uBC1C\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Egoist_201
    ko: "\uB178\uD2B8\uAC00 \uC5C6\uC5B4\uB3C4 \uC81C \uBA38\uB9BF\uC18D\uC5D4 \uB370\uC774\uD130\uAC00
      \uC788\uC2B5\uB2C8\uB2E4. \uC2DC\uD0A4\uB294 \uB300\uB85C \uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Egoist_2
    ko: "\uC9C8\uCC45\uC5D0 \uBC18\uD56D\uC2EC\uC774 \uB4E4\uC9C0\uB9CC, \uC2A4\uC2A4\uB85C
      \uC2E4\uB825\uC744 \uC99D\uBA85\uD558\uAE30 \uC704\uD574 \uAE30\uACC4\uC801\uC73C\uB85C
      \uC218\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Fighter_201
    ko: "\uAC10\uD788 \uC81C \uB178\uB825\uC744 \uD3C4\uD558\uD558\uC2ED\uB2C8\uAE4C?
      \uD654\uB098\uC11C\uB77C\uB3C4 \uC548 \uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Fighter_2
    ko: "\uC9C8\uCC45\uC744 \uACBD\uC7C1\uC801 \uBAA8\uB3C5\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uAC10\uC815\uC801 \uB300\uB9BD \uD6C4 \uD6C8\uB828\uC744 \uC911\uB2E8\uD568."
    en: 
    ja: 
  - stringKey: Event_00008_Ch_Instinct_003
    ko: "\uAC10\uB3C5\uC740 \uBB35\uBB35\uD788 \uC120\uC218\uC758 \uC29B\uC744 5\uBD84\uAC04
      \uC9C0\uCF1C\uBCF4\uB2E4\uAC00, \uC120\uC218\uAC00 \uB178\uD2B8\uB97C \uBCF4\uB824
      \uD560 \uB54C\uB9C8\uB2E4 \uC218\uCCA9\uC73C\uB85C \uB178\uD2B8\uB97C \uAC00\uB9AC\uACE0,
      \uC544\uBB34 \uB9D0 \uC5C6\uC774 \uACF5\uC744 \uC8FC\uC6CC \uC120\uC218\uC758
      \uC190\uC5D0 \uC950\uC5EC\uC8FC\uAE30\uB9CC \uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Bluffer_301
    ko: "\uC65C \uB178\uD2B8\uB97C \uAC00\uB9AC\uC2DC\uC8E0? \uBCF4\uC5EC\uB4DC\uB9AC\uACE0
      \uC2F6\uC740\uB370... \uC29B\uC5D0 \uC9D1\uC911\uC774 \uC548 \uB418\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Bluffer_3
    ko: "\uC790\uC2E0\uC758 \uD654\uB824\uD55C \uC218\uC2DD\uC744 \uBCF4\uC5EC\uC904
      \uAE30\uD68C\uB97C \uCC28\uB2E8\uB2F9\uD574 \uC8FC\uC758\uAC00 \uBD84\uC0B0\uB428."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Wild_301
    ko: "\uC65C \uB0B4 \uB178\uD2B8\uB97C \uB9C9\uC73C\uC2DC\uC8E0? \uC800\uB294
      \uC81C \uBC29\uC2DD\uB300\uB85C \uBD84\uC11D\uD558\uACE0 \uC2F6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Wild_3
    ko: "\uD589\uB3D9\uC758 \uC81C\uC57D\uC744 \uB290\uAEF4 \uAC10\uB3C5\uC758 \uC720\uB3C4\uB97C
      \uC815\uBA74\uC73C\uB85C \uAC70\uC2A4\uB974\uACE0 \uB3C5\uC790\uC801 \uD6C8\uB828
      \uACE0\uC9D1."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Egoist_301
    ko: "\uB9D0\uC5C6\uC774 \uACF5\uB9CC \uC8FC\uC2E0\uB2E4\uACE0\uC694? \uC88B\uC2B5\uB2C8\uB2E4.
      \uB0B4 \uC29B\uC774 \uB4E4\uC5B4\uAC00\uB294 \uAC78 \uBCF4\uACE0\uB3C4 \uADF8\uB7F0
      \uD45C\uC815\uC77C\uC9C0 \uBCF4\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Egoist_3
    ko: "\uC678\uBD80 \uD53C\uB4DC\uBC31\uC744 \uCC28\uB2E8\uD558\uACE0 \uC2A4\uC2A4\uB85C
      \uC99D\uBA85\uD558\uACA0\uB2E4\uB294 \uB3C5\uAE30\uAC00 \uC62C\uB77C \uAE30\uC220\uC801
      \uB3CC\uD30C\uAD6C\uB97C \uCC3E\uC74C."
    en: 
    ja: 
  - stringKey: Event_00008_Desc_Fighter_301
    ko: "\uB9D0\uC5C6\uC774 \uACF5\uB9CC \uC8FC\uC2DC\uB2E4\uB2C8... \uC800\uB791
      \uB300\uACB0\uD558\uC790\uB294 \uB73B\uC785\uB2C8\uAE4C? \uCD5C\uACE0 \uAE30\uB85D\uC744
      \uAE68\uC11C \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00008_Rs_Fighter_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uC5B8\uC758 \uD589\uB3D9\uC744 \uACBD\uC7C1\uC73C\uB85C
      \uC778\uC2DD\uD574 \uD22C\uC7C1\uC2EC\uC744 \uBD88\uD0DC\uC6CC \uAE30\uC220\uC801
      \uC131\uCDE8\uB97C \uC774\uB8F8."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Discipline_001
    ko: "\uD6C8\uB828 \uC2DC\uC791 \uC9C1\uC804, \uBA3C\uC9C0 \uC11E\uC778 \uBC14\uB78C\uC774
      \uBD80\uB294 \uCF54\uD2B8. \uC120\uC218\uB294 \uC790\uC2E0\uC758 \uD328\uC2A4\uAC00
      \uB3D9\uB8CC\uC758 \uAC00\uC2B4\uC5D0 \uC815\uD655\uD788 \uB3C4\uB2EC\uD558\uC9C0
      \uC54A\uC790 \uD328\uB2C9\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Discipline_002
    ko: "\uD328\uC2A4\uB294 \uC815\uD574\uC9C4 \uADA4\uC801\uC744 \uADF8\uB824\uC57C
      \uD55C\uB2E4 \uB294 \uC6D0\uCE59\uC5D0 \uC0AC\uB85C\uC7A1\uD600 \uADFC\uC721\uC774
      \uAD73\uC740 \uCC44 \uACF5\uC744 \uB358\uC9C0\uACE0 \uC788\uACE0 \uC2E4\uC218
      \uD6C4\uC5D4 \uC8FC\uC800\uC549\uC544 \uC2A4\uC2A4\uB85C\uB97C \uC6D0\uB9DD\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Discipline_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Discipline_001
    ko: "\uD328\uC2A4\uC758 \uADA4\uC801\uC744 \uACE0\uBBFC\uD558\uB294 \uAC74 \uB124\uAC00
      \uD300 \uC804\uCCB4\uC758 \uD750\uB984\uC744 \uCC45\uC784\uC9C0\uACE0 \uC2F6\uC5B4
      \uD55C\uB2E4\uB294 \uC99D\uAC70\uACA0\uC9C0. \uD6CC\uB96D\uD55C \uD0DC\uB3C4\uB2E4.\uC774\uBC88\uC5D0\uB294 
      \uB3D9\uB8CC\uC758 '\uC6C0\uC9C1\uC784'\uC5D0\uB9CC \uC9D1\uC911\uD574\uC11C
      \uACF5\uC744 \uB358\uC838\uBCFC\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Principled_101
    ko: "\uADA4\uC801\uBCF4\uB2E4 \uC6C0\uC9C1\uC784... \uC0C8\uB85C\uC6B4 \uADDC\uCE59\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC774\uACA0\uC2B5\uB2C8\uB2E4. \uBC14\uB85C \uC218\uC815\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Principled_1
    ko: "\uC6C0\uC9C1\uC784\uC5D0 \uC9D1\uC911'\uC774\uB77C\uB294 \uC0C8\uB85C\uC6B4
      \uADDC\uCE59\uC744 \uC6D0\uCE59\uC73C\uB85C \uC0BC\uC544 \uC989\uC2DC \uD68C\uBCF5."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Guardian_101
    ko: "\uC81C\uAC00 \uD300\uC758 \uD750\uB984\uC744 \uB9DD\uCE58\uACE0 \uC788\uC5C8\uAD70\uC694.
      \uB3D9\uB8CC\uB9CC \uBCF4\uACE0 \uB354 \uC9D1\uC911\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Guardian_1
    ko: "\uCC45\uC784\uAC10\uC744 \uC9C0\uB098\uCE58\uAC8C \uB290\uAEF4 \uC555\uBC15\uAC10\uC774
      \uAC00\uC911\uB418\uC5B4 \uD328\uC2A4 \uD3FC\uC774 \uBB34\uAC70\uC6CC\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Tactician_101
    ko: "\uC0C1\uD669\uB9C8\uB2E4 \uBCC0\uD558\uB294 \uADA4\uC801\uC740 \uBCC0\uC218\uAC00
      \uB108\uBB34 \uB9CE\uC2B5\uB2C8\uB2E4. \uD1B5\uC81C \uBD88\uAC00\uB2A5\uD55C
      \uBCC0\uC218\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Tactician_1
    ko: "\uC790\uC2E0\uC758 \uC6D0\uCE59(\uC815\uD574\uC9C4 \uADA4\uC801)\uC744 \uBC84\uB9AC\uC9C0
      \uBABB\uD574 \uAC10\uB3C5\uC758 \uC870\uC5B8\uC744 \uB17C\uB9AC\uC801\uC73C\uB85C
      \uBC30\uCC99."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Exemplary_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C\uB124\uC694! \uB3D9\uB8CC\uB4E4\uACFC
      \uD638\uD761\uC744 \uB9DE\uCDB0 \uC131\uACF5\uC801\uC778 \uD328\uC2A4\uB97C
      \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Exemplary_1
    ko: "\uAC10\uB3C5\uC758 \uACA9\uB824\uB97C \uBAA8\uBC94\uC801 \uC131\uC7A5\uC758
      \uACC4\uAE30\uB85C \uC0BC\uC544 \uD65C\uAE30\uCC28\uAC8C \uD6C8\uB828 \uBCF5\uADC0."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Discipline_002
    ko: "\uADF8\uB807\uAC8C \uB358\uC9C0\uB2C8 \uADA4\uC801\uC774 \uBE44\uB6A4\uC5B4\uC9C0\uB294
      \uAC70\uB2E4. \uB124 \uAC15\uBC15\uC774 \uB3D9\uB8CC\uB4E4\uAE4C\uC9C0 \uACBD\uC9C1\uB418\uAC8C
      \uB9CC\uB4E4\uACE0 \uC788\uC5B4. \uC815\uB2F5\uC740 \uADA4\uC801\uC774 \uC544\uB2C8\uB77C
      \uB3D9\uB8CC\uC758 \uC190\uB05D\uC5D0 \uC788\uB2E4. \uB2F9\uC7A5 \uC77C\uC5B4\uB098\uC11C
      \uAE30\uBCF8\uAE30\uBD80\uD130 \uB2E4\uC2DC \uD574."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Principled_201
    ko: "\uB3D9\uB8CC\uB97C \uACBD\uC9C1\uC2DC\uCF30\uB2E4\uB2C8... \uC81C \uADA4\uC801\uBCF4\uB2E4
      \uD070 \uBB38\uC81C\uAD70\uC694. \uB2F9\uC7A5 \uAE30\uBCF8\uAE30\uBD80\uD130
      \uACE0\uCE58\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Principled_2
    ko: "\uC9C8\uCC45\uC744 \uC0C8\uB85C\uC6B4 \uADDC\uC728\uB85C \uC218\uC6A9\uD574
      \uAE30\uACC4\uC801\uC73C\uB85C \uBC18\uBCF5 \uD6C8\uB828\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Guardian_201
    ko: "\uD300\uC744 \uACBD\uC9C1\uC2DC\uCF30\uB2E4\uB2C8 \uC81C \uD328\uC2A4\uB294
      \uC815\uB9D0 \uCD5C\uC545\uC774\uC5C8\uC2B5\uB2C8\uB2E4... \uB2E4\uC2DC \uC2DC\uC791\uD560
      \uC790\uACA9\uC774 \uC788\uC744\uAE4C\uC694."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Guardian_2
    ko: "\uC9C8\uCC45\uC744 \uC790\uC2E0\uC758 \uC874\uC7AC \uAC00\uCE58 \uBD80\uC815\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uAE4A\uC740 \uC790\uCC45\uC5D0 \uBE60\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Tactician_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uB3D9\uB8CC\uC758 \uC190\uB05D\uC774 \uACB0\uACFC\uAC12\uC774\uB77C\uBA74
      \uADF8\uC5D0 \uB9DE\uCDB0 \uB370\uC774\uD130\uB97C \uB2E4\uC2DC \uC785\uB825\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uD6A8\uC728\uC801\uC778 \uC804\uC220 \uC9C0\uC2DC\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uC989\uC2DC \uACB0\uACFC(\uD328\uC2A4)\uB97C \uC218\uC815\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Exemplary_201
    ko: "\uB124, \uADA4\uC801\uC740 \uC77C\uB2E8 \uC811\uC5B4\uB450\uACA0\uC2B5\uB2C8\uB2E4.
      \uB2E4\uB978 \uC120\uC218\uB4E4\uB3C4 \uC800\uB97C \uB530\uB77C\uC624\uAC8C\uB054
      \uB2F9\uC7A5 \uACE0\uCE58\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Exemplary_2
    ko: "\uC2DC\uC120\uC744 \uC758\uC2DD\uD574 \uC9C8\uCC45\uC744 \uBAA8\uBA74\uD558\uB824\uB294
      \uBC29\uC5B4\uC801 \uD0DC\uB3C4\uB85C \uD6C8\uB828\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Discipline_003
    ko: "\uC120\uC218\uAC00 \uC2E4\uC218\uB97C \uBC18\uBCF5\uD558\uC790 \uAC10\uB3C5\uC740
      \uC544\uBB34 \uB9D0 \uC5C6\uC774  \uC120\uC218\uC758 \uAD73\uC740 \uC5B4\uAE68\uC640
      \uD314\uAFC8\uCE58\uB97C \uBD80\uB4DC\uB7FD\uAC8C \uB20C\uB7EC \uC774\uC644\uC2DC\uCF1C
      \uC900 \uB4A4 \uB2E4\uC2DC \uC790\uAE30 \uC790\uB9AC\uB85C \uB3CC\uC544\uAC00
      \uAE30\uB85D\uC9C0\uC5D0 \uBB34\uC5B8\uAC00\uB97C \uC801\uB294\uB2E4"
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC81C \uBAB8\uC744 \uB9CC\uC9C0\uC168\uC5B4...
      \uB0B4 \uD328\uC2A4 \uADA4\uC801\uC774 \uBB3C\uB9AC\uC801\uC73C\uB85C \uC798\uBABB\uB418\uC5C8\uB2E4\uB294
      \uB73B\uC778\uAC00? \uBAB8\uC774 \uB354 \uC548 \uC6C0\uC9C1\uC5EC."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Principled_3
    ko: "\uC2E0\uCCB4\uC801 \uC811\uCD09\uC744 \uC790\uC2E0\uC758 \uC6D0\uCE59\uC774
      \uC644\uC804\uD788 \uBD95\uAD34\uB418\uC5C8\uB2E4\uB294 \uC2E0\uD638\uB85C
      \uBC1B\uC544\uB4E4\uC784."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC800\uB97C \uB3D5\uACE0 \uACC4\uC154... \uC81C
      \uADA4\uC801\uC744 \uC9C0\uCF1C\uBCF4\uACE0 \uACC4\uC2DC\uB2C8\uAE4C \uC774\uBC88\uC5D4
      \uC131\uACF5\uD560 \uC218 \uC788\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Guardian_3
    ko: "\uC2E0\uCCB4\uC801 \uBC30\uB824\uB97C \uD300\uC744 \uC704\uD55C \uBCF4\uD638\uB85C
      \uD574\uC11D\uD558\uC5EC \uC2EC\uB9AC\uC801 \uC548\uC815\uAC10 \uD68C\uBCF5."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Tactician_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC81C \uADFC\uC721 \uB370\uC774\uD130\uB97C \uBD84\uC11D\uD558\uC2E0
      \uAC74\uAC00? \uC5B4\uAE68 \uC774\uC644\uC774 \uD328\uC2A4 \uD6A8\uC728\uC5D0
      \uC5B4\uB5A4 \uC601\uD5A5\uC744 \uBBF8\uCE58\uB294\uC9C0 \uAE30\uB85D\uD574\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Tactician_3
    ko: "\uD589\uB3D9\uC758 \uC758\uBBF8\uB97C \uBD84\uC11D\uD558\uC5EC \uB2E4\uC74C
      \uD6C8\uB828\uC744 \uC704\uD55C \uC815\uBCF4\uB85C \uD65C\uC6A9\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Exemplary_301
    ko: "\uC544\uBB34 \uB9D0\uC500\uB3C4 \uC5C6\uC73C\uC2DC\uB2E4\uB2C8... \uC81C\uAC00
      \uBAA8\uBC94\uC774 \uB418\uC9C0 \uBABB\uD574 \uC2E4\uB9DD\uD558\uC2E0 \uAC74\uAC00
      \uBD10."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Exemplary_3
    ko: "\uBB34\uC5B8\uC758 \uD589\uB3D9\uC744 \uC790\uC2E0\uC758 \uB099\uC81C\uC810\uC73C\uB85C
      \uD574\uC11D\uD558\uC5EC \uADF9\uC2EC\uD558\uAC8C \uC704\uCD95\uB428."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Bond_001
    ko: "\uC815\uADDC \uD6C8\uB828 \uC9C1\uC804, \uAC74\uC870\uD55C \uBC14\uB78C\uACFC
      \uBA3C\uC9C0\uAC00 \uD718\uB0A0\uB9AC\uB294 \uCF54\uD2B8. \uC120\uC218\uB294
      \uC790\uC2E0\uC758 \uD328\uC2A4\uAC00 \uB3D9\uB8CC\uC758 \uAC00\uC2B4\uC5D0
      \uB2FF\uC9C0 \uC54A\uC790 \uC2EC\uD55C \uD328\uB2C9\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Bond_002
    ko: "\uD328\uC2A4\uB294 \uC815\uD574\uC9C4 \uADA4\uC801\uC744 \uADF8\uB824\uC57C
      \uD55C\uB2E4 \uB294 \uC6D0\uCE59\uC744 \uAC15\uBC15\uC801\uC73C\uB85C \uC9C0\uD0A4\uB824\uB2E4
      \uADFC\uC721\uC774 \uAD73\uC5B4\uBC84\uB838\uACE0 \uACB0\uAD6D \uC2A4\uC2A4\uB85C\uB97C
      \uC6D0\uB9DD\uD558\uBA70 \uBC14\uB2E5\uC5D0 \uC8FC\uC800\uC549\uC558\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Bond_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Bond_001
    ko: "\uD328\uC2A4 \uD558\uB098\uAC00 \uC870\uAE08 \uBE57\uB098\uAC14\uB2E4\uACE0
      \uD300 \uC804\uCCB4\uAC00 \uBB34\uB108\uC9C0\uB294 \uAC74 \uC544\uB2C8\uB2E4.
      \uB108\uB294 \uB3D9\uB8CC\uB97C \uB3D5\uACE0 \uC2F6\uC740 \uB9C8\uC74C\uC774
      \uC55E\uC11C\uC11C \uADF8\uB7F4 \uBFD0\uC774\uC57C.  \uB3D9\uB8CC\uC758 '\uD45C\uC815'\uC744
      \uBCF4\uBA74\uC11C \uAC00\uC7A5 \uD3B8\uD558\uAC8C \uACF5\uC744 \uBCF4\uB0B4\uBD10."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uC81C \uB9C8\uC74C\uC744 \uC54C\uC544\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uB3D9\uB8CC\uB97C \uBCF4\uBA70 \uB2E4\uC2DC
      \uB358\uC838\uBCFC\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Kind_1
    ko: "\uC815\uC11C\uC801 \uC9C0\uC9C0\uB97C \uD655\uC778\uD558\uC790 \uC2EC\uB9AC\uC801
      \uC548\uC815\uAC10\uC774 \uC989\uC2DC \uD68C\uBCF5\uB418\uC5B4 \uC29B \uBC38\uB7F0\uC2A4\uB97C
      \uCC3E\uC74C."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uBC30\uB824\uB97C \uC78A\uC9C0 \uC54A\uACA0\uC2B5\uB2C8\uB2E4.
      \uD300\uC744 \uC704\uD574 \uB05D\uAE4C\uC9C0 \uCD5C\uC120\uC744 \uB2E4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Loyal_1
    ko: "\uACA9\uB824\uB97C \uC0AC\uBA85\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC \uD5CC\uC2E0\uD558\uACA0\uB2E4\uACE0
      \uB2E4\uC9D0\uD558\uB098, \uB2F9\uC7A5\uC758 \uC29B \uBBF8\uC2A4\uB294 \uD574\uACB0\uB418\uC9C0
      \uC54A\uC74C."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Sincere_101
    ko: "\uB3D9\uB8CC\uC758 \uD45C\uC815\uC744 \uBCF4\uB77C\uACE0\uC694? \uADA4\uC801\uC774
      \uC544\uB2CC \uAC10\uAC01\uC5D0 \uC758\uC874\uD558\uB77C\uB294 \uAC74\uC9C0
      \uC774\uD574\uAC00 \uC548 \uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Sincere_1
    ko: "\uAC10\uB3C5\uC758 \uC870\uC5B8\uC774 \uAE30\uC874 \uB8E8\uD2F4\uACFC \uCDA9\uB3CC\uD558\uC5EC
      \uBC29\uD5A5\uC131\uC744 \uC783\uACE0 \uD63C\uB780\uC5D0 \uBE60\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Moodmaker_101
    ko: "\uB124! \uAE30\uBD84 \uC88B\uAC8C \uB2E4\uC2DC \uC2DC\uC791\uD560\uAC8C\uC694!
      \uB2E4\uB4E4 \uD30C\uC774\uD305!"
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Moodmaker_1
    ko: "\uACA9\uB824\uB97C \uAC00\uBCCD\uAC8C \uBC1B\uC544\uB4E4\uC5EC \uAE30\uBD84\uC740
      \uB098\uC544\uC84C\uC73C\uB098 \uAE30\uC220\uC801 \uBCF4\uC644\uC740 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Bond_002
    ko: "\uADF8\uB807\uAC8C \uAD73\uC5B4\uC11C \uC8FC\uC800\uC549\uC544 \uC788\uB294
      \uAC74 \uB3D9\uB8CC\uC5D0 \uB300\uD55C \uC608\uC758\uAC00 \uC544\uB2C8\uC57C.
      \uADA4\uC801\uC5D0 \uC9D1\uCC29\uD558\uB290\uB77C \uC815\uC791 \uB124\uAC00
      \uB3C4\uC640\uC57C \uD560 \uC0AC\uB78C\uC744 \uC678\uBA74\uD558\uACE0 \uC788\uC9C0
      \uC54A\uB098? \uB2F9\uC7A5 \uC77C\uC5B4\uB098\uC11C \uD300\uC744 \uC704\uD574
      \uC6C0\uC9C1\uC5EC."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Kind_201
    ko: "\uC800 \uB54C\uBB38\uC5D0 \uB3D9\uB8CC\uB4E4\uC774 \uD798\uB4E4\uC5C8\uAD70\uC694...
      \uC81C\uAC00 \uC815\uB9D0 \uC4F8\uBAA8\uC5C6\uB294 \uC0AC\uB78C\uC778\uAC00
      \uBD10\uC694."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Kind_2
    ko: "\uC9C8\uCC45\uC744 \uAD00\uACC4\uC801 \uBD80\uC815\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uC790\uC874\uAC10\uC774 \uAE09\uB77D\uD558\uACE0 \uD6C8\uB828 \uC758\uC695
      \uC0C1\uC2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Loyal_201
    ko: "\uC81C\uAC00 \uB3D9\uB8CC\uB97C \uC678\uBA74\uD558\uACE0 \uC788\uC5C8\uAD70\uC694!
      \uBC14\uB85C \uD300\uC744 \uC704\uD574 \uB2E4\uC2DC \uB6F0\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC744 \uCDA9\uC131\uC2EC\uC5D0 \uB300\uD55C \uACBD\uACE0\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uC989\uC2DC \uD22C\uC9C0\uB97C \uBD88\uD0DC\uC6B0\uBA70
      \uD3FC\uC744 \uBCF5\uAD6C\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Sincere_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uADA4\uC801 \uC678\uC5D0 \uB2E4\uB978 \uBCC0\uC218\uB97C
      \uACE0\uB824\uD558\uC5EC \uD6C8\uB828 \uACC4\uD68D\uC744 \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Sincere_2
    ko: "\uC9C8\uCC45\uC744 \uC0C8\uB85C\uC6B4 \uACFC\uC81C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uAC10\uC815 \uC5C6\uC774 \uAE30\uACC4\uC801\uC73C\uB85C \uC218\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Moodmaker_201
    ko: "\uC800\uBCF4\uACE0 \uB3D9\uB8CC\uB97C \uC678\uBA74\uD588\uB2E4\uB2C8\uC694...
      \uAC10\uB3C5\uB2D8\uAED8 \uBBF8\uC6C0\uC744 \uBC1B\uB294 \uAC83 \uAC19\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Moodmaker_2
    ko: "\uC9C8\uCC45\uC744 \uAD00\uACC4\uC758 \uB2E8\uC808\uB85C \uD574\uC11D\uD558\uC5EC
      \uD070 \uCDA9\uACA9\uC744 \uBC1B\uACE0 \uCF54\uD2B8\uC5D0\uC11C \uB3C4\uB9DD\uCE58\uB4EF
      \uD6C8\uB828 \uC911\uB2E8."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Bond_003
    ko: "\uAC10\uB3C5\uC740 \uC544\uBB34 \uB9D0 \uC5C6\uC774 \uD6C8\uB828 \uC911\uC778
      \uB2E4\uB978 \uC120\uC218\uB4E4 \uC0AC\uC774\uB85C \uB4E4\uC5B4\uAC00 \uACF5\uC744
      \uC9C1\uC811 \uD558\uB098 \uC8FC\uC6CC\uC628 \uB4A4, \uC8FC\uC800\uC549\uC544
      \uC788\uB294 \uC120\uC218\uC758 \uC190\uC5D0 \uC950\uC5EC\uC8FC\uACE0\uB294
      \uB2E4\uC74C \uD6C8\uB828 \uC21C\uC11C\uB85C \uBC00\uC5B4 \uB123\uB294\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC606\uC5D0 \uACC4\uC2DC\uB2C8 \uC870\uAE08 \uB9C8\uC74C\uC774
      \uB193\uC774\uB124\uC694. \uB2E4\uC2DC \uD574\uBCFC\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Kind_3
    ko: "\uBB34\uC5B8\uC758 \uC9C0\uC9C0\uB97C \uB290\uAEF4 \uBD88\uC548\uAC10\uC740
      \uAC00\uC168\uC73C\uB098 \uAE30\uC220\uC801 \uAC1C\uC120\uC740 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Loyal_301
    ko: "\uC800\uB97C \uBBFF\uC5B4\uC8FC\uC2DC\uB294 \uB9CC\uD07C \uBC18\uB4DC\uC2DC
      \uC131\uACF5\uD574\uC57C \uD55C\uB2E4\uB294 \uC0DD\uAC01\uC5D0... \uC190\uC774
      \uB354 \uB5A8\uB9BD\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Loyal_3
    ko: "\uAC10\uB3C5\uC758 \uC2E0\uB8B0 \uD589\uB3D9\uC744 \uBB34\uAC70\uC6B4 \uCC45\uC784\uAC10\uC73C\uB85C
      \uB290\uAEF4 \uADF9\uB3C4\uC758 \uC555\uBC15\uAC10\uC5D0 \uD3FC\uC774 \uBB34\uB108\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Sincere_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uACF5\uC744 \uC8FC\uC2E0 \uAC74 \uB8E8\uD2F4\uC744
      \uB2E4\uC2DC \uC138\uC6B0\uB77C\uB294 \uC758\uBBF8\uAD70\uC694. \uC774 \uD589\uB3D9\uC744
      \uBD84\uC11D\uD574 \uD3FC\uC744 \uC815\uB9BD\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Sincere_3
    ko: "\uD589\uB3D9\uC744 \uC0C8\uB85C\uC6B4 \uD6C8\uB828 \uB370\uC774\uD130\uB85C
      \uB3C4\uCD9C\uD558\uC5EC \uC2A4\uC2A4\uB85C \uB8E8\uD2F4\uC744 \uC7AC\uC124\uACC4\uD558\uACE0
      \uC131\uACF5\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Moodmaker_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC808 \uCC59\uACA8\uC8FC\uC2DC\uB2E4\uB2C8! \uB2E4\uC2DC
      \uBD84\uC704\uAE30 \uB744\uC6CC\uC11C \uBAA8\uB450\uB97C \uC6C3\uAC8C \uB9CC\uB4E4\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Moodmaker_3
    ko: "\uAC10\uB3C5\uC758 \uC2E0\uCCB4\uC801 \uBC30\uB824\uB97C \uD300\uC758 \uBD84\uC704\uAE30\uB97C
      \uC0B4\uB9AC\uB77C\uB294 \uBA54\uC2DC\uC9C0\uB85C \uD574\uC11D\uD558\uC5EC
      \uC989\uC2DC \uD3FC\uC744 \uD68C\uBCF5\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Cold_001
    ko: "\uC815\uADDC \uD6C8\uB828 \uC9C1\uC804, \uBA3C\uC9C0 \uC11E\uC778 \uBC14\uB78C\uC774
      \uBD80\uB294 \uCF54\uD2B8. \uC120\uC218\uB294 \uC790\uC2E0\uC758 \uD328\uC2A4\uAC00
      \uB3D9\uB8CC\uC758 \uAC00\uC2B4\uC5D0 \uC815\uD655\uD788 \uB3C4\uB2EC\uD558\uC9C0
      \uC54A\uC790 \uB370\uC774\uD130 \uC624\uB958\uAC00 \uBC1C\uC0DD\uD55C \uAC83\uCC98\uB7FC
      \uD328\uB2C9\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Cold_002
    ko: "\uD328\uC2A4\uB294 \uC815\uD574\uC9C4 \uADA4\uC801\uC744 \uADF8\uB824\uC57C
      \uD55C\uB2E4 \uB294 \uC6D0\uCE59\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uADFC\uC721\uC774
      \uACBD\uC9C1\uB41C \uCC44 \uC2A4\uC2A4\uB85C\uB97C \uC6D0\uB9DD\uD558\uBA70
      \uC8FC\uC800\uC549\uC544 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Cold_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Cold_001
    ko: "\uD604\uC7AC \uB124 \uD328\uC2A4\uC758 \uACB0\uACFC\uAC12\uC774 \uC608\uC0C1
      \uBC94\uC704\uC5D0\uC11C \uC774\uD0C8\uD55C \uAC74, \uC678\uBD80 \uD658\uACBD
      \uBCC0\uC218\uC778 \uBC14\uB78C\uACFC \uBA3C\uC9C0 \uB54C\uBB38\uC774\uC57C.
      \uBB3C\uB9AC\uC801 \uD658\uACBD \uBCC0\uC218\uB97C \uBCF4\uC815\uAC12\uC73C\uB85C
      \uC218\uC2DD\uC5D0 \uB123\uACE0 \uB2E4\uC2DC \uB358\uC838\uBD10. "
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Planner_101
    ko: "\uC678\uBD80 \uBCC0\uC218 \uBCF4\uC815... \uADF8 \uC0DD\uAC01\uC744 \uBABB
      \uD588\uC2B5\uB2C8\uB2E4. \uBC14\uB85C \uADA4\uC801\uC744 \uC218\uC815\uD574
      \uC131\uACF5\uB960\uC744 \uB192\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Planner_1
    ko: "\uC678\uBD80 \uBCC0\uC218\uB97C \uB17C\uB9AC\uC801 \uC218\uC2DD\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uD6C8\uB828 \uD6A8\uC728\uC744 \uADF9\uB300\uD654\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Opportunist_101
    ko: "\uBCF4\uC815\uAC12\uC744 \uB123\uC73C\uBA74 \uD328\uC2A4 \uC815\uD655\uB3C4\uAC00
      \uC624\uB974\uACA0\uAD70\uC694. \uADF8\uAC78 \uB0B4 \uC2E4\uB825\uC73C\uB85C
      \uD3EC\uC7A5\uD558\uBA74 \uB418\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Opportunist_1
    ko: "\uAC10\uB3C5\uC758 \uC81C\uC548\uC744 \uD65C\uC6A9\uD574 \uC790\uC2E0\uC758
      \uC29B \uC131\uACF5\uB960\uC744 \uB192\uC77C \uAE30\uD68C\uB85C\uB9CC \uC778\uC2DD\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Cunning_101
    ko: "\uB370\uC774\uD130 \uBCF4\uC815? \uC81C \uAC10\uAC01\uC740 \uC774\uBBF8
      \uBC14\uB78C\uAE4C\uC9C0 \uB2E4 \uACC4\uC0B0\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4.
      \uC9C0\uC2DC \uC548 \uB530\uB974\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Cunning_1
    ko: "\uD1B5\uC81C\uAD8C\uC744 \uBE8F\uAE30\uC9C0 \uC54A\uC73C\uB824\uB294 \uBCF8\uC131
      \uB54C\uBB38\uC5D0 \uACA9\uB824\uB97C \uBB34\uC2DC\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Believer_101
    ko: "\uB370\uC774\uD130 \uBCF4\uC815\uC740 \uC81C \uADA4\uC801\uC758 \uC21C\uC218\uC131\uC744
      \uD574\uCE69\uB2C8\uB2E4. \uBCC0\uC218\uBCF4\uB2E4\uB294 \uADA4\uC801\uC758
      \uC815\uD655\uC131\uC744 \uB192\uC774\uB294 \uAC8C \uC6B0\uC120\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Believer_1
    ko: "\uC790\uC2E0\uC758 \uCCA0\uD559(\uC21C\uC218 \uADA4\uC801)\uC774 \uD655\uACE0\uD558\uC5EC
      \uC678\uBD80 \uC81C\uC548\uC744 \uAC70\uC808\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Cold_002
    ko: "\uACB0\uACFC\uAC12\uC774 \uC548 \uB098\uC624\uB294\uB370 \uD3FC\uB9CC \uACE0\uC9D1\uD558\uB294
      \uAC74 \uC804\uC220\uC801 \uACE0\uB9BD\uC774\uB2E4. \uADFC\uC721\uC758 \uAE34\uC7A5\uC740
      \uD328\uC2A4 \uC18D\uB3C4\uB97C \uC800\uD558\uC2DC\uD0A4\uB294 \uC624\uCC28\uC57C.
      \uAE30\uBCF8 \uADA4\uC801\uC73C\uB85C \uB370\uC774\uD130\uB97C \uC7AC\uC785\uB825\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Planner_201
    ko: "\uC2DC\uC2A4\uD15C \uC624\uB958\uB97C \uBC29\uCE58\uD588\uAD70\uC694. \uC989\uC2DC
      \uAE30\uBCF8 \uADA4\uC801\uC73C\uB85C \uB3CC\uC544\uAC00 \uB370\uC774\uD130\uB97C
      \uBCF4\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Planner_2
    ko: "\uC2DC\uC2A4\uD15C\uC801 \uD6A8\uC728\uC131\uC744 \uCD5C\uC6B0\uC120\uC73C\uB85C
      \uC5EC\uACA8 \uC989\uAC01\uC801\uC778 \uD3FC \uC218\uC815\uC774 \uC77C\uC5B4\uB0A8."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Opportunist_201
    ko: "\uBD84\uC11D\uC774 \uBD80\uC871\uD588\uB2E4\uB294 \uB9D0\uC500\uC778\uAC00\uC694?
      \uACB0\uACFC\uB9CC \uB0B4\uBA74 \uB418\uB294 \uAC70 \uC544\uB2D9\uB2C8\uAE4C...
      \uC774\uC81C \uADA4\uC801 \uC548 \uBC14\uAFC9\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Opportunist_2
    ko: "\uC790\uC2E0\uC758 \uBC29\uC2DD\uC744 \uBD80\uC815\uB2F9\uD588\uB2E4\uACE0
      \uB290\uAEF4 \uD6C8\uB828 \uC790\uCCB4\uB97C \uAC70\uBD80\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Cunning_201
    ko: "\uC804\uC220\uC801 \uACE0\uB9BD\uC744 \uC790\uCD08\uD588\uAD70\uC694. \uC1A1\uAD6C\uD569\uB2C8\uB2E4.
      \uB9D0\uC500\uB300\uB85C \uB2F9\uC7A5 \uAD50\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Cunning_2
    ko: "\uC9C8\uCC45\uC744 \uAD8C\uC704\uC801 \uBA85\uB839\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uAC89\uC73C\uB85C\uB9CC \uC989\uC2DC \uC21C\uC751\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Believer_201
    ko: "\uACB0\uACFC\uAC12\uC774 \uC548 \uB098\uC624\uB294 \uAC74 \uC81C \uC6D0\uCE59\uC774
      \uBD80\uC871\uD588\uAE30 \uB54C\uBB38\uC774\uAD70\uC694. \uC2B9\uB960 \uB370\uC774\uD130\uB97C
      \uC704\uD574 \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Believer_2
    ko: "\uC2B9\uB960\uC774\uB77C\uB294 \uBAA9\uD45C\uB97C \uB370\uC774\uD130\uC801
      \uC2E0\uB150\uACFC \uC77C\uCE58\uC2DC\uCF1C \uC989\uC2DC \uC218\uC815\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Cold_003
    ko: "\uC120\uC218\uAC00 \uC2E4\uC218\uD558\uC790 \uAC10\uB3C5\uC740 \uC544\uBB34
      \uB9D0 \uC5C6\uC774 \uCF54\uD2B8 \uC704\uB85C \uC62C\uB77C\uAC00 \uD328\uC2A4
      \uACBD\uB85C\uC0C1\uC758 \uBC14\uB78C \uBC29\uD5A5\uC744 \uC190\uC73C\uB85C
      \uAC00\uB9AC\uD0A4\uACE0  \uC120\uC218\uC758 \uC2E4\uCC45 \uD69F\uC218\uB97C
      \uBB34\uD45C\uC815\uD558\uAC8C \uAE30\uB85D\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Planner_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC2E4\uCC45\uC744 \uAE30\uB85D\uD558\uACE0 \uACC4\uC154...
      \uB0B4 \uBD84\uC11D\uC5D0 \uACB0\uD568\uC774 \uC788\uB2E4\uB294 \uB73B\uC778\uAC00?
      \uBA38\uB9AC\uAC00 \uBCF5\uC7A1\uD574 \uC544\uBB34\uAC83\uB3C4 \uBABB \uD558\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Planner_3
    ko: "\uD53C\uB4DC\uBC31\uC758 \uBD80\uC7AC\uB97C \uC2DC\uC2A4\uD15C \uACB0\uD568\uC73C\uB85C
      \uAC04\uC8FC\uD574 \uD328\uB2C9\uC774 \uAC00\uC911\uB428."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Opportunist_301
    ko: "\uBC14\uB78C \uBC29\uD5A5\uC744 \uAC00\uB9AC\uD0A4\uC2DC\uB2E4\uB2C8...
      \uC774\uAC78 \uC774\uC6A9\uD558\uBA74 \uC544\uBB34\uB3C4 \uB0B4 \uD328\uC2A4\uB97C
      \uBABB \uC77D\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Opportunist_3
    ko: "\uAC10\uB3C5\uC758 \uD589\uB3D9\uC744 \uC804\uB7B5\uC801 \uD78C\uD2B8\uB85C
      \uC0BC\uC544 \uC790\uAE30\uB9CC\uC758 \uD328\uC2A4 \uAE30\uC220\uC744 \uC644\uC131\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Cunning_301
    ko: "\uB370\uC774\uD130 \uAE30\uB85D \uC911\uC774\uC2DC\uB124... \uC77C\uB2E8
      \uD3FC \uC7A1\uACE0 \uB358\uC9C0\uB294 \uCC99\uD558\uB2E4\uAC00 \uB098\uC911\uC5D0
      \uB0B4 \uBC29\uC2DD\uB300\uB85C \uD574\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Cunning_3
    ko: "\uAC10\uB3C5\uC758 \uAC10\uC2DC\uB97C \uC5ED\uC774\uC6A9\uD574 \uAC89\uC73C\uB85C\uB9CC
      \uD6C8\uB828\uD558\uB294 \uCC99\uD558\uBA70 \uC2DC\uAC04 \uB54C\uC6C0."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Believer_301
    ko: "\uB098\uB97C \uAE30\uB85D\uD558\uACE0 \uACC4\uC154... \uB0B4 \uD328\uC2A4\uB294
      \uB354 \uC774\uC0C1 \uD300\uC758 \uC6D0\uCE59\uC5D0 \uBD80\uD569\uD558\uC9C0
      \uC54A\uB098 \uBD10."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Believer_3
    ko: "\uCE68\uBB35\uC744 \uC790\uC2E0\uC758 \uCCA0\uD559\uC5D0 \uB300\uD55C \uAC70\uBD80\uB85C
      \uD574\uC11D\uD558\uC5EC \uBA58\uD0C8 \uBD95\uAD34."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Instinct_001
    ko: "\uD6C8\uB828 \uC9C1\uC804, \uBC14\uB78C\uACFC \uBA3C\uC9C0\uAC00 \uC11E\uC778
      \uCF54\uD2B8. \uC120\uC218\uB294 \uD328\uC2A4 \uBBF8\uC2A4 \uC774\uD6C4 '\uADA4\uC801'\uC774\uB77C\uB294
      \uAC15\uBC15\uC5D0 \uAC07\uD600 \uBAB8\uC774 \uC644\uC804\uD788 \uAD73\uC5C8\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Instinct_002
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Instinct_001
    ko: "\uADA4\uC801\uC774 \uD2C0\uC5B4\uC9C0\uB294 \uAC74 \uBC14\uB78C \uB54C\uBB38\uC774\uC9C0
      \uB124 \uC2E4\uB825\uC774 \uC544\uB2C8\uC57C. \uC218\uC2DD\uC740 \uC78A\uC5B4\uB77C.
      \uB3D9\uB8CC\uC758 \uB208\uBE5B\uACFC \uC6C0\uC9C1\uC784\uB9CC \uBCF4\uACE0,
      \uACF5\uC744 \uB358\uC9C0\uB294 \uAC8C \uC544\uB2C8\uB77C '\uBCF4\uB0B4\uC900\uB2E4\uB294'
      \uB290\uB08C\uC73C\uB85C \uBAB8\uC744 \uB9E1\uACA8\uBD10."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uC81C \uAC10\uAC01\uC744 \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694!
      \uC218\uC2DD \uBC84\uB9AC\uACE0 \uBCF8\uB2A5\uB300\uB85C \uAF42\uC544\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Bluffer_1
    ko: "\uC790\uC2E0\uC758 \uCC9C\uC7AC\uC131\uC744 \uC778\uC815\uBC1B\uC558\uB2E4\uACE0
      \uB290\uAEF4 \uC790\uC874\uAC10\uC774 \uD68C\uBCF5\uB418\uBA70 \uAE30\uC220\uC801
      \uC790\uC2E0\uAC10\uC774 \uD3ED\uBC1C\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Wild_101
    ko: "\uBC14\uB78C \uACC4\uC0B0\uD560 \uAC83 \uC5C6\uACA0\uB124\uC694. \uB290\uB08C\uB300\uB85C
      \uB358\uC838\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Wild_1
    ko: "\uBCF8\uB2A5\uC801 \uAC10\uAC01\uC744 \uC778\uC815\uBC1B\uC544 \uD6C8\uB828\uC5D0
      \uBAB0\uC785\uD558\uB098, \uACB0\uACFC\uB294 \uD3C9\uC774\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Egoist_101
    ko: "\uAC10\uAC01\uC774 \uB2F5\uC774\uB77C\uACE0\uC694? \uC774\uBBF8 \uC804 \uC81C
      \uADA4\uC801\uC744 \uCC3E\uC558\uC2B5\uB2C8\uB2E4. \uAC04\uC12D\uD558\uC9C0
      \uB9C8\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Egoist_1
    ko: "\uAC10\uB3C5\uC758 \uC81C\uC548\uC744 \uC790\uC2E0\uC758 \uC644\uBCBD\uD55C
      \uC6D0\uCE59\uC5D0 \uB300\uD55C \uBC29\uD574\uB85C \uAC04\uC8FC\uD558\uC5EC
      \uAC70\uBD80\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Fighter_101
    ko: "\uADA4\uC801\uC740 \uC81C \uBC29\uC2DD\uB300\uB85C \uADF8\uB9B4 \uAC81\uB2C8\uB2E4.
      \uB204\uAD6C\uC758 \uC9C0\uC2DC\uB3C4 \uD544\uC694 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Fighter_1
    ko: "\uACA9\uB824\uB97C \uC790\uC2E0\uC744 \uB098\uC57D\uD558\uAC8C \uB9CC\uB4DC\uB294
      \uC694\uC18C\uB85C \uC5EC\uACA8 \uC758\uC695\uC744 \uC0C1\uC2E4\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Instinct_002
    ko: "\uB18D\uAD6C\uB294 \uC218\uD559\uC774 \uC544\uB2C8\uB2E4. \uADA4\uC801\uC5D0
      \uC9D1\uCC29\uD558\uB290\uB77C \uC815\uC791 \uB124 \uD300\uC6D0\uC758 \uC6C0\uC9C1\uC784\uC744
      \uB193\uCE58\uACE0 \uC788\uC796\uC544. \uBA38\uB9AC \uC4F0\uC9C0 \uB9C8. \uB124
      \uBAB8\uC774 \uAE30\uC5B5\uD558\uB294 \uB300\uB85C \uADF8\uB0E5 \uB358\uC838!"
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Bluffer_201
    ko: "\uC81C \uBCF8\uB2A5\uC744 \uBAA8\uB974\uC2DC\uB124\uC694... \uC624\uB298
      \uD328\uC2A4\uAC00 \uC548 \uB418\uB294 \uAC74 \uAC10\uB3C5\uB2D8 \uB54C\uBB38\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Bluffer_2
    ko: "\uC9C8\uCC45\uC744 \uC790\uC2E0\uC758 \uAC10\uAC01\uC5D0 \uB300\uD55C \uBAA8\uC695\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uAC10\uB3C5\uACFC \uB300\uB9BD\uD558\uACE0 \uD6C8\uB828\uC744
      \uC911\uB2E8\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Wild_201
    ko: "\uC774 \uC9C0\uAE0B\uC9C0\uAE0B\uD55C \uACC4\uC0B0\uC5D0\uC11C \uD574\uBC29\uC2DC\uCF1C
      \uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uC774\uC81C\uC57C \uC9C4\uC9DC
      \uC81C \uD328\uC2A4\uAC00 \uB098\uAC11\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Wild_2
    ko: "\uAC10\uAC01\uC744 \uC5B5\uC555\uD558\uB358 \uC6D0\uCE59\uC801 \uAC15\uBC15\uC774
      \uD574\uC18C\uB418\uC790 \uC7A0\uC7AC\uB825\uC774 \uC989\uC2DC \uD3ED\uBC1C\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Egoist_201
    ko: "\uADA4\uC801\uBCF4\uB2E4 \uB3D9\uB8CC\uB77C\uACE0\uC694? \uC54C\uACA0\uC2B5\uB2C8\uB2E4.
      \uC81C \uD328\uC2A4\uB97C \uBC1B\uB294 \uB188\uC774 \uC54C\uC544\uC11C \uBC1B\uAC8C
      \uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Egoist_2
    ko: "\uC9C8\uCC45\uC5D0 \uBC18\uBC1C\uC2EC\uC774 \uB4E4\uC9C0\uB9CC, \uC2A4\uC2A4\uB85C
      \uC2E4\uB825\uC744 \uC99D\uBA85\uD558\uAE30 \uC704\uD574 \uAE30\uACC4\uC801\uC73C\uB85C
      \uC218\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Fighter_201
    ko: "\uC81C\uAC00 \uB3D9\uB8CC\uB97C \uB193\uCCE4\uB2E4\uACE0\uC694? \uC88B\uC2B5\uB2C8\uB2E4.
      \uBCF4\uB780 \uB4EF\uC774 \uC644\uBCBD\uD55C \uD328\uC2A4\uB97C \uCC14\uB7EC\uB123\uC5B4
      \uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Fighter_2
    ko: "\uC9C8\uCC45\uC744 \uACBD\uC7C1\uC801 \uB3C4\uC804\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uC624\uAE30\uB97C \uAC00\uC9C0\uACE0 \uC644\uBCBD\uD55C \uD3FC\uC744 \uC5F0\uCD9C\uD568."
    en: 
    ja: 
  - stringKey: Event_00009_Ch_Instinct_003
    ko: "\uACF5\uC744 \uB358\uC9C0\uB824\uB294 \uC120\uC218\uC758 \uC190\uC744 \uC7A1\uACE0
      \uAC15\uC81C\uB85C \uD0C0\uAC9F(\uB3D9\uB8CC)\uC758 \uAC00\uC2B4 \uCABD\uC73C\uB85C
      \uC190\uBAA9\uC744 \uD22D \uCCD0\uC11C \uADA4\uC801\uC744 \uC218\uC815\uD574
      \uC900 \uB4A4, \uC544\uBB34 \uB9D0 \uC5C6\uC774 \uACF5\uC744 \uD328\uC2A4\uD558\uAC8C
      \uB9CC\uB4E0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Bluffer_301
    ko: "\uC65C \uB0B4 \uC190\uBAA9\uC744 \uC7A1\uC73C\uC2DC\uC8E0? \uC804 \uC2A4\uC2A4\uB85C
      \uADA4\uC801\uC744 \uADF8\uB9B4 \uC218 \uC788\uB294\uB370..."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Bluffer_3
    ko: "\uD0C0\uC778\uC758 \uC2E0\uCCB4\uC801 \uAC1C\uC785\uC744 \uC790\uC2E0\uC758
      \uAD8C\uC704 \uCE68\uD574\uB85C \uB290\uAEF4 \uD6C8\uB828 \uC9D1\uC911\uB825\uC744
      \uC783\uC74C."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Wild_301
    ko: "\uC65C \uB0B4 \uD314\uC744 \uAC15\uC81C\uB85C \uC6C0\uC9C1\uC774\uC2DC\uC8E0?
      \uB09C \uB0B4 \uBAB8\uC73C\uB85C \uB290\uB080 \uB300\uB85C \uB358\uC9C8 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Wild_3
    ko: "\uBB3C\uB9AC\uC801 \uD1B5\uC81C\uB97C \uC790\uC2E0\uC758 \uC57C\uC0DD\uC131\uC744
      \uC8FD\uC774\uB294 \uD589\uC704\uB85C \uBC1B\uC544\uB4E4\uC5EC \uC989\uC2DC
      \uCF54\uD2B8\uB97C \uB098\uAC10."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Egoist_301
    ko: "\uAC10\uB3C5\uB2D8 \uC190\uAE38\uC744 \uAC70\uCE58\uB2C8 \uD328\uC2A4\uAC00
      \uC815\uD655\uD558\uB124\uC694... \uC774 \uAC01\uB3C4\uB97C \uAE30\uC5B5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Egoist_3
    ko: "\uC790\uC2E0\uC758 \uD328\uC2A4\uAC00 \uC644\uBCBD\uD558\uAC8C \uB4E4\uC5B4\uAC00\uB294
      \uAC83\uC744 \uD655\uC778\uD558\uC790, \uBB3C\uB9AC\uC801 \uAC1C\uC785\uC744
      \uAE30\uC220\uC801 \uB3CC\uD30C\uAD6C\uB85C \uC0BC\uC74C."
    en: 
    ja: 
  - stringKey: Event_00009_Desc_Fighter_301
    ko: "\uB0B4 \uC190\uC744 \uC7A1\uC73C\uC168\uAD70\uC694. \uB2E4\uC74C\uBC88\uC5D4
      \uAC10\uB3C5\uB2D8\uC774 \uC190 \uC548 \uB300\uB3C4 \uB3D9\uB8CC \uAC00\uC2B4\uC5D0
      \uAF42\uC544 \uB123\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00009_Rs_Fighter_3
    ko: "\uBB3C\uB9AC\uC801 \uB3C4\uC6C0\uC744 \uACBD\uC7C1\uC801\uC778 \uD328\uBC30\uB85C
      \uAC04\uC8FC\uD558\uACE0 \uC2A4\uC2A4\uB85C \uAE30\uB85D\uC744 \uACBD\uC2E0\uD558\uB824
      \uB178\uB825\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Discipline_001
    ko: "\uC2B5\uAE30 \uCC2C \uCCB4\uC721\uAD00, \uD300\uC758 \uD328\uC2A4 \uD750\uB984\uC744
      \uC8FC\uB3C4\uD574\uC57C \uD560 \uC120\uC218\uAC00 \uC790\uC2E0\uC758 \uC804\uC220\uC801
      \uAE38\uB9CC\uC744 \uACE0\uC9D1\uD558\uB2E4 \uC5F0\uB2EC\uC544 \uC2E4\uCC45\uC744
      \uBC94\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Discipline_002
    ko: "\uC790\uC720\uB85C\uC6B4 \uC6C0\uC9C1\uC784\uC744 '\uD63C\uB780'\uC73C\uB85C
      \uAC04\uC8FC\uD558\uB294 \uC120\uC218\uB294, \uD300\uC6D0\uB4E4\uACFC\uC758
      \uD638\uD761 \uC2E4\uD328\uB97C \uC790\uC2E0\uC758 \uC124\uACC4 \uACB0\uD568\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uC790\uAD34\uAC10\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Discipline_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Discipline_001
    ko: "\uB124\uAC00 \uC124\uACC4\uD55C \uADF8 \uAE38\uC740 \uC544\uC8FC \uC815\uAD50\uD558\uB2E4.
      \uB124 \uC124\uACC4 \uC548\uC5D0\uC11C \uD300\uC6D0\uB4E4\uC758 \uBCC0\uCE59\uC801
      \uC6C0\uC9C1\uC784\uC744 '\uC608\uC0C1\uB41C \uBCC0\uC218'\uB85C \uD3EC\uD568\uD558\uBA74,
      \uB124 \uD328\uC2A4\uB294 \uB354 \uC644\uBCBD\uD574\uC9C8 \uAC70\uC57C."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Principled_101
    ko: "20cm\uC758 \uBCF4\uC815\uAC12... \uBCC0\uC218\uB97C \uC6D0\uCE59\uC5D0 \uD3EC\uD568\uD558\uBA74
      \uB418\uB294\uAD70\uC694. \uC9C0\uAE08 \uC989\uC2DC \uC804\uC220\uC744 \uC5C5\uB370\uC774\uD2B8\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Principled_1
    ko: "\uC0C8\uB85C\uC6B4 \uC6D0\uCE59\uC744 \uD655\uB9BD\uD568\uC73C\uB85C\uC368
      \uBD88\uC548\uC744 \uC81C\uAC70\uD558\uACE0 \uD6C8\uB828\uC758 \uC9C8\uC744
      \uB192\uC784."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Guardian_101
    ko: "\uBCC0\uCE59\uC801 \uC6C0\uC9C1\uC784\uC744 \uC218\uC6A9\uD558\uBA74 \uD328\uC2A4
      \uD6A8\uC728\uC774 \uB354 \uC624\uB97C\uAE4C\uC694? \uD300\uC744 \uC704\uD574
      \uC5F0\uAD6C\uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Guardian_1
    ko: "\uD300\uC744 \uC9C0\uD0A4\uB824\uB294 \uCC45\uC784\uAC10\uC774 \uC804\uC220
      \uD655\uC7A5\uC73C\uB85C \uC774\uC5B4\uC9C0\uB098, \uC555\uBC15\uAC10\uC774
      \uCEE4\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Tactician_101
    ko: "\uBCC0\uCE59\uC801 \uC6C0\uC9C1\uC784\uC740 \uD1B5\uACC4\uC801\uC73C\uB85C
      \uBD88\uD655\uC2E4\uC131\uC774 \uB192\uC2B5\uB2C8\uB2E4. \uC81C \uC815\uC11D
      \uD328\uC2A4\uAC00 \uB354 \uC548\uC804\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Tactician_1
    ko: "\uD655\uB960 \uC911\uC2EC\uC758 \uC0AC\uACE0\uBC29\uC2DD \uB54C\uBB38\uC5D0
      \uAC10\uB3C5\uC758 \uC804\uC220 \uD655\uC7A5\uC744 \uB17C\uB9AC\uC801\uC73C\uB85C
      \uAC70\uBD80."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Exemplary_101
    ko: "\uB124! \uAC10\uB3C5\uB2D8 \uC870\uC5B8\uB300\uB85C \uB3D9\uB8CC\uC640 \uC18C\uD1B5\uD558\uBA70
      \uCD5C\uACE0\uC758 \uD328\uC2A4 \uAE38\uC744 \uB2E4\uC2DC \uB9CC\uB4E4\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Exemplary_1
    ko: "\uAC10\uB3C5\uC758 \uAE0D\uC815\uC801\uC778 \uC804\uC220 \uC9C0\uCE68\uC744
      \uBC1B\uC544\uB4E4\uC5EC \uC790\uC2E0\uAC10 \uC788\uAC8C \uD300\uC744 \uC774\uB054."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Discipline_002
    ko: "\uC9C0\uAE08 \uB124 \uD328\uC2A4\uB294 \uD300\uC744 \uC704\uD55C \uAC8C
      \uC544\uB2C8\uB77C \uB124 \uC544\uC9D1\uC744 \uC704\uD55C \uAC70\uB2E4. \uC804\uC220\uC740
      \uD300\uC774 \uC6C0\uC9C1\uC774\uB294 \uAE38\uC774\uC9C0, \uB124\uAC00 \uC120
      \uAE0B\uB294 \uC120\uC774 \uC544\uB2C8\uC57C.  \uB2F9\uC7A5 \uACE0\uC815\uAD00\uB150\uC744
      \uBC84\uB824\uB77C."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Principled_201
    ko: "\uC544\uC9D1\uC774\uC5C8\uAD70\uC694... \uD300\uC758 \uC804\uC220\uC801
      \uC77C\uAD00\uC131\uC744 \uC704\uD574 \uC989\uC2DC \uC124\uACC4\uB3C4\uB97C
      \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Principled_2
    ko: "\uC790\uC2E0\uC758 \uC624\uB958\uB97C \uC9C8\uCC45\uC73C\uB85C \uAE68\uB2EB\uACE0
      \uAE30\uACC4\uC801\uC73C\uB85C \uC815\uC11D \uD328\uC2A4\uB85C \uBCF5\uADC0\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Guardian_201
    ko: "\uC81C\uAC00 \uD300\uC744 \uBC29\uD574\uD558\uACE0 \uC788\uC5C8\uB2E4\uB2C8...
      \uC804\uC220\uC801 \uC790\uC9C8\uC774 \uBD80\uC871\uD55C \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Guardian_2
    ko: "\uC9C8\uCC45\uC744 \uC790\uC2E0\uC758 \uC804\uC220\uC801 \uB2A5\uB825\uC5D0
      \uB300\uD55C \uD30C\uBA78\uC801 \uD3C9\uAC00\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uC758\uC695 \uC0C1\uC2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Tactician_201
    ko: "\uD1B5\uACC4\uC801 \uD6A8\uC728\uC131\uC774 \uB0AE\uC740 \uD328\uC2A4\uB97C
      \uACE0\uC9D1\uD588\uAD70\uC694. \uB370\uC774\uD130 \uAE30\uBC18\uC73C\uB85C
      \uC804\uC220\uC744 \uC7AC\uD3B8\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Tactician_2
    ko: "\uD6A8\uC728\uC131\uC774\uB77C\uB294 \uBA85\uBD84\uC774 \uC81C\uACF5\uB418\uC790
      \uC989\uC2DC \uADA4\uC801\uC744 \uC218\uC815\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Exemplary_201
    ko: "\uB124, \uBC14\uB85C \uC815\uC11D\uB300\uB85C \uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uD300\uC6D0\uB4E4\uC774 \uD63C\uB780\uC2A4\uB7FD\uC9C0 \uC54A\uAC8C \uC81C\uAC00
      \uBA3C\uC800 \uBAA8\uBC94\uC744 \uBCF4\uC774\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Exemplary_2
    ko: "\uC9C8\uCC45\uC744 \uD53C\uD558\uAE30 \uC704\uD574 \uC989\uAC01\uC801\uC73C\uB85C
      \uBAA8\uBC94\uC801\uC778 \uC815\uC11D \uD328\uC2A4\uB85C \uD68C\uADC0\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Discipline_003
    ko: "\uAC10\uB3C5\uC740 \uC804\uC220\uD310\uC744 \uAC00\uC838\uC640 \uC120\uC218\uAC00
      \uACE0\uC9D1\uD55C \uD328\uC2A4 \uAE38 \uC704\uC5D0 \uD300\uC6D0\uB4E4\uC758
      \uB3D9\uC120\uC744 \uB367\uADF8\uB824 \uBCF4\uC5EC\uC8FC\uACE0, \uB354 \uB113\uC740
      \uC804\uC220\uC801 \uD6A8\uC728\uC774\uB77C\uB294 \uBA54\uBAA8\uB97C \uB0A8\uAE34
      \uCC44 \uB3CC\uC544\uC120\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Principled_301
    ko: "\uC81C \uC804\uC220\uD310\uC5D0 \uD300\uC6D0\uB4E4\uC758 \uBCC0\uCE59\uC801\uC778
      \uB3D9\uC120\uC774... \uC774\uAC8C \uB9DE\uB2E4\uBA74 \uC81C \uAE30\uC874 \uC124\uACC4\uB294
      \uD3D0\uAE30\uD574\uC57C \uD558\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Principled_3
    ko: "\uC790\uC2E0\uC758 \uB17C\uB9AC \uCCB4\uACC4\uAC00 \uBD80\uC815\uB2F9\uD55C
      \uAC83\uC73C\uB85C \uC778\uC2DD\uD574 \uC804\uC220\uC801 \uBA58\uD0C8 \uBD95\uAD34."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC124\uACC4\uD558\uC2E0 \uC774 \uBCC0\uCE59\uC801
      \uAE38... \uC774\uAC8C \uBC14\uB85C \uD300\uC744 \uC9C0\uD0A4\uB294 \uC804\uC220\uC774\uAD70\uC694.
      \uBC14\uB85C \uC801\uC6A9\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Guardian_3
    ko: "\uC2DC\uAC01\uC801 \uAD50\uC815\uC744 \uD1B5\uD574 \uAC10\uB3C5\uC758 \uC758\uB3C4\uB97C
      \uD30C\uC545\uD558\uACE0 \uC2DC\uC2A4\uD15C\uC744 \uC644\uBCBD\uD788 \uD761\uC218\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Tactician_301
    ko: "\uC774 \uBCC0\uC218\uAC12\uB4E4\uC740 \uACE0\uB824\uD558\uC9C0 \uBABB\uD588\uAD70\uC694.
      \uB2E4\uC74C \uD6C8\uB828 \uB54C\uB294 \uC774 \uB3D9\uC120 \uB370\uC774\uD130\uB97C
      \uD3EC\uD568\uD574 \uD328\uC2A4\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Tactician_3
    ko: "\uC804\uC220\uD310\uC758 \uB370\uC774\uD130\uB97C \uBD84\uC11D\uD558\uC5EC
      \uC790\uC2E0\uC758 \uC804\uC220\uC744 \uC815\uBC00\uD558\uAC8C \uC5C5\uADF8\uB808\uC774\uB4DC\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Exemplary_301
    ko: "\uC81C \uC804\uC220\uD310\uC5D0 \uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uADF8\uB824\uC8FC\uC168\uC5B4...
      \uC81C\uAC00 \uBAA8\uBC94\uC801\uC774\uC9C0 \uBABB\uD574\uC11C \uC2E4\uB9DD\uD558\uC2E0
      \uAC74\uAC00 \uBD10."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Exemplary_3
    ko: "\uBB34\uC5B8\uC758 \uD53C\uB4DC\uBC31\uC744 \uC790\uC2E0\uC758 \uC804\uC220\uC801
      \uB099\uC81C\uB85C \uD574\uC11D\uD558\uC5EC \uD06C\uAC8C \uC704\uCD95\uB428."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Bond_001
    ko: "\uC2B5\uAE30 \uCC2C \uCCB4\uC721\uAD00, \uD300\uC758 \uD328\uC2A4 \uD750\uB984\uC744
      \uC8FC\uB3C4\uD574\uC57C \uD560 \uC120\uC218\uAC00 \uC790\uC2E0\uC758 \uC804\uC220\uC801
      \uAE38\uB9CC\uC744 \uACE0\uC9D1\uD558\uB2E4 \uC5F0\uB2EC\uC544 \uC2E4\uCC45\uC744
      \uBC94\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Bond_002
    ko: "\uC790\uC720\uB85C\uC6B4 \uC6C0\uC9C1\uC784\uC744 '\uD63C\uB780'\uC73C\uB85C
      \uAC04\uC8FC\uD558\uB294 \uC120\uC218\uB294, \uB3D9\uB8CC\uB4E4\uACFC\uC758
      \uD638\uD761 \uC2E4\uD328\uB97C \uC790\uC2E0\uC758 \uCC45\uC784\uC73C\uB85C
      \uB3CC\uB9AC\uBA70 \uAE4A\uC740 \uC790\uAD34\uAC10\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Bond_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Bond_001
    ko: "\uB124\uAC00 \uC815\uD55C \uAE38\uC744 \uC7A0\uC2DC \uBE44\uC6CC\uB450\uACE0
      \uB3D9\uB8CC\uB4E4\uC758 \uB208\uC744 \uBCF4\uBA74\uC11C \uADF8\uB4E4\uC758
      \uC6C0\uC9C1\uC784\uC5D0 \uB9DE\uCDB0\uBCF4\uB294 \uAC74 \uC5B4\uB5A8\uAE4C?
      \uADF8\uAC8C \uC624\uB298 \uB108\uC640 \uB3D9\uB8CC\uB4E4\uC744 \uC774\uC5B4\uC8FC\uB294
      \uAC00\uC7A5 \uC548\uC804\uD55C \uAE38\uC77C \uAC70\uC57C."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uC81C \uC9C4\uC2EC\uC744 \uC54C\uC544\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uB3D9\uB8CC\uB4E4\uC758 \uB208\uC744 \uBCF4\uACE0
      \uB2E4\uC2DC \uC5F0\uACB0\uD574\uBCFC\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Kind_1
    ko: "\uC790\uC2E0\uC758 \uB178\uB825\uC774 \uB3D9\uB8CC\uB97C \uC704\uD55C \uAC83\uC784\uC744
      \uC778\uC815\uBC1B\uC790, \uC815\uC11C\uC801 \uC548\uC815\uAC10\uC774 \uD68C\uBCF5\uB418\uC5B4
      \uD328\uC2A4 \uB9AC\uB4EC\uC744 \uB418\uCC3E\uC74C."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Loyal_101
    ko: "\uB3D9\uB8CC\uB97C \uC704\uD574 \uC81C \uBC29\uC2DD\uC744 \uC7A0\uC2DC \uB0B4\uB824\uB193\uACA0\uC2B5\uB2C8\uB2E4.
      \uD300\uC744 \uC704\uD574 \uC804\uC220\uC744 \uC870\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Loyal_1
    ko: "\uAC10\uB3C5\uC758 \uC81C\uC548\uC744 \uD300\uC744 \uC704\uD55C \uBA85\uB839\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uD5CC\uC2E0\uD558\uACA0\uB2E4\uACE0 \uB2E4\uC9D0\uD558\uB098,
      \uD328\uC2A4 \uD3FC\uC758 \uADFC\uBCF8\uC801 \uC218\uC815\uC740 \uBD80\uC871\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Sincere_101
    ko: "\uB3D9\uB8CC\uC758 \uC6C0\uC9C1\uC784\uC5D0 \uB9DE\uCD94\uB77C\uACE0\uC694?
      \uADF8\uB7FC \uAE30\uC874 \uD328\uC2A4 \uB8E8\uD2F4\uC740 \uBC84\uB824\uC57C
      \uD569\uB2C8\uAE4C? \uAE30\uC900\uC774 \uBAA8\uD638\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Sincere_1
    ko: "\uAC10\uB3C5\uC758 \uC870\uC5B8\uC774 \uAE30\uC874 \uC804\uC220 \uADDC\uC728\uACFC
      \uCDA9\uB3CC\uD558\uC5EC \uC804\uC220\uC801 \uBC29\uD5A5\uC131\uC744 \uC783\uACE0
      \uD070 \uD63C\uB780\uC744 \uACAA\uC74C."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Moodmaker_101
    ko: "\uB124! \uB3D9\uB8CC\uB4E4\uACFC \uC6C3\uC73C\uBA74\uC11C \uB2E4\uC2DC \uD55C\uBC88
      \uB9DE\uCDB0\uBCFC\uAC8C\uC694! \uD328\uC2A4 \uBBF8\uC2A4\uB294 \uC78A\uC790!"
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Moodmaker_1
    ko: "\uACA9\uB824\uB97C \uB2E8\uC21C\uD55C \uC751\uC6D0\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uAE30\uBD84\uC740 \uB098\uC544\uC84C\uC73C\uB098 \uC804\uC220\uC801\uC778
      \uBBF8\uC2A4 \uBCF4\uC644\uC740 \uC774\uB8E8\uC5B4\uC9C0\uC9C0 \uC54A\uC74C."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Bond_002
    ko: "\uADF8\uB807\uAC8C \uACE0\uB9BD\uB418\uC5B4\uC11C \uC790\uAE30 \uC124\uACC4\uB9CC
      \uD0D3\uD558\uACE0 \uC788\uC73C\uBA74 \uB3D9\uB8CC\uB4E4\uC774 \uB108\uB97C
      \uC5B4\uB5BB\uAC8C \uBCF4\uACA0\uB098? \uB108\uB294 \uB3D9\uB8CC\uB97C \uB3D5\uB294
      \uAC8C \uC544\uB2C8\uB77C \uB124 \uACE0\uC9D1\uB9CC \uC138\uC6B0\uACE0 \uC788\uB294
      \uAC70\uC57C."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Kind_201
    ko: "\uC81C\uAC00 \uB3D9\uB8CC\uB4E4\uC744 \uC678\uBA74\uD558\uACE0 \uC788\uC5C8\uB2E4\uB2C8...
      \uC815\uB9D0 \uB108\uBB34 \uC8C4\uC1A1\uD574\uC694. \uC774\uC81C \uC5B4\uB5BB\uAC8C
      \uB2E4\uAC00\uAC00\uC57C \uD560\uC9C0 \uBAA8\uB974\uACA0\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Kind_2
    ko: "\uB3D9\uB8CC\uC640\uC758 \uAD00\uACC4\uAC00 \uB098\uBE60\uC84C\uB2E4\uB294
      \uC9C8\uCC45\uC744 \uACAC\uB514\uC9C0 \uBABB\uD558\uACE0 \uC815\uC11C\uC801\uC73C\uB85C
      \uBD95\uAD34\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Loyal_201
    ko: "\uC81C\uAC00 \uB3D9\uB8CC\uB4E4\uC744 \uD798\uB4E4\uAC8C \uD558\uACE0 \uC788\uC5C8\uAD70\uC694!
      \uBC14\uB85C \uB9C8\uC74C\uC744 \uBC14\uAFD4 \uB3D9\uB8CC\uB4E4\uC5D0\uAC8C
      \uB9DE\uCD94\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC744 \uB3D9\uB8CC\uB97C \uC9C0\uD0A4\uC9C0 \uBABB\uD588\uB2E4\uB294
      \uACBD\uACE0\uB85C \uBC1B\uC544\uB4E4\uC5EC \uC989\uC2DC \uD22C\uC9C0\uB97C
      \uBD88\uD0DC\uC6B0\uBA70 \uD328\uC2A4 \uADA4\uC801\uC744 \uC218\uC815\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Sincere_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uD300\uC758 \uC6C0\uC9C1\uC784\uC5D0 \uB9DE\uCDB0
      \uC804\uC220 \uC218\uCE58\uB97C \uB2E4\uC2DC \uC124\uC815\uD558\uACE0 \uD6C8\uB828\uC744
      \uC7AC\uAC1C\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Sincere_2
    ko: "\uC9C8\uCC45\uC744 \uC0C8\uB85C\uC6B4 \uACFC\uC81C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uAC10\uC815\uC801 \uC694\uC18C\uB97C \uBC30\uC81C\uD558\uACE0 \uAE30\uACC4\uC801\uC73C\uB85C
      \uD328\uC2A4\uB97C \uC870\uC815\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Moodmaker_201
    ko: "\uC800\uBCF4\uACE0 \uACE0\uC9D1\uBD88\uD1B5\uC774\uB77C\uB2C8\uC694... \uD300
      \uBD84\uC704\uAE30\uB97C \uB9DD\uCE58\uACE0 \uC2F6\uC9C0 \uC54A\uC740\uB370,
      \uB3D9\uB8CC\uB4E4\uC774 \uC774\uC81C \uC800\uB97C \uBBF8\uC6CC\uD560 \uAC83
      \uAC19\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Moodmaker_2
    ko: "\uC9C8\uCC45\uC744 \uAD00\uACC4\uC801 \uBC30\uCC99\uC73C\uB85C \uD574\uC11D\uD558\uC5EC
      \uD300 \uBD84\uC704\uAE30\uB97C \uC774\uB04C\uC5B4\uC57C \uD55C\uB2E4\uB294
      \uAC15\uBC15\uC5D0 \uC9D3\uB20C\uB824 \uD6C8\uB828\uC744 \uC911\uB2E8\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Bond_003
    ko: "\uAC10\uB3C5\uC740 \uB2E4\uAC00\uAC00 \uC120\uC218\uC758 \uB4F1\uC744 \uB530\uB73B\uD558\uAC8C
      \uC4F8\uC5B4\uC8FC\uBA70, \uADFC\uCC98\uC5D0\uC11C \uC26C\uACE0 \uC788\uB358
      \uB3D9\uB8CC \uD55C \uBA85\uC744 \uBD88\uB7EC\uC640 \uC120\uC218\uC758 \uC5B4\uAE68\uB97C
      \uB9DE\uB300\uAC8C \uD558\uACE0 \uD328\uC2A4 \uD6C8\uB828\uC744 \uB2E4\uC2DC
      \uC720\uB3C4\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Kind_301
    ko: "\uB3D9\uB8CC\uB791 \uC5B4\uAE68\uB97C \uB9DE\uB300\uB2C8 \uAE34\uC7A5\uC774
      \uC880 \uD480\uB9AC\uB124\uC694. \uAC10\uB3C5\uB2D8 \uB355\uBD84\uC5D0 \uB2E4\uC2DC
      \uD638\uD761\uC744 \uB9DE\uCDB0\uBCFC \uC218 \uC788\uACA0\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Kind_3
    ko: "\uBB34\uC5B8\uC758 \uC911\uC7AC\uB97C \uD1B5\uD574 \uB3D9\uB8CC\uC640\uC758
      \uBB3C\uB9AC\uC801 \uAC70\uB9AC\uAC00 \uAC00\uAE4C\uC6CC\uC9C0\uC790 \uC2EC\uB9AC\uC801
      \uBD88\uC548\uC774 \uC644\uD654\uB428."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8, \uC81C\uAC00 \uC2E4\uC218\uD574\uC11C \uD300\uC758 \uC2E0\uB8B0\uB97C
      \uC783\uC740 \uAC83 \uAC19\uC544 \uB108\uBB34 \uAD34\uB86D\uC2B5\uB2C8\uB2E4.
      \uC5B4\uAE68\uB97C \uB300\uACE0 \uC788\uB294 \uAC83\uB3C4 \uC8C4\uC1A1\uD574\uC694."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Loyal_3
    ko: "\uB3D9\uB8CC\uC640\uC758 \uD654\uD569\uC744 \uAC15\uC694\uBC1B\uB294 \uC0C1\uD669\uC744
      \uC2E4\uC218\uC5D0 \uB300\uD55C \uACF5\uAC1C\uC801 \uB9DD\uC2E0\uC73C\uB85C
      \uB290\uAEF4 \uC555\uBC15\uAC10\uC5D0 \uD3FC\uC774 \uBB34\uB108\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Sincere_301
    ko: "\uB3D9\uB8CC\uC640 \uC5B4\uAE68\uB97C \uB9DE\uB300\uACE0 \uB2E4\uC2DC \uD574\uBCF4\uB2C8,
      \uC774 \uC704\uCE58\uC5D0\uC11C\uC758 \uD328\uC2A4 \uAC01\uB3C4\uAC00 \uD6E8\uC52C
      \uC815\uD655\uD558\uAD70\uC694. \uAE30\uB85D\uD574\uB450\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Sincere_3
    ko: "\uC2E0\uCCB4\uC801 \uBC00\uCC29 \uD6C8\uB828\uC744 \uC804\uC220 \uC815\uB9BD\uC758
      \uB370\uC774\uD130\uB85C \uD65C\uC6A9\uD558\uC5EC \uC790\uC2E0\uC758 \uD328\uC2A4
      \uD3FC\uC744 \uC644\uBCBD\uD788 \uC7AC\uAD6C\uCD95\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Moodmaker_301
    ko: "\uC624! \uC774\uB807\uAC8C \uC5B4\uAE68\uB97C \uB9DE\uB300\uB2C8 \uD6E8\uC52C
      \uCE5C\uADFC\uD558\uB124\uC694! \uD30C\uC774\uD305\uD574\uC11C \uB2E4\uC2DC
      \uC5F0\uACB0\uD574\uBD05\uC2DC\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Moodmaker_3
    ko: "\uBB34\uC5B8\uC758 \uC911\uC7AC\uB97C \uAD00\uACC4 \uD68C\uBCF5\uC758 \uAE30\uD68C\uB85C
      \uC0BC\uC544 \uBD84\uC704\uAE30\uB97C \uC218\uC2B5\uD558\uACE0 \uC989\uC2DC
      \uD328\uC2A4 \uD750\uB984\uC744 \uBCF5\uAD6C\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Cold_001
    ko: "\uC2B5\uAE30 \uCC2C \uCCB4\uC721\uAD00, \uD300\uC758 \uD328\uC2A4 \uD750\uB984\uC744
      \uC8FC\uB3C4\uD574\uC57C \uD560 \uC120\uC218\uAC00 \uC790\uC2E0\uC758 \uC804\uC220\uC801
      \uAE38\uB9CC\uC744 \uACE0\uC9D1\uD558\uB2E4 \uC5F0\uB2EC\uC544 \uC2E4\uCC45\uC744
      \uBC94\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Cold_002
    ko: "\uC790\uC720\uB85C\uC6B4 \uC6C0\uC9C1\uC784\uC744 '\uD63C\uB780'\uC73C\uB85C
      \uAC04\uC8FC\uD558\uB294 \uC120\uC218\uB294, \uB3D9\uB8CC\uB4E4\uACFC\uC758
      \uD638\uD761 \uC2E4\uD328\uB97C \uC790\uC2E0\uC758 \uC124\uACC4 \uACB0\uD568\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uAE4A\uC740 \uC790\uAD34\uAC10\uC5D0 \uBE60\uC838
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Cold_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Cold_001
    ko: "\uB124\uAC00 \uC124\uACC4\uD55C \uD328\uC2A4 \uAE38\uC740 \uC774\uB860\uC801\uC73C\uB85C
      \uC644\uBCBD\uD558\uB2E4. \uD558\uC9C0\uB9CC \uB3D9\uB8CC\uB4E4\uC758 \uC720\uB3D9\uC801\uC778
      \uC6C0\uC9C1\uC784\uC740 \uC608\uCE21\uD558\uC9C0 \uBABB\uD55C '\uBCC0\uC218'\uC600\uC744
      \uBFD0\uC774\uC57C. \uADF8 \uBCC0\uC218\uB97C \uC218\uC2DD\uC5D0 \uCD94\uAC00\uD574\uC11C
      \uC7AC\uC124\uACC4\uD574\uBD10."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Planner_101
    ko: "\uD655\uB960\uC801 \uD328\uC2A4 \uAE38... \uBCC0\uC218\uB97C \uB123\uC73C\uBA74
      \uC131\uACF5\uB960\uC774 15% \uC0C1\uC2B9\uD558\uACA0\uAD70\uC694. \uBC14\uB85C
      \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Planner_1
    ko: "\uC804\uC220\uC801 \uBCF4\uC644\uC810\uC744 \uB17C\uB9AC\uC801\uC73C\uB85C
      \uC81C\uC2DC\uD558\uC790 \uC989\uC2DC \uC218\uC6A9\uD558\uC5EC \uD6C8\uB828
      \uD6A8\uC728\uC744 \uB192\uC784."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Opportunist_101
    ko: "\uB370\uC774\uD130\uB97C \uBCF4\uC815\uD558\uBA74 \uC81C \uD328\uC2A4\uAC00
      \uB354 \uC798 \uB4E4\uC5B4\uAC00\uACA0\uB124\uC694. \uC81C \uAE30\uB85D\uC744
      \uC704\uD574\uC11C\uB77C\uB3C4 \uADF8\uB807\uAC8C \uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Opportunist_1
    ko: "\uAC10\uB3C5\uC758 \uACA9\uB824\uB97C \uC790\uC2E0\uC758 \uAE30\uB85D\uC744
      \uB192\uC77C \uAE30\uD68C\uB85C \uC778\uC2DD\uD574 \uC804\uB7B5\uC801\uC73C\uB85C
      \uD0C0\uD611\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Cunning_101
    ko: "\uC81C \uC804\uC220\uC740 \uC774\uBBF8 \uBCC0\uC218\uB97C \uB2E4 \uACE0\uB824\uD588\uC2B5\uB2C8\uB2E4.
      \uC218\uC815\uD560 \uD544\uC694 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Cunning_1
    ko: "\uC790\uC2E0\uC758 \uC6B0\uC6D4\uD568\uC744 \uACFC\uC2DC\uD558\uB824\uB294
      \uC131\uD5A5 \uB54C\uBB38\uC5D0 \uAC10\uB3C5\uC758 \uC870\uC5B8\uC744 \uC815\uBA74\uC73C\uB85C
      \uAC70\uBD80\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Believer_101
    ko: "\uD655\uB960\uC801\uC778 \uD328\uC2A4 \uAE38\uC740 \uC81C \uCCA0\uD559\uC774
      \uC544\uB2D9\uB2C8\uB2E4. \uC800\uB294 \uC644\uBCBD\uD55C \uADA4\uC801\uB9CC\uC744
      \uACE0\uC218\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Believer_1
    ko: "\uB370\uC774\uD130\uC801 \uD6A8\uC728\uC131\uBCF4\uB2E4 \uC790\uC2E0\uC758
      \uC124\uACC4 \uC2E0\uB150\uC774 \uD655\uACE0\uD558\uC5EC \uC81C\uC548\uC744
      \uAC70\uC808\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Cold_002
    ko: "\uC124\uACC4\uAC00 \uD2C0\uB9B0 \uAC8C \uC544\uB2C8\uB77C \uC804\uC220 \uC801\uC6A9\uC774
      \uBE44\uD6A8\uC728\uC801\uC778 \uAC70\uB2E4. \uB370\uC774\uD130\uB294 \uD604\uC7A5\uC744
      \uBC18\uC601\uD558\uC9C0 \uC54A\uC73C\uBA74 \uBB34\uC6A9\uC9C0\uBB3C\uC774\uC57C.
      \uB124 \uACE0\uC9D1\uB300\uB85C\uB9CC \uB358\uC9C0\uB294 \uD328\uC2A4\uB294
      \uD1B5\uACC4\uC801\uC73C\uB85C \uC131\uACF5\uB960\uC774 0\uC5D0 \uAC00\uAE5D\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Planner_201
    ko: "\uD604\uC7A5 \uBCC0\uC218 \uBBF8\uBC18\uC601\uC740 \uBA85\uBC31\uD55C \uC624\uB958\uC785\uB2C8\uB2E4.
      \uB370\uC774\uD130\uBCA0\uC774\uC2A4\uB97C \uC989\uC2DC \uAC31\uC2E0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Planner_2
    ko: "\uC790\uC2E0\uC758 \uC804\uC220\uC801 \uC624\uB958\uB97C \uB370\uC774\uD130\uC801
      \uAD00\uC810\uC5D0\uC11C \uBC1B\uC544\uB4E4\uC5EC \uAE30\uACC4\uC801\uC73C\uB85C
      \uC218\uC815\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Opportunist_201
    ko: "\uACE0\uC9D1\uBD80\uB9B0 \uAC8C \uC544\uB2C8\uB77C \uD300\uC6D0\uC774 \uBABB
      \uBC1B\uC740 \uAC81\uB2C8\uB2E4. \uC65C \uC800\uB9CC \uBE44\uB09C\uD558\uC2DC\uC8E0?
      \uC548 \uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Opportunist_2
    ko: "\uC9C8\uCC45\uC744 \uC790\uC2E0\uC758 \uC774\uC775\uC5D0 \uBC18\uD558\uB294
      \uAC83\uC73C\uB85C \uAC04\uC8FC\uD558\uC5EC \uD6C8\uB828\uC744 \uAC70\uBD80\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Cunning_201
    ko: "\uB370\uC774\uD130\uB97C \uC989\uC2DC \uAC31\uC2E0\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uC2B9\uB960\uC744 \uC704\uD574\uC11C\uB294 \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uC774
      \uC633\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Cunning_2
    ko: "\uB17C\uB9AC\uC801 \uC9C8\uCC45\uC744 \uBC1B\uC544\uB4E4\uC5EC\uC57C\uB9CC
      \uC790\uC2E0\uC758 \uC804\uC220\uC801 \uC704\uCE58\uAC00 \uBCF4\uC874\uB428\uC744
      \uC54C\uACE0 \uC804\uB7B5\uC801\uC73C\uB85C \uC21C\uC751\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Believer_201
    ko: "\uC131\uACF5\uB960 0%\uB77C\uB294 \uC218\uCE58\uB294 \uCE58\uBA85\uC801\uC785\uB2C8\uB2E4.
      \uC2E0\uB150\uC744 \uC704\uD574\uC11C\uB77C\uB3C4 \uB370\uC774\uD130\uC758
      \uD6A8\uC728\uC744 \uADF9\uB300\uD654\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Believer_2
    ko: "\uC2B9\uB960\uC774\uB77C\uB294 \uC218\uCE58\uB97C \uC2E0\uB150\uC758 \uCC99\uB3C4\uB85C
      \uC0BC\uC544, \uB370\uC774\uD130\uC801\uC73C\uB85C \uC790\uC2E0\uC758 \uD328\uC2A4\uB97C
      \uC7AC\uC124\uACC4\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Cold_003
    ko: "\uC120\uC218\uAC00 \uB2E4\uC2DC \uC790\uAE30 \uAE38\uC744 \uACE0\uC9D1\uD558\uC790,
      \uAC10\uB3C5\uC740 \uC804\uC220\uD310\uC5D0 \uB3D9\uB8CC\uB4E4\uC758 \uC774\uB3D9
      \uACBD\uB85C\uB97C \uD655\uB960\uC801\uC73C\uB85C \uD45C\uC2DC\uD55C \uB4A4,
      \uC120\uC218\uC758 \uC190\uC5D0 \uC950\uC5EC\uC8FC\uACE0\uB294 \uBB34\uD45C\uC815\uD558\uAC8C
      \uD6C8\uB828\uC744 \uACC4\uC18D\uD558\uAC8C \uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Planner_301
    ko: "\uBCC0\uC218\uAC12\uC774 \uB108\uBB34 \uBCF5\uC7A1\uD574... \uB0B4 \uC124\uACC4\uAC00
      \uC774 \uC815\uB3C4\uB85C \uBD88\uC644\uC804\uD588\uB2E4\uB2C8. \uBAA8\uB4E0
      \uAC8C \uC758\uBBF8 \uC5C6\uAC8C \uB290\uAEF4\uC838."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Planner_3
    ko: "\uC804\uC220\uD310\uC758 \uBCF5\uC7A1\uD55C \uBCC0\uC218\uB97C \uC790\uC2E0\uC758
      \uC124\uACC4\uB97C \uB300\uCCB4\uD560 \uC218 \uC5C6\uB294 \uACB0\uD568\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uBA58\uD0C8 \uBD95\uAD34."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Opportunist_301
    ko: "\uC774 \uD655\uB960\uAC12... \uC774\uAC78 \uC774\uC6A9\uD558\uBA74 \uB3D9\uB8CC\uC758
      \uC6C0\uC9C1\uC784\uC744 \uC608\uCE21\uD574\uC11C \uB0B4 \uD328\uC2A4\uB97C
      \uB3CB\uBCF4\uC774\uAC8C \uD560 \uC218 \uC788\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Opportunist_3
    ko: "\uC804\uC220\uD310\uC758 \uD655\uB960 \uC815\uBCF4\uB97C \uD65C\uC6A9\uD574
      \uC790\uC2E0\uC758 \uD328\uC2A4 \uAC00\uCE58\uB97C \uB192\uC77C \uB3CC\uD30C\uAD6C\uB97C
      \uCC3E\uC74C."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Cunning_301
    ko: "\uC804\uC220\uD310 \uB370\uC774\uD130... \uC77C\uB2E8 \uBCF4\uB294 \uCC99\uD558\uBA74\uC11C
      \uC81C \uAE30\uC874 \uBC29\uC2DD\uC73C\uB85C \uB358\uC838\uC57C\uC9C0. \uAC10\uB3C5\uB2D8\uC740
      \uD1B5\uACC4\uB9CC \uBCF4\uC2DC\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Cunning_3
    ko: "\uAC10\uB3C5\uC758 \uC804\uC220\uD310\uC744 \uB208\uC18D\uC784\uC6A9 \uB3C4\uAD6C\uB85C
      \uC0AC\uC6A9\uD558\uC5EC \uD6C8\uB828 \uC9D1\uC911\uB825\uC744 \uBD84\uC0B0\uC2DC\uD0B4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Believer_301
    ko: "\uC804\uC220\uD310\uC5D0 \uADF8\uB824\uC9C4 \uBCC0\uC218\uB4E4... \uC81C
      \uD328\uC2A4\uAC00 \uD300\uC744 \uD63C\uB780\uC2A4\uB7FD\uAC8C \uD55C\uB2E4\uB294
      \uC99D\uAC70\uC778\uAC00 \uBD10\uC694."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Believer_3
    ko: "\uAC10\uB3C5\uC758 \uC804\uC220\uD310\uC744 \uC790\uC2E0\uC758 \uC2E0\uB150\uC774
      \uC644\uC804\uD788 \uBD80\uC815\uB2F9\uD588\uB2E4\uB294 \uC99D\uAC70\uB85C
      \uAC04\uC8FC\uD558\uC5EC \uD6C8\uB828\uC744 \uD3EC\uAE30\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Instinct_001
    ko: "\uC2B5\uAE30 \uCC2C \uCCB4\uC721\uAD00, \uD328\uC2A4 \uD750\uB984\uC744
      \uC8FC\uB3C4\uD574\uC57C \uD560 \uC120\uC218\uAC00 \uC790\uAE30 \uBC29\uC2DD\uB300\uB85C\uB9CC
      \uD328\uC2A4\uB97C \uCC0C\uB974\uB2E4 \uC2E4\uCC45\uC744 \uC5F0\uBC1C\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Instinct_002
    ko: "\uC790\uC720\uB85C\uC6B4 \uC6C0\uC9C1\uC784\uC744 \uD63C\uB780\uC73C\uB85C
      \uBCF4\uB358 \uADF8\uB294, \uACB0\uAD6D \uB3D9\uB8CC\uC640\uC758 \uD638\uD761
      \uC2E4\uD328\uB97C \uC790\uC2E0\uC758 \uC124\uACC4 \uC2E4\uD328\uB85C \uADDC\uC815\uD558\uACE0
      \uC790\uAD34\uAC10\uC5D0 \uBE60\uC838 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Instinct_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Instinct_001
    ko: "\uB124 \uBCF8\uB2A5\uC801\uC778 \uAC10\uAC01\uC744 \uBBFF\uC5B4\uBD10. \uB3D9\uB8CC\uAC00
      \uB6F0\uB294 \uACF3\uC774 \uBC14\uB85C \uAE38\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uC81C \uC7AC\uB2A5\uC744 \uC54C\uC544\uBCF4\uC2DC\uB294\uAD70\uC694!
      \uC218\uC2DD \uBC84\uB9AC\uACE0 \uBCF8\uB2A5\uC801\uC778 \uD328\uC2A4\uB97C
      \uAF42\uC544\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Bluffer_1
    ko: "\uCC9C\uC7AC\uC131 \uC778\uC815\uC5D0 \uC790\uC874\uAC10\uC774 \uACE0\uCDE8\uB418\uC5B4
      \uACFC\uAC10\uD55C \uD50C\uB808\uC774 \uC131\uACF5."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Wild_101
    ko: "\uAE38\uC744 \uB9CC\uB4E4\uC9C0 \uB9D0\uB77C\uACE0\uC694? \uC54C\uACA0\uC2B5\uB2C8\uB2E4.
      \uB290\uB08C \uC624\uB294 \uB300\uB85C \uCC14\uB7EC\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Wild_1
    ko: "\uBCF8\uB2A5 \uAE0D\uC815\uC5D0\uB294 \uACF5\uAC10\uD558\uB098 \uC804\uC220
      \uCCB4\uACC4\uB294 \uBB34\uB108\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Egoist_101
    ko: "\uC774\uBBF8 \uC804 \uC81C \uADA4\uC801\uC744 \uCC3E\uC558\uC2B5\uB2C8\uB2E4.
      \uAC04\uC12D\uD558\uC9C0 \uB9C8\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Egoist_1
    ko: "\uB3C5\uC790\uC801 \uB178\uC120 \uBC29\uD574\uB85C \uAC04\uC8FC\uD558\uC5EC
      \uACA9\uB824\uB97C \uAC70\uBD80."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Fighter_101
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD2C0\uB838\uB2E4\uB294 \uAC81\uB2C8\uAE4C? \uBC1B\uC544\uB4E4\uC77C
      \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Fighter_1
    ko: "\uBC29\uC2DD\uC744 \uBD80\uC815\uB2F9\uD55C \uAC83\uC73C\uB85C \uB290\uAEF4
      \uC758\uC695 \uC0C1\uC2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Instinct_002
    ko: "\uACC4\uC0B0\uD558\uC9C0 \uB9C8\uB77C. \uC804\uC220\uC5D0 \uAC07\uD600 \uC2E4\uCC45\uB9CC
      \uBC94\uD558\uACE0 \uC788\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Bluffer_201
    ko: "\uC81C \uBCF8\uB2A5\uC744 \uBAA8\uB974\uC2DC\uB124\uC694... \uC624\uB298
      \uD328\uC2A4\uAC00 \uC548 \uB418\uB294 \uAC74 \uAC10\uB3C5\uB2D8\uC774 \uBD84\uC704\uAE30\uB97C
      \uB9DD\uCCD0\uC11C\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Bluffer_2
    ko: "\uC9C8\uCC45\uC744 \uBAA8\uC695\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC \uD6C8\uB828
      \uD3D0\uC1C4\uC801 \uAC70\uBD80."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Wild_201
    ko: "\uACC4\uC0B0\uAE30 \uB450\uB4DC\uB9AC\uB358 \uAC8C \uB2F5\uB2F5\uD588\uB294\uB370,
      \uC774\uC81C\uC57C \uC18D\uC774 \uC2DC\uC6D0\uD558\uB124\uC694! \uC9C4\uC9DC
      \uC81C \uD328\uC2A4\uB97C \uBCF4\uC5EC\uC8FC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Wild_2
    ko: "\uAC15\uBC15\uC801 \uACC4\uC0B0 \uD574\uBC29\uC73C\uB85C \uC7A0\uC7AC\uB825
      \uD3ED\uBC1C."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Egoist_201
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uC81C \uBCF8\uB2A5\uC774 \uC5BC\uB9C8\uB098
      \uC815\uD655\uD55C\uC9C0 \uC624\uB298 \uACBD\uAE30\uC5D0\uC11C \uBCF4\uC5EC\uB4DC\uB9AC\uBA74
      \uB418\uACA0\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Egoist_2
    ko: "\uC9C8\uCC45\uC744 \uC2B9\uBD80\uC695\uC73C\uB85C \uCE58\uD658\uD574 \uAE30\uACC4\uC801\uC73C\uB85C
      \uC218\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Fighter_201
    ko: "\uB3D9\uB8CC\uB97C \uB193\uCE58\uACE0 \uC788\uC5C8\uB2E4\uACE0\uC694? \uC9C0\uCF1C\uBCF4\uC2ED\uC2DC\uC624.
      \uC5B4\uB5A4 \uC0C1\uD669\uC5D0\uC11C\uB3C4 \uC644\uBCBD\uD55C \uD328\uC2A4\uB97C
      \uAF42\uC544 \uB123\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Fighter_2
    ko: "\uC815\uBA74 \uC2B9\uBD80\uB85C \uBC1B\uC544\uB4E4\uC5EC \uC624\uAE30\uAC00
      \uBC1C\uB3D9\uD568."
    en: 
    ja: 
  - stringKey: Event_00010_Ch_Instinct_003
    ko: "\uC804\uC220\uD310\uC744 \uCF54\uD2B8 \uBC16\uC73C\uB85C \uCE58\uC6B0\uACE0,
      \uACF5\uC744 \uAC15\uD558\uAC8C \uB358\uC838\uC8FC\uBA70 \uD6C8\uB828 \uD15C\uD3EC\uB97C
      \uCD5C\uACE0\uC870\uB85C \uC62C\uB9BC"
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Bluffer_301
    ko: "\uC804\uC220\uD310\uC744 \uC65C \uCE58\uC6B0\uC2DC\uC8E0? \uC81C \uC644\uBCBD\uD55C
      \uAD6C\uC0C1\uC744 \uBCF4\uC5EC\uB4DC\uB9B4 \uAE30\uD68C\uC600\uB294\uB370..."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Bluffer_3
    ko: "\uC790\uC2E0\uC758 \uAE30\uB7C9 \uACFC\uC2DC \uAE30\uD68C \uBC15\uD0C8\uB85C
      \uC778\uD55C \uC9D1\uC911\uB825 \uBD84\uC0B0."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Wild_301
    ko: "\uC65C \uB0B4 \uD314\uC744 \uAC15\uC81C\uB85C \uC6C0\uC9C1\uC774\uC2DC\uC8E0?
      \uB09C \uB0B4 \uBAB8\uC73C\uB85C \uB290\uB080 \uB300\uB85C \uB358\uC9C8 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Wild_3
    ko: "\uBB3C\uB9AC\uC801 \uAC15\uC81C\uC131\uC744 \uCE68\uD574\uB85C \uAC04\uC8FC\uD574
      \uD6C8\uB828 \uBC18\uBC1C."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Egoist_301
    ko: "\uC804\uC220\uD310\uC744 \uCE58\uC6B0\uC168\uAD70\uC694. \uC88B\uC2B5\uB2C8\uB2E4.
      \uB0B4 \uB208\uC5D0 \uB4E4\uC5B4\uC628 \uD2C8\uC744 \uB0B4\uAC00 \uC9C1\uC811
      \uCC14\uB7EC\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Egoist_3
    ko: "\uAC15\uC81C\uC801 \uAC1C\uC785\uC774 \uC2DC\uC57C\uB97C \uD2B8\uC5EC\uC8FC\uC5B4
      \uC644\uBCBD\uD55C \uD328\uC2A4 \uC131\uACF5."
    en: 
    ja: 
  - stringKey: Event_00010_Desc_Fighter_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uB9AC\uB4EC\uC744 \uC62C\uB9AC\uC168\uAD70\uC694.
      \uADF8\uB7FC \uC800\uB3C4 \uB354 \uBE60\uB974\uAC8C \uC6C0\uC9C1\uC5EC\uC11C
      \uD2C8\uC744 \uCC3E\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00010_Rs_Fighter_3
    ko: "\uACBD\uC7C1\uC801 \uC790\uADF9\uC740 \uC720\uC9C0\uD558\uB098 \uC804\uC220\uBCF4\uB2E4
      \uAC1C\uC778\uAE30 \uC704\uC8FC\uB85C \uD750\uB984."
    en: 
    ja: 
