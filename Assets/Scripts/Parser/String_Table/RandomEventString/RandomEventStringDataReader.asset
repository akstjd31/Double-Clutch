  m_Script: {fileID: 11500000, guid: d038e6d66bfd4d14791d22a39b361bcc, type: 3}
  m_Name: RandomEventStringDataReader
  m_EditorClassIdentifier: Assembly-CSharp::RandomEventStringDataReader
  associatedSheet: 1GCr74ngPVVRLTbKcy8sNDbilnzMgu8WKokqp9r1M-Eo
  associatedWorksheet: RandomEventString
  START_ROW_LENGTH: 3
  END_ROW_LENGTH: -1
  DataList:
  - stringKey: Event_00001_Desc_Discipline_001
    ko: "\uC815\uADDC \uC288\uD305 \uD6C8\uB828 \uC2DC\uAC04, \uD300\uC758 \uD55C
      \uC120\uC218\uAC00 \uC9C0\uC815\uB41C \uC704\uCE58\uAC00 \uC544\uB2CC \uACF3\uC5D0\uC11C
      \uBB34\uBD84\uBCC4\uD558\uAC8C \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Discipline_002
    ko: "\uC120\uC218\uB294 \uAC10\uB3C5\uC774 \uC9C0\uC2DC\uD55C '\uAE30\uBCF8 \uC790\uC138
      \uC720\uC9C0'\uC640 '\uC815\uD574\uC9C4 \uC2A4\uD31F\uC5D0\uC11C\uC758 \uBC18\uBCF5
      \uD6C8\uB828'\uC744 \uBB34\uC2DC\uD55C \uCC44 \uD654\uB824\uD55C \uAE30\uC220\uB9CC
      \uC11E\uC5B4\uAC00\uBA70 2\uC810 \uC29B\uC744 \uC2DC\uB3C4\uD558\uB2E4 \uBBF8\uB044\uB7EC\uC9C8
      \uBED4\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Discipline_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Discipline_001
    ko: "\uC790\uC138\uB294 \uB098\uC058\uC9C0 \uC54A\uC9C0\uB9CC, \uC9C0\uAE08\uC740
      \uC57D\uC18D\uB41C \uC9C0\uC810\uC5D0\uC11C \uC815\uD655\uB3C4\uB97C \uB192\uC774\uB294
      \uAC8C \uC6B0\uC120\uC774\uB2E4. \uB124 \uB2A5\uB825\uC744 \uBBFF\uC73C\uB2C8
      \uC6D0\uCE59\uB300\uB85C \uB2E4\uC2DC \uD574\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Principled_101
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4, \uAC10\uB3C5\uB2D8. \uC81C\uAC00 \uC7A0\uC2DC
      \uD6A8\uC728\uBCF4\uB2E4 \uC7AC\uBBF8\uB97C \uC55E\uC138\uC6E0\uC2B5\uB2C8\uB2E4.
      \uB2E4\uC2DC \uC815\uD574\uC9C4 \uB9E4\uB274\uC5BC\uB300\uB85C 100\uAC1C \uCC44\uC6B0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Principled_102
    ko: "\uC88B\uC544, \uADF8 \uC815\uAD50\uD568\uC774 \uACBD\uAE30\uC7A5\uC5D0 \uADF8\uB300\uB85C
      \uB098\uD0C0\uB0A0 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Principled_1
    ko: "\uADDC\uCE59\uC744 \uBC14\uB85C \uC218\uC6A9\uD588\uC73C\uB098 \uC774\uBBF8
      \uD750\uD2B8\uB7EC\uC9C4 \uB9AC\uB4EC\uC744 \uBCF5\uAD6C\uD558\uB294 \uB370
      \uC2DC\uAC04\uC774 \uC18C\uC694\uB428"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Guardian_101
    ko: "\uD300\uC758 \uC2DC\uC2A4\uD15C\uC744 \uB9DD\uCE58\uACE0 \uC788\uC5C8\uAD70\uC694.
      \uC81C\uAC00 \uC911\uC2EC\uC744 \uC7A1\uC544\uC57C \uD558\uB294\uB370... \uC870\uC5B8
      \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uB2E4\uC2DC \uAE30\uBCF8\uBD80\uD130 \uD0C4\uD0C4\uD788
      \uB2E4\uC9C0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Guardian_1
    ko: "\uCC45\uC784\uAC10\uC744 \uB290\uB07C\uACE0 \uC9D1\uC911\uB825\uC744 \uBC1C\uD718\uD558\uC5EC
      \uC29B \uBA54\uCEE4\uB2C8\uC998\uC744 \uC644\uBCBD\uD788 \uBCF5\uAD6C\uD568"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Tactician_101
    ko: "\uACA9\uB824\uB294 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uC81C \uACC4\uC0B0\uC73C\uB85C\uB294
      \uC774 \uC2B5\uB3C4\uC5D0\uC11C \uC774 \uAC01\uB3C4\uAC00 \uB354 \uD6A8\uC728\uC801\uC774\uB77C
      \uC0DD\uAC01\uD588\uC2B5\uB2C8\uB2E4. \uD63C\uC120\uC774 \uC0DD\uACA8 \uC9D1\uC911\uB825\uC774
      \uB5A8\uC5B4\uC9C0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Tactician_1
    ko: "\uC790\uC2E0\uC758 \uACC4\uC0B0\uACFC \uAC10\uB3C5\uC758 \uC9C0\uC2DC \uC0AC\uC774\uC5D0\uC11C
      \uAC08\uB4F1\uD558\uB2E4 \uC29B \uBC38\uB7F0\uC2A4\uAC00 \uBD95\uAD34\uB428"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Exemplary_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uAE30\uB300\uB97C \uC800\uBC84\uB838\uB124\uC694.
      \uB2E4\uB978 \uBD80\uC6D0\uB4E4\uC774 \uBCF4\uAE30 \uC804\uC5D0 \uC5BC\uB978
      \uC81C\uC790\uB9AC\uB85C \uB3CC\uC544\uAC00 \uC815\uC11D\uB300\uB85C \uC218\uD589\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Exemplary_1
    ko: "\uCCB4\uBA74\uC744 \uCC28\uB9AC\uB290\uB77C \uAE09\uAE09\uD574 \uD6C8\uB828\uC758
      \uC9C8\uC801 \uD5A5\uC0C1\uC740 \uC774\uB8E8\uC5B4\uC9C0\uC9C0 \uC54A\uC74C"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Discipline_002
    ko: "\uAE30\uBCF8\uB3C4 \uC548 \uB41C \uB140\uC11D\uC774 \uBA4B\uBD80\uB9B4 \uC0DD\uAC01\uBD80\uD130
      \uD558\uB098? \uB2F9\uC7A5 \uCF54\uD2B8 \uBC16\uC73C\uB85C \uB098\uAC00\uC11C
      \uD0DC\uB3C4\uBD80\uD130 \uACE0\uCCD0\uC624\uB4E0\uAC00, \uC544\uB2C8\uBA74
      \uC81C\uB300\uB85C \uC6D0\uCE59\uC744 \uC9C0\uCF1C!"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Principled_201
    ko: "\uC815\uACE1\uC744 \uCC14\uB838\uC2B5\uB2C8\uB2E4. \uADDC\uC728\uC744 \uC5B4\uAE34
      \uC81C \uC798\uBABB\uC785\uB2C8\uB2E4. \uC29B \uD3FC 1,000\uBC88 \uBC18\uBCF5
      \uD6C4 \uB2E4\uC2DC \uD6C8\uB828\uC5D0 \uC784\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Principled_2
    ko: "\uC5C4\uACA9\uD55C \uD6C8\uC721\uC5D0 \uAC01\uC131\uD558\uC5EC \uD750\uD2B8\uB7EC\uC9D0
      \uC5C6\uB294 \uC644\uBCBD\uD55C \uC288\uD305 \uD3FC\uC744 \uCCB4\uB4DD\uD568"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Guardian_201
    ko: "\uBB34\uC9C8\uC11C\uD55C \uBAA8\uC2B5\uC744 \uBCF4\uC5EC\uB4DC\uB824 \uC1A1\uAD6C\uD569\uB2C8\uB2E4.
      \uD300\uC758 \uBD84\uC704\uAE30\uB97C \uD574\uCE58\uC9C0 \uC54A\uB3C4\uB85D
      \uC790\uC219\uD558\uBA70 \uC5F0\uC2B5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Guardian_2
    ko: "\uBC18\uC131\uC740 \uAE4A\uC73C\uB098 \uC9C8\uCC45\uC73C\uB85C \uC778\uD55C
      \uC704\uCD95\uAC10\uC774 \uC288\uD305 \uBE44\uAC70\uB9AC\uC5D0 \uC601\uD5A5\uC744
      \uC90C"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Tactician_201
    ko: "\uC9C0\uC801\uC774 \uD0C0\uB2F9\uD569\uB2C8\uB2E4. \uAC10\uC815\uC5D0 \uCE58\uC6B0\uCE5C
      \uC5F0\uC2B5\uC740 \uBE44\uD6A8\uC728\uC801\uC774\uAD70\uC694. \uB2E4\uC2DC
      \uCCB4\uACC4\uC801\uC778 \uB8E8\uD2F4\uC73C\uB85C \uBCF5\uADC0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Tactician_2
    ko: "\uB17C\uB9AC\uC801\uC73C\uB85C \uB0A9\uB4DD\uD558\uC5EC \uBCF5\uADC0\uD588\uC73C\uB098
      \uD6C8\uB828 \uB370\uC774\uD130\uAC00 \uCD08\uAE30\uD654\uB428"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Exemplary_201
    ko: "\uBAA8\uB450\uAC00 \uBCF4\uB294 \uC55E\uC5D0\uC11C \uC774\uB807\uAC8C\uAE4C\uC9C0...
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC81C \uC9C4\uC2EC\uAE4C\uC9C0
      \uBB34\uC2DC\uB2F9\uD55C \uAC83 \uAC19\uC544 \uB9C8\uC74C\uC774 \uBB34\uAC81\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Exemplary_2
    ko: "\uACF5\uAC1C\uC801\uC778 \uC9C8\uCC45\uC5D0 \uC790\uC874\uC2EC\uC774 \uC0C1\uD574
      \uC190 \uB05D\uC758 \uAC10\uAC01\uC774 \uBB34\uB38C\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Discipline_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uB97C \uCC28\uAC00\uC6B4 \uB208\uC73C\uB85C
      \uBC14\uB77C\uBCF4\uB2E4\uAC00, \uCD9C\uC11D\uBD80\uC5D0 X\uD45C\uB97C \uCE58\uACE0
      \uB2E4\uB978 \uC120\uC218\uC5D0\uAC8C\uB85C \uBC1C\uAE38\uC744 \uB3CC\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC800\uB97C \uD3EC\uAE30\uD558\uC2E0 \uAC74\uAC00\uC694?
      \uAE30\uC900\uC774 \uC5C6\uB294 \uD6C8\uB828\uC740 \uC758\uBBF8\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4...
      \uAC08\uD53C\uB97C \uBABB \uC7A1\uACA0\uC5B4\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Principled_3
    ko: "\uD1B5\uC81C\uAC00 \uC0AC\uB77C\uC9C0\uC790 \uC2A4\uC2A4\uB85C\uC758 \uAE30\uC900\uB9C8\uC800
      \uD754\uB4E4\uB9AC\uBA70 \uC288\uD305 \uC131\uACF5\uB960\uC774 \uAE09\uB77D\uD568"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Guardian_301
    ko: "\uC81C\uAC00 \uD300\uC758 \uADDC\uC728\uC744 \uAE68\uB728\uB824\uC11C \uC2E4\uB9DD\uD558\uC2E0
      \uAC70\uAD70\uC694. \uBB34\uC5B8\uC758 \uC555\uBC15\uC774 \uB354 \uAD34\uB86D\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Guardian_3
    ko: "\uC8C4\uCC45\uAC10\uC5D0 \uC0AC\uB85C\uC7A1\uD600 \uB9BC\uC744 \uC870\uC900\uD558\uB294
      \uC2DC\uC57C\uAC00 \uD750\uB824\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Tactician_301
    ko: "\uAD00\uC2EC\uC744 \uB04A\uC73C\uC2E0 \uAC74\uAC00\uC694? \uC544\uB2C8\uBA74
      \uC2A4\uC2A4\uB85C \uAE68\uB2EB\uAE30\uB97C \uAE30\uB2E4\uB9AC\uC2DC\uB294
      \uAC74\uAC00\uC694? \uC77C\uB2E8 \uD558\uB358 \uB370\uC774\uD130\uB97C \uB9C8\uC800
      \uBF51\uC544\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Tactician_3
    ko: "\uD63C\uC790 \uD6C8\uB828\uC744 \uC774\uC5B4\uAC00\uC9C0\uB9CC \uAC10\uB3C5\uC758
      \uD53C\uB4DC\uBC31 \uC5C6\uC774\uB294 \uD55C\uACC4\uAC00 \uBA85\uD655\uD568"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Exemplary_301
    ko: "\uC544\uBB34 \uB9D0\uC500 \uC5C6\uC73C\uC2E0 \uAC8C \uAC00\uC7A5 \uBB34\uC12D\uAD70\uC694.
      \uC81C\uAC00 \uC2A4\uC2A4\uB85C \uC99D\uBA85\uD558\uC9C0 \uBABB\uD558\uBA74
      \uC774 \uD300\uC5D0\uC11C \uC81C \uC790\uB9AC\uB294 \uC5C6\uB2E4\uB294 \uB73B\uC774\uACA0\uC8E0.
      \uBCF4\uC2ED\uC2DC\uC624, \uB2E4\uC2DC \uC644\uBCBD\uD558\uAC8C \uB358\uC9C0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Exemplary_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uAD00\uC2EC\uC744 \uC704\uAE30\uB85C \uB290\uB07C\uACE0
      \uC2A4\uC2A4\uB85C\uB97C \uC5C4\uACA9\uD788 \uD1B5\uC81C\uD558\uC5EC \uC288\uD305
      \uC815\uD655\uB3C4\uB97C \uADF9\uB300\uD654\uD568"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Bond_001
    ko: "\uC815\uADDC \uC288\uD305 \uD6C8\uB828 \uC2DC\uAC04, \uD300\uC758 \uD55C
      \uC120\uC218\uAC00 \uC9C0\uC815\uB41C \uC704\uCE58\uAC00 \uC544\uB2CC \uACF3\uC5D0\uC11C
      \uBB34\uBD84\uBCC4\uD558\uAC8C \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Bond_002
    ko: "\uC120\uC218\uB294 \uAC10\uB3C5\uC774 \uC9C0\uC2DC\uD55C '\uAE30\uBCF8 \uC790\uC138
      \uC720\uC9C0'\uC640 '\uC815\uD574\uC9C4 \uC2A4\uD31F\uC5D0\uC11C\uC758 \uBC18\uBCF5
      \uD6C8\uB828'\uC744 \uBB34\uC2DC\uD55C \uCC44 \uD654\uB824\uD55C \uAE30\uC220\uB9CC
      \uC11E\uC5B4\uAC00\uBA70 2\uC810 \uC29B\uC744 \uC2DC\uB3C4\uD558\uB2E4 \uBBF8\uB044\uB7EC\uC9C8
      \uBED4\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Bond_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Bond_001
    ko: "\uC790\uC138\uB294 \uB098\uC058\uC9C0 \uC54A\uC9C0\uB9CC, \uC9C0\uAE08\uC740
      \uC57D\uC18D\uB41C \uC9C0\uC810\uC5D0\uC11C \uC815\uD655\uB3C4\uB97C \uB192\uC774\uB294
      \uAC8C \uC6B0\uC120\uC774\uB2E4. \uB124 \uB2A5\uB825\uC744 \uBBFF\uC73C\uB2C8
      \uC6D0\uCE59\uB300\uB85C \uB2E4\uC2DC \uD574\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Kind_101
    ko: "\uBD80\uB4DC\uB7FD\uAC8C \uB9D0\uC500\uD574 \uC8FC\uC2DC\uB2C8 \uB9C8\uC74C\uC774
      \uB193\uC774\uB124\uC694. \uC2DC\uD0A4\uB294 \uB300\uB85C \uD560\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Kind_1
    ko: "\uC2EC\uB9AC\uC801 \uC548\uC815\uB9CC \uCC3E\uC74C"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC800\uB97C \uBBFF\uC5B4\uC8FC\uC2E0\uB2E4\uBA74,
      \uC800\uB294 \uBB34\uC870\uAC74 \uB530\uB97C \uBFD0\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Loyal_1
    ko: "\uC218\uB3D9\uC801\uC778 \uD0DC\uB3C4 \uC720\uC9C0"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Sincere_101
    ko: "\uBB35\uBB35\uD788 \uC81C \uC790\uB9AC\uB97C \uC9C0\uD0A4\uB294 \uAC8C \uB2F5\uC774\uACA0\uC8E0.
      \uB2E4\uC2DC \uC2DC\uC791\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Sincere_1
    ko: "\uBCC0\uD654 \uC5C6\uB294 \uB8E8\uD2F4 \uC218\uD589"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Moodmaker_101
    ko: "\uD5E4\uD5E4, \uC54C\uACA0\uC2B5\uB2C8\uB2E4! \uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C
      \uC9C4\uC9C0\uD558\uAC8C \uAC00\uBCFC\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Moodmaker_1
    ko: "\uC5EC\uC804\uD55C \uC0B0\uB9CC\uD568"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Bond_002
    ko: "\uAE30\uBCF8\uB3C4 \uC548 \uB41C \uB140\uC11D\uC774 \uBA4B\uBD80\uB9B4 \uC0DD\uAC01\uBD80\uD130
      \uD558\uB098? \uB2F9\uC7A5 \uCF54\uD2B8 \uBC16\uC73C\uB85C \uB098\uAC00\uC11C
      \uD0DC\uB3C4\uBD80\uD130 \uACE0\uCCD0\uC624\uB4E0\uAC00, \uC544\uB2C8\uBA74
      \uC81C\uB300\uB85C \uC6D0\uCE59\uC744 \uC9C0\uCF1C!"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Kind_201
    ko: "\uB108\uBB34 \uBB34\uC12D\uAC8C \uB9D0\uC500\uD558\uC2DC\uB124\uC694...
      \uC758\uC695\uC774 \uB69D \uB5A8\uC5B4\uC84C\uC5B4\uC694..."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Kind_2
    ko: "\uC790\uC2E0\uAC10 \uAE09\uB77D"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Loyal_201
    ko: "\uC808 \uD3EC\uAE30\uD558\uC9C0 \uB9C8\uC138\uC694! \uAC10\uB3C5\uB2D8!
      \uB2E4\uC2DC\uB294 \uC2E4\uB9DD \uC548 \uC2DC\uD0B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Loyal_2
    ko: "\uACFC\uB3C4\uD55C \uAE34\uC7A5\uC73C\uB85C \uADFC\uC721 \uACBD\uC9C1"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Sincere_201
    ko: "\uC5F4\uC2EC\uD788 \uD558\uB824\uB358 \uAC74\uB370... \uC81C\uAC00 \uBD80\uC871\uD588\uB098
      \uBD05\uB2C8\uB2E4. \uC8C4\uC1A1\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Sincere_2
    ko: "\uC790\uCC45\uC73C\uB85C \uC778\uD55C \uC9D1\uC911\uB825 \uC800\uD558"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Moodmaker_201
    ko: "\uC545! \uBD84\uC704\uAE30 \uC2F8\uD574\uC84C\uB124... \uC870\uC6A9\uD788
      \uC29B\uC774\uB098 \uB358\uC838\uC57C\uACA0\uB2E4..."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Moodmaker_2
    ko: "\uD765\uBBF8 \uC0C1\uC2E4\uB85C \uC778\uD55C \uB300\uCDA9 \uB358\uC9C0\uAE30"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Bond_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uB97C \uCC28\uAC00\uC6B4 \uB208\uC73C\uB85C
      \uBC14\uB77C\uBCF4\uB2E4\uAC00, \uCD9C\uC11D\uBD80\uC5D0 X\uD45C\uB97C \uCE58\uACE0
      \uB2E4\uB978 \uC120\uC218\uC5D0\uAC8C\uB85C \uBC1C\uAE38\uC744 \uB3CC\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8? \uD654\uB098\uC168\uC5B4\uC694? \uC81C\uBC1C \uBB50\uB77C\uACE0
      \uB9D0\uC500 \uC880 \uD574\uC8FC\uC138\uC694..."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Kind_3
    ko: "\uAC10\uB3C5\uC744 \uB418\uCC3E\uAE30 \uC704\uD574 \uAC04\uC808\uD558\uAC8C
      \uC29B\uC5D0 \uC9D1\uC911"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uCE68\uBB35\uC740 \uC800\uB97C \uB354 \uAC15\uD558\uAC8C
      \uB9CC\uB4DC\uB824\uB294 \uC2DC\uB828\uC77C \uAC81\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Loyal_3
    ko: "\uB9F9\uBAA9\uC801 \uBBFF\uC74C\uC774 \uAC00\uC838\uC628 \uAE30\uC801\uC801
      \uC9D1\uC911\uB825"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Sincere_301
    ko: "\uAE30\uB2E4\uB824 \uC8FC\uC2DC\uB294 \uAC70\uAD70\uC694. \uC81C\uAC00 \uC2A4\uC2A4\uB85C
      \uC815\uB2F5\uC744 \uCC3E\uC744 \uB54C\uAE4C\uC9C0\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Sincere_3
    ko: "\uC790\uAE30 \uC131\uCC30\uC744 \uD1B5\uD55C \uC29B \uD3FC \uC644\uC131"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Moodmaker_301
    ko: "\uC5B4\uB77C? \uC790\uC720 \uC2DC\uAC04\uC778\uAC00? \uADF8\uB7FC \uB0B4
      \uB9C8\uC74C\uB300\uB85C \uB354 \uBA4B\uC9C0\uAC8C \uC29B!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Moodmaker_3
    ko: "\uC555\uBC15 \uC5C6\uB294 \uD658\uACBD\uC5D0\uC11C \uCC3D\uC758\uC801 \uC29B
      \uC131\uACF5"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Cold_001
    ko: "\uC815\uADDC \uC288\uD305 \uD6C8\uB828 \uC2DC\uAC04, \uD300\uC758 \uD55C
      \uC120\uC218\uAC00 \uC9C0\uC815\uB41C \uC704\uCE58\uAC00 \uC544\uB2CC \uACF3\uC5D0\uC11C
      \uBB34\uBD84\uBCC4\uD558\uAC8C \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Cold_002
    ko: "\uC120\uC218\uB294 \uAC10\uB3C5\uC774 \uC9C0\uC2DC\uD55C '\uAE30\uBCF8 \uC790\uC138
      \uC720\uC9C0'\uC640 '\uC815\uD574\uC9C4 \uC2A4\uD31F\uC5D0\uC11C\uC758 \uBC18\uBCF5
      \uD6C8\uB828'\uC744 \uBB34\uC2DC\uD55C \uCC44 \uD654\uB824\uD55C \uAE30\uC220\uB9CC
      \uC11E\uC5B4\uAC00\uBA70 2\uC810 \uC29B\uC744 \uC2DC\uB3C4\uD558\uB2E4 \uBBF8\uB044\uB7EC\uC9C8
      \uBED4\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Cold_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Cold_001
    ko: "\uC790\uC138\uB294 \uB098\uC058\uC9C0 \uC54A\uC9C0\uB9CC, \uC9C0\uAE08\uC740
      \uC57D\uC18D\uB41C \uC9C0\uC810\uC5D0\uC11C \uC815\uD655\uB3C4\uB97C \uB192\uC774\uB294
      \uAC8C \uC6B0\uC120\uC774\uB2E4. \uB124 \uB2A5\uB825\uC744 \uBBFF\uC73C\uB2C8
      \uC6D0\uCE59\uB300\uB85C \uB2E4\uC2DC \uD574\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Planner_101
    ko: "\uACA9\uB824 \uB4A4\uC5D0 \uC228\uC740 \uC758\uB3C4\uB97C \uD30C\uC545\uD588\uC2B5\uB2C8\uB2E4.
      \uC77C\uB2E8\uC740 \uB9DE\uCDB0\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Planner_1
    ko: "\uD6C8\uB828\uBCF4\uB2E4 \uC758\uC911 \uD30C\uC545\uC5D0 \uB1CC \uACFC\uBD80\uD558"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Opportunist_101
    ko: "\uC9C0\uAE08\uC740 \uC218\uAE0D\uD558\uB294 \uCC99\uD558\uB294 \uAC8C \uC81C
      \uC785\uC9C0\uC5D0 \uC720\uB9AC\uD558\uACA0\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Opportunist_1
    ko: "\uC9C4\uC815\uC131 \uACB0\uC5EC\uB85C \uD3FC \uBD95\uAD34"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Cunning_101
    ko: "\uACA9\uB824\uB77C\uB2C8, \uC800\uB97C \uB2E4\uB8E8\uB294 \uBC95\uC744 \uC544\uC2DC\uB124\uC694.
      \uD558\uC9C0\uB9CC \uBAB8\uC740 \uC548 \uB530\uB77C\uC8FC\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Cunning_1
    ko: "\uC2EC\uB9AC\uC801 \uAC70\uB9AC\uAC10\uC73C\uB85C \uC778\uD55C \uBD88\uD611\uD654\uC74C"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Believer_101
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD2C0\uB838\uB2E4\uACE0 \uC0DD\uAC01\uD558\uC9C4
      \uC54A\uC9C0\uB9CC... \uC77C\uB2E8\uC740 \uBA48\uCD94\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Believer_1
    ko: "\uACE0\uC9D1\uACFC \uC9C0\uC2DC \uC0AC\uC774\uC758 \uCDA9\uB3CC"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Cold_002
    ko: "\uAE30\uBCF8\uB3C4 \uC548 \uB41C \uB140\uC11D\uC774 \uBA4B\uBD80\uB9B4 \uC0DD\uAC01\uBD80\uD130
      \uD558\uB098? \uB2F9\uC7A5 \uCF54\uD2B8 \uBC16\uC73C\uB85C \uB098\uAC00\uC11C
      \uD0DC\uB3C4\uBD80\uD130 \uACE0\uCCD0\uC624\uB4E0\uAC00, \uC544\uB2C8\uBA74
      \uC81C\uB300\uB85C \uC6D0\uCE59\uC744 \uC9C0\uCF1C!"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Planner_201
    ko: "\uACF5\uD3EC \uC815\uCE58\uB97C \uC4F0\uC2DC\uB294\uAD70\uC694. \uD558\uC9C0\uB9CC
      \uD6A8\uC728\uC801\uC778 \uC9C0\uB3C4\uB294 \uC544\uB2CC \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Planner_2
    ko: "\uBC18\uBC1C\uC2EC\uC744 \uC2E4\uB825 \uC99D\uBA85\uC73C\uB85C \uC2B9\uD654"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Opportunist_201
    ko: "\uCE58, \uBB34\uC11C\uC6CC\uC11C \uD558\uACA0\uB098. \uC77C\uB2E8 \uC2DC\uD0A4\uB294
      \uAC83\uB9CC \uC644\uBCBD\uD558\uAC8C \uD574\uC11C \uC785 \uB9C9\uC790."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Opportunist_2
    ko: "\uC0DD\uC874 \uBCF8\uB2A5\uC774 \uC815\uD655\uB3C4\uB97C \uB192\uC784"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Cunning_201
    ko: "\uC544\uD504\uB124\uC694. \uD558\uC9C0\uB9CC \uC81C \uC2E4\uB825\uC744 \uBCF4\uC5EC\uC8FC\uBA74
      \uADF8 \uC785\uC744 \uB2EB\uC73C\uC2DC\uACA0\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Cunning_2
    ko: "\uB3C5\uAE30\uB97C \uD488\uC740 \uC288\uD305 \uC9D1\uC911\uB825"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Believer_201
    ko: "\uC81C \uB18D\uAD6C\uB97C \uBB34\uC2DC\uD558\uC2DC\uB2E4\uB2C8. \uC81C\uAC00
      \uC633\uB2E4\uB294 \uAC78 \uC29B\uC73C\uB85C \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Believer_2
    ko: "\uC2E0\uB150\uC744 \uC9C0\uD0A4\uAE30 \uC704\uD55C \uACE0\uB3C4\uC758 \uBAB0\uC785"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Cold_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uB97C \uCC28\uAC00\uC6B4 \uB208\uC73C\uB85C
      \uBC14\uB77C\uBCF4\uB2E4\uAC00, \uCD9C\uC11D\uBD80\uC5D0 X\uD45C\uB97C \uCE58\uACE0
      \uB2E4\uB978 \uC120\uC218\uC5D0\uAC8C\uB85C \uBC1C\uAE38\uC744 \uB3CC\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Planner_301
    ko: "\uC774 \uCE68\uBB35\uC870\uCC28 \uAC10\uB3C5\uB2D8\uC758 \uC2DC\uB098\uB9AC\uC624\uAD70.
      \uB0B4 \uC790\uBC1C\uC131\uC744 \uB04C\uC5B4\uB0B4\uB824\uB294."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Planner_3
    ko: "\uBD84\uC11D\uB9CC \uD558\uB290\uB77C \uC2E4\uD589 \uBD80\uC871"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Opportunist_301
    ko: "\uAC04\uC12D \uC548 \uD558\uB2C8\uAE4C \uD3B8\uD558\uB124. \uB300\uCDA9
      \uB358\uC9C0\uBA74\uC11C \uC2DC\uAC04\uC774\uB098 \uB54C\uC6B0\uC790."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Opportunist_3
    ko: "\uD6C8\uB828 \uAC15\uB3C4 \uC800\uD558"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Cunning_301
    ko: "\uBB34\uC2A8 \uAFCD\uAFCD\uC774\uC2E4\uAE4C. \uD568\uC815\uC778\uAC00? \uC77C\uB2E8\uC740
      \uD3C9\uBC94\uD558\uAC8C \uB358\uC9C0\uACE0 \uC788\uC790."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Cunning_3
    ko: "\uC758\uAD6C\uC2EC\uC73C\uB85C \uC778\uD55C \uC18C\uADF9\uC801 \uD0DC\uB3C4"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Believer_301
    ko: "\uB098\uB97C \uC778\uC815\uD55C\uB2E4\uB294 \uB73B\uC778\uAC00. \uC5ED\uC2DC
      \uB0B4 \uB18D\uAD6C\uB294 \uB0B4\uAC00 \uB9CC\uB4DC\uB294 \uAC70\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Believer_3
    ko: "\uB3C5\uB2E8\uC801\uC778 \uD6C8\uB828 \uBC29\uC2DD \uACE0\uC218"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Instinct_001
    ko: "\uC815\uADDC \uC288\uD305 \uD6C8\uB828 \uC2DC\uAC04, \uD300\uC758 \uD55C
      \uC120\uC218\uAC00 \uC9C0\uC815\uB41C \uC704\uCE58\uAC00 \uC544\uB2CC \uACF3\uC5D0\uC11C
      \uBB34\uBD84\uBCC4\uD558\uAC8C \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Instinct_002
    ko: "\uC120\uC218\uB294 \uAC10\uB3C5\uC774 \uC9C0\uC2DC\uD55C '\uAE30\uBCF8 \uC790\uC138
      \uC720\uC9C0'\uC640 '\uC815\uD574\uC9C4 \uC2A4\uD31F\uC5D0\uC11C\uC758 \uBC18\uBCF5
      \uD6C8\uB828'\uC744 \uBB34\uC2DC\uD55C \uCC44 \uD654\uB824\uD55C \uAE30\uC220\uB9CC
      \uC11E\uC5B4\uAC00\uBA70 2\uC810 \uC29B\uC744 \uC2DC\uB3C4\uD558\uB2E4 \uBBF8\uB044\uB7EC\uC9C8
      \uBED4\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Instinct_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Instinct_001
    ko: "\uC790\uC138\uB294 \uB098\uC058\uC9C0 \uC54A\uC9C0\uB9CC, \uC9C0\uAE08\uC740
      \uC57D\uC18D\uB41C \uC9C0\uC810\uC5D0\uC11C \uC815\uD655\uB3C4\uB97C \uB192\uC774\uB294
      \uAC8C \uC6B0\uC120\uC774\uB2E4. \uB124 \uB2A5\uB825\uC744 \uBBFF\uC73C\uB2C8
      \uC6D0\uCE59\uB300\uB85C \uB2E4\uC2DC \uD574\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Bluffer_101
    ko: "\uC5D0\uC774, \uC81C \uCC9C\uC7AC\uC131\uC744 \uAC00\uB450\uC2DC\uB294 \uAC74\uAC00\uC694?
      \uBB50, \uC77C\uB2E8 \uD558\uB77C\uBA74 \uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Bluffer_1
    ko: "\uC790\uB9CC\uC2EC\uC774 \uC29B \uD130\uCE58\uB97C \uBB34\uB514\uAC8C \uD568"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Wild_101
    ko: "\uB2F5\uB2F5\uD574\uC694. \uD2C0\uC5D0 \uBC15\uD78C \uD6C8\uB828\uC740 \uC81C
      \uAC10\uAC01\uC744 \uC8FD\uC774\uB294 \uAC83 \uAC19\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Wild_1
    ko: "\uBCF8\uB2A5 \uC5B5\uC81C\uB85C \uC778\uD55C \uB9AC\uB4EC \uD30C\uAD34"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Egoist_101
    ko: "\uB098\uD55C\uD14C \uC9C0\uC2DC\uD558\uC9C0 \uB9C8\uC138\uC694. \uACA9\uB824\uD55C\uB2E4\uACE0
      \uB0B4\uAC00 \uC88B\uC544\uD560 \uC904 \uC54C\uC558\uB098?"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Egoist_1
    ko: "\uBC18\uD56D\uC2EC\uC5D0 \uC758\uD55C \uBB34\uC131\uC758\uD55C \uC288\uD305"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Fighter_101
    ko: "\uACA9\uB824\uBCF4\uB2E4\uB294 \uC2B9\uBD80\uAC00 \uD544\uC694\uD55C\uB370...
      \uC2DC\uC2DC\uD558\uAC8C \uB3CC\uC544\uAC00\uC57C \uD55C\uB2E4\uB2C8."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Fighter_1
    ko: "\uD22C\uC9C0 \uC0C1\uC2E4\uB85C \uC778\uD55C \uD30C\uC6CC \uC870\uC808 \uC2E4\uD328"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Instinct_002
    ko: "\uAE30\uBCF8\uB3C4 \uC548 \uB41C \uB140\uC11D\uC774 \uBA4B\uBD80\uB9B4 \uC0DD\uAC01\uBD80\uD130
      \uD558\uB098? \uB2F9\uC7A5 \uCF54\uD2B8 \uBC16\uC73C\uB85C \uB098\uAC00\uC11C
      \uD0DC\uB3C4\uBD80\uD130 \uACE0\uCCD0\uC624\uB4E0\uAC00, \uC544\uB2C8\uBA74
      \uC81C\uB300\uB85C \uC6D0\uCE59\uC744 \uC9C0\uCF1C!"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Bluffer_201
    ko: "\uC808 \uACFC\uC18C\uD3C9\uAC00\uD558\uC2DC\uB124? \uC81C \uC29B\uC774 \uADF8\uBB3C
      \uCC22\uB294 \uAC70 \uBCF4\uACE0 \uC0AC\uACFC\uD558\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Bluffer_2
    ko: "\uADFC\uAC70 \uC5C6\uB294 \uC790\uC2E0\uAC10\uC774 \uC2E4\uC9C8\uC801 \uB4DD\uC810\uC73C\uB85C"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Wild_201
    ko: "\uC624, \uADF8 \uAE30\uC138! \uB9C8\uC74C\uC5D0 \uB4ED\uB2C8\uB2E4. \uC57C\uC0DD\uB9C8\uB97C
      \uAE38\uB4E4\uC5EC \uBCF4\uC2DC\uB4E0\uAC00\uC694!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Wild_2
    ko: "\uAC70\uCE5C \uC790\uADF9\uC774 \uAC10\uAC01\uC744 \uAE68\uC6C0"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Egoist_201
    ko: "\uB204\uAC00 \uB204\uAD6C\uBCF4\uACE0 \uC2E4 \uC790\uB9AC\uAC00 \uC5C6\uB300?
      \uB0B4\uAC00 \uCF54\uD2B8\uC758 \uC8FC\uC778\uC774\uC57C. \uBD10!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Egoist_2
    ko: "\uADF9\uB3C4\uC758 \uC790\uAE30\uC560\uAC00 \uB9CC\uB4DC\uB294 \uBB34\uACB0\uC810
      \uC29B"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Fighter_201
    ko: "\uC2F8\uC6C0\uC744 \uAC70\uC2DC\uB294 \uAC74\uAC00\uC694? \uC88B\uC2B5\uB2C8\uB2E4.
      \uC2E4\uB825\uC73C\uB85C \uAD74\uBCF5\uC2DC\uCF1C \uB4DC\uB9AC\uC9C0!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Fighter_2
    ko: "\uC2B9\uBD80\uC695 \uD3ED\uBC1C\uB85C \uC29B \uBA54\uCEE4\uB2C8\uC998 \uCD5C\uC801\uD654"
    en: 
    ja: 
  - stringKey: Event_00001_Ch_Instinct_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uB97C \uCC28\uAC00\uC6B4 \uB208\uC73C\uB85C
      \uBC14\uB77C\uBCF4\uB2E4\uAC00, \uCD9C\uC11D\uBD80\uC5D0 X\uD45C\uB97C \uCE58\uACE0
      \uB2E4\uB978 \uC120\uC218\uC5D0\uAC8C\uB85C \uBC1C\uAE38\uC744 \uB3CC\uB9B0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Bluffer_301
    ko: "\uD560 \uB9D0\uC744 \uC783\uC73C\uC2E0 \uAC70\uC9C0. \uB0B4 \uC29B\uC774
      \uB108\uBB34 \uC644\uBCBD\uD574\uC11C \uB9D0\uC774\uC57C!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Bluffer_3
    ko: "\uC790\uAE30 \uAC1D\uAD00\uD654 \uC2E4\uD328"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Wild_301
    ko: "\uCE68\uBB35\uC774 \uD750\uB974\uB294 \uCF54\uD2B8... \uC624\uC9C1 \uACF5
      \uC18C\uB9AC\uBFD0. \uB098\uC058\uC9C0 \uC54A\uC740\uB370?"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Wild_3
    ko: "\uC790\uC720\uB97C \uC990\uAE30\uB098 \uC2E4\uB825 \uD5A5\uC0C1\uC740 \uBBF8\uBBF8"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Egoist_301
    ko: "\uADF8\uB798, \uCC38\uACAC\uD558\uC9C0 \uB9C8. \uB09C \uB098\uB9CC\uC758
      \uAE38\uC744 \uAC08 \uD14C\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Egoist_3
    ko: "\uACE0\uB9BD\uB41C \uD6C8\uB828"
    en: 
    ja: 
  - stringKey: Event_00001_Desc_Fighter_301
    ko: "\uB098\uB97C \uBB34\uC2DC\uD574? \uC5B4\uB514 \uB208\uC744 \uB5BC\uC9C0
      \uBABB\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC8FC\uC9C0!"
    en: 
    ja: 
  - stringKey: Event_00001_Rs_Fighter_3
    ko: "\uACFC\uC695\uC73C\uB85C \uC778\uD55C \uC29B \uAE30\uBCF5"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Discipline_001
    ko: "\uC815\uADDC \uD6C8\uB828\uC774 \uB05D\uB09C \uB4A4, \uB0A1\uC740 \uACE8\uB300
      \uBC11\uC5D0\uC11C \uD55C \uC120\uC218\uAC00 \uD640\uB85C 2\uC810 \uC29B \uC5F0\uC2B5\uC744
      \uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Discipline_002
    ko: "\uD558\uC9C0\uB9CC \uB9BC\uC774 \uD718\uC5B4\uC838 \uC788\uB294\uC9C0, \uB358\uC9C0\uB294
      \uACF5\uB9C8\uB2E4 \uC790\uAFB8\uB9CC \uB9BC\uC744 \uB9DE\uACE0 \uD295\uACA8
      \uB098\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Discipline_003
    ko: "\uC120\uC218\uB294 \uD55C\uC228\uC744 \uC26C\uBA70 \uB540\uC5D0 \uC816\uC740
      \uC720\uB2C8\uD3FC \uC18C\uB9E4\uB85C \uC774\uB9C8\uB97C \uB2E6\uC2B5\uB2C8\uB2E4.
      \uC774\uB54C \uADFC\uCC98\uB97C \uC9C0\uB098\uAC00\uB358 \uB2F9\uC2E0(\uAC10\uB3C5)\uACFC
      \uB208\uC774 \uB9C8\uC8FC\uCE69\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Discipline_004
    ko: "\uC120\uC218\uB294 \uBA38\uC4F1\uD55C \uB4EF \uACF5\uC744 \uC7A1\uC73C\uBA70
      \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Discipline_005
    ko: "\uAC10\uB3C5\uB2D8, \uC544\uC9C1 \uC548 \uAC00\uC168\uC5B4\uC694? \uC694\uC998
      \uC911\uAC70\uB9AC \uC29B \uAC10\uAC01\uC774 \uB3C4\uBB34\uC9C0 \uC548 \uC7A1\uD600\uC11C\uC694...
      \uC6B0\uB9AC \uD559\uAD50 \uACE8\uB300\uAC00 \uC880 \uC774\uC0C1\uD55C \uAC74\uC9C0,
      \uC81C \uC190\uC774 \uBB38\uC81C\uC778 \uAC74\uC9C0 \uBAA8\uB974\uACA0\uB124\uC694.
      \uD558\uD558."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Discipline_006
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Discipline_001
    ko: "\uD658\uACBD \uD0D3\uD558\uC9C0 \uB9C8\uB77C. \uB9BC\uC774 \uD718\uC5B4
      \uC788\uB2E4\uBA74 \uADF8 \uAD74\uC808\uAE4C\uC9C0 \uACC4\uC0B0\uD574\uC11C
      \uB123\uB294 \uAC8C \uC2E4\uB825\uC774\uB2E4. \uC9C0\uAE08 \uB124 \uB178\uB825\uC740
      \uD5DB\uB418\uC9C0 \uC54A\uC544. \uC870\uAE08\uB9CC \uB354 \uC190\uB05D\uC758
      \uAC10\uAC01\uC744 \uBBFF\uC5B4\uBD10."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Principled_101
    ko: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uAD74\uC808\uB41C \uAC01\uB3C4\uB97C \uACE0\uB824\uD55C
      \uC0C8\uB85C\uC6B4 \uC870\uC900\uC810\uC744 \uC124\uC815\uD574 \uC5F0\uC2B5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Principled_1
    ko: "\uAC10\uB3C5\uC758 \uACA9\uB824\uAC00 \uBCF8\uC778\uC758 \uC5F0\uC2B5 \uAC00\uC774\uB4DC\uB77C\uC778\uC5D0
      \uD655\uC2E0\uC744 \uC90C"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Guardian_101
    ko: "\uAC10\uB3C5\uB2D8 \uB9D0\uC500\uB300\uB85C \uC81C\uAC00 \uD754\uB4E4\uB9AC\uBA74
      \uC548 \uB418\uC8E0. \uD300\uC758 \uB4DD\uC810\uC6D0\uC73C\uB85C\uC11C \uC790\uBD80\uC2EC\uC744
      \uAC00\uC9C8\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Guardian_1
    ko: "\uC2EC\uB9AC\uC801 \uC555\uBC15\uC744 \uC774\uACA8\uB0B4\uACE0 \uD0C0\uC810\uC744
      \uC815\uD655\uD788 \uCC3E\uC544\uB0C4"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Tactician_101
    ko: "\uAD74\uC808 \uACC4\uC0B0\uC774\uB77C... \uD765\uBBF8\uB86D\uB124\uC694.
      \uB9BC\uC758 \uC67C\uCABD 5cm \uC9C0\uC810\uC744 \uACA8\uB0E5\uD574\uC11C \uB358\uC838\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Tactician_1
    ko: "\uD718\uC5B4\uC9C4 \uB9BC\uC744 \uACF5\uB7B5\uD558\uB294 \uC0C8\uB85C\uC6B4
      \uD3EC\uC778\uD2B8\uB97C \uACC4\uC0B0\uD574\uB0B4\uBA70 \uC29B \uC9C0\uB2A5\uC774
      \uD55C \uB2E8\uACC4 \uC0C1\uC2B9"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Exemplary_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uAE30\uB300\uB97C \uC800\uBC84\uB9AC\uC9C0 \uC54A\uACA0\uC2B5\uB2C8\uB2E4.
      \uAC00\uC7A5 \uC644\uBCBD\uD55C \uD3FC\uC73C\uB85C \uB123\uC5B4\uBCF4\uC774\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Exemplary_1
    ko: "\uD0C0\uC778\uC758 \uAE30\uB300\uB97C \uB3D9\uB825\uC73C\uB85C \uC0BC\uB294
      \uC131\uACA9 \uB355\uBD84\uC5D0 \uC9D1\uC911\uB825\uC774 \uADF9\uB300\uD654"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Discipline_002
    ko: "\uACE8\uB300\uAC00 \uBB38\uC81C\uB77C\uBA74 \uB2E4\uB978 \uACE8\uB300\uC5D0\uC11C
      \uC3D8\uBA74 \uB420 \uC77C\uC774\uB2E4. \uC548 \uB4E4\uC5B4\uAC00\uB294 \uC774\uC720\uB97C
      \uC678\uBD80\uC5D0\uC11C \uCC3E\uC73C\uB824\uB294 \uD0DC\uB3C4 \uC790\uCCB4\uAC00
      \uBB38\uC81C\uC57C. \uC9D1\uC911\uB825\uC774 \uD750\uD2B8\uB7EC\uC9C4 \uAC70
      \uC544\uB2CC\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Principled_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uC81C \uC548\uC77C\uD568\uC744 \uBC18\uC131\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      1,000\uAC1C \uC131\uACF5 \uC804\uC5D4 \uC548 \uAC00\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Principled_2
    ko: "\uC2A4\uC2A4\uB85C\uB97C \uACFC\uD558\uAC8C \uBAB0\uC544\uC138\uC6B0\uB290\uB77C
      \uADFC\uC721\uC774 \uACBD\uC9C1"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Guardian_201
    ko: "\uD300\uC744 \uC704\uD55C \uD6C8\uB828\uC778\uB370 \uAC1C\uC778\uC801\uC778
      \uBD88\uB9CC\uC744 \uB298\uC5B4\uB193\uC558\uAD70\uC694. \uB2E4\uC2DC \uC9D1\uC911\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Guardian_2
    ko: "\uC2E4\uD328\uC5D0 \uB300\uD55C \uACF5\uD3EC\uAC00 \uCEE4\uC9C0\uBA74\uC11C
      \uC29B \uADA4\uC801\uC774 \uD3C9\uC18C\uBCF4\uB2E4 \uC9E7\uC544\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Tactician_201
    ko: "\uC9D1\uC911\uB825\uC774 \uBD80\uC871\uD588\uB358 \uBAA8\uC591\uC785\uB2C8\uB2E4.
      \uD658\uACBD \uD0D3\uC744 \uD558\uAE30 \uC804 \uBB3C\uB9AC\uC801 \uADA4\uC801\uBD80\uD130
      \uC7AC\uACC4\uC0B0\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uC218\uC6A9\uD558\uACE0 \uBD84\uC11D\uC5D0 \uB4E4\uC5B4\uAC14\uC73C\uB098,
      \uB108\uBB34 \uB9CE\uC740 \uBCC0\uC218\uB97C \uACE0\uB824\uD558\uB290\uB77C
      \uC2E4\uC81C \uC29B \uC2DC\uB3C4 \uD69F\uC218\uAC00 \uAE09\uACA9\uD788 \uC904\uC5B4\uB4EC"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Exemplary_201
    ko: "\uC5D0\uC774\uC2A4\uB85C\uC11C \uBD80\uB044\uB7EC\uC6B4 \uBAA8\uC2B5\uC744
      \uBCF4\uC600\uB124\uC694. \uB2E4\uC2DC\uB294 \uC7A5\uBE44 \uD0D3\uC744 \uD558\uC9C0
      \uC54A\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Exemplary_2
    ko: "\uAC10\uB3C5\uC758 \uC9C8\uCC45\uC5D0 \uC790\uC874\uC2EC\uC774 \uC0C1\uD574
      \uC5B4\uAE68\uC5D0 \uACFC\uB3C4\uD55C \uD798\uC774 \uB4E4\uC5B4\uAC10"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Discipline_003
    ko: "\uB9D0\uC5C6\uC774 \uC120\uC218\uC758 \uC29B \uB3D9\uC791\uC744 \uB05D\uAE4C\uC9C0
      \uC9C0\uCF1C\uBCF8 \uB4A4, \uB5A8\uC5B4\uC9C4 \uACF5\uC744 \uC9C1\uC811 \uC8FC\uC6CC
      \uC120\uC218\uC5D0\uAC8C \uAC15\uD558\uAC8C \uB358\uC838\uC8FC\uACE0\uB294
      \uADF8\uB300\uB85C \uCCB4\uC721\uAD00 \uBC16\uC73C\uB85C \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Principled_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uACF5\uC744 \uC8FC\uC6CC\uC8FC\uC2E0 \uAC74 \uC9C1\uC811
      \uAE68\uB2EC\uC73C\uB77C\uB294 \uB73B\uC774\uACA0\uC8E0. \uBA48\uCD94\uC9C0
      \uC54A\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Principled_3
    ko: "\uBB34\uC758\uBBF8\uD55C \uBC18\uBCF5 \uC29B\uC73C\uB85C \uC778\uD574 \uC190\uBAA9\uC5D0
      \uBB34\uB9AC"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uADF8 \uAC15\uD55C \uD328\uC2A4... \uC81C\uAC00
      \uD300\uC744 \uC9C0\uCF1C\uC57C \uD55C\uB2E4\uB294 \uBB34\uC5B8\uC758 \uC555\uBC15\uC774\uACA0\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Guardian_3
    ko: "\uAE30\uC220\uC801\uC778 \uC870\uC5B8 \uBD80\uC7AC\uB85C \uC778\uD574 \uC131\uACF5\uB960\uC740
      \uD06C\uAC8C \uBCC0\uD558\uC9C0 \uC54A\uC74C"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Tactician_301
    ko: "\uC774 \uB0A1\uC740 \uACF5\uC758 \uD68C\uC804\uB825\uACFC \uD718\uC5B4\uC9C4
      \uB9BC\uC758 \uC0C1\uAD00\uAD00\uACC4\uB97C \uC9C1\uC811 \uD30C\uC545\uD574\uBCF4\uB77C\uB294
      \uC758\uBBF8\uAD70\uC694."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Tactician_3
    ko: "\uAC10\uB3C5\uC758 \uC758\uC911\uC744 \uD30C\uC545\uD558\uB294 \uB370 \uC5D0\uB108\uC9C0\uB97C
      \uC3DF\uB290\uB77C \uC815\uC791 \uC29B \uBA54\uCEE4\uB2C8\uC998\uC744 \uB193\uCE68"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Exemplary_301
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uCE68\uBB35\uC774 \uBB34\uC12D\uB124\uC694. \uB354
      \uC644\uBCBD\uD574\uC838\uC57C\uB9CC \uC778\uC815\uBC1B\uC744 \uC218 \uC788\uB2E4\uB294
      \uB73B\uC774\uACA0\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Exemplary_3
    ko: "\uC778\uC815\uBC1B\uAE30 \uC704\uD574 \uD544\uC0AC\uC801\uC73C\uB85C \uC5F0\uC2B5\uD558\uC9C0\uB9CC,
      \uAE30\uC220\uC801 \uD53C\uB4DC\uBC31 \uC5C6\uC774 \uD63C\uC790 \uD6C8\uB828\uD558\uB2E4
      \uBCF4\uB2C8 \uC798\uBABB\uB41C \uC2B5\uAD00\uC774 \uACE0\uCC29\uB420 \uC704\uD5D8\uC5D0
      \uCC98\uD568"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bond_001
    ko: "\uC815\uADDC \uD6C8\uB828\uC774 \uB05D\uB09C \uB4A4, \uB0A1\uC740 \uACE8\uB300
      \uBC11\uC5D0\uC11C \uD55C \uC120\uC218\uAC00 \uD640\uB85C 2\uC810 \uC29B \uC5F0\uC2B5\uC744
      \uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bond_002
    ko: "\uD558\uC9C0\uB9CC \uB9BC\uC774 \uD718\uC5B4\uC838 \uC788\uB294\uC9C0, \uB358\uC9C0\uB294
      \uACF5\uB9C8\uB2E4 \uC790\uAFB8\uB9CC \uB9BC\uC744 \uB9DE\uACE0 \uD295\uACA8
      \uB098\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bond_003
    ko: "\uC120\uC218\uB294 \uD55C\uC228\uC744 \uC26C\uBA70 \uB540\uC5D0 \uC816\uC740
      \uC720\uB2C8\uD3FC \uC18C\uB9E4\uB85C \uC774\uB9C8\uB97C \uB2E6\uC2B5\uB2C8\uB2E4.
      \uC774\uB54C \uADFC\uCC98\uB97C \uC9C0\uB098\uAC00\uB358 \uB2F9\uC2E0(\uAC10\uB3C5)\uACFC
      \uB208\uC774 \uB9C8\uC8FC\uCE69\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bond_004
    ko: "\uC120\uC218\uB294 \uBA38\uC4F1\uD55C \uB4EF \uACF5\uC744 \uC7A1\uC73C\uBA70
      \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bond_005
    ko: "\uAC10\uB3C5\uB2D8, \uC544\uC9C1 \uC548 \uAC00\uC168\uC5B4\uC694? \uC694\uC998
      \uC911\uAC70\uB9AC \uC29B \uAC10\uAC01\uC774 \uB3C4\uBB34\uC9C0 \uC548 \uC7A1\uD600\uC11C\uC694...
      \uC6B0\uB9AC \uD559\uAD50 \uACE8\uB300\uAC00 \uC880 \uC774\uC0C1\uD55C \uAC74\uC9C0,
      \uC81C \uC190\uC774 \uBB38\uC81C\uC778 \uAC74\uC9C0 \uBAA8\uB974\uACA0\uB124\uC694.
      \uD558\uD558."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bond_006
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Bond_001
    ko: "\uD658\uACBD \uD0D3\uD558\uC9C0 \uB9C8\uB77C. \uB9BC\uC774 \uD718\uC5B4
      \uC788\uB2E4\uBA74 \uADF8 \uAD74\uC808\uAE4C\uC9C0 \uACC4\uC0B0\uD574\uC11C
      \uB123\uB294 \uAC8C \uC2E4\uB825\uC774\uB2E4. \uC9C0\uAE08 \uB124 \uB178\uB825\uC740
      \uD5DB\uB418\uC9C0 \uC54A\uC544. \uC870\uAE08\uB9CC \uB354 \uC190\uB05D\uC758
      \uAC10\uAC01\uC744 \uBBFF\uC5B4\uBD10."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8 \uB9D0\uC500 \uB355\uBD84\uC5D0 \uAC11\uC790\uAE30 \uACF5\uC774
      \uC798 \uB4E4\uC5B4\uAC08 \uAC83 \uAC19\uC740 \uAE30\uBD84\uC774\uC5D0\uC694!
      \uAC10\uC0AC\uD574\uC694."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Kind_102
    ko: "\uB124 \uB9C8\uC74C\uC774 \uD3B8\uC548\uD574\uC57C \uACF5\uB3C4 \uD3B8\uC548\uD558\uAC8C
      \uB0A0\uC544\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Kind_1
    ko: "\uC11C\uC801 \uC9C0\uC9C0\uAC00 \uC5D4\uB3C4\uB974\uD540\uC744 \uC0DD\uC131\uD558\uC5EC
      \uADFC\uC721\uC758 \uAE34\uC7A5\uC744 \uD480\uC5B4\uC90C"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Loyal_101
    ko: "\uC800\uB97C \uBBFF\uC5B4\uC8FC\uC2DC\uB294 \uAC10\uB3C5\uB2D8\uC744 \uC704\uD574\uC11C\uB77C\uB3C4
      \uC774 \uAC70\uB9AC\uC758 \uC29B\uC740 \uBB34\uC870\uAC74 \uB9C8\uC2A4\uD130\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Loyal_1
    ko: "\uC2E0\uB8B0\uC5D0 \uBCF4\uB2F5\uD558\uB824\uB294 \uAC15\uB825\uD55C \uC815\uC2E0\uB825\uC774
      \uAC01\uC131"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Sincere_101
    ko: "\uB124, \uB9BC\uC758 \uC0C1\uD0DC\uC5D0 \uC0C1\uAD00\uC5C6\uC774 \uC81C
      \uD3FC\uC774 \uC77C\uC815\uD558\uBA74 \uACB0\uAD6D \uB4E4\uC5B4\uAC04\uB2E4\uB294
      \uB9D0\uC500\uC774\uC2DC\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Sincere_102
    ko: "\uB9DE\uB2E4. 1%\uC758 \uD658\uACBD\uBCF4\uB2E4 99%\uC758 \uC77C\uAD00\uC131\uC774
      \uC911\uC694\uD558\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Sincere_1
    ko: "\uAFB8\uC900\uD568\uC758 \uAC00\uCE58\uB97C \uC778\uC815\uBC1B\uC790 \uD6C8\uB828
      \uBAB0\uC785\uB3C4\uAC00 \uC0C1\uC2B9"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Moodmaker_101
    ko: "\uC624~ \uAC10\uB3C5\uB2D8 \uBA58\uD2B8 \uBA4B\uC9C4\uB370\uC694? \uAD74\uC808\uAE4C\uC9C0
      \uC9C0\uBC30\uD558\uB294 \uC288\uD130! \uC644\uC804 \uC8FC\uC778\uACF5 \uAC19\uC796\uC544\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Moodmaker_1
    ko: "\uC990\uAC70\uC6B4 \uAE34\uC7A5\uAC10\uC774 \uC9D1\uC911\uB825\uC744 \uB192\uC5EC
      \uD3C9\uC18C\uBCF4\uB2E4 \uB192\uC740 \uC57C\uD22C\uC728\uC744 \uAE30\uB85D\uD568"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Bond_002
    ko: "\uACE8\uB300\uAC00 \uBB38\uC81C\uB77C\uBA74 \uB2E4\uB978 \uACE8\uB300\uC5D0\uC11C
      \uC3D8\uBA74 \uB420 \uC77C\uC774\uB2E4. \uC548 \uB4E4\uC5B4\uAC00\uB294 \uC774\uC720\uB97C
      \uC678\uBD80\uC5D0\uC11C \uCC3E\uC73C\uB824\uB294 \uD0DC\uB3C4 \uC790\uCCB4\uAC00
      \uBB38\uC81C\uC57C. \uC9D1\uC911\uB825\uC774 \uD750\uD2B8\uB7EC\uC9C4 \uAC70
      \uC544\uB2CC\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Kind_201
    ko: "\uC544... \uAC10\uB3C5\uB2D8 \uD654\uB098\uC168\uB098\uC694? \uC8C4\uC1A1\uD574\uC694.
      \uBD84\uC704\uAE30 \uC88B\uAC8C \uC5F0\uC2B5\uD558\uB824\uACE0 \uD55C \uAC74\uB370..."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Kind_2
    ko: "\uBD80\uC815\uC801\uC778 \uAC10\uC815\uC801 \uCDA9\uACA9\uC774 \uC29B \uAC10\uAC01\uC744
      \uC644\uC804\uD788 \uC557\uC544\uAC10"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Loyal_201
    ko: "\uC81C\uAC00 \uAC10\uB3C5\uB2D8\uAED8 \uC2E4\uB9DD\uC744 \uB4DC\uB838\uAD70\uC694.
      \uC2E4\uB825\uC73C\uB85C \uC81C \uCDA9\uC131\uC2EC\uC744 \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Loyal_2
    ko: "\uB9DD\uAC10\uC744 \uC53B\uAE30 \uC704\uD574 \uB178\uB825\uD558\uC9C0\uB9CC,
      \uACFC\uB3C4\uD55C \uC5F4\uB9DD\uC774 \uC624\uD788\uB824 \uC190\uBAA9\uC758
      \uC2A4\uB0C5\uC744 \uBC29\uD574"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Sincere_201
    ko: "\uBCC0\uBA85\uC740 \uD544\uC694 \uC5C6\uC8E0. \uB4E4\uC5B4\uAC08 \uB54C\uAE4C\uC9C0
      \uBC24\uC744 \uC0C8\uC6CC\uC11C\uB77C\uB3C4 \uAC10\uAC01\uC744 \uCC3E\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Sincere_2
    ko: "\uBB35\uBB35\uD788 \uC5F0\uC2B5\uC744 \uC774\uC5B4\uAC00\uC9C0\uB9CC \uC2E0\uCCB4\uC801
      \uD55C\uACC4\uC5D0 \uBD80\uB52A\uD798"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Moodmaker_201
    ko: "\uC5D0\uC774, \uAC10\uB3C5\uB2D8 \uB108\uBB34 \uC5C4\uACA9\uD558\uC2DC\uB2E4!
      \uC54C\uC558\uC5B4\uC694. \uC9C4\uC9C0 \uBAA8\uB4DC\uB85C \uB531 10\uAC1C\uB9CC
      \uC5F0\uC18D\uC73C\uB85C \uB123\uC744\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Moodmaker_202
    ko: "\uC6C3\uC74C\uAE30\uB97C \uBE7C\uB77C. \uADF8\uB798\uC57C \uC9C4\uC815\uD55C
      \uC288\uD130\uAC00 \uB41C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Moodmaker_2
    ko: "\uD2B9\uC720\uC758 \uD65C\uBC1C\uD568\uC774 \uC5B5\uB20C\uB9AC\uBA70 \uD50C\uB808\uC774\uC758
      \uB9AC\uB4EC\uAC10\uC744 \uC0C1\uC2E4"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Bond_003
    ko: "\uB9D0\uC5C6\uC774 \uC120\uC218\uC758 \uC29B \uB3D9\uC791\uC744 \uB05D\uAE4C\uC9C0
      \uC9C0\uCF1C\uBCF8 \uB4A4, \uB5A8\uC5B4\uC9C4 \uACF5\uC744 \uC9C1\uC811 \uC8FC\uC6CC
      \uC120\uC218\uC5D0\uAC8C \uAC15\uD558\uAC8C \uB358\uC838\uC8FC\uACE0\uB294
      \uADF8\uB300\uB85C \uCCB4\uC721\uAD00 \uBC16\uC73C\uB85C \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uACF5\uC744 \uC8FC\uC6CC\uC8FC\uC2DC\uB2E4\uB2C8...
      \uCE24\uB370\uB808 \uAC19\uC73C\uC154. \uB354 \uC5F4\uC2EC\uD788 \uD574\uC57C\uC9C0!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Kind_3
    ko: "\uAC10\uB3C5\uC758 \uD589\uB3D9\uC744 \uD638\uC758\uB85C \uD574\uC11D\uD558\uC5EC
      \uAE30\uBD84\uC740 \uC88B\uC544\uC84C\uC73C\uB098, \uC29B \uAE30\uC220\uC744
      \uBCF4\uC644\uD560 \uBB3C\uB9AC\uC801 \uC870\uC5B8\uC774 \uC5C6\uC5B4 \uC131\uACF5\uB960\uC740
      \uC81C\uC790\uB9AC"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uB358\uC838\uC900 \uACF5\uC758 \uBB34\uAC8C\uAC00
      \uBB34\uAC81\uB124\uC694. \uB05D\uAE4C\uC9C0 \uB0A8\uC73C\uB77C\uB294 \uC9C0\uC2DC\uB85C
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Loyal_3
    ko: "\uC2EC\uB9AC\uC801\uC73C\uB85C \uC704\uCD95\uB418\uC5C8\uC2B5\uB2C8\uB2E4.
      \uBC18\uBCF5\uB418\uB294 \uC2E4\uCC45\uC5D0 \uC2A4\uC2A4\uB85C\uB97C \uC790\uCC45\uD558\uBA70
      \uD3FC\uC774 \uBB34\uB108\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Sincere_301
    ko: "\uB9D0\uC5C6\uC774 \uACF5\uC744 \uC8FC\uC6CC\uC8FC\uC2DC\uB294 \uAC10\uB3C5\uB2D8...
      \uC800\uB3C4 \uBB35\uBB35\uD788 \uC81C \uD560 \uC77C\uC744 \uACC4\uC18D\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Sincere_3
    ko: "\uC798\uBABB\uB41C \uD0C0\uC810\uC744 \uACE0\uC9D1\uC2A4\uB7FD\uAC8C \uBC18\uBCF5\uD558\uBA70
      \uADFC\uC721 \uAE30\uC5B5\uC774 \uC5C9\uB6B1\uD55C \uBC29\uD5A5\uC73C\uB85C
      \uC124\uC815"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Moodmaker_301
    ko: "\uC640, \uAC10\uB3C5\uB2D8 \uD328\uC2A4 \uC9C4\uC9DC \uC138\uB124\uC694!
      \uC800\uB791 \uB0B4\uAE30 \uD55C \uD310 \uD558\uACE0 \uAC00\uC2DC\uC9C0~ \uC544\uC27D\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Moodmaker_3
    ko: "\uAC10\uB3C5\uC758 \uD589\uB3D9\uC5D0 \uD070 \uC758\uBBF8\uB97C \uB450\uC9C0
      \uC54A\uACE0 \uC790\uAE30 \uD398\uC774\uC2A4\uB300\uB85C \uC5F0\uC2B5\uD568"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cold_001
    ko: "\uC815\uADDC \uD6C8\uB828\uC774 \uB05D\uB09C \uB4A4, \uB0A1\uC740 \uACE8\uB300
      \uBC11\uC5D0\uC11C \uD55C \uC120\uC218\uAC00 \uD640\uB85C 2\uC810 \uC29B \uC5F0\uC2B5\uC744
      \uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cold_002
    ko: "\uD558\uC9C0\uB9CC \uB9BC\uC774 \uD718\uC5B4\uC838 \uC788\uB294\uC9C0, \uB358\uC9C0\uB294
      \uACF5\uB9C8\uB2E4 \uC790\uAFB8\uB9CC \uB9BC\uC744 \uB9DE\uACE0 \uD295\uACA8
      \uB098\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cold_003
    ko: "\uC120\uC218\uB294 \uD55C\uC228\uC744 \uC26C\uBA70 \uB540\uC5D0 \uC816\uC740
      \uC720\uB2C8\uD3FC \uC18C\uB9E4\uB85C \uC774\uB9C8\uB97C \uB2E6\uC2B5\uB2C8\uB2E4.
      \uC774\uB54C \uADFC\uCC98\uB97C \uC9C0\uB098\uAC00\uB358 \uB2F9\uC2E0(\uAC10\uB3C5)\uACFC
      \uB208\uC774 \uB9C8\uC8FC\uCE69\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cold_004
    ko: "\uC120\uC218\uB294 \uBA38\uC4F1\uD55C \uB4EF \uACF5\uC744 \uC7A1\uC73C\uBA70
      \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cold_005
    ko: "\uAC10\uB3C5\uB2D8, \uC544\uC9C1 \uC548 \uAC00\uC168\uC5B4\uC694? \uC694\uC998
      \uC911\uAC70\uB9AC \uC29B \uAC10\uAC01\uC774 \uB3C4\uBB34\uC9C0 \uC548 \uC7A1\uD600\uC11C\uC694...
      \uC6B0\uB9AC \uD559\uAD50 \uACE8\uB300\uAC00 \uC880 \uC774\uC0C1\uD55C \uAC74\uC9C0,
      \uC81C \uC190\uC774 \uBB38\uC81C\uC778 \uAC74\uC9C0 \uBAA8\uB974\uACA0\uB124\uC694.
      \uD558\uD558."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cold_006
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Cold_001
    ko: "\uD658\uACBD \uD0D3\uD558\uC9C0 \uB9C8\uB77C. \uB9BC\uC774 \uD718\uC5B4
      \uC788\uB2E4\uBA74 \uADF8 \uAD74\uC808\uAE4C\uC9C0 \uACC4\uC0B0\uD574\uC11C
      \uB123\uB294 \uAC8C \uC2E4\uB825\uC774\uB2E4. \uC9C0\uAE08 \uB124 \uB178\uB825\uC740
      \uD5DB\uB418\uC9C0 \uC54A\uC544. \uC870\uAE08\uB9CC \uB354 \uC190\uB05D\uC758
      \uAC10\uAC01\uC744 \uBBFF\uC5B4\uBD10."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Planner_101
    ko: "\uAD74\uC808\uC744 \uACC4\uC0B0\uD558\uB77C... \uD655\uC2E4\uD788 \uD658\uACBD
      \uBCC0\uC218\uB97C \uC0C1\uC218\uB85C \uB450\uB294 \uD3B8\uC774 \uC804\uB7B5\uC801\uC73C\uB85C
      \uC720\uB9AC\uD558\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Planner_102
    ko: "\uBCC0\uC218\uB97C \uC9C0\uBC30\uD558\uB294 \uC790\uAC00 \uCF54\uD2B8\uB97C
      \uC9C0\uBC30\uD558\uB294 \uBC95\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Planner_1
    ko: "\uB17C\uB9AC\uC801 \uC218\uAE0D\uC740 \uD588\uC73C\uB098 \uBA38\uB9BF\uC18D\uC73C\uB85C
      \uACF5\uC2DD\uC744 \uC218\uC815\uD558\uB290\uB77C \uC2E4\uC81C \uD22C\uAD6C
      \uB9AC\uB4EC\uC774 \uB04A\uAE40"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Opportunist_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uBCF4\uC2DC\uB294 \uC55E\uC5D0\uC11C \uC131\uACF5\uC2DC\uCF1C\uC57C
      \uC8FC\uC804 \uC790\uB9AC \uAD73\uD788\uAE30\uC5D0 \uC720\uB9AC\uD558\uACA0\uC8E0.
      \uAC11\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Opportunist_1
    ko: "\uB3C5\uC5D0\uAC8C \uC810\uC218\uB97C \uB530\uC57C \uD55C\uB2E4\uB294 \uC2E4\uB9AC\uC801
      \uBAA9\uC801\uC774 \uCD08\uC9D1\uC911\uB825\uC744 \uC720\uBC1C"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cunning_101
    ko: "\uD6C4\uD6C4, \uB9BC\uC774 \uD718\uC5C8\uB2E4\uB294 \uAC78 \uC0C1\uB300\uAC00
      \uBAA8\uB97C \uB54C \uC81C\uAC00 \uBA3C\uC800 \uC801\uC751\uD558\uBA74, \uC774\uAC74
      \uC800\uB9CC\uC758 \uBE44\uBC00 \uBCD1\uAE30\uAC00 \uB418\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Cunning_1
    ko: "\uBD88\uB9AC\uD55C \uC870\uAC74\uC744 \uBCF8\uC778\uB9CC\uC758 \uC774\uB4DD\uC73C\uB85C
      \uBC14\uAFC0 \uC2EC\uB9AC\uC801 \uC6B0\uC704\uB97C \uC810\uD568"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Believer_101
    ko: "\uC81C \uC29B \uD3FC\uC740 \uC644\uBCBD\uD569\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8
      \uB9D0\uC500\uB300\uB85C \uB9BC\uC758 \uC624\uCC28 \uB530\uC704 \uC81C \uC2E4\uB825\uC73C\uB85C
      \uB36E\uC5B4\uBC84\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Believer_1
    ko: "\uBCF8\uC778\uC758 \uBC29\uC2DD\uC5D0 \uB300\uD55C \uD655\uC2E0\uC740 \uAC15\uD574\uC84C\uC73C\uB098,
      \uB9BC\uC774 \uD718\uC5C8\uB2E4\uB294 \uBB3C\uB9AC\uC801 \uC0AC\uC2E4\uC744
      \uC778\uC815\uD558\uC9C0 \uC54A\uC544 \uC131\uACF5\uB960 \uBCF4\uC815\uC5D0\uB294
      \uC2E4\uD328"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Cold_002
    ko: "\uACE8\uB300\uAC00 \uBB38\uC81C\uB77C\uBA74 \uB2E4\uB978 \uACE8\uB300\uC5D0\uC11C
      \uC3D8\uBA74 \uB420 \uC77C\uC774\uB2E4. \uC548 \uB4E4\uC5B4\uAC00\uB294 \uC774\uC720\uB97C
      \uC678\uBD80\uC5D0\uC11C \uCC3E\uC73C\uB824\uB294 \uD0DC\uB3C4 \uC790\uCCB4\uAC00
      \uBB38\uC81C\uC57C. \uC9D1\uC911\uB825\uC774 \uD750\uD2B8\uB7EC\uC9C4 \uAC70
      \uC544\uB2CC\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Planner_201
    ko: "\uB9DE\uB294 \uB9D0\uC500\uC785\uB2C8\uB2E4. \uACE8\uB300 \uD0D3\uC744 \uD558\uB294
      \uAC74 \uD558\uC218\uB098 \uD558\uB294 \uC9D3\uC774\uC8E0. \uBC14\uB85C \uBCF4\uC815
      \uC791\uC5C5 \uB4E4\uC5B4\uAC11\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Planner_2
    ko: "\uC678\uBD80 \uD551\uACC4\uB97C \uC989\uAC01 \uCC28\uB2E8\uD558\uACE0 \uB0B4\uBA74\uC758
      \uC2DC\uC2A4\uD15C\uC744 \uAD50\uC815"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Opportunist_201
    ko: "\uD6C4\uBCF4\uB85C \uBC00\uB824\uB098\uAE34 \uC2EB\uC73C\uB2C8\uAE4C\uC694.
      \uB2F9\uC7A5 \uACE8\uB300\uC5D0 \uACF5\uC744 \uC464\uC154 \uBC15\uC544\uB123\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Opportunist_2
    ko: "\uC704\uAE30\uAC10 \uB54C\uBB38\uC5D0 \uC29B\uC744 \uB358\uC9C0\uB294 \uD589\uC704
      \uC790\uCCB4\uC5D0 \uAE09\uAE09\uD574\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cunning_201
    ko: "\uC815\uC2E0\uB825 \uC6B4\uC6B4\uD558\uC2DC\uB294 \uAC78 \uBCF4\uB2C8 \uC800\uB97C
      \uC2DC\uD5D8\uD558\uC2DC\uB294 \uAC70\uAD70\uC694. \uADF8 \uC2DC\uD5D8, \uAC00\uBCCD\uAC8C
      \uD1B5\uACFC\uD574\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Cunning_2
    ko: "\uAC10\uB3C5\uACFC\uC758 \uC2EC\uB9AC\uC804\uC5D0\uC11C \uC9C0\uC9C0 \uC54A\uC73C\uB824\uB2E4
      \uBCF8\uC778\uC758 \uD398\uC774\uC2A4\uB97C \uC783\uC74C"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Believer_201
    ko: "\uC81C \uC9D1\uC911\uB825\uC774 \uBB38\uC81C\uB77C\uACE0\uC694? \uC778\uC815\uD560
      \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uC81C \uBC29\uC2DD\uC774 \uB9DE\uB2E4\uB294
      \uAC78 \uACB0\uACFC\uB85C \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Believer_2
    ko: "\uAC10\uB3C5\uC758 \uBD80\uC815\uC5D0 \uB300\uD55C \uBC18\uBC1C\uC2EC\uC774
      \uB3C5\uAE30\uAC00 \uB428"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Cold_003
    ko: "\uB9D0\uC5C6\uC774 \uC120\uC218\uC758 \uC29B \uB3D9\uC791\uC744 \uB05D\uAE4C\uC9C0
      \uC9C0\uCF1C\uBCF8 \uB4A4, \uB5A8\uC5B4\uC9C4 \uACF5\uC744 \uC9C1\uC811 \uC8FC\uC6CC
      \uC120\uC218\uC5D0\uAC8C \uAC15\uD558\uAC8C \uB358\uC838\uC8FC\uACE0\uB294
      \uADF8\uB300\uB85C \uCCB4\uC721\uAD00 \uBC16\uC73C\uB85C \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Planner_301
    ko: "\uAC10\uB3C5\uB2D8\uC740 \uC81C\uAC00 \uC2A4\uC2A4\uB85C \uD658\uACBD\uC5D0
      \uC801\uC751\uD558\uB294 \uB2A5\uB825\uC744 \uD0A4\uC6B0\uAE38 \uC6D0\uD558\uC2DC\uB294\uAD70\uC694.
      \uC758\uB3C4 \uD30C\uC545\uD588\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Planner_3
    ko: "\uAC10\uB3C5\uC758 \uC758\uB3C4\uB97C \uC124\uACC4\uD558\uB294 \uB370 \uACFC\uBAB0\uC785\uD558\uC5EC
      \uC815\uC791 \uBCF8\uC778\uC758 \uC29B \uD0C0\uC774\uBC0D\uC744 \uB193\uCE68"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Opportunist_301
    ko: "\uACF5 \uC8FC\uC6CC\uC8FC\uC2DC\uB294 \uAC70 \uBCF4\uB2C8 \uC800\uD55C\uD14C
      \uAE30\uB300\uAC00 \uD06C\uC2E0\uAC00 \uBCF4\uB124\uC694? \uC810\uC218 \uC880
      \uB530\uB46C\uC57C\uACA0\uB124."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Opportunist_3
    ko: "\uAC10\uB3C5\uC758 \uD589\uB3D9\uC744 \uACFC\uC789 \uD574\uC11D\uD558\uC5EC
      \uC6B0\uCB50\uD574\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Cunning_301
    ko: "\uAC15\uD55C \uD328\uC2A4\uB85C \uC81C \uBC18\uC751\uC744 \uC0B4\uD53C\uC2E0
      \uAC74\uAC00\uC694? \uAC10\uB3C5\uB2D8\uB3C4 \uCC38 \uC18D\uC744 \uC54C \uC218
      \uC5C6\uB294 \uBD84\uC774\uB77C\uB2C8\uAE4C\uC694."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Cunning_3
    ko: "\uAC10\uC815\uC801\uC73C\uB85C \uD754\uB4E4\uB9AC\uC9C0\uB294 \uC54A\uC73C\uB098
      \uAE30\uC220\uC801\uC778 \uC5F0\uC2B5 \uD6A8\uC728\uC740 \uD3C9\uC774\uD568"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Believer_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uAC00\uC154\uB3C4 \uC804 \uC81C \uC2E0\uB150\uC744
      \uAD7D\uD788\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4. \uC81C \uAC10\uAC01\uC774 \uB9DE\uC744
      \uB54C\uAE4C\uC9C0 \uC548 \uBA48\uCDA5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Believer_3
    ko: "\uBD80\uC758 \uC870\uC5B8\uC744 \uC644\uC804\uD788 \uCC28\uB2E8\uD558\uACE0
      \uC790\uC2E0\uB9CC\uC758 \uC138\uACC4\uC5D0 \uAC07\uD798"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Instinct_001
    ko: "\uC815\uADDC \uD6C8\uB828\uC774 \uB05D\uB09C \uB4A4, \uB0A1\uC740 \uACE8\uB300
      \uBC11\uC5D0\uC11C \uD55C \uC120\uC218\uAC00 \uD640\uB85C 2\uC810 \uC29B \uC5F0\uC2B5\uC744
      \uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Instinct_002
    ko: "\uD558\uC9C0\uB9CC \uB9BC\uC774 \uD718\uC5B4\uC838 \uC788\uB294\uC9C0, \uB358\uC9C0\uB294
      \uACF5\uB9C8\uB2E4 \uC790\uAFB8\uB9CC \uB9BC\uC744 \uB9DE\uACE0 \uD295\uACA8
      \uB098\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Instinct_003
    ko: "\uC120\uC218\uB294 \uD55C\uC228\uC744 \uC26C\uBA70 \uB540\uC5D0 \uC816\uC740
      \uC720\uB2C8\uD3FC \uC18C\uB9E4\uB85C \uC774\uB9C8\uB97C \uB2E6\uC2B5\uB2C8\uB2E4.
      \uC774\uB54C \uADFC\uCC98\uB97C \uC9C0\uB098\uAC00\uB358 \uB2F9\uC2E0(\uAC10\uB3C5)\uACFC
      \uB208\uC774 \uB9C8\uC8FC\uCE69\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Instinct_004
    ko: "\uC120\uC218\uB294 \uBA38\uC4F1\uD55C \uB4EF \uACF5\uC744 \uC7A1\uC73C\uBA70
      \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC635\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Instinct_005
    ko: "\uAC10\uB3C5\uB2D8, \uC544\uC9C1 \uC548 \uAC00\uC168\uC5B4\uC694? \uC694\uC998
      \uC911\uAC70\uB9AC \uC29B \uAC10\uAC01\uC774 \uB3C4\uBB34\uC9C0 \uC548 \uC7A1\uD600\uC11C\uC694...
      \uC6B0\uB9AC \uD559\uAD50 \uACE8\uB300\uAC00 \uC880 \uC774\uC0C1\uD55C \uAC74\uC9C0,
      \uC81C \uC190\uC774 \uBB38\uC81C\uC778 \uAC74\uC9C0 \uBAA8\uB974\uACA0\uB124\uC694.
      \uD558\uD558."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Instinct_006
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Instinct_001
    ko: "\uD658\uACBD \uD0D3\uD558\uC9C0 \uB9C8\uB77C. \uB9BC\uC774 \uD718\uC5B4
      \uC788\uB2E4\uBA74 \uADF8 \uAD74\uC808\uAE4C\uC9C0 \uACC4\uC0B0\uD574\uC11C
      \uB123\uB294 \uAC8C \uC2E4\uB825\uC774\uB2E4. \uC9C0\uAE08 \uB124 \uB178\uB825\uC740
      \uD5DB\uB418\uC9C0 \uC54A\uC544. \uC870\uAE08\uB9CC \uB354 \uC190\uB05D\uC758
      \uAC10\uAC01\uC744 \uBBFF\uC5B4\uBD10."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bluffer_101
    ko: "\uD558! \uB9BC\uC774 \uD718\uC5C8\uB4E0 \uBD80\uC11C\uC84C\uB4E0 \uC81C
      \uC190\uC744 \uB5A0\uB09C \uACF5\uC740 \uBB34\uC870\uAC74 \uB4E4\uC5B4\uAC11\uB2C8\uB2E4.
      \uC9C0\uCF1C\uBCF4\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Bluffer_1
    ko: "\uADFC\uAC70 \uC5C6\uB294 \uC790\uC2E0\uAC10\uC73C\uB85C \uAE30\uBD84\uC740
      \uCD5C\uACE0\uC870\uC774\uB098, \uC2E4\uC9C8\uC801\uC778 \uC29B \uC131\uACF5\uB960\uC740
      \uD3C9\uC18C\uC640 \uB2E4\uB97C \uBC14 \uC5C6\uC2B4"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Wild_101
    ko: "\uB9BC\uC758 \uAC01\uB3C4 \uB530\uC704 \uB290\uAEF4\uC9D1\uB2C8\uB2E4. \uC81C
      \uBAB8\uC774 \uC54C\uC544\uC11C \uBC18\uC751\uD558\uACE0 \uC788\uC5B4\uC694.
      \uAC11\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Wild_102
    ko: "\uBCF8\uB2A5\uC744 \uBBFF\uC5B4\uB77C. \uBA38\uB9AC\uB85C \uC0DD\uAC01\uD558\uAE30
      \uC804\uC5D0 \uBAB8\uC774 \uBA3C\uC800 \uB098\uAC00\uAC8C."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Wild_1
    ko: "\uB3C5\uC774 \uC57C\uC131\uC801\uC778 \uAC10\uAC01\uC744 \uC9C0\uC9C0\uD574\uC8FC\uC790
      \uC9C1\uAD00\uC774 \uC0B4\uC544\uB0A8"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Egoist_101
    ko: "\uB9BC\uC774 \uC81C \uC29B\uC744 \uAC70\uBD80\uD558\uB294 \uAC8C \uAE30\uBD84
      \uB098\uC058\uB124\uC694. \uC81C\uAC00 \uC5B5\uC9C0\uB85C\uB77C\uB3C4 \uAD74\uBCF5\uC2DC\uD0A4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Egoist_1
    ko: "\uC790\uAE30\uC911\uC2EC\uC801\uC778 \uBAB0\uC785\uAC10\uC774 \uCD5C\uACE0\uC870\uC5D0
      \uB2EC\uD568"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Fighter_101
    ko: "\uB9BC\uC774 \uC808 \uACE8\uD0D5 \uBA39\uC774\uB824 \uB4DC\uB294\uAD70\uC694.
      \uBC15\uC0B4\uC744 \uB0B4\uC11C\uB77C\uB3C4 \uC81C \uC790\uB9AC\uC5D0 \uAF42\uC544
      \uB123\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Fighter_1
    ko: "\uC758\uC695\uC774 \uB108\uBB34 \uC55E\uC11C \uC29B \uC2A4\uD53C\uB4DC\uAC00
      \uC9C0\uB098\uCE58\uAC8C \uBE68\uB77C\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Instinct_002
    ko: "\uACE8\uB300\uAC00 \uBB38\uC81C\uB77C\uBA74 \uB2E4\uB978 \uACE8\uB300\uC5D0\uC11C
      \uC3D8\uBA74 \uB420 \uC77C\uC774\uB2E4. \uC548 \uB4E4\uC5B4\uAC00\uB294 \uC774\uC720\uB97C
      \uC678\uBD80\uC5D0\uC11C \uCC3E\uC73C\uB824\uB294 \uD0DC\uB3C4 \uC790\uCCB4\uAC00
      \uBB38\uC81C\uC57C. \uC9D1\uC911\uB825\uC774 \uD750\uD2B8\uB7EC\uC9C4 \uAC70
      \uC544\uB2CC\uAC00?"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bluffer_201
    ko: "\uBB50\uB77C\uACE0\uC694? \uC81C\uAC00 \uC9D1\uC911\uC744 \uC548 \uD55C\uB2E4\uACE0\uC694?
      \uC9C0\uAE08 \uB2F9\uC7A5 \uB208 \uAC10\uACE0\uB3C4 \uB123\uC5B4\uC904 \uD14C\uB2C8\uAE4C
      \uB611\uB611\uD788 \uBCF4\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Bluffer_2
    ko: "\uC790\uC874\uC2EC\uC744 \uAC74 \uB3C4\uBC1C\uC5D0 \uBCF8\uB2A5\uC774 \uAE68\uC5B4\uB0A8"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Wild_201
    ko: "\uC794\uC18C\uB9AC\uB294 \uD544\uC694 \uC5C6\uC2B5\uB2C8\uB2E4! \uADF8\uB0E5
      \uB9BC\uC744 \uCC22\uC5B4\uBC84\uB9AC\uBA74 \uADF8\uB9CC\uC778 \uAC70\uC796\uC544\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Wild_2
    ko: "\uC774\uC131\uC801\uC778 \uC9C8\uCC45\uC5D0 \uD765\uBD84\uB3C4\uAC00 \uC9C0\uB098\uCE58\uAC8C
      \uB192\uC544\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Egoist_201
    ko: "\uB0A8 \uD0D3\uC774 \uC544\uB2C8\uB77C \uC81C \uC218\uC900\uC5D0 \uC548
      \uB9DE\uB294 \uACE8\uB300\uC778 \uAC8C \uD329\uD2B8\uC8E0. \uD558\uC9C0\uB9CC...
      \uC81C\uAC00 \uB123\uC73C\uB77C\uBA74 \uB123\uB294 \uAC81\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Egoist_2
    ko: "\uACE8\uB300\uC640 \uAE30 \uC2F8\uC6C0\uC744 \uD558\uB290\uB77C \uCCB4\uB825\uC744
      \uB0AD\uBE44 \uC911"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Fighter_201
    ko: "\uC9D1\uC911\uB825\uC774 \uBD80\uC871\uD558\uB2E4\uB294 \uB9D0, \uCDE8\uC18C\uD558\uAC8C
      \uD574\uB4DC\uB9AC\uC8E0. \uB2F9\uC7A5 \uC2B9\uBD80\uC785\uB2C8\uAE4C? 100\uAC1C
      \uB123\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Fighter_2
    ko: "\uC9C8\uCC45\uC774 \uC644\uBCBD\uD55C \uC2B9\uBD80\uC695\uC758 \uB3C4\uD654\uC120\uC774
      \uB428"
    en: 
    ja: 
  - stringKey: Event_00002_Ch_Instinct_003
    ko: "\uB9D0\uC5C6\uC774 \uC120\uC218\uC758 \uC29B \uB3D9\uC791\uC744 \uB05D\uAE4C\uC9C0
      \uC9C0\uCF1C\uBCF8 \uB4A4, \uB5A8\uC5B4\uC9C4 \uACF5\uC744 \uC9C1\uC811 \uC8FC\uC6CC
      \uC120\uC218\uC5D0\uAC8C \uAC15\uD558\uAC8C \uB358\uC838\uC8FC\uACE0\uB294
      \uADF8\uB300\uB85C \uCCB4\uC721\uAD00 \uBC16\uC73C\uB85C \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Bluffer_301
    ko: "\uBC29\uAE08 \uADF8 \uD328\uC2A4 \uBCF4\uC168\uC8E0? \uAC10\uB3C5\uB2D8\uB3C4
      \uC81C \uD3ED\uBC1C\uC801\uC778 \uC7A0\uC7AC\uB825\uC744 \uAC10\uB2F9 \uBABB
      \uD574\uC11C \uB3C4\uB9DD\uAC00\uC2DC\uB294 \uAC70\uB77C\uACE0\uC694!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Bluffer_3
    ko: "\uCC29\uAC01\uC5D0 \uBE60\uC838 \uC5F0\uC2B5\uBCF4\uB2E4\uB294 \uBA4B\uC9C4
      \uD3EC\uC988\uC640 \uC138\uB9AC\uBA38\uB2C8\uC5D0 \uCE58\uC911"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Wild_301
    ko: "\uD06C\uC73C... \uC774 \uC815\uB9C9 \uC18D\uC5D0\uC11C \uB9BC\uAE4C\uC9C0
      \uC774\uC5B4\uC9C0\uB294 \uAE38\uC774 \uBCF4\uC774\uB124\uC694. \uAC10\uB3C5\uB2D8\uC758
      \uD328\uC2A4, \uB728\uAC81\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Wild_3
    ko: "\uAC10\uB3C5\uC758 \uAC15\uD55C \uD328\uC2A4\uC5D0\uC11C \uC5D0\uB108\uC9C0\uB97C
      \uC5BB\uC5C8\uC9C0\uB9CC \uC815\uAD50\uD568\uC774 \uBD80\uC871\uD574 \uC131\uACF5\uB960\uC740
      \uB4E4\uC465\uB0A0\uC465\uD568"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Egoist_301
    ko: "\uAC10\uD788 \uC800\uB97C \uB450\uACE0 \uADF8\uB0E5 \uAC00\uC2DC\uB2E4\uB2C8...
      \uC81C\uAC00 \uC5BC\uB9C8\uB098 \uB300\uB2E8\uD55C\uC9C0 \uB098\uC911\uC5D0
      \uD6C4\uD68C\uD558\uAC8C \uD574\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Egoist_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uAD00\uC2EC\uC5D0 \uBD84\uB178\uB97C \uB290\uB08D\uB2C8\uB2E4.
      \uAC10\uC815\uC801\uC778 \uB3D9\uC694\uB85C \uC778\uD574 \uD3C9\uC18C \uC720\uC9C0\uD558\uB358
      \uBCF8\uC778\uB9CC\uC758 \uC29B \uB9AC\uB4EC\uC774 \uBB34\uB108\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00002_Desc_Fighter_301
    ko: "\uC808 \uBC84\uB9AC\uACE0 \uAC00\uC2DC\uB294 \uAC74\uAC00\uC694? \uB3C4\uB9DD\uCE58\uC2DC\uB294
      \uAC70\uBA74 \uB530\uB77C\uAC00\uC11C \uC81C \uC2E4\uB825\uC744 \uC5B5\uC9C0\uB85C
      \uBCF4\uC5EC\uB4DC\uB9B4 \uAC81\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00002_Rs_Fighter_3
    ko: "\uAC10\uB3C5\uACFC\uC758 \uBCF4\uC774\uC9C0 \uC54A\uB294 \uC2F8\uC6C0\uC5D0
      \uC9D1\uCC29\uD558\uAE30 \uC2DC\uC791\uD568"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Discipline_001
    ko: "\uD300\uC6D0\uB4E4\uC774 \uBAA8\uB450 \uB3CC\uC544\uAC04 \uC2DC\uAC01, \uB9BC\uC744
      \uAC00\uB974\uB294 \uB9C8\uCC30\uC74C \uB300\uC2E0 \uD305\uACA8 \uB098\uC624\uB294
      \uB454\uD0C1\uD55C \uC18C\uB9AC\uB9CC\uC774 \uCCB4\uC721\uAD00\uC744 \uCC44\uC6C1\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Discipline_002
    ko: "\uCD5C\uADFC \uC288\uD305 \uC131\uACF5\uB960\uC774 \uBBF8\uC138\uD558\uAC8C
      \uB5A8\uC5B4\uC9C4 \uD55C \uC120\uC218\uAC00 \uB540\uC5D0 \uC816\uC740 \uCC44
      \uBC18\uBCF5\uD574\uC11C \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Discipline_003
    ko: "\uB370\uC774\uD130\uC640 \uAC01\uB3C4\uC5D0 \uC9D1\uCC29\uD558\uB294 \uC774
      \uC120\uC218\uB294 \uC790\uC2E0\uC758 \uC190\uB05D \uAC10\uAC01\uC774 \uD3C9\uC18C\uC640
      0.1cm \uB2E4\uB974\uB2E4\uB294 \uC0AC\uC2E4\uC5D0 \uADF9\uC2EC\uD55C \uC2A4\uD2B8\uB808\uC2A4\uB97C
      \uB290\uB07C\uBA70 \uC2A4\uC2A4\uB85C\uB97C \uBAB0\uC544\uC138\uC6B0\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Discipline_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Discipline_001
    ko: "\uB124\uAC00 \uC138\uC6B4 \uC5C4\uACA9\uD55C \uAE30\uC900\uC774 \uC9C0\uAE08\uC758
      \uB108\uB97C \uB9CC\uB4E0 \uAC74 \uB9DE\uB2E4. \uD558\uC9C0\uB9CC \uAC00\uB054\uC740
      \uADF8 \uAE30\uC900\uC744 \uC870\uAE08 \uB113\uD600\uB3C4 \uAD1C\uCC2E\uC544.
      \uB108\uB294 \uCDA9\uBD84\uD788 \uC798\uD574\uC654\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Principled_101
    ko: "\uAE30\uC900\uC744 \uB113\uD788\uB294 \uAC74 \uC81C \uC2E0\uB150\uC5D0 \uB300\uD55C
      \uD0C0\uD611\uC785\uB2C8\uB2E4. \uD0C0\uD611\uD558\uB294 \uC21C\uAC04 \uC81C
      \uC288\uD305\uC740 \uBB34\uB108\uC9C8 \uAC81\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Principled_1
    ko: "\uC790\uC2E0\uC758 \uAC00\uC774\uB4DC\uB77C\uC778\uC774 \uD754\uB4E4\uB9AC\uB294
      \uAC83\uC744 \uACBD\uACC4\uD558\uC5EC \uACA9\uB824\uB97C \uAC70\uBD80\uD568"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Guardian_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uADF8\uB807\uAC8C \uB9D0\uC500\uD574 \uC8FC\uC2DC\uB2C8
      \uB2E4\uD589\uC785\uB2C8\uB2E4. \uD300\uC744 \uC704\uD574 \uC81C \uAC10\uAC01\uC744
      \uBE68\uB9AC \uB418\uCC3E\uACE0 \uC2F6\uC5C8\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Guardian_1
    ko: "\uAC10\uB3C5\uC758 \uC9C0\uC9C0\uB97C \uD300\uC744 \uC704\uD55C \uD5CC\uC2E0\uC73C\uB85C
      \uCE58\uD658\uD558\uC5EC \uC2EC\uB9AC\uC801 \uC548\uC815\uACFC \uD65C\uB825
      \uC0C1\uC2B9."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Tactician_101
    ko: "\uAC10\uC0AC\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC774 \uC624\uCC28 \uBC94\uC704\uB97C
      \uC218\uC815\uD558\uC9C0 \uC54A\uC73C\uBA74 \uB2E4\uC74C \uACBD\uAE30 \uC804\uC220\uC5D0
      \uCC28\uC9C8\uC774 \uC0DD\uAE41\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Tactician_1
    ko: "\uACA9\uB824\uB97C \uB4E3\uACE0\uB3C4 \uAC15\uBC15\uC744 \uBC84\uB9AC\uC9C0
      \uBABB\uD574 \uADFC\uC721\uC774 \uACFC\uBD80\uD558 \uC0C1\uD0DC\uB85C \uB0A8\uC74C."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Exemplary_101
    ko: "\uC81C\uAC00 \uD754\uB4E4\uB9AC\uB294 \uBAA8\uC2B5\uC744 \uBCF4\uC5EC \uC8C4\uC1A1\uD569\uB2C8\uB2E4.
      \uB2E4\uC2DC \uD3C9\uC815\uC2EC\uC744 \uCC3E\uACE0 \uB8E8\uD2F4\uB300\uB85C
      \uB9C8\uBB34\uB9AC\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Exemplary_102
    ko: "\uC0AC\uACFC\uD560 \uAC83 \uC5C6\uB2E4. \uB108\uB294 \uC774\uBBF8 \uC6B0\uB9AC
      \uD300\uC758 \uD6CC\uB96D\uD55C \uBCF8\uBCF4\uAE30\uB2E4. \uC774\uC81C \uADF8\uB9CC
      \uC26C\uC5B4\uB77C."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Exemplary_1
    ko: "\uB3C4\uB355\uC801 \uC548\uB3C4\uAC10\uC740 \uC5BB\uC5C8\uC73C\uB098 \uC288\uD305\uC5D0
      \uB300\uD55C \uAE30\uC220\uC801 \uD574\uACB0\uCC45\uC740 \uCC3E\uC9C0 \uBABB\uD568."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Discipline_002
    ko: "\uC9C0\uAE08 \uB124 \uAF34\uC744 \uBD10\uB77C! \uADF8\uAC8C \uD6C8\uB828\uC778\uAC00,
      \uACE0\uC9D1\uC778\uAC00? \uC815\uD574\uC9C4 \uD734\uC2DD \uC2DC\uAC04\uC744
      \uC5B4\uAE30\uACE0 \uBAB8\uC744 \uD639\uC0AC\uD558\uB294 \uAC74 \uD300\uC758
      \uADDC\uC728\uC744 \uC5B4\uAE30\uB294 \uD589\uC704\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Principled_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uD6C8\uB828 \uC885\uB8CC \uC2DC\uAC04\uC744
      \uC9C0\uD0A4\uB294 \uAC83\uB3C4 \uC120\uC218\uC758 \uC6D0\uCE59\uC778\uB370...
      \uC81C\uAC00 \uC120\uC744 \uB118\uC5C8\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Principled_2
    ko: "\uC0C1\uC704 \uC6D0\uCE59(\uC2DC\uAC04 \uC5C4\uC218)\uC744 \uC77C\uAE68\uC6CC\uC8FC\uC790
      \uBBF8\uC2DC\uC801\uC778 \uAC15\uBC15\uC5D0\uC11C \uBC97\uC5B4\uB098 \uD3FC
      \uD68C\uBCF5."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Guardian_201
    ko: "\uD300\uC5D0 \uD53C\uD574\uB97C \uC8FC\uB824\uB294 \uAC8C \uC544\uB2C8\uC5C8\uC2B5\uB2C8\uB2E4!
      \uB2E8\uC9C0 \uB354 \uC644\uBCBD\uD574\uC838\uC11C \uBAA8\uB450\uB97C \uC9C0\uD0A4\uACE0
      \uC2F6\uC5C8\uC744 \uBFD0\uC785\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Guardian_202
    ko: "\uC644\uBCBD\uD574\uC9C0\uB824\uB2E4 \uBD80\uC0C1\uB2F9\uD558\uBA74 \uADF8\uAC8C
      \uD300\uC744 \uB3D5\uB294 \uAC70\uB0D0? \uB0B4\uC77C \uB2E4\uC2DC \uD574."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Guardian_2
    ko: "\uC9C8\uCC45\uC744 \uBCF8\uC778\uC758 \uD5CC\uC2E0\uC5D0 \uB300\uD55C \uBD80\uC815\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uAE4A\uC740 \uC0C1\uCC98\uB97C \uC785\uACE0 \uC704\uCD95\uB428."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Tactician_201
    ko: "\uD6A8\uC728\uC801\uC774\uC9C0 \uBABB\uD55C \uD589\uB3D9\uC774\uC5C8\uC2B5\uB2C8\uB2E4.
      \uB0C9\uC815\uD558\uAC8C \uD310\uB2E8\uD558\uC9C0 \uBABB\uD55C \uC81C \uC798\uBABB\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Tactician_2
    ko: "\uC790\uC2E0\uC758 \uBE44\uD6A8\uC728\uC131\uC744 \uC778\uC815\uD558\uACE0
      \uC989\uAC01 \uBA48\uCD94\uC9C0\uB9CC \uAE30\uB7C9\uC758 \uC989\uAC01\uC801
      \uBCC0\uD654\uB294 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Exemplary_201
    ko: "\uB2E4\uB978 \uBD80\uC6D0\uB4E4\uC5D0\uAC8C \uC88B\uC9C0 \uBABB\uD55C \uBCF8\uBCF4\uAE30\uAC00
      \uB418\uC5C8\uAD70\uC694. \uBC14\uB85C \uC815\uB9AC\uD558\uACE0 \uB4E4\uC5B4\uAC00\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Exemplary_2
    ko: "\uC790\uC2E0\uC758 \uC704\uCE58\uB97C \uC790\uAC01\uD558\uACE0 \uCC45\uC784\uAC10\uC744
      \uBC1C\uD718\uD558\uC5EC \uD750\uD2B8\uB7EC\uC9C4 \uBC38\uB7F0\uC2A4\uB97C
      \uC989\uC2DC \uBC14\uB85C\uC7A1\uC74C."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Discipline_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uAC00 \uC2A4\uC2A4\uB85C \uB2F5\uC744
      \uCC3E\uC744 \uB54C\uAE4C\uC9C0 \uB05D\uAE4C\uC9C0 \uC9C0\uCF1C\uBCF8 \uB4A4,
      \uB9C8\uC9C0\uB9C9\uC5D0 \uACF5\uB9CC \uCC59\uACA8\uC11C \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Principled_301
    ko: "\uC65C \uC544\uBB34 \uB9D0\uC500\uB3C4 \uC548 \uD558\uC2DC\uC8E0? \uC81C
      \uBC29\uC2DD\uC774 \uAC10\uB3C5\uB2D8 \uAE30\uC900\uC5D0\uB3C4 \uD569\uACA9\uC774\uB77C\uB294
      \uB73B\uC785\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Principled_3
    ko: "\uCE68\uBB35\uC744 \uBD80\uC815\uC801\uC778 \uD3C9\uAC00\uB85C \uC624\uD574\uD558\uACE0
      \uC815\uB2F5\uC744 \uCC3E\uAE30 \uC704\uD574 \uBAB8\uC744 \uB354 \uD639\uC0AC\uD568."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Guardian_301
    ko: "...\uAC10\uB3C5\uB2D8, \uC774\uC81C \uB410\uC2B5\uB2C8\uB2E4. \uC800\uB97C
      \uBBFF\uC5B4\uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Guardian_3
    ko: "\uAC10\uB3C5\uC758 \uC874\uC7AC \uC790\uCCB4\uB85C \uC704\uC548\uC744 \uC5BB\uC9C0\uB9CC
      \uC288\uD305 \uC624\uCC28\uB294 \uC2A4\uC2A4\uB85C \uD574\uACB0\uD558\uC9C0
      \uBABB\uD568."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Tactician_301
    ko: "\uC9C1\uC811 \uACF5\uC744 \uC7A1\uC544\uC8FC\uC2DC\uB294 \uAC83\uB3C4 \uC544\uB2C8\uBA74\uC11C
      \uC9C0\uCF1C\uB9CC \uBCF4\uC2DC\uB2E4\uB2C8... \uD6A8\uC728\uC774 \uB5A8\uC5B4\uC9C0\uB294\uAD70\uC694.
      \uADF8\uB9CC\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Tactician_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uC5B8\uC758 \uC555\uBC15\uC744 \uD1B5\uD574 \uD6C8\uB828
      \uC885\uB8CC\uAC00 \uCD5C\uC120\uC758 \uC804\uC220\uC784\uC744 \uAE68\uB2EB\uACE0
      \uC9D1\uC911\uB825 \uAC15\uD654."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Exemplary_301
    ko: "\uAC10\uB3C5\uB2D8\uAE4C\uC9C0 \uACE0\uC0DD\uC2DC\uD0A4\uB2E4\uB2C8... \uC81C\uAC00
      \uC815\uB9D0 \uD55C\uC2EC\uD558\uAD70\uC694. \uBC14\uB85C \uC815\uB9AC\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Exemplary_3
    ko: "\uC790\uCC45\uAC10\uC774 \uADF9\uC5D0 \uB2EC\uD574 \uC288\uD305\uC5D0 \uB300\uD55C
      \uC790\uC2E0\uAC10\uC744 \uC783\uACE0 \uC2AC\uB7FC\uD504\uAC00 \uAE4A\uC5B4\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bond_001
    ko: "\uD300\uC6D0\uB4E4\uC774 \uBAA8\uB450 \uB3CC\uC544\uAC04 \uC2DC\uAC01, \uB9BC\uC744
      \uAC00\uB974\uB294 \uB9C8\uCC30\uC74C \uB300\uC2E0 \uD305\uACA8 \uB098\uC624\uB294
      \uB454\uD0C1\uD55C \uC18C\uB9AC\uB9CC\uC774 \uCCB4\uC721\uAD00\uC744 \uCC44\uC6C1\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bond_002
    ko: "\uCD5C\uADFC \uC288\uD305 \uC131\uACF5\uB960\uC774 \uBBF8\uC138\uD558\uAC8C
      \uB5A8\uC5B4\uC9C4 \uD55C \uC120\uC218\uAC00 \uB540\uC5D0 \uC816\uC740 \uCC44
      \uBC18\uBCF5\uD574\uC11C \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bond_003
    ko: "\uB370\uC774\uD130\uC640 \uAC01\uB3C4\uC5D0 \uC9D1\uCC29\uD558\uB294 \uC774
      \uC120\uC218\uB294 \uC790\uC2E0\uC758 \uC190\uB05D \uAC10\uAC01\uC774 \uD3C9\uC18C\uC640
      0.1cm \uB2E4\uB974\uB2E4\uB294 \uC0AC\uC2E4\uC5D0 \uADF9\uC2EC\uD55C \uC2A4\uD2B8\uB808\uC2A4\uB97C
      \uB290\uB07C\uBA70 \uC2A4\uC2A4\uB85C\uB97C \uBAB0\uC544\uC138\uC6B0\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bond_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Bond_001
    ko: "\uD63C\uC790\uC11C \uB2E4 \uC9CA\uC5B4\uC9C0\uB824\uACE0 \uD558\uC9C0 \uB9C8\uB77C.
      0.1cm\uC758 \uC624\uCC28\uBCF4\uB2E4 \uC911\uC694\uD55C \uAC74 \uB124 \uACC1\uC5D0
      \uC6B0\uB9AC\uAC00 \uC788\uB2E4\uB294 \uC0AC\uC2E4\uC774\uC57C. \uB10C \uCDA9\uBD84\uD788
      \uC798\uD558\uACE0 \uC788\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uC800 \uB54C\uBB38\uC5D0 \uD300\uC6D0\uB4E4\uC774
      \uACE0\uC0DD\uD558\uB294 \uAC83 \uAC19\uC544 \uB9C8\uC74C\uC774 \uD3B8\uCE58
      \uC54A\uC558\uC5B4\uC694. \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Kind_102
    ko: "\uADF8 \uB530\uB73B\uD55C \uB9C8\uC74C\uC774 \uB124 \uC29B\uC5D0 \uB179\uC544\uB4E4
      \uAC70\uB2E4. \uC624\uB298\uC740 \uADF8\uB9CC \uC26C\uB834."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Kind_1
    ko: "\uC815\uC11C\uC801 \uC9C0\uC9C0\uB97C \uD1B5\uD574 \uC2EC\uB9AC\uC801 \uC555\uBC15\uAC10\uC774
      \uD574\uC18C\uB418\uBA70 \uBD80\uB4DC\uB7EC\uC6B4 \uC29B \uD130\uCE58 \uD68C\uBCF5."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uADF8\uB807\uAC8C \uB9D0\uC500\uD558\uC2DC\uB2C8
      \uB354 \uC8C4\uC1A1\uD558\uB124\uC694. \uC81C\uAC00 \uB354 \uC644\uBCBD\uD574\uC57C
      \uAC10\uB3C5\uB2D8 \uCCB4\uBA74\uC774 \uC124 \uD150\uB370..."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Loyal_1
    ko: "\uAC10\uB3C5\uC758 \uACA9\uB824\uB97C \uCC45\uC784\uAC10\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uACE0\uB9C8\uC6CC\uD558\uC9C0\uB9CC, \uC2E4\uB825 \uBCC0\uD654\uB294 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Sincere_101
    ko: "\uB9D0\uC500\uC740 \uAC10\uC0AC\uD558\uC9C0\uB9CC, \uC544\uC9C1 \uC81C \uD560\uB2F9\uB7C9\uC744
      \uCC44\uC6B0\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4. \uC870\uAE08\uB9CC \uB354
      \uB358\uC9C0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Sincere_1
    ko: "\uACA9\uB824\uB97C \uB4E3\uACE0\uB3C4 \uBA48\uCD94\uC9C0 \uBABB\uD574 \uD53C\uB85C\uAC00
      \uB204\uC801\uB418\uACE0 \uC288\uD305 \uBC38\uB7F0\uC2A4\uAC00 \uB354 \uBB34\uB108\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Moodmaker_101
    ko: "\uC5D0\uC774, \uAC10\uB3C5\uB2D8! \uAC11\uC790\uAE30 \uADF8\uB807\uAC8C
      \uC9C4\uC9C0\uD558\uAC8C \uB9D0\uC500\uD558\uC2DC\uBA74 \uC800 \uC6B8\uC9C0\uB3C4
      \uBAB0\uB77C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Moodmaker_1
    ko: "\uD2B9\uC720\uC758 \uB099\uCC9C\uC131\uC73C\uB85C \uC0C1\uD669\uC744 \uB118\uAE30\uBA70
      \uAE30\uBD84 \uC804\uD658\uC740 \uC131\uACF5\uD558\uB098 \uB2A5\uB825\uCE58
      \uBCC0\uD654 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Bond_002
    ko: "\uB3D9\uB8CC\uB4E4\uB3C4 \uC5C6\uC774 \uC5EC\uAE30\uC11C \uD63C\uC790 \uBB50
      \uD558\uB294 \uAC70\uB0D0? \uB18D\uAD6C\uAC00 \uD63C\uC790 \uD558\uB294 \uC6B4\uB3D9\uC778
      \uC904 \uC54C\uC544? \uB124 \uACE0\uC9D1\uC774 \uD300\uC758 \uD654\uD569\uC744
      \uAE68\uACE0 \uC788\uB2E4\uB294 \uAC78 \uC65C \uBAB0\uB77C!"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Kind_201
    ko: "\uD654\uD569\uC744 \uAE68\uB824\uB358 \uAC8C \uC544\uB2C8\uB77C... \uB3C4\uC6C0\uC774
      \uB418\uACE0 \uC2F6\uC5B4\uC11C... \uC8C4\uC1A1\uD569\uB2C8\uB2E4, \uAC10\uB3C5\uB2D8."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Kind_202
    ko: "\uC9C4\uC9DC \uB3C4\uC6C0\uC774 \uB418\uACE0 \uC2F6\uB2E4\uBA74 \uB3D9\uB8CC\uB4E4\uACFC
      \uC18C\uD1B5\uD574\uB77C. \uC5EC\uAE30\uC11C \uC0BD\uC9C8\uD558\uC9C0 \uB9D0\uACE0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Kind_2
    ko: "\uB0A0\uCE74\uB85C\uC6B4 \uBE44\uD310\uC5D0 \uC0C1\uCC98\uB97C \uC785\uACE0
      \uC790\uC2E0\uAC10\uC744 \uC0C1\uC2E4\uD558\uC5EC \uC288\uD305 \uC131\uACF5\uB960
      \uD558\uB77D."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Loyal_201
    ko: "\uC81C \uB3C5\uB2E8\uC801\uC778 \uD589\uB3D9\uC774 \uD300\uC5D0 \uC2E4\uB840\uAC00
      \uB418\uC5C8\uAD70\uC694. \uAC10\uB3C5\uB2D8\uC758 \uC9C0\uC2DC\uB300\uB85C
      \uC989\uC2DC \uC911\uB2E8\uD558\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Loyal_202
    ko: "\uADF8\uB798. \uD300\uC758 \uC2B9\uB9AC\uB294 \uB124 \uACE0\uC9D1\uC774
      \uC544\uB2C8\uB77C \uC6B0\uB9AC\uC758 \uD611\uB825\uC5D0\uC11C \uB098\uC628\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Loyal_2
    ko: "\uD300\uC758 \uADDC\uC728\uACFC \uCDA9\uC131\uC2EC\uC744 \uC790\uADF9\uBC1B\uC544
      \uAC1C\uC778 \uAC15\uBC15\uC744 \uBC84\uB9AC\uACE0 \uD300 \uD50C\uB808\uC774\uC5D0
      \uC9D1\uC911\uD568."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Sincere_201
    ko: "\uAC1C\uC778 \uD6C8\uB828\uB3C4 \uD300\uC5D0 \uAE30\uC5EC\uD558\uB294 \uAE38\uC774\uB77C
      \uC0DD\uAC01\uD588\uC2B5\uB2C8\uB2E4. \uC81C \uD310\uB2E8\uC774 \uD2C0\uB838\uB358
      \uBAA8\uC591\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Sincere_2
    ko: "\uC9C0\uC801\uC744 \uACB8\uD5C8\uD788 \uC218\uC6A9\uD558\uACE0 \uD6C8\uB828\uC744
      \uC911\uB2E8\uD558\uC9C0\uB9CC \uAE30\uB7C9\uC758 \uC989\uAC01\uC801 \uBC18\uB4F1\uC740
      \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Moodmaker_201
    ko: "\uC544\uC774\uAD6C, \uAC10\uB3C5\uB2D8 \uD654\uB098\uC168\uB124! \uC81C\uAC00
      \uC798\uBABB\uD588\uC2B5\uB2C8\uB2E4! \uBD84\uC704\uAE30 \uB9DD\uCE58\uAE30
      \uC804\uC5D0 \uBC14\uB85C \uD1F4\uADFC\uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Moodmaker_2
    ko: "\uC555\uBC15\uAC10\uC5D0 \uC9D3\uB20C\uB824 \uD3C9\uC18C\uC758 \uC720\uC5F0\uD55C
      \uC6C0\uC9C1\uC784\uC744 \uC783\uACE0 \uC288\uD305 \uB9AC\uB4EC\uC774 \uAE68\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Bond_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uAC00 \uB358\uC9C4 \uACF5\uC744
      \uACE8\uB300 \uBC11\uC5D0\uC11C \uBC1B\uC544\uC900\uB2E4. \uC120\uC218\uAC00
      \uC9C0\uCCD0\uC11C \uC2A4\uC2A4\uB85C \uBA48\uCD9C \uB54C\uAE4C\uC9C0 \uBB35\uBB35\uD788
      \uD328\uC2A4\uB9CC \uD574\uC900\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Kind_301
    ko: "\uAC10\uB3C5\uB2D8\uB3C4 \uD53C\uACE4\uD558\uC2E4 \uD150\uB370... \uC774\uC81C
      \uADF8\uB9CC\uD560\uAC8C\uC694. \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Kind_3
    ko: "\uAC10\uB3C5\uC758 \uBC30\uB824\uC5D0 \uAC10\uB3D9\uD558\uC5EC \uD6C8\uB828\uC744
      \uBA48\uCD94\uC9C0\uB9CC \uAC10\uAC01\uC801\uC778 \uBB38\uC81C\uB294 \uD574\uACB0\uB418\uC9C0
      \uC54A\uC74C."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C1\uC811 \uD328\uC2A4\uB97C... \uC81C\uAC00
      \uAC10\uD788 \uC774\uB7F0 \uB300\uC6B0\uB97C \uBC1B\uC544\uB3C4 \uB418\uB294\uC9C0
      \uBAA8\uB974\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Loyal_3
    ko: "\uAC10\uB3C5\uC5D0 \uB300\uD55C \uBBF8\uC548\uD568\uACFC \uACFC\uB3C4\uD55C
      \uBD80\uB2F4\uAC10\uC744 \uB290\uAEF4 \uC288\uD305 \uC190\uB05D\uC774 \uB354\uC6B1
      \uACBD\uC9C1\uB428."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Sincere_301
    ko: "(\uCE68\uBB35 \uC18D\uC5D0 \uACC4\uC18D \uB358\uC9C0\uB2E4\uAC00) ...\uC774\uC81C
      0.1cm\uAC00 \uBB54\uC9C0 \uC54C \uAC83 \uAC19\uC2B5\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8
      \uB355\uBD84\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Sincere_302
    ko: "\uC2A4\uC2A4\uB85C \uAE68\uB2EC\uC558\uB2E4\uBA74 \uB410\uB2E4. \uADF8 \uAC10\uAC01
      \uC78A\uC9C0 \uB9D0\uACE0 \uC798 \uAC04\uC9C1\uD574\uB77C."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Sincere_3
    ko: "\uAC10\uB3C5\uC758 \uBB35\uBB35\uD55C \uC9C0\uC6D0 \uC18D\uC5D0 \uD3C9\uC815\uC2EC\uC744
      \uCC3E\uACE0 \uC2A4\uC2A4\uB85C \uC288\uD305 \uBA54\uCEE4\uB2C8\uC998\uC744
      \uC644\uC131\uD568."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Moodmaker_301
    ko: "\uC640! \uAC10\uB3C5\uB2D8\uC774 \uD328\uC2A4 \uC154\uD2C0\uC774\uB77C\uB2C8!
      \uC774\uAC70 \uD300\uC6D0\uB4E4\uC774 \uC54C\uBA74 \uB09C\uB9AC \uB098\uACA0\uB294\uB370\uC694?"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Moodmaker_3
    ko: "\uAC10\uB3C5\uACFC\uC758 \uCE5C\uBC00\uD55C \uAD50\uAC10\uC744 \uD1B5\uD574
      \uD65C\uAE30\uB97C \uB418\uCC3E\uACE0 \uD300\uC6D0\uB4E4\uC744 \uD5A5\uD55C
      \uC2DC\uC57C\uAC00 \uB113\uC5B4\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cold_001
    ko: "\uD300\uC6D0\uB4E4\uACFC \uC5B4\uC6B8\uB9AC\uC9C0 \uBABB\uD558\uACE0 \uD640\uB85C
      \uCF54\uD2B8\uC5D0 \uB0A8\uC740 \uC120\uC218\uAC00 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cold_002
    ko: "\uD3C9\uC18C \uD300\uC6CC\uD06C\uB97C \uC911\uC2DC\uD558\uB358 \uC120\uC218\uC600\uC9C0\uB9CC,
      \uCD5C\uADFC \uC288\uD305 \uC2AC\uB7FC\uD504\uAC00 \uC624\uC790 \uB098 \uB54C\uBB38\uC5D0
      \uD300\uC774 \uC9C4\uB2E4\uB294 \uBD80\uCC44\uAC10\uC5D0 \uC0AC\uB85C\uC7A1\uD600
      \uC790\uC2E0\uC744 \uAC00\uB450\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cold_003
    ko: "0.1cm\uC758 \uAC10\uAC01 \uCC28\uC774\uC5D0 \uC9D1\uCC29\uD558\uBA70 \uC2E0\uACBD\uC9C8\uC801\uC73C\uB85C
      \uACF5\uC744 \uB358\uC9C0\uB294 \uC120\uC218\uC758 \uB208\uC740 \uC774\uBBF8
      \uCDA9\uD608\uB418\uC5B4 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cold_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Cold_001
    ko: "\uC218\uCE58\uC5D0 \uB108\uBB34 \uC5F0\uC5F0\uD558\uC9C0 \uB9C8\uB77C. \uC9C0\uAE08
      \uB124 \uD3FC\uC740 \uCDA9\uBD84\uD788 \uC548\uC815\uC801\uC774\uB2E4. \uC870\uAE08\uB9CC
      \uC5B4\uAE68\uC5D0 \uD798\uC744 \uBE7C\uBA74 \uB2E4\uC2DC \uADA4\uC801\uC744
      \uCC3E\uC744 \uC218 \uC788\uC744 \uAC70\uC57C."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Planner_101
    ko: "\uC218\uCE58\uB294 \uAC70\uC9D3\uB9D0\uC744 \uC548 \uD569\uB2C8\uB2E4. \uACA9\uB824\uBCF4\uB2E4\uB294
      \uC81C \uADA4\uC801\uC758 \uC624\uCC28 \uC6D0\uC778\uC744 \uC9DA\uC5B4\uC8FC\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Planner_102
    ko: "\uC6D0\uC778\uC740 \uACFC\uBD80\uD558\uB2E4. \uC9C0\uAE08\uC740 \uBD84\uC11D\uBCF4\uB2E4
      \uB1CC\uB97C \uC26C\uAC8C \uD558\uB294 \uAC8C \uC6B0\uC120\uC774\uC57C."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Planner_1
    ko: "\uAC10\uC131\uC801\uC778 \uACA9\uB824\uB97C \uB17C\uB9AC\uC801\uC73C\uB85C
      \uAC70\uBD80\uD558\uBA70 \uC0C1\uD0DC\uAC00 \uC720\uC9C0\uB428"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Opportunist_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uAD1C\uCC2E\uB2E4\uBA74 \uB2E4\uD589\uC774\uB124\uC694. "
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Opportunist_1
    ko: "\uAC10\uB3C5\uC758 \uAE0D\uC815\uC801 \uD0DC\uB3C4\uB97C \uD655\uC778\uD558\uACE0
      \uC2EC\uB9AC\uC801 \uC555\uBC15\uC5D0\uC11C \uBC97\uC5B4\uB098 \uD3FC \uD68C\uBCF5"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cunning_101
    ko: "\uB124, \uBA85\uC2EC\uD558\uACA0\uC2B5\uB2C8\uB2E4. (\uC18D\uC73C\uB85C:
      \uB0B4 \uC2AC\uB7FC\uD504\uB97C \uB300\uC218\uB86D\uC9C0 \uC54A\uAC8C \uBCF4\uAC8C
      \uC720\uB3C4\uD574\uC57C\uACA0\uC5B4.)"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Cunning_1
    ko: "\uC790\uC2E0\uC758 \uC57D\uC810\uC744 \uAC10\uCD94\uB824\uB294 \uC2EC\uB9AC\uC801
      \uBC29\uC5B4 \uAE30\uC81C\uAC00 \uBAB8\uC744 \uB354 \uACBD\uC9C1\uC2DC\uD0B4"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Believer_101
    ko: "\uAC10\uC0AC\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC800\uB294 \uC81C \uACC4\uC0B0\uC774
      \uB9DE\uB2E4\uB294 \uAC78 \uC99D\uBA85\uD560 \uB54C\uAE4C\uC9C0 \uC548 \uC27D\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Believer_1
    ko: "\uACA9\uB824\uC640 \uC0C1\uAD00\uC5C6\uC774 \uBCF8\uC778\uC758 \uC8FC\uAD00\uB300\uB85C
      \uD6C8\uB828\uC744 \uC9C0\uC18D\uD558\uC5EC \uBCC0\uD654\uAC00 \uC5C6\uC74C"
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Cold_002
    ko: "\uC9C0\uAE08 \uB358\uC9C0\uB294 \uAC74 \uC5F0\uC2B5\uC774 \uC544\uB2C8\uB77C
      \uB178\uB3D9\uC774\uB2E4! \uC0DD\uAC01 \uC5C6\uC774 \uB358\uC9C0\uAE30\uB9CC
      \uD55C\uB2E4\uACE0 \uB4E4\uC5B4\uAC08 \uAC83 \uAC19\uB098? \uB124 \uB0C9\uCCA0\uD568\uC740
      \uC5B4\uB514 \uAC14\uC5B4?"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Planner_201
    ko: "\uB9DE\uC2B5\uB2C8\uB2E4. \uB9F9\uBAA9\uC801\uC778 \uBC18\uBCF5\uC774\uC5C8\uAD70\uC694.
      \uB2E4\uC2DC \uC5ED\uD559\uC801\uC73C\uB85C \uC811\uADFC\uD574\uC11C \uD3FC\uC744
      \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Planner_2
    ko: "\uC790\uC2E0\uC758 \uBE44\uD6A8\uC728\uC131\uC744 \uC989\uAC01 \uC778\uC815\uD558\uACE0
      \uB17C\uB9AC\uC801 \uC218\uC815\uC744 \uD1B5\uD574 \uD6A8\uC728 \uC0C1\uC2B9"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Opportunist_201
    ko: "\uC73D, \uB4E4\uCF30\uB098\uC694? \uD6A8\uC728\uC774 \uB5A8\uC5B4\uC9C4\uB2E4\uB294
      \uAC74 \uC778\uC815\uD569\uB2C8\uB2E4. \uBC14\uB85C \uBA48\uCD94\uACE0 \uC26C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Opportunist_2
    ko: "\uBE44\uB09C\uC744 \uD53C\uD558\uAE30 \uC704\uD574 \uC989\uAC01 \uC21C\uC751\uD558\uC9C0\uB9CC
      \uC2E4\uC9C8\uC801\uC778 \uAE30\uB7C9 \uBCC0\uD654\uB294 \uC5C6\uC74C"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cunning_201
    ko: "\uC0DD\uAC01\uC774 \uC5C6\uC5C8\uB358 \uAC8C \uC544\uB2C8\uB77C, \uB2E4\uB978
      \uC804\uC220\uC801 \uBCC0\uC218\uB97C \uACE0\uBBFC \uC911\uC774\uC5C8\uC2B5\uB2C8\uB2E4.
      \uC624\uD574\uD558\uC9C0 \uB9C8\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Cunning_2
    ko: "\uC9C0\uC801\uC5D0 \uB300\uD574 \uAC70\uC9D3 \uBCC0\uBA85\uC73C\uB85C \uC77C\uAD00\uD558\uBA70
      \uBB38\uC81C\uC758 \uBCF8\uC9C8\uC744 \uC678\uBA74\uD568."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Believer_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uD2C0\uB838\uB2E4\uACE0 \uC0DD\uAC01\uD558\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4. \uAC10\uB3C5\uB2D8\uC774 \uD2C0\uB838\uB2E4\uB294
      \uAC78 \uACB0\uACFC\uB85C \uC99D\uBA85\uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Believer_202
    ko: "\uC88B\uB2E4. \uADF8 \uC624\uAE30\uAC00 \uB3C5\uC774 \uB420\uC9C0 \uC57D\uC774
      \uB420\uC9C0\uB294 \uB0B4\uC77C \uD655\uC778\uD558\uACA0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Believer_2
    ko: "\uAC15\uD55C \uC790\uADF9\uC774 \uC2B9\uBD80\uC695\uC744 \uAC74\uB4DC\uB824
      \uADF9\uD55C\uC758 \uC9D1\uC911\uB825\uC73C\uB85C \uC29B \uC815\uD655\uB3C4
      \uC0C1\uC2B9."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Cold_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uBA40\uB9AC\uC11C \uC120\uC218\uAC00 \uC2A4\uC2A4\uB85C
      \uB2F5\uC744 \uCC3E\uC744 \uB54C\uAE4C\uC9C0 \uB05D\uAE4C\uC9C0 \uC9C0\uCF1C\uBCF8
      \uB4A4, \uACF5\uB9CC \uCC59\uACA8\uC11C \uB098\uAC04\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Planner_301
    ko: "\uBB34\uC5B8\uC758 \uAE0D\uC815\uC778\uAC00... \uC544\uB2C8\uBA74 \uD3EC\uAE30\uC778\uAC00?
      \uB2E4\uC2DC \uACC4\uC0B0\uD574\uBCF4\uC790."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Planner_3
    ko: "\uAC00\uC774\uB4DC\uAC00 \uC5C6\uB294 \uC0C1\uD0DC\uC5D0\uC11C \uACFC\uB3C4\uD55C
      \uBD84\uC11D\uC5D0 \uBE60\uC838 \uC288\uD305 \uBA54\uCEE4\uB2C8\uC998\uC774
      \uAF2C\uC784"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Opportunist_301
    ko: "\uD734, \uC794\uC18C\uB9AC \uC548 \uB4E4\uC5B4\uC11C \uB2E4\uD589\uC774\uB124.
      \uC801\uB2F9\uD788 \uB358\uC9C0\uB294 \uCC99\uD558\uB2E4\uAC00 \uB4E4\uC5B4\uAC00\uC57C\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Opportunist_3
    ko: "\uAC10\uC2DC\uAC00 \uC5C6\uC790 \uBC14\uB85C \uC694\uB839\uC744 \uD53C\uC6B0\uBA70
      \uD6C8\uB828 \uBC00\uB3C4\uAC00 \uAE09\uACA9\uD788 \uD558\uB77D\uD568"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Cunning_301
    ko: "\uC544\uBB34 \uB9D0\uB3C4 \uC548 \uD558\uC2DC\uB2E4\uB2C8... \uB0B4 \uAC00\uCE58\uB97C
      \uD14C\uC2A4\uD2B8\uD558\uB294 \uAC74\uAC00? \uB354 \uC644\uBCBD\uD558\uAC8C
      \uB358\uC838\uC57C\uACA0\uC5B4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Cunning_3
    ko: "\uCE68\uBB35\uC744 \uC2EC\uB9AC\uC801 \uC2DC\uD5D8\uC73C\uB85C \uD574\uC11D\uD558\uACE0
      \uC9C0\uC9C0 \uC54A\uC73C\uB824 \uC9D1\uC911\uB825\uC744 \uCD5C\uB300\uCE58\uB85C
      \uBC1C\uD718"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Believer_301
    ko: "\uC5ED\uC2DC \uACE0\uB3C5\uD55C \uC2F8\uC6C0\uC774\uAD70. \uAC10\uB3C5\uC870\uCC28
      \uB0B4 \uACE0\uB1CC\uB97C \uC774\uD574 \uBABB \uD558\uB294 \uAC70\uC57C. \uB098
      \uD63C\uC790 \uD574\uB0B8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Believer_3
    ko: "\uACE0\uB3C5\uC744 \uC539\uC73C\uBA70 \uBB35\uBB35\uD788 \uD6C8\uB828\uC744
      \uC774\uC5B4\uAC00\uC9C0\uB9CC \uD2B9\uBCC4\uD55C \uBC18\uB4F1\uC740 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Instinct_001
    ko: "\uD3C9\uC18C \uB3D9\uBB3C\uC801\uC778 \uAC10\uAC01\uC73C\uB85C \uB4DD\uC810\uC744
      \uC62C\uB9AC\uB358 \uC120\uC218\uAC00 \uC624\uB298\uB530\uB77C \uAE30\uACC4\uC801\uC778
      \uC218\uCE58\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Instinct_002
    ko: "\uC190\uB05D\uC774 0.1cm \uB0AE\uC544... \uAC01\uB3C4\uAC00 \uBD80\uC871\uD574."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Instinct_003
    ko: "\uC790\uC2E0\uC758 \uC57C\uC131\uC744 \uBBFF\uC9C0 \uBABB\uD558\uACE0 \uACC4\uC0B0\uAE30\uC5D0
      \uBAB8\uC744 \uB07C\uC6CC \uB9DE\uCD94\uB824\uB294 \uC120\uC218\uC758 \uC6C0\uC9C1\uC784\uC740
      \uB454\uD0C1\uD558\uACE0 \uBD80\uC790\uC5F0\uC2A4\uB7FD\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Instinct_004
    ko: "\uBCF8\uB2A5\uC774 \uC0AC\uB77C\uC9C4 \uC120\uC218\uC758 \uC288\uD305\uC740
      \uB9BC\uC744 \uC678\uBA74\uD55C \uCC44 \uBC14\uB2E5\uC744 \uAD74\uB7EC \uB2F9\uC2E0\uC758
      \uBC1C\uBC11\uC5D0 \uBA48\uCDA5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Instinct_005
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Instinct_001
    ko: "\uC218\uCE58 \uAC19\uC740 \uAC74 \uC78A\uC5B4\uBC84\uB824. \uB124 \uBAB8\uC774
      \uAE30\uC5B5\uD558\uB294 \uAC10\uAC01\uC744 \uBBFF\uC5B4\uB77C. \uB108\uB294
      \uACC4\uC0B0\uAE30\uAC00 \uC544\uB2C8\uB77C \uCF54\uD2B8 \uC704\uC758 \uD3EC\uC2DD\uC790\uC796\uC544.
      \uC790\uC2E0\uAC10\uC744 \uAC00\uC838!"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bluffer_101
    ko: "\uD3EC\uC2DD\uC790\uB77C... \uD6C4\uD6D7, \uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740
      \uC81C \uC9C4\uAC00\uB97C \uC544\uC2DC\uB294\uAD70\uC694. \uC88B\uC2B5\uB2C8\uB2E4,
      \uB2E4\uC2DC \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0!"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Bluffer_1
    ko: "\uC790\uC874\uAC10\uC744 \uC790\uADF9\uBC1B\uC790 \uC2EC\uB9AC\uC801 \uC704\uCD95\uC774
      \uC0AC\uB77C\uC9C0\uACE0 \uD2B9\uC720\uC758 \uACFC\uAC10\uD55C \uC29B\uC774
      \uC0B4\uC544\uB0A8."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Wild_101
    ko: "\uAC10\uAC01... \uB124, \uC54C \uAC83 \uAC19\uC544\uC694. \uBA38\uB9AC\uAC00
      \uC544\uB2C8\uB77C \uBAB8\uC774 \uC2DC\uD0A4\uB294 \uB300\uB85C \uB358\uC838\uBCFC\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Wild_1
    ko: "\uACA9\uB824\uB97C \uB4E3\uACE0 \uB9C8\uC74C\uC740 \uD3B8\uD574\uC84C\uC73C\uB098,
      \uD5DD\uD074\uC5B4\uC9C4 \uD3FC\uC744 \uBC14\uB85C\uC7A1\uAE30\uC5D4 \uC2DC\uAC04\uC774
      \uBD80\uC871\uD568."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Egoist_101
    ko: "\uC81C \uC790\uC2E0\uAC10\uC740 \uC81C\uAC00 \uCC59\uAE41\uB2C8\uB2E4. \uC9C0\uAE08\uC740
      \uC774 \uC624\uCC28\uB97C \uD574\uACB0\uD558\uB294 \uAC8C \uC6B0\uC120\uC774\uC5D0\uC694."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Egoist_1
    ko: "\uACA9\uB824\uB97C \uAC04\uC12D\uC73C\uB85C \uCE58\uBD80\uD558\uACE0 \uACE0\uC9D1\uC744
      \uBD80\uB9AC\uB2E4 \uC288\uD305 \uBA54\uCEE4\uB2C8\uC998\uC774 \uC644\uC804\uD788
      \uAF2C\uC784."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Fighter_101
    ko: "\uC704\uB85C \uB530\uC704 \uD544\uC694 \uC5C6\uC2B5\uB2C8\uB2E4. \uC81C
      \uAC10\uAC01\uC774 \uD2C0\uB838\uB2E4\uB294 \uC0AC\uC2E4\uC774 \uC9DC\uC99D
      \uB0A0 \uBFD0\uC774\uC5D0\uC694."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Fighter_1
    ko: "\uC2B9\uBD80\uC695\uC740 \uD0C0\uC624\uB974\uC9C0\uB9CC \uACA9\uB824\uB9CC\uC73C\uB85C\uB294
      \uAE30\uC220\uC801\uC778 \uC2AC\uB7FC\uD504\uB97C \uADF9\uBCF5\uD558\uC9C0
      \uBABB\uD568."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Instinct_002
    ko: "\uD55C\uC2EC\uD558\uAD70! \uC5B8\uC81C\uBD80\uD130 \uB124\uAC00 \uD1B5\uACC4\uD559\uC790\uC600\uC9C0?
      0.1cm\uC5D0 \uBC8C\uBC8C \uB5A8 \uAC70\uBA74 \uB18D\uAD6C \uADF8\uB9CC\uB450\uACE0
      \uC218\uD559 \uBB38\uC81C\uB098 \uD480\uC5B4\uB77C! \uB124 \uC57C\uC131\uC740
      \uC8FD\uC5C8\uB098?"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bluffer_201
    ko: "\uC218\uD559 \uBB38\uC81C\uB77C\uB2C8\uC694, \uB9D0\uC774 \uB108\uBB34 \uC2EC\uD558\uC2DC\uB124!
      \uC81C\uAC00 \uC99D\uBA85\uD558\uBA74 \uC0AC\uACFC\uD558\uC2DC\uB294 \uAC81\uB2C8\uB2E4?"
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bluffer_202
    ko: "\uC0AC\uACFC\uB4E0 \uBB50\uB4E0 \uC88B\uC73C\uB2C8 \uACB0\uACFC\uB85C \uBCF4\uC5EC\uB77C.
      \uC785\uB9CC \uC0B4\uC544\uC788\uC9C0 \uB9D0\uACE0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Bluffer_2
    ko: "\uBE44\uB09C\uC5D0 \uB2F9\uD669\uD558\uC5EC \uC5B5\uC9C0\uB85C \uD3FC\uC744
      \uC7A1\uC73C\uB824\uB2E4 \uC624\uD788\uB824 \uC5B4\uAE68\uC5D0 \uD798\uC774
      \uB4E4\uC5B4\uAC00 \uB9DD\uAC00\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Wild_201
    ko: "(\uC73C\uB974\uB801\uAC70\uB9AC\uBA70) \uC57C\uC131\uC774 \uC8FD\uC5C8\uB2E4\uACE0\uC694?
      \uC9C0\uAE08 \uB2F9\uC7A5 \uB9BC\uC774 \uBD80\uC11C\uC9C0\uB294 \uAC78 \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Wild_2
    ko: "\uAC15\uD55C \uC790\uADF9\uC774 \uC7A0\uC790\uB358 \uC57C\uC131\uC744 \uAE68\uC6CC
      \uACC4\uC0B0\uC744 \uBA48\uCD94\uACE0 \uC9C1\uAD00\uC801\uC778 \uC288\uD305\uC744
      \uD68C\uBCF5\uD568."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Egoist_201
    ko: "\uB204\uAD6C\uBCF4\uACE0 \uB18D\uAD6C\uB97C \uADF8\uB9CC\uB450\uB77C\uB294
      \uAC70\uC8E0? \uC804 \uC81C \uBC29\uC2DD\uB300\uB85C \uCD5C\uACE0\uAC00 \uB420
      \uAC81\uB2C8\uB2E4. \uC9C0\uCF1C\uBCF4\uC2DC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Egoist_2
    ko: "\uAC10\uB3C5\uC758 \uBB34\uC2DC\uB97C \uACAC\uB514\uC9C0 \uBABB\uD574 \uB3C5\uAE30\uB85C
      \uC9D1\uC911\uB825\uC744 \uBC1C\uD718, \uC2A4\uC2A4\uB85C \uCD5C\uC801\uC758
      \uAC10\uAC01\uC744 \uCC3E\uC74C."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Fighter_201
    ko: "\uC218\uD559 \uBB38\uC81C? \uC6C3\uAE30\uC9C0 \uB9C8\uC138\uC694. \uAC10\uB3C5\uB2D8
      \uCF54\uAC00 \uB0A9\uC791\uD574\uC9C8 \uC815\uB3C4\uB85C \uAF42\uC544 \uB123\uC5B4\uC8FC\uACA0\uC2B5\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Fighter_2
    ko: "\uACBD\uC7C1\uC2EC\uC740 \uC790\uADF9\uB418\uC5C8\uC73C\uB098 \uACFC\uB3C4\uD55C
      \uD765\uBD84 \uC0C1\uD0DC\uAC00 \uB418\uC5B4 \uC29B \uC131\uACF5\uB960\uC740
      \uC81C\uC790\uB9AC\uAC78\uC74C."
    en: 
    ja: 
  - stringKey: Event_00003_Ch_Instinct_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uB9BC \uB4A4\uC5D0 \uC11C\uC11C \uC120\uC218\uC758
      \uC29B\uC774 \uB4E4\uC5B4\uC624\uAE30\uB97C \uAE30\uB2E4\uB9B0\uB2E4. \uC2E4\uD328\uD55C
      \uACF5\uC744 \uB358\uC838\uC8FC\uBA70 \uC120\uC218\uC758 \uB208\uC744 \uB6AB\uC5B4\uC9C0\uAC8C
      \uC751\uC2DC\uD560 \uBFD0\uC774\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Bluffer_301
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uC29B \uAC01\uB3C4 \uBCF4\uACE0 \uAC10\uD0C4\uD574\uC11C
      \uB9D0\uC774 \uC548 \uB098\uC624\uC2DC\uB294 \uAC70\uC8E0? \uD558\uD558..."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Bluffer_3
    ko: "\uCE68\uBB35\uC744 \uC790\uAE30 \uC88B\uC744 \uB300\uB85C \uD574\uC11D\uD558\uBA70
      \uADFC\uAC70 \uC5C6\uB294 \uC790\uC2E0\uAC10\uC744 \uC720\uC9C0\uD558\uC9C0\uB9CC
      \uBC1C\uC804\uC740 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Wild_301
    ko: "(\uCE68\uBB35 \uC18D\uC5D0 \uACC4\uC18D \uACF5\uC744 \uB358\uC9C0\uB2E4\uAC00)
      ...\uC65C \uC790\uAFB8 \uCCD0\uB2E4\uBCF4\uC138\uC694? \uC9DC\uC99D \uB098\uAC8C
      \uC9C4\uC9DC!"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Wild_3
    ko: "\uC2DC\uC120\uC5D0 \uB300\uD55C \uC555\uBC15\uAC10\uC744 \uC774\uAE30\uC9C0
      \uBABB\uD558\uACE0 \uB9AC\uB4EC\uC774 \uC644\uC804\uD788 \uAE68\uC838 \uCD5C\uC545\uC758
      \uC131\uACF5\uB960 \uAE30\uB85D."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Egoist_301
    ko: "\uC544\uBB34 \uB9D0 \uB9C8\uC138\uC694. \uC81C \uBB38\uC81C\uB294 \uC81C\uAC00
      \uC81C\uC77C \uC798 \uC555\uB2C8\uB2E4. \uACE7 \uB2F5\uC744 \uCC3E\uC744 \uAC70\uB2C8\uAE4C."
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Egoist_3
    ko: "\uC678\uBD80\uC758 \uD53C\uB4DC\uBC31 \uC5C6\uC774 \uD63C\uC790\uB9CC\uC758
      \uACE0\uB9BD\uB41C \uD6C8\uB828\uC744 \uC774\uC5B4\uAC00\uBA70 \uD604\uC0C1
      \uC720\uC9C0\uC5D0 \uADF8\uCE68."
    en: 
    ja: 
  - stringKey: Event_00003_Desc_Fighter_301
    ko: "\uC774 \uACF5\uC774 \uB4E4\uC5B4\uAC08 \uB54C\uAE4C\uC9C0 \uC548 \uAC00\uC2E4
      \uAC70\uC8E0? \uC88B\uC2B5\uB2C8\uB2E4. \uB05D\uAE4C\uC9C0 \uAC00\uBCF4\uC790\uACE0\uC694!"
    en: 
    ja: 
  - stringKey: Event_00003_Rs_Fighter_3
    ko: "\uCE68\uBB35\uC758 \uAE30 \uC2F8\uC6C0\uC5D0\uC11C \uC9C0\uC9C0 \uC54A\uC73C\uB824
      \uC9D1\uC911\uB825\uC744 \uC3DF\uC544\uBD80\uC5B4 \uC9D1\uC694\uD55C \uBCFC
      \uC9D1\uC911\uB825 \uC0C1\uC2B9."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Discipline_001
    ko: "\uD300\uC758 \uC5D0\uC774\uC2A4\uAC00 \uC790\uC720\uD22C \uB77C\uC778 \uC591
      \uB05D\uC778 '\uC5D8\uBCF4\uC6B0' \uC9C0\uC5ED\uC5D0\uC11C \uBB34\uC11C\uC6B4
      \uC9D1\uC911\uB825\uC73C\uB85C \uC29B\uC744 \uB358\uC9D1\uB2C8\uB2E4. \uB540\uC5D0
      \uC816\uC740 \uADF8\uAC00 \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC640 \uB2E8\uD638\uD558\uAC8C
      \uB9D0\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Discipline_002
    ko: "\uAC10\uB3C5\uB2D8, \uC774 \uAD6C\uC5ED\uC740 \uC81C '\uC131\uC5ED'\uC785\uB2C8\uB2E4.
      \uC5EC\uAE30\uC11C \uB358\uC9C0\uB294 \uC81C \uC29B\uC740 100% \uB4E4\uC5B4\uAC04\uB2E4\uACE0
      \uACC4\uC0B0\uD558\uC154\uB3C4 \uC88B\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Discipline_003
    ko: "\uC81C\uAC00 \uC2B9\uB9AC\uD558\uB294 \uBC95\uC744 \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4.
      \uC808 \uBBFF\uACE0 \uC774 \uAD6C\uC5ED \uC804\uC220\uC744 \uC9DC\uC8FC\uC2E4
      \uC218 \uC788\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Discipline_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Discipline_001
    ko: "\uB124 \uC790\uC2E0\uAC10\uC740 \uC778\uC815\uD55C\uB2E4. \uB124\uAC00 \uADF8
      \uAD6C\uC5ED\uC744 \uCC45\uC784\uC838\uC900\uB2E4\uBA74 \uD300\uC5D0 \uD070
      \uD798\uC774 \uB418\uACA0\uC9C0. \uB124 \uB178\uB825\uC744 \uBBFF\uACE0 \uC5D8\uBCF4\uC6B0
      \uC9C0\uC5ED\uC758 \uC29B \uC635\uC158\uC744 \uCD5C\uC6B0\uC120\uC73C\uB85C
      \uBC30\uCE58\uD558\uACA0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Principled_101
    ko: "\uBBFF\uC5B4\uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uC81C\uAC00
      \uC815\uD55C \uB8E8\uD2F4\uB300\uB85C \uC2B9\uB9AC\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Principled_1
    ko: "\uAC10\uB3C5\uC758 \uC2B9\uC778\uC774 \uC790\uC2E0\uC758 \uC6D0\uCE59\uC5D0
      \uD655\uC2E0\uC744 \uC8FC\uC5B4 \uC288\uD305 \uC815\uD655\uB3C4 \uD5A5\uC0C1."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Guardian_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uC804\uC220\uC744 \uC81C\uAC00 \uBC18\uB4DC\uC2DC
      \uC9C0\uCF1C\uB0B4\uACA0\uC2B5\uB2C8\uB2E4. \uD300\uC6D0\uB4E4\uC744 \uBBFF\uAC8C
      \uB9CC\uB4E4\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Guardian_1
    ko: "\uCC45\uC784\uAC10\uC744 \uB290\uB07C\uBA70 \uACB0\uC758\uB97C \uB2E4\uC9C0\uC9C0\uB9CC,
      \uAE30\uB7C9\uC740 \uD3C9\uC18C \uC218\uC900 \uC720\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Tactician_101
    ko: "\uD569\uB9AC\uC801\uC778 \uACB0\uC815\uC785\uB2C8\uB2E4. 100%\uC758 \uD655\uB960\uC774
      \uC788\uB294 \uACF3\uC5D0 \uC790\uC6D0\uC744 \uC9D1\uC911\uD574\uC57C\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Tactician_1
    ko: "\uC790\uC2E0\uC758 \uACF5\uACA9 \uAD6C\uC5ED\uC5D0\uB9CC \uB9E4\uBAB0\uB418\uC5B4
      \uB3D9\uB8CC\uB4E4\uC758 \uC6C0\uC9C1\uC784\uC744 \uB193\uCE58\uAC8C \uB428."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Exemplary_101
    ko: "\uC5D0\uC774\uC2A4\uB85C\uC11C \uD300\uC758 \uC911\uC2EC\uC744 \uC7A1\uC73C\uB77C\uB294
      \uB73B\uC73C\uB85C \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uBCF8\uBCF4\uAE30\uAC00
      \uB418\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Exemplary_1
    ko: "\uB3C4\uB355\uC801 \uB9CC\uC871\uAC10\uC744 \uB290\uB07C\uBA70 \uC131\uC2E4\uD788
      \uC784\uD558\uB098 \uAE30\uB7C9 \uBCC0\uD654\uB294 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Discipline_002
    ko: "100%? \uC790\uB9CC\uD558\uC9C0 \uB9C8\uB77C! \uB18D\uAD6C\uC5D0 \uC808\uB300\uC801\uC778
      \uAC74 \uC5C6\uB2E4. \uD2B9\uC815 \uAD6C\uC5ED\uC5D0\uB9CC \uC9D1\uCC29\uD558\uB294
      \uAC74 \uD300 \uC804\uC220\uC758 \uC720\uC5F0\uC131\uC744 \uC8FD\uC774\uB294
      \uC9D3\uC774\uB2E4. "
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Principled_201
    ko: "\uC790\uB9CC\uC774 \uC544\uB2C8\uC5C8\uC2B5\uB2C8\uB2E4... \uD558\uC9C0\uB9CC
      \uAC10\uB3C5\uB2D8 \uC9C0\uC801\uC774 \uC633\uC2B5\uB2C8\uB2E4. \uADDC\uC728
      \uC548\uC5D0\uC11C \uC6C0\uC9C1\uC774\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Principled_2
    ko: "\uC790\uC2E0\uC758 \uD655\uC2E0\uC774 \uBD80\uC815\uB2F9\uD558\uC790 \uC2EC\uB9AC\uC801\uC73C\uB85C
      \uC704\uCD95\uB418\uC5B4 \uC29B \uAC10\uAC01\uC774 \uD754\uB4E4\uB9BC."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Guardian_201
    ko: "\uD300\uC758 \uC9C8\uC11C\uB97C \uD574\uCE60 \uC0DD\uAC01\uC740 \uC5C6\uC5C8\uC2B5\uB2C8\uB2E4.
      \uC81C\uAC00 \uB108\uBB34 \uC55E\uC11C\uB098\uAC14\uAD70\uC694. \uC8C4\uC1A1\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Guardian_2
    ko: "\uAC1C\uC778\uC758 \uC695\uC2EC\uC744 \uBC84\uB9AC\uACE0 \uD300\uC744 \uC9C0\uD0A4\uB294
      \uD0DC\uB3C4\uB85C \uC804\uD658\uD558\uBA70 \uC9D1\uC911\uB825 \uC0C1\uC2B9."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Tactician_201
    ko: "\uC81C \uC81C\uC548\uC774 \uBE44\uD6A8\uC728\uC801\uC774\uC5C8\uAD70\uC694.
      \uB2E4\uC2DC \uC804\uCCB4\uC801\uC778 \uD750\uB984\uC5D0 \uB9DE\uAC8C \uC218\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uD1B5\uD574 \uC790\uC2E0\uC758 \uD55C\uACC4\uB97C \uAE68\uB2EB\uACE0
      \uC774\uD0C0\uC801\uC778 \uC2DC\uC57C\uB97C \uD655\uBCF4\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Exemplary_201
    ko: "\uC81C \uD0DC\uB3C4\uAC00 \uC624\uB9CC\uC73C\uB85C \uBE44\uCCE4\uB2E4\uBA74
      \uBC18\uC131\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uB2E4\uC2DC \uAE30\uBCF8\uBD80\uD130
      \uC900\uBE44\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Exemplary_2
    ko: "\uAC15\uD55C \uC9C8\uCC45\uC5D0 \uD3C9\uC815\uC2EC\uC744 \uC783\uACE0 \uC790\uC2E0\uC758
      \uBA54\uCEE4\uB2C8\uC998\uC5D0 \uC758\uAD6C\uC2EC\uC774 \uC0DD\uAE40."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Discipline_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uC758 \uC29B\uC744 \uB05D\uAE4C\uC9C0
      \uC9C0\uCF1C\uBCF8 \uB4A4, \uC804\uC220 \uBCF4\uB4DC\uC758 \uC5D8\uBCF4\uC6B0
      \uC9C0\uC5ED\uC5D0 \uC791\uC740 \uC6D0 \uD558\uB098\uB9CC \uADF8\uB824\uB193\uACE0
      \uC790\uB9AC\uB97C \uB5A0\uB09C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Principled_301
    ko: "\uBB34\uC5B8\uC758 \uC57D\uC18D\uC774\uAD70\uC694. \uAC10\uB3C5\uB2D8\uC758
      \uCE68\uBB35\uC774 \uD5DB\uB418\uC9C0 \uC54A\uAC8C \uACB0\uACFC\uB85C \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Principled_3
    ko: "\uAC10\uB3C5\uC758 \uD589\uB3D9\uC744 \uAE0D\uC815\uC801 \uC2E0\uD638\uB85C
      \uD574\uC11D\uD558\uBA70 \uBCF8\uC778\uC758 \uB8E8\uD2F4\uC744 \uC218\uD589\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Guardian_301
    ko: "\uC81C\uAC00 \uC99D\uBA85\uD558\uC9C0 \uBABB\uD558\uBA74 \uC774 \uC6D0\uC740
      \uC544\uBB34 \uC758\uBBF8\uAC00 \uC5C6\uACA0\uC8E0. \uB0B4\uC77C \uACB0\uACFC\uB85C
      \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Guardian_3
    ko: "\uCE68\uBB35\uC758 \uC555\uBC15\uC744 \uACFC\uB3C4\uD558\uAC8C \uB290\uAEF4
      \uC5B4\uAE68\uC5D0 \uD798\uC774 \uB4E4\uC5B4\uAC00\uACE0 \uB9AC\uB4EC\uC774
      \uAE68\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Tactician_301
    ko: "\uCE68\uBB35\uC740 \uACE7 \uB3D9\uC758\uB77C\uACE0 \uC774\uD574\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      \uB0B4\uC77C \uC81C\uAC00 \uC5B4\uB5BB\uAC8C \uC9C0\uBC30\uD558\uB294\uC9C0
      \uBCF4\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Tactician_3
    ko: "\uAC10\uB3C5\uC758 \uBC29\uAD00\uC744 \uC804\uC220\uC801 \uC2E0\uB8B0\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uD3C9\uC18C\uC758 \uD6A8\uC728\uC744 \uC720\uC9C0\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Exemplary_301
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC9C0\uCF1C\uBCF4\uACE0 \uACC4\uC2DC\uB2C8 \uB354
      \uCC45\uC784\uAC10\uC774 \uB290\uAEF4\uC9D1\uB2C8\uB2E4. \uADF8 \uAE30\uB300\uB97C
      \uC2B9\uB9AC\uB85C \uB3CC\uB824\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Exemplary_3
    ko: "\uC2A4\uC2A4\uB85C \uCC45\uC784\uC838\uC57C \uD560 \uC601\uC5ED\uC774 \uC0DD\uACBC\uC74C\uC744
      \uC9C1\uC2DC\uD558\uACE0 \uAD82\uC740\uC77C\uC5D0 \uC801\uADF9\uC801\uC73C\uB85C
      \uBCC0\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bond_001
    ko: "\uD300\uC758 \uC5D0\uC774\uC2A4\uAC00 \uC790\uC720\uD22C \uB77C\uC778 \uC591
      \uB05D\uC778 '\uC5D8\uBCF4\uC6B0' \uC9C0\uC5ED\uC5D0\uC11C \uBB34\uC11C\uC6B4
      \uC9D1\uC911\uB825\uC73C\uB85C \uC29B\uC744 \uB358\uC9D1\uB2C8\uB2E4. \uB540\uC5D0
      \uC816\uC740 \uADF8\uAC00 \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC640 \uB2E8\uD638\uD558\uAC8C
      \uB9D0\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bond_002
    ko: "\uAC10\uB3C5\uB2D8, \uC774 \uAD6C\uC5ED\uC740 \uC81C '\uC131\uC5ED'\uC785\uB2C8\uB2E4.
      \uC5EC\uAE30\uC11C \uB358\uC9C0\uB294 \uC81C \uC29B\uC740 100% \uB4E4\uC5B4\uAC04\uB2E4\uACE0
      \uACC4\uC0B0\uD558\uC154\uB3C4 \uC88B\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bond_003
    ko: "\uC81C\uAC00 \uC2B9\uB9AC\uD558\uB294 \uBC95\uC744 \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4.
      \uC808 \uBBFF\uACE0 \uC774 \uAD6C\uC5ED \uC804\uC220\uC744 \uC9DC\uC8FC\uC2E4
      \uC218 \uC788\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bond_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Bond_001
    ko: "\uB124 \uC790\uC2E0\uAC10\uC740 \uC778\uC815\uD55C\uB2E4. \uB124\uAC00 \uADF8
      \uAD6C\uC5ED\uC744 \uCC45\uC784\uC838\uC900\uB2E4\uBA74 \uD300\uC5D0 \uD070
      \uD798\uC774 \uB418\uACA0\uC9C0. "
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Bond_002
    ko: "\uB124 \uB178\uB825\uC744 \uBBFF\uACE0 \uC5D8\uBCF4\uC6B0 \uC9C0\uC5ED\uC758
      \uC29B \uC635\uC158\uC744 \uCD5C\uC6B0\uC120\uC73C\uB85C \uBC30\uCE58\uD558\uACA0\uB2E4.
      \uB3D9\uB8CC\uB4E4\uB3C4 \uB108\uB97C \uBBFF\uACE0 \uD328\uC2A4\uD560 \uAC70\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8... \uBBFF\uC5B4\uC8FC\uC154\uC11C \uAC10\uC0AC\uD574\uC694.
      \uD300\uC6D0\uB4E4\uC5D0\uAC8C \uBBF8\uC548\uD558\uC9C0 \uC54A\uAC8C \uAF2D
      \uB123\uC744\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Kind_1
    ko: "\uAC10\uB3C5\uC758 \uB530\uB73B\uD55C \uC2E0\uB8B0\uC5D0 \uAC10\uB3D9\uD558\uC5EC
      \uC815\uC11C\uC801 \uC548\uC815\uACFC \uC288\uD305 \uC9D1\uC911\uB825 \uC0C1\uC2B9."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC758 \uC804\uC220\uC744 \uC81C\uAC00 \uBC18\uB4DC\uC2DC
      \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uC800\uB97C \uBBFF\uC5B4\uC8FC\uC2E0
      \uC120\uD0DD, \uD6C4\uD68C \uC5C6\uAC8C \uD558\uC8E0"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Loyal_1
    ko: "\uAC10\uB3C5\uC5D0 \uB300\uD55C \uCDA9\uC131\uC2EC\uC73C\uB85C \uC758\uC9C0\uB294
      \uB2E4\uC9C0\uC9C0\uB9CC, \uAE30\uB7C9\uC740 \uD3C9\uC18C \uC218\uC900 \uC720\uC9C0."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Sincere_101
    ko: "\uAC10\uC0AC\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC 100%\uB97C \uC720\uC9C0\uD558\uB824\uBA74
      500\uAC1C\uB294 \uB354 \uB358\uC9C0\uACE0 \uAC00\uC57C\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Sincere_1
    ko: "\uACA9\uB824\uC5D0 \uBCF4\uB2F5\uD558\uB824\uB294 \uAC15\uBC15\uC5D0 \uC624\uBC84\uD398\uC774\uC2A4\uD558\uC5EC
      \uC624\uD788\uB824 \uC190\uBAA9\uC5D0 \uBB34\uB9AC\uAC00 \uAC10."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Moodmaker_101
    ko: "\uC640! \uAC10\uB3C5\uB2D8 \uB098\uC774\uC2A4 \uC0F7! \uC81C\uAC00 \uB0B4\uC77C
      \uCCB4\uC721\uAD00 \uC9C0\uBD95 \uB6AB\uC5B4\uBC84\uB9AC\uB294 \uAC70 \uC9C0\uCF1C\uBCF4\uC138\uC694!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Moodmaker_1
    ko: "\uD2B9\uC720\uC758 \uB109\uC0B4\uB85C \uBD84\uC704\uAE30\uB294 \uB744\uC6B0\uB098,
      \uC2E4\uC9C8\uC801\uC778 \uAE30\uB7C9 \uBCC0\uD654\uB294 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Bond_003
    ko: "100%? \uC790\uB9CC\uD558\uC9C0 \uB9C8\uB77C! \uB18D\uAD6C\uB294 \uD63C\uC790
      \uD558\uB294 \uAC8C \uC544\uB2C8\uB2E4. "
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Bond_004
    ko: "\uB124 '\uC131\uC5ED'\uC5D0 \uC9D1\uCC29\uD558\uB290\uB77C \uC606\uC5D0
      \uC788\uB294 \uB3D9\uB8CC\uB4E4\uC744 \uBABB \uBCF8\uB2E4\uBA74, \uADF8\uAC74
      \uD300\uC744 \uC704\uD55C \uC804\uC220\uC774 \uC544\uB2C8\uB77C \uB3C5\uC774\uB2E4.
      \uD300\uC744 \uBA3C\uC800 \uC0DD\uAC01\uD574\uB77C!"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Kind_201
    ko: "\uC544... \uC81C\uAC00 \uB108\uBB34 \uC81C \uC0DD\uAC01\uB9CC \uD588\uB098
      \uBD10\uC694. \uD300\uC6D0\uB4E4\uC774 \uC18C\uC678\uAC10\uC744 \uB290\uAF08\uC744\uC9C0\uB3C4
      \uBAA8\uB974\uACA0\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Kind_2
    ko: "\uB0A0\uCE74\uB85C\uC6B4 \uC9C0\uC801\uC5D0 \uB9C8\uC74C\uC774 \uC704\uCD95\uB418\uC5B4
      \uC7A5\uC810\uC778 \uBD80\uB4DC\uB7EC\uC6B4 \uC29B \uB9AC\uB4EC\uC774 \uAE68\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Loyal_201
    ko: "\uC81C \uB3C5\uB2E8\uC801\uC778 \uD0DC\uB3C4\uAC00 \uD300\uC758 \uACB0\uC18D\uC744
      \uD574\uCCE4\uAD70\uC694. \uAC10\uB3C5\uB2D8\uC758 \uC9C0\uC2DC\uB300\uB85C
      \uD300 \uC804\uC220\uC5D0 \uB179\uC544\uB4E4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Loyal_2
    ko: "\uAC10\uB3C5\uC758 \uC9C8\uCC45\uC744 \uD300\uC744 \uC704\uD55C \uAC00\uB974\uCE68\uC73C\uB85C
      \uC218\uC6A9\uD558\uBA70 \uC774\uD0C0\uC801\uC778 \uC2DC\uC57C \uD655\uBCF4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Sincere_201
    ko: "\uC9D1\uC911\uD558\uB290\uB77C \uC8FC\uBCC0\uC744 \uC0B4\uD53C\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4.
      \uB2E4\uC2DC \uD300\uC6D0\uB4E4\uACFC\uC758 \uC5F0\uACC4 \uD6C8\uB828\uC5D0
      \uC9D1\uC911\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Sincere_2
    ko: "\uC790\uC2E0\uC758 \uBD80\uC871\uD568\uC744 \uC778\uC815\uD558\uACE0 \uAD82\uC740\uC77C\uC5D0
      \uB354 \uD5CC\uC2E0\uC801\uC778 \uD0DC\uB3C4\uB85C \uBCC0\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Moodmaker_201
    ko: "\uC73D, \uAC10\uB3C5\uB2D8 \uB108\uBB34 \uBB34\uC11C\uC6CC\uC694! \uB124,
      \uB124! \uC131\uC5ED \uCDE8\uC18C! \uB0B4\uC77C\uC740 \uD328\uC2A4 \uC154\uD2C0\uC774\uB098
      \uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Moodmaker_2
    ko: "\uC555\uBC15\uAC10\uC5D0 \uD2B9\uC720\uC758 \uC720\uC5F0\uD568\uC774 \uC0AC\uB77C\uC9C0\uACE0
      \uC2E0\uCCB4 \uBC18\uC751\uC774 \uB454\uD574\uC838 \uC29B \uC815\uD655\uB3C4
      \uD558\uB77D."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Bond_005
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uC758 \uC29B\uC744 \uB05D\uAE4C\uC9C0
      \uC9C0\uCF1C\uBCF8 \uB4A4, \uC804\uC220 \uBCF4\uB4DC\uC758 \uC5D8\uBCF4\uC6B0
      \uC9C0\uC5ED\uC5D0 \uD300\uC6D0 \uC804\uC6D0\uC758 \uBC88\uD638\uB97C \uC801\uC5B4
      \uB123\uACE0 \uC790\uB9AC\uB97C \uB5A0\uB09C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Kind_301
    ko: "(\uBC88\uD638\uB97C \uBCF4\uBA70) \uBAA8\uB450\uAC00 \uD568\uAED8\uD558\uB294
      \uAD6C\uC5ED\uC774\uB77C\uB294 \uB73B\uC774\uAD70\uC694. \uC800 \uD63C\uC790\uAC00
      \uC544\uB2C8\uC5C8\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Kind_3
    ko: "\uAC10\uB3C5\uC758 \uC758\uC911\uC744 \uC774\uD574\uD558\uBA70 \uC548\uB3C4\uAC10\uC744
      \uC5BB\uC73C\uB098 \uB2A5\uB825\uCE58 \uBCC0\uB3D9\uC740 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Loyal_301
    ko: "\uB9D0\uC500\uD558\uC2DC\uC9C0 \uC54A\uC544\uB3C4 \uC555\uB2C8\uB2E4. \uB3D9\uB8CC\uB4E4\uC744
      \uC704\uD574 \uC81C \uC131\uC5ED\uC744 \uBC14\uCE58\uB77C\uB294 \uB73B\uC774\uC8E0?
      \uD574\uB0B4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Loyal_3
    ko: "\uAC10\uB3C5\uC758 \uCE68\uBB35\uC744 \uACFC\uD55C \uAE30\uB300\uC640 \uC555\uBC15\uC73C\uB85C
      \uB290\uAEF4 \uC288\uD305 \uC2DC \uC5B4\uAE68\uC5D0 \uD798\uC774 \uB4E4\uC5B4\uAC10."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Sincere_301
    ko: "(\uBB35\uBB35\uD788 \uBCF4\uB4DC\uB97C \uBCF4\uB2E4\uAC00 \uB2E4\uC2DC \uC29B\uC744
      \uB358\uC9C0\uAE30 \uC2DC\uC791\uD55C\uB2E4.) ...\uB354 \uC644\uBCBD\uD574\uC838\uC57C\uACA0\uAD70."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Sincere_3
    ko: "\uD3C9\uC18C\uC640 \uB2E4\uB984\uC5C6\uC774 \uBB35\uBB35\uD788 \uD6C8\uB828\uC744
      \uC9C0\uC18D\uD558\uBA70 \uC790\uC2E0\uC758 \uD398\uC774\uC2A4\uB97C \uC720\uC9C0\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Moodmaker_301
    ko: "\uC624, \uC5ED\uC2DC \uAC10\uB3C5\uB2D8 \uC13C\uC2A4! \uC6B0\uB9AC \uB2E4
      \uAC19\uC774 \uC774 \uAD6C\uC5ED \uC539\uC5B4\uBA39\uC73C\uB77C\uB294 \uAC70\uC8E0?
      \uC560\uB4E4\uC544, \uBAA8\uC5EC\uBD10!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Moodmaker_3
    ko: "\uAC10\uB3C5\uC758 \uBB34\uC5B8\uC758 \uBA54\uC2DC\uC9C0\uB97C \uD300 \uD654\uD569\uC73C\uB85C
      \uC774\uB04C\uC5B4\uB0B4\uBA70 \uC804\uC220 \uC218\uD589 \uB2A5\uB825 \uC0C1\uC2B9."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cold_001
    ko: "\uD300\uC758 \uC5D0\uC774\uC2A4\uAC00 \uC790\uC720\uD22C \uB77C\uC778 \uC591
      \uB05D\uC778 '\uC5D8\uBCF4\uC6B0' \uC9C0\uC5ED\uC5D0\uC11C \uBB34\uC11C\uC6B4
      \uC9D1\uC911\uB825\uC73C\uB85C \uC29B\uC744 \uB358\uC9D1\uB2C8\uB2E4. \uB540\uC5D0
      \uC816\uC740 \uADF8\uAC00 \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC640 \uB2E8\uD638\uD558\uAC8C
      \uB9D0\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cold_002
    ko: "\uAC10\uB3C5\uB2D8, \uC774 \uAD6C\uC5ED\uC740 \uC81C '\uC131\uC5ED'\uC785\uB2C8\uB2E4.
      \uC5EC\uAE30\uC11C \uB358\uC9C0\uB294 \uC81C \uC29B\uC740 100% \uB4E4\uC5B4\uAC04\uB2E4\uACE0
      \uACC4\uC0B0\uD558\uC154\uB3C4 \uC88B\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cold_003
    ko: "\uC81C\uAC00 \uC2B9\uB9AC\uD558\uB294 \uBC95\uC744 \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4.
      \uC808 \uBBFF\uACE0 \uC774 \uAD6C\uC5ED \uC804\uC220\uC744 \uC9DC\uC8FC\uC2E4
      \uC218 \uC788\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cold_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Cold_001
    ko: "\uB124 \uACC4\uC0B0\uC744 \uBBFF\uB294\uB2E4. \uADF8 \uAD6C\uC5ED\uC5D0\uC11C
      \uB124\uAC00 \uD655\uC2E4\uD55C \uB4DD\uC810\uC6D0\uC774 \uB418\uC5B4\uC900\uB2E4\uBA74
      \uC6B0\uB9AC \uD300\uC758 \uC2B9\uB9AC \uD655\uB960\uC740 \uBE44\uC57D\uC801\uC73C\uB85C
      \uC0C1\uC2B9\uD560 \uAC70\uC57C."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Planner_101
    ko: "\uD569\uB9AC\uC801\uC778 \uD310\uB2E8\uC785\uB2C8\uB2E4. \uADF8 \uAD6C\uC5ED\uC744
      \uD65C\uC6A9\uD55C \uC138\uBD80 \uB3D9\uC120\uC744 \uB2E4\uC2DC \uC9DC\uBCF4\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Planner_1
    ko: "\uC774\uBBF8 \uACC4\uC0B0\uC744 \uB9C8\uCE5C \uC0C1\uD0DC\uB77C \uACA9\uB824\uAC00
      \uC2E4\uB825 \uC0C1\uC2B9\uC73C\uB85C \uC774\uC5B4\uC9C0\uC9C4 \uC54A\uC74C."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Opportunist_101
    ko: "\uBC00\uC5B4\uC8FC\uC2E0\uB2E4\uBA74 \uB354\uD560 \uB098\uC704 \uC5C6\uC8E0.
      \uC81C \uAC00\uCE58\uB97C \uC99D\uBA85\uD560 \uCD5C\uACE0\uC758 \uD0C0\uC774\uBC0D\uC774\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Opportunist_1
    ko: "\uAC10\uB3C5\uC758 \uC804\uD3ED\uC801\uC778 \uC9C0\uC9C0\uB97C \uAE30\uD68C\uB85C
      \uC0BC\uC544 \uC2EC\uB9AC\uC801 \uC548\uC815\uC744 \uC5BB\uACE0 \uC29B\uAC10\uC774
      \uD3ED\uBC1C\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cunning_101
    ko: "\uB124, \uAC10\uC0AC\uD569\uB2C8\uB2E4. (\uC18D\uC73C\uB85C: \uC2E4\uD328\uD574\uB3C4
      \uAC10\uB3C5 \uD0D3\uC744 \uD560 \uAD6C\uC2E4\uC740 \uC0DD\uACBC\uAD70.)"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Cunning_1
    ko: "\uCC45\uC784 \uD68C\uD53C \uC218\uB2E8\uC73C\uB85C \uACA9\uB824\uB97C \uC774\uC6A9\uD558\uB824\uB2E4
      \uBCF4\uB2C8 \uC9D1\uC911\uB825\uC774 \uBD84\uC0B0\uB418\uC5B4 \uAC10\uAC01\uC774
      \uBB34\uB108\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Believer_101
    ko: "\uC81C \uB17C\uB9AC\uAC00 \uD2C0\uB9AC\uC9C0 \uC54A\uC558\uC74C\uC744 \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0.
      \uAC10\uB3C5\uB2D8\uC758 \uC120\uD0DD\uC774 \uC633\uC558\uC74C\uC744 \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Believer_1
    ko: "\uC790\uC2E0\uC758 \uB17C\uB9AC\uB97C \uC7AC\uD655\uC778\uD588\uC744 \uBFD0,
      \uAE30\uC874 \uAE30\uB7C9\uC5D0\uC11C \uD070 \uBCC0\uD654\uB294 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Cold_002
    ko: "100%? \uC624\uB9CC\uD558\uAD70! \uC218\uCE58\uC5D0 \uB208\uC774 \uBA40\uC5B4
      \uACBD\uAE30\uC7A5 \uC804\uCCB4\uC758 \uD750\uB984\uC744 \uB193\uCE58\uACE0
      \uC788\uC5B4. \uB124 \uC131\uC5ED\uC5D0 \uC9D1\uCC29\uD558\uB2E4 \uD300\uC758
      \uBC38\uB7F0\uC2A4\uAC00 \uBB34\uB108\uC9C0\uBA74 \uB124\uAC00 \uCC45\uC784\uC9C8
      \uAC70\uB0D0? \uC804\uCCB4\uB97C \uBD10\uB77C!"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Planner_201
    ko: "\uB370\uC774\uD130\uC5D0 \uADFC\uAC70\uD588\uC73C\uB098 \uC804\uCCB4 \uBC38\uB7F0\uC2A4\uB97C
      \uB193\uCCE4\uAD70\uC694. \uC2DC\uC57C\uB97C \uB113\uD600 \uC7AC\uACC4\uC0B0\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Planner_2
    ko: "\uC9C0\uC801\uC744 \uD1B5\uD574 \uC790\uC2E0\uC758 \uC2DC\uC57C\uAC00 \uC881\uC558\uC74C\uC744
      \uC778\uC815\uD558\uACE0 \uC774\uD0C0\uC801\uC778 \uC2DC\uC57C\uB97C \uD655\uBCF4\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Opportunist_201
    ko: "\uC73D, \uC81C \uC695\uC2EC\uC774 \uACFC\uD588\uB098\uC694? \uC54C\uACA0\uC2B5\uB2C8\uB2E4.
      \uD300\uC758 \uD750\uB984\uC5D0 \uBC29\uD574\uB418\uC9C0 \uC54A\uAC8C\uB9CC
      \uD558\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Opportunist_2
    ko: "\uBE44\uB09C\uC744 \uD53C\uD558\uB824\uB2E4 \uBCF4\uB2C8 \uC790\uC2E0\uC758
      \uAC15\uB825\uD55C \uBB34\uAE30\uC778 \uC288\uD305\uB9C8\uC800 \uC8FC\uC800\uD558\uAC8C
      \uB428."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cunning_201
    ko: "\uC544... \uC624\uD574\uD558\uC168\uAD70\uC694. \uD300\uC744 \uC704\uD55C
      \uC21C\uC218\uD55C \uC81C\uC548\uC774\uC5C8\uC2B5\uB2C8\uB2E4. "
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Cunning_2
    ko: "\uAC70\uC9D3 \uC0AC\uACFC\uB85C \uC0C1\uD669\uC744 \uB118\uAE30\uB824 \uD558\uBA70,
      \uC2EC\uB9AC \uC0C1\uD0DC\uC5D0 \uC2E4\uC9C8\uC801 \uBCC0\uD654\uAC00 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Believer_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uC624\uB9CC\uD558\uB2E4\uBA74, \uB0B4\uC77C \uACB0\uACFC\uB85C
      \uC81C \uC624\uB9CC\uC774 \uC815\uB2F5\uC774\uC5C8\uC74C\uC744 \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Believer_2
    ko: "\uC9C8\uCC45\uC5D0 \uC624\uAE30\uAC00 \uBC1C\uB3D9\uD558\uC5EC \uC790\uC2E0\uC758
      \uB17C\uB9AC\uAC00 \uB9DE\uC74C\uC744 \uC99D\uBA85\uD558\uAE30 \uC704\uD574
      \uADF9\uD55C\uC73C\uB85C \uC9D1\uC911\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Cold_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uC758 \uC29B\uC744 \uB05D\uAE4C\uC9C0
      \uC9C0\uCF1C\uBCF8 \uB4A4, \uC804\uC220 \uBCF4\uB4DC\uC758 \uC5D8\uBCF4\uC6B0
      \uC9C0\uC5ED\uC5D0 \uC9E7\uC740 \uC810 \uD558\uB098\uB9CC \uCC0D\uACE0 \uC790\uB9AC\uB97C
      \uB5A0\uB09C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Planner_301
    ko: "(\uBCF4\uB4DC\uC758 \uC810\uC744 \uBCF4\uBA70) \uC800 \uC810\uC758 \uC758\uBBF8\uB294...
      \uC5EC\uBC31?"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Planner_3
    ko: "\uAC10\uB3C5\uC758 \uC758\uB3C4\uB97C \uC9C0\uB098\uCE58\uAC8C \uBCF5\uC7A1\uD558\uAC8C
      \uBD84\uC11D\uD558\uB2E4\uAC00 \uC288\uD305 \uBA54\uCEE4\uB2C8\uC998\uC5D0
      \uD63C\uC120\uC774 \uC634."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Opportunist_301
    ko: "\uCE68\uBB35\uC774\uB77C... \uAE0D\uC815\uB3C4 \uBD80\uC815\uB3C4 \uC544\uB2C8\uB2C8
      \uB0B4 \uB9D8\uB300\uB85C \uD574\uB3C4 \uB41C\uB2E4\uB294 \uB73B\uC774\uACA0\uC9C0.
      \uD3B8\uD558\uB124."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Opportunist_3
    ko: "\uAC04\uC12D\uC774 \uC5C6\uC74C\uC744 \uD3B8\uD558\uAC8C \uC5EC\uAE30\uBA70
      \uD3C9\uC18C \uD558\uB358 \uB300\uB85C\uC758 \uAE30\uB7C9\uC744 \uC720\uC9C0\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Cunning_301
    ko: "\uC544\uBB34 \uD655\uB2F5\uB3C4 \uC548 \uC8FC\uC2DC\uB2E4\uB2C8... \uB0B4
      \uC2E4\uB825\uC73C\uB85C \uC9C1\uC811 \uC804\uC220\uC744 \uC7C1\uCDE8\uD558\uB77C\uB294
      \uB73B\uC778\uAC00. \uBCF4\uC2ED\uC2DC\uC624."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Cunning_3
    ko: "\uCE68\uBB35\uC744 \uC2EC\uB9AC\uC801 \uC2DC\uD5D8\uC73C\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uAC10\uB3C5\uC744 \uC555\uB3C4\uD558\uAE30 \uC704\uD574 \uD544\uC0AC\uC801\uC73C\uB85C
      \uC29B\uC744 \uC5F0\uB9C8\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Believer_301
    ko: "\uB9D0\uC774 \uD544\uC694 \uC5C6\uAD70\uC694. \uD558\uC9C0\uB9CC \uAC10\uB3C5\uC870\uCC28
      \uC81C \uACE0\uB1CC\uB97C \uC774\uD574 \uBABB \uD55C\uB2E4\uB2C8..."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Believer_3
    ko: "\uC18C\uD1B5 \uC5C6\uC774 \uC790\uC2E0\uB9CC\uC758 \uC138\uACC4\uC5D0 \uAC07\uD600
      \uACE0\uC9D1\uC2A4\uB7FD\uAC8C \uB358\uC9C0\uB2E4 \uBCF4\uB2C8 \uC288\uD305
      \uB9AC\uB4EC\uC774 \uAD73\uC5B4\uBC84\uB9BC."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Instinct_001
    ko: "\uD300\uC758 \uC5D0\uC774\uC2A4\uAC00 \uC790\uC720\uD22C \uB77C\uC778 \uC591
      \uB05D\uC778 '\uC5D8\uBCF4\uC6B0' \uC9C0\uC5ED\uC5D0\uC11C \uBB34\uC11C\uC6B4
      \uC9D1\uC911\uB825\uC73C\uB85C \uC29B\uC744 \uB358\uC9D1\uB2C8\uB2E4. \uB540\uC5D0
      \uC816\uC740 \uADF8\uAC00 \uB2F9\uC2E0\uC5D0\uAC8C \uB2E4\uAC00\uC640 \uB2E8\uD638\uD558\uAC8C
      \uB9D0\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Instinct_002
    ko: "\uAC10\uB3C5\uB2D8, \uC774 \uAD6C\uC5ED\uC740 \uC81C '\uC131\uC5ED'\uC785\uB2C8\uB2E4.
      \uC5EC\uAE30\uC11C \uB358\uC9C0\uB294 \uC81C \uC29B\uC740 100% \uB4E4\uC5B4\uAC04\uB2E4\uACE0
      \uACC4\uC0B0\uD558\uC154\uB3C4 \uC88B\uC544\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Instinct_003
    ko: "\uC81C\uAC00 \uC2B9\uB9AC\uD558\uB294 \uBC95\uC744 \uBCF4\uC5EC\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4.
      \uC808 \uBBFF\uACE0 \uC774 \uAD6C\uC5ED \uC804\uC220\uC744 \uC9DC\uC8FC\uC2E4
      \uC218 \uC788\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Instinct_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Instinct_001
    ko: "\uB124 \uAE30\uC138\uAC00 \uB300\uB2E8\uD558\uAD6C\uB098. \uADF8 \uAD6C\uC5ED\uC740
      \uB124 \uB9C8\uC74C\uB300\uB85C \uD718\uC800\uC5B4\uBD10\uB77C. \uB124 \uBCF8\uB2A5\uC774
      \uC2B9\uB9AC\uB97C \uAC00\uC838\uC62C \uAC70\uB77C\uACE0 \uBBFF\uB294\uB2E4.
      \uD310\uC740 \uB0B4\uAC00 \uAE54\uC544\uC8FC\uB9C8."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bluffer_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uBCF4\uB294 \uB208\uC774 \uC788\uC73C\uC2DC\uB124\uC694!
      \uC804\uC124\uC774 \uB418\uB294 \uAC78 \uBCF4\uAC8C \uB418\uC2E4 \uAC81\uB2C8\uB2E4!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Bluffer_1
    ko: "\uC778\uC815\uC744 \uBC1B\uC790 \uAE30\uC138\uAC00 \uC0B4\uC544\uB098 \uC288\uD305
      \uAC10\uAC01\uC774 \uD3ED\uBC1C\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Wild_101
    ko: "\uBBFF\uC5B4\uC8FC\uC2E0 \uB9CC\uD07C \uBAB8\uC73C\uB85C \uBCF4\uC5EC\uB4DC\uB9B4\uAC8C\uC694.
      \uB9BC\uC774 \uBD80\uC11C\uC9C8 \uC815\uB3C4\uB85C \uAF42\uC544 \uB123\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Wild_1
    ko: "\uAE30\uBD84\uC740 \uC88B\uC544\uC84C\uC73C\uB098 \uAE30\uC220\uC801\uC778
      \uC815\uAD50\uD568\uC740 \uD3C9\uC18C\uC640 \uB2E4\uB984\uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Egoist_101
    ko: "\uB2F9\uC5F0\uD55C \uACB0\uC815\uC744 \uD558\uC168\uB124\uC694. \uC81C\uAC00
      \uC8FC\uC778\uACF5\uC774 \uB418\uC5B4\uC57C \uC774 \uD300\uC774 \uC0AC\uB294
      \uBC95\uC774\uB2C8\uAE4C\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Egoist_1
    ko: "\uACFC\uB3C4\uD55C \uC790\uB9CC\uC2EC\uC5D0 \uBE60\uC838 \uC29B \uBC38\uB7F0\uC2A4\uAC00
      \uD750\uD2B8\uB7EC\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Fighter_101
    ko: "\uACA9\uB824 \uACE0\uB9D9\uC2B5\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC81C\uAC00
      \uC774\uAE30\uB294 \uAC74 \uB2F9\uC5F0\uD55C \uAC70\uB77C, \uC804\uC220\uC774\uB098
      \uC798 \uC9DC\uC8FC\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Fighter_1
    ko: "\uACA9\uB824\uB97C \uB2F9\uC5F0\uC2DC\uD558\uBA70 \uD3C9\uC18C \uD398\uC774\uC2A4\uB97C
      \uC720\uC9C0\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Instinct_002
    ko: "100%? \uC790\uB9CC\uD558\uC9C0 \uB9C8\uB77C! \uB18D\uAD6C\uB294 \uD63C\uC790
      \uD558\uB294 \uAC8C \uC544\uB2C8\uB2E4. \uB124 '\uC131\uC5ED' \uD0C0\uB839\uC774
      \uD300\uC758 \uC720\uC5F0\uC131\uC744 \uC8FD\uC778\uB2E4\uB294 \uAC78 \uC65C
      \uBAB0\uB77C? \uC815\uC2E0 \uB611\uBC14\uB85C \uCC28\uB824\uB77C!"
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bluffer_201
    ko: "\uC544... \uC790\uB9CC\uC774 \uC544\uB2C8\uB77C \uD655\uC2E0\uC774\uC5C8\uB294\uB370...
      \uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uD300 \uD50C\uB808\uC774\uC5D0 \uB354 \uC2E0\uACBD
      \uC4F8\uAC8C\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Bluffer_2
    ko: "\uBE44\uB09C\uC5D0 \uAE30\uAC00 \uC8FD\uC5B4 \uACFC\uAC10\uD55C \uC2DC\uB3C4\uB97C
      \uC8FC\uC800\uD558\uAC8C \uB428."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Wild_201
    ko: "\uC81C \uC57C\uC131\uC774 \uD2C0\uB9AC\uC9C0 \uC54A\uC558\uB2E4\uB294 \uAC78
      \uACB0\uACFC\uB85C \uC99D\uBA85\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uB450\uACE0
      \uBCF4\uC138\uC694."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Wild_2
    ko: "\uAC15\uD55C \uC790\uADF9\uC5D0 \uBCF8\uB2A5\uC801\uC778 \uC9D1\uC911\uB825\uC774
      \uC0B4\uC544\uB098 \uC29B\uAC10\uC774 \uC0C1\uC2B9\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Egoist_201
    ko: "\uC81C \uBC29\uC2DD\uC774 \uB9C8\uC74C\uC5D0 \uC548 \uB4DC\uC2DC\uB098 \uBCF8\uB370,
      \uACB0\uAD6D \uC800 \uB9D0\uACE0 \uB204\uAC00 \uB4DD\uC810\uD558\uC8E0? \uC804
      \uC81C \uAE38\uC744 \uAC11\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Egoist_2
    ko: "\uBC18\uBC1C\uC2EC\uB9CC \uC0DD\uAE38 \uBFD0 \uC2E4\uB825 \uC790\uCCB4\uC5D0
      \uBCC0\uD654\uB294 \uC0DD\uAE30\uC9C0 \uC54A\uC74C."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Fighter_201
    ko: "\uD300\uC758 \uC720\uC5F0\uC131\uC694? \uC81C\uAC00 \uB2E4 \uB123\uC73C\uBA74
      \uADF8\uAC8C \uACE7 \uC804\uC220\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Fighter_2
    ko: "\uAC10\uC815\uC774 \uC55E\uC11C \uD798\uC774 \uACFC\uD558\uAC8C \uB4E4\uC5B4\uAC00
      \uC29B \uBA54\uCEE4\uB2C8\uC998\uC774 \uBB34\uB108\uC9D0."
    en: 
    ja: 
  - stringKey: Event_00004_Ch_Instinct_003
    ko: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uC120\uC218\uC758 \uC29B\uC744 \uC9C0\uCF1C\uBCF4\uB2E4\uAC00
      \uC804\uC220 \uBCF4\uB4DC\uC758 \uC5D8\uBCF4\uC6B0 \uC9C0\uC5ED\uC5D0 \uC810
      \uD558\uB098\uB9CC \uCC0D\uACE0 \uC790\uB9AC\uB97C \uB5A0\uB09C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Bluffer_301
    ko: "\uC800 \uC810... \uC800\uB97C \uC704\uD55C \uD2B9\uBCC4 \uC804\uC220\uC774\uC8E0?
      \uD558\uD558, \uC5ED\uC2DC \uAC10\uB3C5\uB2D8\uC740 \uCE24\uB370\uB808\uB77C\uB2C8\uAE4C!"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Bluffer_3
    ko: "\uCC29\uAC01 \uC18D\uC5D0 \uD3C9\uC18C \uC2E4\uB825\uC744 \uC720\uC9C0\uD558\uBA70
      \uBCC4\uB2E4\uB978 \uC131\uC7A5\uC774 \uC5C6\uC74C."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Wild_301
    ko: "\uB9D0\uB85C \uC548 \uD558\uC154\uB3C4 \uC54C\uC544\uC694. \uB9BC\uC744
      \uB2E4 \uCC22\uC5B4\uB193\uC73C\uB77C\uB294 \uAC70\uC8E0?"
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Wild_3
    ko: "\uD53C\uB4DC\uBC31\uC774 \uC5C6\uC790 \uC870\uAE09\uD568\uC744 \uB290\uB07C\uACE0
      \uC29B \uBC38\uB7F0\uC2A4\uAC00 \uAF2C\uC778 \uCC44 \uD6C8\uB828 \uC885\uB8CC."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Egoist_301
    ko: "\uD765, \uB300\uB2F5\uD560 \uAC00\uCE58\uB3C4 \uC5C6\uB2E4\uB294 \uAC74\uAC00.
      \uB0B4 \uC2E4\uB825\uC73C\uB85C \uC9C1\uC811 \uC804\uC220\uC744 \uC7C1\uCDE8\uD558\uACA0\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Egoist_3
    ko: "\uCE68\uBB35\uC744 \uC2B9\uBD80\uB85C \uBC1B\uC544\uB4E4\uC5EC \uADF9\uD55C\uC758
      \uAC1C\uC778 \uC9D1\uC911\uB825\uC744 \uBC1C\uD718\uD568."
    en: 
    ja: 
  - stringKey: Event_00004_Desc_Fighter_301
    ko: "\uC81C\uAC00 \uC2B9\uB9AC\uD558\uC9C0 \uBABB\uD558\uBA74 \uAC00\uB9CC \uC548
      \uB450\uC2DC\uACA0\uB2E4\uB294 \uB73B\uC774\uAD70\uC694. \uC88B\uC2B5\uB2C8\uB2E4.
      \uBCF4\uC5EC\uB4DC\uB9AC\uC8E0."
    en: 
    ja: 
  - stringKey: Event_00004_Rs_Fighter_3
    ko: "\uAE30 \uC2F8\uC6C0\uC5D0\uC11C \uC9C0\uC9C0 \uC54A\uC73C\uB824 \uAD82\uC740\uC77C\uC5D0\uB3C4
      \uC57C\uC131\uC801\uC778 \uC9D1\uC911\uB825\uC744 \uBC1C\uD718\uD568."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Discipline_001
    ko: "\uC120\uC218 \uD55C \uBA85\uC774 3\uC810 \uB77C\uC778 \uB4A4\uC5D0\uC11C
      \uBB35\uBB35\uD788 \uC29B\uC744 \uB358\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Discipline_002
    ko: "\uAC19\uC740 \uD3FC\uC73C\uB85C 100\uAC1C\uB97C \uB358\uC9C0\uB294 \uAC83\uC774
      \uC624\uB298 \uD6C8\uB828\uC758 \uBAA9\uD45C\uC9C0\uB9CC, \uBC8C\uC368 90\uBC88\uC9F8
      \uACF5\uC744 \uB358\uC9C0\uB294\uB370 \uD3FC\uC774 \uD750\uD2B8\uB7EC\uC9C0\uACE0
      \uB9BC\uC744 \uBE57\uB098\uAC11\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Discipline_003
    ko: "\uC120\uC218\uB294 \uC790\uC2E0\uC758 \uADDC\uCE59\uC744 \uAE68\uC9C0 \uC54A\uAE30
      \uC704\uD574 \uC9C0\uCE5C \uBAB8\uC744 \uC774\uB04C\uACE0 \uB2E4\uC2DC \uACF5\uC744
      \uC90D\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Discipline_004
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Discipline_001
    ko: "90\uAC1C\uAE4C\uC9C0 \uC720\uC9C0\uD558\uB358 \uB8E8\uD2F4\uC774 \uBB34\uB108\uC9C0\uB294
      \uAC74 \uC790\uAE30 \uD1B5\uC81C \uC2E4\uD328\uB2E4. \uADDC\uCE59 \uC900\uC218\uB3C4
      \uC88B\uC9C0\uB9CC \uCEE8\uB514\uC158 \uAD00\uB9AC\uAC00 \uCD5C\uC6B0\uC120\uC774\uC57C. "
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Principled_101
    ko: "\uAC10\uB3C5\uB2D8, \uC81C \uB178\uB825\uC744 \uC54C\uC544\uC8FC\uC154\uC11C
      \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Principled_1
    ko: "\uB530\uB73B\uD55C \uC778\uC815\uC5D0 \uAC10\uB3D9\uD558\uC5EC \uD300 \uC2E0\uB8B0\uB3C4
      \uC0C1\uC2B9"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Guardian_101
    ko: "\uD300\uC744 \uC704\uD574 \uB2F9\uC5F0\uD55C \uACFC\uC815\uC785\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Guardian_1
    ko: "\uACB8\uC190\uD558\uAC8C \uD6C8\uB828\uC758 \uB2F9\uC704\uC131\uC744 \uACE0\uC218\uD568"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Tactician_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uCE6D\uCC2C\uD574\uC8FC\uC2DC\uB2C8 \uD6C8\uB828\uC744
      \uBA48\uCD94\uACE0 \uC2F6\uC5B4\uC9D1\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Tactician_1
    ko: "\uC678\uBD80\uC758 \uC628\uC815\uC5D0 \uD6C8\uB828 \uAE34\uC7A5\uAC10\uC774
      \uD480\uC5B4\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Exemplary_101
    ko: "\uC5ED\uC2DC \uAC10\uB3C5\uB2D8 \uCD5C\uACE0! \uB0B4\uC77C \uB354 \uC798\uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Exemplary_1
    ko: "\uCE6D\uCC2C\uC5D0 \uD798\uC785\uC5B4 \uD300\uC758 \uC0AC\uAE30\uAE4C\uC9C0
      \uB04C\uC5B4\uC62C\uB9BC"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Discipline_002
    ko: "\uBB34\uB9AC\uD558\uB294 \uAC74 \uACB0\uCF54 \uD300\uC744 \uC704\uD55C \uAC8C
      \uC544\uB2C8\uC57C. \uB124\uAC00 \uB2E4\uCE58\uBA74 \uD300\uC758 \uC804\uB825\uC774
      \uBB34\uB108\uC9C4\uB2E4. \uB0B4\uC77C \uB2E4\uC2DC \uC644\uBCBD\uD55C \uCEE8\uB514\uC158\uC73C\uB85C
      \uC2DC\uC791\uD558\uC790."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Principled_201
    ko: "\uC81C\uAC00 \uB108\uBB34 \uBD80\uC871\uD574\uC11C \uAC10\uB3C5\uB2D8 \uAC71\uC815\uC744
      \uB07C\uCCE4\uB124\uC694."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Principled_2
    ko: "\uC9C8\uCC45\uC758 \uC758\uB3C4\uB97C \uC624\uD574\uD574 \uC2A4\uC2A4\uB85C
      \uC791\uC544\uC9D0"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Guardian_201
    ko: "\uD300\uC744 \uC704\uD574 \uBD80\uC0C1 \uBC29\uC9C0\uC5D0 \uB354 \uD798\uC4F0\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Guardian_2
    ko: "\uC790\uC2E0\uBCF4\uB2E4 \uD300\uC758 \uC804\uB825\uC744 \uC0DD\uAC01\uD558\uB294
      \uAC10\uB3C5\uC758 \uB9C8\uC74C\uC744 \uC774\uD574"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Tactician_201
    ko: "\uC9C0\uC2DC\uD558\uC2E0 \uB300\uB85C \uCEE8\uB514\uC158 \uC870\uC808\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Tactician_2
    ko: "\uC9C8\uCC45\uC744 \uC5C5\uBB34\uC0C1 \uC9C0\uC2DC\uB85C \uBC1B\uC544\uB4E4\uC5EC
      \uC131\uC2E4\uD788 \uC774\uD589"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Exemplary_201
    ko: "\uD751... \uC81C\uAC00 \uB108\uBB34 \uBB34\uB9AC\uD588\uB098 \uBD10\uC694."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Exemplary_2
    ko: "\uAC10\uB3C5\uC758 \uC5C4\uACA9\uD55C \uC5B4\uC870\uC5D0 \uD06C\uAC8C \uAE30\uC8FD\uC5B4
      \uC5D0\uB108\uC9C0 \uC800\uD558"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Discipline_003
    ko: "\uC120\uC218\uC758 \uBC1C\uCE58\uC5D0 \uC218\uAC74\uACFC \uB530\uB73B\uD55C
      \uBB3C\uC744 \uC2AC\uBA70\uC2DC \uAC00\uC838\uB2E4 \uB450\uACE0, \uBE57\uC18C\uB9AC\uB97C
      \uB4E4\uC73C\uBA70 \uB098\uB780\uD788 \uC11C\uC11C \uC29B\uC744 \uB358\uC9C0\uB294
      \uBAA8\uC2B5\uC744 \uBB35\uBB35\uD788 \uC9C0\uCF1C\uBCF8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Principled_301
    ko: "\uB530\uB73B\uD55C \uBBF8\uC18C\uB85C \uD654\uB2F5\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Principled_3
    ko: "\uC2A4\uD0A8\uC2ED \uC5C6\uC774\uB3C4 \uAC10\uB3C5\uC758 \uC9C0\uC9C0\uB97C
      \uCCB4\uAC10"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Guardian_301
    ko: "\uAC10\uB3C5\uB2D8\uAED8\uC11C \uC81C \uD6C8\uB828\uC5D0 \uC2E4\uB9DD\uD558\uC168\uB098\uC694?"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Guardian_3
    ko: "\uAD00\uC2EC\uC744 \uAC08\uAD6C\uD558\uBA70 \uAC10\uB3C5\uACFC\uC758 \uAC70\uB9AC\uAC10\uC5D0
      \uBD88\uC548"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Tactician_301
    ko: "\uC774 \uCE68\uBB35\uC774 \uC81C\uAC8C \uD070 \uD798\uC774 \uB429\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Tactician_3
    ko: "\uC9C0\uCF1C\uBD10 \uC8FC\uB294 \uAC83\uB9CC\uC73C\uB85C\uB3C4 \uB354 \uC644\uBCBD\uD788
      \uC644\uC218"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Exemplary_301
    ko: "\uC7A5\uB09C\uC2A4\uB7FD\uAC8C \uC218\uAC74\uC744 \uB450\uB978\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Exemplary_3
    ko: "\uAC10\uB3C5\uC758 \uCE68\uBB35\uC744 \uAE0D\uC815\uC801 \uC9C0\uC9C0\uB85C
      \uD574\uC11D"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Bond_001
    ko: "\uC120\uC218 \uD55C \uBA85\uC774 3\uC810 \uB77C\uC778 \uB4A4\uC5D0\uC11C
      \uBB35\uBB35\uD788 \uC29B\uC744 \uB358\uC9C0\uB294 \uB8E8\uD2F4 \uD6C8\uB828
      \uC911\uC785\uB2C8\uB2E4. 90\uAC1C\uC9F8\uC5D0 \uC811\uC5B4\uB4E4\uC5B4 \uD3FC\uC774
      \uD750\uD2B8\uB7EC\uC9C0\uC9C0\uB9CC,"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Bond_002
    ko: "\uC120\uC218\uB294 \uADDC\uCE59\uC744 \uC9C0\uD0A4\uAE30 \uC704\uD574 \uC9C0\uCE5C
      \uBAB8\uC744 \uC774\uB04C\uACE0 \uB2E4\uC2DC \uACF5\uC744 \uC90D\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Bond_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Bond_001
    ko: "\uC624\uB298 90\uAC1C\uAE4C\uC9C0 \uC815\uB9D0 \uACE0\uC0DD \uB9CE\uC558\uC5B4.
      \uB124\uAC00 \uC5BC\uB9C8\uB098 \uC5F4\uC2EC\uD788 \uD558\uB294\uC9C0 \uB2E4
      \uC54C\uC544. \uBAB8 \uC0C1\uD558\uBA74 \uC548 \uB418\uB2C8\uAE4C \uC624\uB298\uC740
      \uC5EC\uAE30\uC11C \uB05D\uB0B4\uC790."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Kind_101
    ko: "\uAC10\uB3C5\uB2D8\uAED8\uC11C \uC81C \uB178\uB825\uC744 \uC54C\uC544\uC8FC\uC2DC\uB2E4\uB2C8...
      \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Kind_1
    ko: "\uC778\uC815\uC5D0 \uAC10\uB3D9\uD558\uC5EC \uD300 \uC2E0\uB8B0\uB3C4 \uC0C1\uC2B9"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Loyal_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC6D0\uD558\uC2E0\uB2E4\uBA74 \uB2F9\uC7A5 \uBA48\uCD94\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Loyal_1
    ko: "\uC790\uC2E0\uC758 \uD310\uB2E8\uBCF4\uB2E4 \uAC10\uB3C5\uC758 \uC9C0\uC2DC\uB97C
      \uC6B0\uC120\uD558\uC5EC \uD6C8\uB828 \uAE30\uD68C \uC0C1\uC2E4"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Sincere_101
    ko: "\uC9C0\uC2DC\uD558\uC2E0 \uB300\uB85C \uB0B4\uC77C \uB2E4\uC2DC \uCEE8\uB514\uC158
      \uAD00\uB9AC\uD574\uC11C \uC2DC\uC791\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Sincere_1
    ko: "\uC870\uC5B8\uC744 \uB8E8\uD2F4\uC758 \uC77C\uBD80\uB85C \uB2F4\uB2F4\uD788
      \uC218\uC6A9"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Moodmaker_101
    ko: "\uAC10\uB3C5\uB2D8 \uCD5C\uACE0! \uCE6D\uCC2C\uD574\uC8FC\uC2DC\uB2C8 \uB0B4\uC77C\uC740
      100\uAC1C \uAF2D \uC131\uACF5\uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Moodmaker_1
    ko: "\uCE6D\uCC2C\uC5D0 \uD798\uC785\uC5B4 \uD300\uC758 \uC0AC\uAE30\uB97C \uB04C\uC5B4\uC62C\uB9BC"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Bond_002
    ko: "\uB108 \uD63C\uC790 \uB2E4\uCE58\uBA74 \uB05D\uC774\uC57C? \uB124 \uACE0\uC9D1
      \uB54C\uBB38\uC5D0 \uD300 \uC804\uCCB4 \uACC4\uD68D\uC774 \uB2E4 \uD2C0\uC5B4\uC9C0\uC796\uC544.
      \uD300\uC5D0 \uB300\uD55C \uCC45\uC784\uAC10\uC774 \uACE0\uC791 \uC774\uAC70\uBFD0\uC778\uAC00?
      \uB2F9\uC7A5 \uADF8\uB9CC\uB46C!"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Kind_201
    ko: "\uAC10\uB3C5\uB2D8... \uC81C\uAC00 \uD300\uC5D0 \uB3C4\uC6C0\uC774 \uB418\uACE0
      \uC2F6\uC5B4\uC11C \uADF8\uB7F0 \uAC74\uB370, \uACB0\uAD6D \uAC71\uC815\uB9CC
      \uB07C\uCCD0 \uB4DC\uB838\uB124\uC694. \uC81C\uAC00 \uB108\uBB34 \uBD80\uC871\uD588\uC2B5\uB2C8\uB2E4.."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Kind_2
    ko: "\uC790\uC2E0\uC758 \uACFC\uC789 \uC758\uC695\uC774 \uAC10\uB3C5\uACFC\uC758
      \uAD00\uACC4\uB97C \uD574\uCCE4\uB2E4\uB294 \uC0C1\uCC98\uB85C \uC704\uCD95"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Loyal_201
    ko: "\uC8C4\uC1A1\uD569\uB2C8\uB2E4. \uC81C \uACE0\uC9D1\uC774 \uD300\uC744 \uB9DD\uCE60
      \uBED4\uD588\uC2B5\uB2C8\uB2E4. \uB9D0\uC500\uD558\uC2E0 \uB300\uB85C \uC9C0\uAE08
      \uC989\uC2DC \uD6C8\uB828\uC744 \uBA48\uCD94\uACE0 \uB0B4\uC77C\uC740 \uD300
      \uC804\uB825\uC744 \uC6B0\uC120\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Loyal_2
    ko: "\uC9C8\uCC45\uC744 \uD300\uC744 \uC704\uD55C \uCC45\uC784\uAC10\uC73C\uB85C
      \uBC1B\uC544\uB4E4\uC5EC \uC989\uAC01 \uC218\uC6A9"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Sincere_201
    ko: "100\uAC1C\uB97C \uCC44\uC6B0\uC9C0 \uBABB\uD558\uBA74 \uC81C \uB8E8\uD2F4\uC774
      \uAE68\uC9C0\uB294\uB370... \uD300\uC5D0 \uD53C\uD574\uB97C \uC92C\uB2E4\uB2C8
      \uC81C \uB178\uB825\uC774 \uB2E4 \uD5C8\uC0AC\uAC00 \uB41C \uAE30\uBD84\uC785\uB2C8\uB2E4.
      \uAD34\uB86D\uB124\uC694.."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Sincere_2
    ko: "\uACFC\uC815\uC758 \uC2E4\uD328\uC5D0 \uB9E4\uBAB0\uB418\uC5B4 \uAC10\uC815\uC801
      \uD754\uB4E4\uB9BC \uBC1C\uC0DD"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Moodmaker_201
    ko: "\uC544... \uC81C\uAC00 \uB610 \uACE0\uC9D1\uBD80\uB9AC\uB2E4\uAC00 \uD300
      \uBD84\uC704\uAE30 \uB9DD\uCCE4\uC8E0? \uC800 \uB54C\uBB38\uC5D0 \uB2E4\uB4E4
      \uAE34\uC7A5\uD55C \uAC83 \uAC19\uC544\uC694. \uC8C4\uC1A1\uD574\uC694, \uB2F9\uC7A5
      \uADF8\uB9CC\uB458\uAC8C\uC694.."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Moodmaker_2
    ko: "\uC790\uC2E0\uC758 \uD589\uB3D9\uC774 \uD300 \uBD84\uC704\uAE30\uB97C \uB9DD\uCCE4\uB2E4\uB294
      \uC790\uCC45\uC73C\uB85C \uC758\uC695 \uC0C1\uC2E4"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Bond_003
    ko: "\uC120\uC218\uC758 \uAC70\uCE5C \uC228\uC18C\uB9AC\uC640 \uD750\uD2B8\uB7EC\uC9C4
      \uD3FC\uC744 \uACC1\uC5D0\uC11C \uBB35\uBB35\uD788 \uC751\uC2DC\uD55C\uB2E4.
      \uC29B\uC774 \uB9BC\uC744 \uBE57\uB098\uAC08 \uB54C\uB9C8\uB2E4 \uC120\uC218\uC758
      \uD45C\uC815\uC744 \uC77D\uC744 \uBFD0 \uCC28\uAC00\uC6B4 \uCE68\uBB35\uC744
      \uC720\uC9C0\uD55C\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Kind_301
    ko: "\uAC10\uB3C5\uC758 \uCE68\uBB35\uC5D0 \uB2F9\uD669\uD558\uBA70 \uD3C9\uC18C
      \uC2E4\uB825\uC744 \uC720\uC9C0\uD568"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Kind_3
    ko: "\uC9C0\uC9C0\uB098 \uC9C8\uCC45\uC774 \uC5C6\uB294 \uC0C1\uD669\uC5D0\uC11C
      \uBD88\uC548\uAC10\uC744 \uB290\uB07C\uBA70 \uB8E8\uD2F4\uC744 \uBC18\uBCF5"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Loyal_301
    ko: "\uAC10\uB3C5\uC758 \uC2DC\uC120\uC744 \uB290\uB07C\uBA70 \uB354\uC6B1 \uBB35\uBB35\uD788
      \uD6C8\uB828 \uC218\uD589"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Loyal_3
    ko: "\uAC10\uB3C5\uC774 \uC65C \uC9C0\uCF1C\uB9CC \uBCF4\uB294\uC9C0 \uACE0\uBBFC\uD558\uBA70
      \uCDA9\uC9C1\uD558\uAC8C \uB8E8\uD2F4 \uC9C0\uC18D"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Sincere_301
    ko: "\uC544\uBB34 \uB9D0\uC500 \uC5C6\uC73C\uC2E0 \uAC74... \uC81C \uD55C\uACC4\uB97C
      \uC2A4\uC2A4\uB85C \uADF9\uBCF5\uD558\uB77C\uB294 \uB73B\uC774\uACA0\uC8E0.
      \uD55C \uBC88 \uB354 \uD574\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Sincere_3
    ko: "\uCE68\uBB35\uC744 \uBB34\uC5B8\uC758 \uC2E0\uB8B0\uC640 \uB3C4\uC804\uC73C\uB85C
      \uD574\uC11D\uD558\uBA70 \uC9D1\uC911\uB825 \uADF9\uB300\uD654"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Moodmaker_301
    ko: "\uAC10\uB3C5\uC758 \uCE68\uBB35\uC774 \uBB34\uAC70\uC6CC \uB208\uCE58\uB97C
      \uBCF4\uBA70 \uD3C9\uC18C \uD398\uC774\uC2A4\uB300\uB85C \uD6C8\uB828\uD568"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Moodmaker_3
    ko: "\uBD84\uC704\uAE30\uBA54\uC774\uCEE4\uB2F5\uAC8C \uCE68\uBB35\uC744 \uAE68\uC9C0
      \uC54A\uC73C\uB824 \uC870\uC6A9\uD788 \uD6C8\uB828 \uC720\uC9C0"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Cold_001
    ko: "\uC120\uC218 \uD55C \uBA85\uC774 3\uC810 \uB77C\uC778 \uB4A4\uC5D0\uC11C
      \uBB35\uBB35\uD788 \uC29B\uC744 \uB358\uC9C0\uB294 \uB8E8\uD2F4 \uD6C8\uB828
      \uC911\uC785\uB2C8\uB2E4. 90\uAC1C\uC9F8\uC5D0 \uC811\uC5B4\uB4E4\uC5B4 \uD3FC\uC774
      \uD750\uD2B8\uB7EC\uC9C0\uC9C0\uB9CC,"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Cold_002
    ko: "\uC120\uC218\uB294 \uADDC\uCE59\uC744 \uC9C0\uD0A4\uAE30 \uC704\uD574 \uC9C0\uCE5C
      \uBAB8\uC744 \uC774\uB04C\uACE0 \uB2E4\uC2DC \uACF5\uC744 \uC90D\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Cold_003
    ko: "\uC5B4\uB5BB\uAC8C \uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Cold_001
    ko: "\uC624\uB298 90\uAC1C\uAE4C\uC9C0 \uC815\uB9D0 \uACE0\uC0DD \uB9CE\uC558\uC5B4.
      \uB124\uAC00 \uC5BC\uB9C8\uB098 \uC5F4\uC2EC\uD788 \uD558\uB294\uC9C0 \uB2E4
      \uC54C\uC544. \uBAB8 \uC0C1\uD558\uBA74 \uC548 \uB418\uB2C8\uAE4C \uC624\uB298\uC740
      \uC5EC\uAE30\uC11C \uB05D\uB0B4\uC790."
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Planner_101
    ko: "\uAC10\uB3C5\uB2D8\uAED8\uC11C \uC81C \uB178\uB825\uC744 \uC54C\uC544\uC8FC\uC2DC\uB2E4\uB2C8...
      \uAC10\uC0AC\uD569\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Planner_1
    ko: "\uC778\uC815\uC5D0 \uAC10\uB3D9\uD558\uC5EC \uD300 \uC2E0\uB8B0\uB3C4 \uC0C1\uC2B9"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Opportunist_101
    ko: "\uAC10\uB3C5\uB2D8\uC774 \uC6D0\uD558\uC2E0\uB2E4\uBA74 \uB2F9\uC7A5 \uBA48\uCD94\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Opportunist_1
    ko: "\uC790\uC2E0\uC758 \uD310\uB2E8\uBCF4\uB2E4 \uAC10\uB3C5\uC758 \uC9C0\uC2DC\uB97C
      \uC6B0\uC120\uD558\uC5EC \uD6C8\uB828 \uAE30\uD68C \uC0C1\uC2E4"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Cunning_101
    ko: "\uC9C0\uC2DC\uD558\uC2E0 \uB300\uB85C \uB0B4\uC77C \uB2E4\uC2DC \uCEE8\uB514\uC158
      \uAD00\uB9AC\uD574\uC11C \uC2DC\uC791\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Cunning_1
    ko: "\uC870\uC5B8\uC744 \uB8E8\uD2F4\uC758 \uC77C\uBD80\uB85C \uB2F4\uB2F4\uD788
      \uC218\uC6A9"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Believer_101
    ko: "\uAC10\uB3C5\uB2D8 \uCD5C\uACE0! \uCE6D\uCC2C\uD574\uC8FC\uC2DC\uB2C8 \uB0B4\uC77C\uC740
      100\uAC1C \uAF2D \uC131\uACF5\uD560\uAC8C\uC694!"
    en: 
    ja: 
  - stringKey: Event_00005_Rs_Believer_1
    ko: "\uCE6D\uCC2C\uC5D0 \uD798\uC785\uC5B4 \uD300\uC758 \uC0AC\uAE30\uB97C \uB04C\uC5B4\uC62C\uB9BC"
    en: 
    ja: 
  - stringKey: Event_00005_Ch_Cold_002
    ko: "\uB108 \uD63C\uC790 \uB2E4\uCE58\uBA74 \uB05D\uC774\uC57C? \uB124 \uACE0\uC9D1
      \uB54C\uBB38\uC5D0 \uD300 \uC804\uCCB4 \uACC4\uD68D\uC774 \uB2E4 \uD2C0\uC5B4\uC9C0\uC796\uC544.
      \uD300\uC5D0 \uB300\uD55C \uCC45\uC784\uAC10\uC774 \uACE0\uC791 \uC774\uAC70\uBFD0\uC778\uAC00?
      \uB2F9\uC7A5 \uADF8\uB9CC\uB46C!"
    en: 
    ja: 
  - stringKey: Event_00005_Desc_Planner_201
    ko: "\uAC10\uB3C5\uB2D8... \uC81C\uAC00 \uD300\uC5D0 \uB3C4\uC6C0\uC774 \uB418\uACE0
